{
	"name": "@mana-bots/matrix-storage-bot",
	"version": "1.0.0",
	"description": "Matrix bot for cloud storage management",
	"private": true,
	"main": "dist/main.js",
	"pnpm": {
		"neverBuiltDependencies": ["@matrix-org/matrix-sdk-crypto-nodejs"],
