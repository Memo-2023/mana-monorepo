		"hono": "^4.7.0",
		"mime-types": "^2.1.35",
		"minio": "^8.0.0",
		"postgres": "^3.4.5",
		"prom-client": "^15.1.0",
		"sharp": "^0.33.0"
	},
	"devDependencies": {
		"@mana/shared-drizzle-config": "workspace:*",
		"@types/mime-types": "^2.1.4",
		"@types/node": "^22.0.0",
