		"fs-extra": "^11.2.0"
	},
	"devDependencies": {
		"@nestjs/cli": "^10.4.9",
		"@nestjs/schematics": "^10.2.3",
		"@nestjs/testing": "^10.4.17",
		"@types/express": "^5.0.0",
