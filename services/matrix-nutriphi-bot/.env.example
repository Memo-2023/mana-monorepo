# Speech-to-Text (mana-stt service)
STT_URL=http://localhost:3020

# Mana Core Auth
MANA_CORE_AUTH_URL=http://localhost:3001

# Development bypass (optional)
DEV_BYPASS_AUTH=false
DEV_USER_ID=
