---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import { games } from '../../data/games';

export function getStaticPaths() {
  return games.map((game) => ({
    params: { slug: game.slug },
    props: { game },
  }));
}

const { game } = Astro.props;
---

<Layout title={game.title} description={game.description} isGamePage={true} gameTitle={game.title} gameSlug={game.slug} hideFooter={true}>
  <div class="game-page">
    <div class="game-container" id="gameContainer">
      <div class="game-panel">
        <iframe 
          src={game.htmlFile} 
          title={game.title}
          allowfullscreen
        ></iframe>
      </div>
      
      <div class="description-panel" id="descriptionPanel">
        <div class="description-header">
          <h3>Spielinfo</h3>
          <Button 
            id="closeDescriptionBtn" 
            variant="ghost" 
            size="icon"
            class="close-btn"
          >
            ✕
          </Button>
        </div>
        <div class="description-content">
          <div class="description-section stats-section">
            <h4>📊 Deine Statistiken</h4>
            <div id="game-stats-panel" class="stats-loading">
              <p>Lade Statistiken...</p>
            </div>
          </div>
          
          <div class="description-section">
            <h4>{game.title}</h4>
            <p>{game.description}</p>
          </div>
          
          <div class="description-section">
            <h4>Steuerung</h4>
            <p>{game.controls}</p>
          </div>
          
          <div class="description-section">
            <h4>Details</h4>
            <div class="game-meta">
              <div class="meta-item">
                <span class="meta-label">Schwierigkeit:</span>
                <span class={`difficulty difficulty-${game.difficulty.toLowerCase()}`}>{game.difficulty}</span>
              </div>
              {game.codeStats && (
                <div class="meta-item">
                  <span class="meta-label">Code:</span>
                  <span class="code-stats">
                    <span class="code-symbol">< ></span>
                    {game.codeStats.total} Zeilen ({game.codeStats.code} Code / {game.codeStats.comments} Kommentare)
                  </span>
                </div>
              )}
            </div>
            <div class="tags">
              {game.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    <div id="gameMenu" class="game-menu">
      <div class="menu-header">
        <h2>{game.title}</h2>
        <Button 
          id="closeMenuBtn" 
          variant="ghost" 
          size="icon"
          class="close-btn"
        >
          ✕
        </Button>
      </div>
      
      <div class="menu-content">
        <div class="menu-section">
          <h3>Beschreibung</h3>
          <p>{game.description}</p>
        </div>
        
        <div class="menu-section">
          <h3>Steuerung</h3>
          <p>{game.controls}</p>
        </div>
        
        <div class="menu-section">
          <h3>Details</h3>
          <div class="game-meta">
            <div class="meta-item">
              <span class="meta-label">Schwierigkeit:</span>
              <span class={`difficulty difficulty-${game.difficulty.toLowerCase()}`}>{game.difficulty}</span>
            </div>
          </div>
          <div class="tags">
            {game.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
        
        <div class="menu-section">
          <h3>Deine Statistiken</h3>
          <div id="game-stats-menu" class="stats-loading">
            <p>Lade Statistiken...</p>
          </div>
        </div>
        
        <div class="menu-section playground-section">
          <Button 
            href={`/games/${game.slug}/playground`} 
            variant="accent"
            class="menu-link playground-link"
          >
            <span>🔧</span>
            <span>Code bearbeiten</span>
          </Button>
        </div>
        
        <div class="menu-section">
          <Button 
            href="/" 
            variant="secondary"
            class="menu-link back-link"
          >
            <span>←</span>
            <span>Zurück zur Spieleübersicht</span>
          </Button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Game communication inline to avoid module issues
  const gameSlug = window.location.pathname.split('/').filter(p => p).pop();
  let gameStartTime = null;
  
  // Stats service functions
  const statsService = {
    getStoredStats() {
      try {
        const stored = localStorage.getItem('mana-games-stats');
        return stored ? JSON.parse(stored) : {};
      } catch (error) {
        console.error('Error reading stats:', error);
        return {};
      }
    },
    
    saveStats(stats) {
      try {
        localStorage.setItem('mana-games-stats', JSON.stringify(stats));
      } catch (error) {
        console.error('Error saving stats:', error);
      }
    },
    
    updateStats(gameId, update) {
      const allStats = this.getStoredStats();
      const currentStats = allStats[gameId] || {
        gameId,
        highScore: 0,
        lastScore: 0,
        gamesPlayed: 0,
        totalPlayTime: 0,
        lastPlayed: new Date().toISOString(),
        achievements: []
      };

      allStats[gameId] = {
        ...currentStats,
        ...update,
        gameId,
        lastPlayed: new Date().toISOString()
      };

      // Update highscore for click-race (lower is better)
      if (gameId === 'click-race' && update.lastScore) {
        if (currentStats.highScore === 0 || update.lastScore < currentStats.highScore) {
          allStats[gameId].highScore = update.lastScore;
        }
      } else if (update.lastScore && update.lastScore > currentStats.highScore) {
        allStats[gameId].highScore = update.lastScore;
      }

      this.saveStats(allStats);
    },
    
    incrementGamesPlayed(gameId) {
      const allStats = this.getStoredStats();
      const stats = allStats[gameId] || {
        gameId,
        highScore: 0,
        lastScore: 0,
        gamesPlayed: 0,
        totalPlayTime: 0,
        lastPlayed: new Date().toISOString()
      };
      
      this.updateStats(gameId, {
        gamesPlayed: stats.gamesPlayed + 1
      });
    },
    
    addPlayTime(gameId, seconds) {
      const allStats = this.getStoredStats();
      const stats = allStats[gameId] || {
        gameId,
        highScore: 0,
        lastScore: 0,
        gamesPlayed: 0,
        totalPlayTime: 0,
        lastPlayed: new Date().toISOString()
      };
      
      this.updateStats(gameId, {
        totalPlayTime: stats.totalPlayTime + seconds
      });
    },
    
    unlockAchievement(gameId, achievement) {
      const allStats = this.getStoredStats();
      const stats = allStats[gameId];
      if (!stats) return;
      
      const achievements = stats.achievements || [];
      const exists = achievements.find(a => a.id === achievement.id);
      
      if (!exists) {
        achievements.push({
          ...achievement,
          unlockedAt: new Date().toISOString()
        });
        
        this.updateStats(gameId, { achievements });
      }
    }
  };
  
  // Listen for game messages
  window.addEventListener('message', (event) => {
    if (event.origin !== window.location.origin) return;
    
    const message = event.data;
    if (!message.type || message.gameId !== gameSlug) return;
    
    console.log('Received game message:', message);
    
    switch (message.type) {
      case 'GAME_LOADED':
        gameStartTime = Date.now();
        statsService.incrementGamesPlayed(gameSlug);
        break;
        
      case 'GAME_EVENT':
        if (message.event === 'SCORE_UPDATE' && message.data?.score) {
          statsService.updateStats(gameSlug, {
            lastScore: message.data.score
          });
        } else if (message.event === 'ACHIEVEMENT_UNLOCKED' && message.data?.achievement) {
          statsService.unlockAchievement(gameSlug, message.data.achievement);
        } else if (message.event === 'GAME_OVER' && message.data?.score) {
          statsService.updateStats(gameSlug, {
            lastScore: message.data.score
          });
        }
        break;
        
      case 'GAME_ENDED':
        if (gameStartTime) {
          const playTime = Math.floor((Date.now() - gameStartTime) / 1000);
          statsService.addPlayTime(gameSlug, playTime);
          gameStartTime = null;
        }
        break;
    }
  });
  
  // Track play time on page unload
  window.addEventListener('beforeunload', () => {
    if (gameStartTime) {
      const playTime = Math.floor((Date.now() - gameStartTime) / 1000);
      statsService.addPlayTime(gameSlug, playTime);
    }
  });
  
  // Load and display game stats
  function loadGameStats() {
    const stats = statsService.getStoredStats()[gameSlug];
    const panelElement = document.getElementById('game-stats-panel');
    const menuElement = document.getElementById('game-stats-menu');
    
    let statsHTML = '';
    
    if (stats) {
      statsHTML = `
        <table style="width: 100%; border-collapse: collapse; margin-bottom: 0.75rem;">
          <tbody>
            <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.05);">
              <td style="padding: 0.3rem 0.5rem 0.3rem 0; font-size: 0.8rem; color: rgba(255, 255, 255, 0.6); font-weight: 500;">Highscore</td>
              <td style="padding: 0.3rem 0; font-size: 0.8rem; color: #fff; font-weight: 700; font-family: monospace;">${statsService.formatScore(gameSlug, stats.highScore)}</td>
            </tr>
            <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.05);">
              <td style="padding: 0.3rem 0.5rem 0.3rem 0; font-size: 0.8rem; color: rgba(255, 255, 255, 0.6); font-weight: 500;">Letzter Score</td>
              <td style="padding: 0.3rem 0; font-size: 0.8rem; color: #fff; font-weight: 700; font-family: monospace;">${statsService.formatScore(gameSlug, stats.lastScore)}</td>
            </tr>
            <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.05);">
              <td style="padding: 0.3rem 0.5rem 0.3rem 0; font-size: 0.8rem; color: rgba(255, 255, 255, 0.6); font-weight: 500;">Gespielt</td>
              <td style="padding: 0.3rem 0; font-size: 0.8rem; color: #fff; font-weight: 700; font-family: monospace;">${stats.gamesPlayed}x</td>
            </tr>
            <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.05);">
              <td style="padding: 0.3rem 0.5rem 0.3rem 0; font-size: 0.8rem; color: rgba(255, 255, 255, 0.6); font-weight: 500;">Spielzeit</td>
              <td style="padding: 0.3rem 0; font-size: 0.8rem; color: #fff; font-weight: 700; font-family: monospace;">${statsService.formatPlayTime(stats.totalPlayTime)}</td>
            </tr>
            <tr>
              <td style="padding: 0.3rem 0.5rem 0.3rem 0; font-size: 0.8rem; color: rgba(255, 255, 255, 0.6); font-weight: 500;">Zuletzt</td>
              <td style="padding: 0.3rem 0; font-size: 0.8rem; color: #fff; font-weight: 700; font-family: monospace;">${statsService.getRelativeTime(stats.lastPlayed)}</td>
            </tr>
          </tbody>
        </table>
        ${stats.achievements && stats.achievements.length > 0 ? `
          <style>
            .game-achievements {
              margin-top: 1rem;
              padding-top: 1rem;
              border-top: 1px solid rgba(255, 255, 255, 0.08);
            }
            .game-achievements-header {
              display: flex;
              justify-content: space-between;
              align-items: center;
              margin-bottom: 0.75rem;
            }
            .game-achievements-title {
              font-size: 0.95rem;
              font-weight: 700;
              color: #fff;
            }
            .game-achievements-count {
              font-size: 0.8rem;
              color: #00ff88;
              font-weight: 600;
              padding: 0.2rem 0.6rem;
              background: rgba(0, 255, 136, 0.1);
              border-radius: 1rem;
            }
            .game-achievement-item {
              display: flex;
              align-items: flex-start;
              gap: 0.5rem;
              padding: 0.5rem;
              background: rgba(255, 215, 0, 0.05);
              border: 1px solid rgba(255, 215, 0, 0.15);
              border-radius: 0.5rem;
              margin-bottom: 0.5rem;
            }
            .game-achievement-item:hover {
              background: rgba(255, 215, 0, 0.08);
              border-color: rgba(255, 215, 0, 0.25);
            }
            .game-achievement-name {
              font-weight: 600;
              color: #fbbf24;
              font-size: 0.9rem;
            }
            .game-achievement-desc {
              font-size: 0.8rem;
              color: rgba(255, 255, 255, 0.6);
              margin-top: 0.2rem;
            }
          </style>
          <div class="game-achievements">
            <div class="game-achievements-header">
              <span class="game-achievements-title">🏆 Achievements</span>
              <span class="game-achievements-count">${stats.achievements.length} freigeschaltet</span>
            </div>
            <div>
              ${stats.achievements.map(a => `
                <div class="game-achievement-item">
                  <span>🏅</span>
                  <div>
                    <div class="game-achievement-name">${a.name}</div>
                    <div class="game-achievement-desc">${a.description}</div>
                  </div>
                </div>
              `).join('')}
            </div>
          </div>
        ` : `
          <style>
            .game-achievements-empty {
              margin-top: 1rem;
              padding-top: 1rem;
              border-top: 1px solid rgba(255, 255, 255, 0.08);
              opacity: 0.6;
            }
            .game-no-achievements {
              text-align: center;
              color: rgba(255, 255, 255, 0.5);
              font-style: italic;
              font-size: 0.85rem;
              padding: 1rem 0;
            }
          </style>
          <div class="game-achievements-empty">
            <div class="game-achievements-header">
              <span class="game-achievements-title">🏆 Achievements</span>
              <span class="game-achievements-count">0 freigeschaltet</span>
            </div>
            <p class="game-no-achievements">Noch keine Achievements freigeschaltet</p>
          </div>
        `}
      `;
    } else {
      statsHTML = '<p class="no-stats">Noch keine Statistiken vorhanden. Spiele das Spiel, um Statistiken zu sammeln!</p>';
    }
    
    if (panelElement) panelElement.innerHTML = statsHTML;
    if (menuElement) menuElement.innerHTML = statsHTML;
  }
  
  // Format score based on game type
  statsService.formatScore = function(gameId, score) {
    if (gameId === 'click-race' || gameId === 'reaction-test') {
      return `${(score / 1000).toFixed(2)}s`;
    }
    return score.toLocaleString('de-DE');
  };
  
  statsService.formatPlayTime = function(seconds) {
    const hours = Math.floor(seconds / 3600);
    const minutes = Math.floor((seconds % 3600) / 60);
    
    if (hours > 0) {
      return `${hours}h ${minutes}m`;
    }
    return `${minutes}m`;
  };
  
  statsService.getRelativeTime = function(dateString) {
    const date = new Date(dateString);
    const now = new Date();
    const diffMs = now.getTime() - date.getTime();
    const diffMins = Math.floor(diffMs / 60000);
    const diffHours = Math.floor(diffMs / 3600000);
    const diffDays = Math.floor(diffMs / 86400000);

    if (diffMins < 1) return 'Gerade eben';
    if (diffMins < 60) return `Vor ${diffMins} Minuten`;
    if (diffHours < 24) return `Vor ${diffHours} Stunden`;
    if (diffDays < 7) return `Vor ${diffDays} Tagen`;
    
    return date.toLocaleDateString('de-DE');
  };
  
  // Load stats on page load
  window.addEventListener('DOMContentLoaded', () => {
    loadGameStats();
  });
  
  // Reload stats when panel opens
  const menuBtn = document.getElementById('menuBtn');
  if (menuBtn) {
    menuBtn.addEventListener('click', () => {
      setTimeout(loadGameStats, 100);
    });
  }
  
  // Listen for stats updates
  window.addEventListener('message', (event) => {
    if (event.data.type && event.data.gameId === gameSlug) {
      setTimeout(loadGameStats, 100);
    }
  });
</script>

<script>
  // Add no-scroll class to body for game pages
  document.body.classList.add('no-scroll');
  
  // Wait for DOM to be fully loaded
  window.addEventListener('DOMContentLoaded', () => {
    const iframe = document.querySelector('iframe') as HTMLIFrameElement;
    const fullscreenBtn = document.getElementById('fullscreenBtn');
    const refreshBtn = document.getElementById('refreshBtn');
    const menuBtn = document.getElementById('menuBtn');
    const gameMenu = document.getElementById('gameMenu');
    const closeMenuBtn = document.getElementById('closeMenuBtn');

    fullscreenBtn?.addEventListener('click', () => {
      if (iframe.requestFullscreen) {
        iframe.requestFullscreen();
      }
    });

    refreshBtn?.addEventListener('click', () => {
      iframe.src = iframe.src;
    });

    const gameContainer = document.getElementById('gameContainer');
    const descriptionPanel = document.getElementById('descriptionPanel');
    const closeDescriptionBtn = document.getElementById('closeDescriptionBtn');

    menuBtn?.addEventListener('click', () => {
      // Toggle zwischen Overlay-Menu und Split-Screen
      if (descriptionPanel?.classList.contains('active')) {
        descriptionPanel.classList.remove('active');
        gameContainer?.classList.remove('split-view');
      } else {
        descriptionPanel?.classList.add('active');
        gameContainer?.classList.add('split-view');
      }
    });

    closeDescriptionBtn?.addEventListener('click', () => {
      descriptionPanel?.classList.remove('active');
      gameContainer?.classList.remove('split-view');
    });

    closeMenuBtn?.addEventListener('click', () => {
      gameMenu?.classList.remove('active');
    });

    // Close menu when clicking outside
    gameMenu?.addEventListener('click', (e) => {
      if (e.target === gameMenu) {
        gameMenu.classList.remove('active');
      }
    });

    // Handle ESC key to exit fullscreen or close menu
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && gameMenu?.classList.contains('active')) {
        gameMenu.classList.remove('active');
      }
    });

    // Prevent scrolling on the page
    window.addEventListener('wheel', (e) => {
      if (!gameMenu?.classList.contains('active')) {
        e.preventDefault();
      }
    }, { passive: false });

    window.addEventListener('touchmove', (e) => {
      if (!gameMenu?.classList.contains('active')) {
        e.preventDefault();
      }
    }, { passive: false });
  });
</script>

<style>
  .game-page {
    position: fixed;
    top: 60px; /* Height of nav */
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: calc(100vh - 60px);
  }

  .game-container {
    width: 100%;
    height: 100%;
    display: grid;
    grid-template-columns: 1fr;
    transition: all 0.3s ease;
  }

  .game-container.split-view {
    grid-template-columns: 1fr 400px;
    gap: 1px;
    background: var(--color-border);
  }

  .game-panel {
    background: #000;
    overflow: hidden;
  }

  .game-panel iframe {
    width: 100%;
    height: 100%;
    border: none;
    background-color: #000;
  }

  .description-panel {
    background: var(--color-bg);
    display: none;
    flex-direction: column;
    overflow: hidden;
  }

  .description-panel.active {
    display: flex;
  }

  .description-header {
    background: var(--color-bg-secondary);
    padding: 1rem;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .description-header h3 {
    margin: 0;
    font-size: 1rem;
    color: var(--color-text);
    font-weight: 600;
  }

  .description-content {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem;
  }

  .description-section {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .description-section:last-child {
    border-bottom: none;
    margin-bottom: 0;
  }

  .description-section h4 {
    color: var(--color-accent);
    margin-bottom: 0.75rem;
    font-size: 1rem;
    font-weight: 600;
  }

  .description-section p {
    color: var(--color-text-secondary);
    line-height: 1.6;
    font-size: 0.9rem;
    margin: 0;
  }

  .code-stats {
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .code-symbol {
    font-family: monospace;
    opacity: 0.7;
  }

  /* Menu Overlay */
  .game-menu {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.95);
    backdrop-filter: blur(10px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    z-index: 1000;
    padding: 1rem;
  }

  .game-menu.active {
    opacity: 1;
    visibility: visible;
  }

  .game-menu > div {
    background-color: var(--color-bg-secondary);
    border: 2px solid var(--color-accent);
    border-radius: 1rem;
    max-width: 600px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    transform: translateY(20px) scale(0.95);
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 20px 60px rgba(0, 255, 136, 0.2);
  }

  .game-menu.active > div {
    transform: translateY(0) scale(1);
  }

  /* Custom scrollbar for menu */
  .game-menu > div::-webkit-scrollbar {
    width: 8px;
  }

  .game-menu > div::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
  }

  .game-menu > div::-webkit-scrollbar-thumb {
    background: var(--color-accent);
    border-radius: 4px;
    transition: background 0.2s ease;
  }

  .game-menu > div::-webkit-scrollbar-thumb:hover {
    background: var(--color-accent-secondary);
  }

  .menu-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem;
    border-bottom: 2px solid var(--color-border);
    background: linear-gradient(135deg, var(--color-bg-secondary), var(--color-bg));
  }

  .menu-header h2 {
    margin: 0;
    color: var(--color-accent);
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .close-btn {
    font-size: 1.25rem !important;
  }

  .close-btn:hover {
    transform: rotate(90deg);
  }

  .menu-content {
    padding: 2rem;
  }

  .menu-section {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 0.75rem;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    transition: all 0.2s ease;
  }

  .menu-section:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(0, 255, 136, 0.2);
    transform: translateY(-2px);
  }

  .menu-section:last-child {
    margin-bottom: 0;
    background: none;
    border: none;
    padding-top: 0.5rem;
  }

  .menu-section:last-child:hover {
    transform: none;
  }

  .menu-section h3 {
    color: var(--color-accent);
    margin-bottom: 0.75rem;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .menu-section p {
