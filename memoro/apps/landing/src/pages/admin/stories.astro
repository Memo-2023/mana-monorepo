---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// Nur im Development-Modus oder mit speziellem Query-Parameter zugänglich
const isDev = import.meta.env.DEV;
const hasAccess = isDev || Astro.url.searchParams.has('access');

if (!hasAccess) {
  return Astro.redirect('/404');
}

// Lade alle Stories
let allStories = [];
try {
  allStories = await getCollection('_stories');
} catch (error) {
  // Collection existiert noch nicht oder ist leer
  console.log('Stories collection not found or empty');
}

// Lade alle Personas für die Zuordnung
let allPersonas = [];
try {
  allPersonas = await getCollection('_personas');
} catch (error) {
  console.log('Personas collection not found or empty');
}

// Erstelle eine Map für schnellen Persona-Lookup
const personaMap = new Map();
allPersonas.forEach(persona => {
  const cleanSlug = persona.slug.includes('/') 
    ? persona.slug.split('/').pop() 
    : persona.slug;
  personaMap.set(cleanSlug, persona.data);
});

// Gruppiere Stories nach Sprache
const storiesByLang = allStories.reduce((acc, story) => {
  const lang = story.data.lang;
  if (!acc[lang]) acc[lang] = [];
  acc[lang].push(story);
  return acc;
}, {} as Record<string, typeof allStories>);

// Sortiere Stories nach Status und Titel
Object.keys(storiesByLang).forEach(lang => {
  storiesByLang[lang].sort((a, b) => {
    // Erst nach Status (published > draft > archived)
    const statusOrder = { published: 0, draft: 1, archived: 2 };
    const statusDiff = statusOrder[a.data.status] - statusOrder[b.data.status];
    if (statusDiff !== 0) return statusDiff;
    
    // Dann nach Titel
    return a.data.title.localeCompare(b.data.title);
  });
});

// Funktion zur Story-Type Farbzuweisung
function getStoryTypeColor(type: string) {
  const colors = {
    'success-story': 'bg-status-success/20 text-status-success border-status-success/30',
    'problem-solution': 'bg-primary/20 text-primary border-primary/30',
    'educational': 'bg-status-info/20 text-status-info border-status-info/30',
    'testimonial': 'bg-accent/20 text-accent border-accent/30'
  };
  return colors[type as keyof typeof colors] || colors['educational'];
}

// Funktion zur Status-Farbzuweisung
function getStatusColor(status: string) {
  const colors = {
    published: 'bg-status-success',
    draft: 'bg-status-warning',
    archived: 'bg-text-muted'
  };
  return colors[status as keyof typeof colors] || colors.draft;
}

// Funktion zur Priority-Anzeige
function getPriorityBadge(priority: string) {
  const badges = {
    'very high': '🔥 Sehr Hoch',
    'high': '⬆️ Hoch',
    'medium': '➡️ Mittel',
    'low': '⬇️ Niedrig'
  };
  return badges[priority as keyof typeof badges] || priority;
}
---

<Layout title="Stories Management | Memoro Admin" lang="de" noindex={true}>
  <div class="min-h-screen bg-background-page">
    <!-- Header -->
    <header class="bg-background-card border-b border-border">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center py-6">
          <div>
            <h1 class="text-3xl font-bold text-text-primary">Stories Management</h1>
            <p class="mt-1 text-sm text-text-secondary">Content Stories für Marketing und Social Media</p>
          </div>
          <div class="flex gap-4">
            <a href="/admin" class="px-4 py-2 bg-background-cardHover text-text-primary rounded-lg hover:bg-primary hover:text-background-page transition duration-200">
              ← Zurück zum Admin
            </a>
          </div>
        </div>
      </div>
    </header>

    <!-- Statistiken -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="bg-background-card border border-border rounded-lg p-6">
          <dt class="text-sm font-medium text-text-secondary">Gesamt</dt>
          <dd class="mt-2 text-3xl font-semibold text-text-primary">{allStories.length}</dd>
        </div>
        <div class="bg-background-card border border-border rounded-lg p-6">
          <dt class="text-sm font-medium text-text-secondary">Veröffentlicht</dt>
          <dd class="mt-2 text-3xl font-semibold text-status-success">
            {allStories.filter(s => s.data.status === 'published').length}
          </dd>
        </div>
        <div class="bg-background-card border border-border rounded-lg p-6">
          <dt class="text-sm font-medium text-text-secondary">Entwurf</dt>
          <dd class="mt-2 text-3xl font-semibold text-status-warning">
            {allStories.filter(s => s.data.status === 'draft').length}
          </dd>
        </div>
        <div class="bg-background-card border border-border rounded-lg p-6">
          <dt class="text-sm font-medium text-text-secondary">High Priority</dt>
          <dd class="mt-2 text-3xl font-semibold text-primary">
            {allStories.filter(s => s.data.production?.priority === 'high' || s.data.production?.priority === 'very high').length}
          </dd>
        </div>
      </div>
    </div>

    <!-- Stories Liste -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8 mb-12">
      {Object.entries(storiesByLang).map(([lang, stories]) => (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-text-primary mb-6">
            {lang === 'de' ? 'Deutsche Stories' : 'English Stories'}
          </h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {stories.map((story) => {
              // Extract just the filename from the slug
              const cleanSlug = story.slug.includes('/') 
                ? story.slug.split('/').pop() 
                : story.slug;
              
              // Get associated persona
              const persona = personaMap.get(story.data.persona);
              
              return (
              <a 
                href={`/admin/stories/${lang}/${cleanSlug}`}
                class="group bg-background-card border border-border rounded-lg p-6 hover:border-primary transition-all duration-200 hover:shadow-lg hover:shadow-primary/10 cursor-pointer"
              >
                <!-- Header with Status and Type -->
                <div class="flex items-start justify-between mb-4">
                  <div class="flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full" class:list={[getStatusColor(story.data.status)]}></div>
                    <span class="text-xs text-text-muted">
                      {story.data.status === 'draft' ? 'Entwurf' : story.data.status === 'published' ? 'Veröffentlicht' : 'Archiviert'}
                    </span>
                  </div>
                  <span class:list={[
                    "text-xs px-2 py-0.5 rounded-full border",
                    getStoryTypeColor(story.data.storyType)
                  ]}>
                    {story.data.storyType}
                  </span>
                </div>
                
                <!-- Story Info -->
                <div>
                  <h3 class="text-lg font-bold text-text-primary group-hover:text-primary transition-colors">
                    {story.data.title}
                  </h3>
                  <p class="text-sm text-text-secondary mt-2 line-clamp-2">
                    {story.data.description}
                  </p>
                  
                  <!-- Persona Info -->
                  {persona && (
                    <div class="mt-3 p-2 bg-background-page rounded flex items-center gap-2">
                      <span class="text-xs text-text-muted">Persona:</span>
                      <span class="text-xs text-text-primary font-medium">{persona.name}</span>
                    </div>
                  )}
                  
                  <!-- Meta Info -->
                  <div class="mt-4 flex flex-wrap gap-2">
                    {/* Priority Badge */}
                    {story.data.production?.priority && (
                      <span class="text-xs px-2 py-1 bg-background-page rounded text-text-secondary">
                        {getPriorityBadge(story.data.production.priority)}
                      </span>
                    )}
                    
                    {/* Duration */}
                    {story.data.production?.duration && (
                      <span class="text-xs px-2 py-1 bg-background-page rounded text-text-secondary">
                        ⏱️ {story.data.production.duration}
                      </span>
                    )}
                    
                    {/* Scene Count */}
                    <span class="text-xs px-2 py-1 bg-background-page rounded text-text-secondary">
                      🎬 {story.data.scenes?.length || 0} Szenen
                    </span>
                  </div>
                  
                  {/* Channels */}
                  {story.data.usage?.channels && (
                    <div class="mt-3 flex flex-wrap gap-1">
                      {story.data.usage.channels.slice(0, 3).map(channel => (
                        <span class="text-xs px-2 py-0.5 bg-primary/10 text-primary rounded">
                          {channel}
                        </span>
                      ))}
                      {story.data.usage.channels.length > 3 && (
                        <span class="text-xs px-2 py-0.5 bg-primary/10 text-primary rounded">
                          +{story.data.usage.channels.length - 3}
                        </span>
                      )}
                    </div>
                  )}
                </div>
                
                <!-- Hover Indicator -->
                <div class="mt-4 text-xs text-primary opacity-0 group-hover:opacity-100 transition-opacity">
                  → Story Details anzeigen
                </div>
              </a>
            )})}
          </div>
        </div>
      ))}
      
      {allStories.length === 0 && (
        <div class="text-center py-12 bg-background-card border border-border rounded-lg">
          <p class="text-text-secondary">Keine Stories gefunden</p>
          <p class="text-sm text-text-muted mt-2">Erstelle deine erste Story in der _stories Collection</p>
        </div>
      )}
    </div>

    <!-- Info Box -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
      <div class="bg-primary/10 border border-primary/30 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-primary mb-2">📖 Über Stories</h3>
        <p class="text-sm text-text-primary mb-4">
          Stories sind narrative Content-Pieces, die unsere Personas in Aktion zeigen. Sie helfen uns bei:
        </p>
        <ul class="list-disc list-inside text-sm text-text-primary space-y-1">
          <li><strong>Marketing:</strong> Emotionale Verbindung zu unseren Zielgruppen aufbauen</li>
          <li><strong>Social Media:</strong> Visueller Content für TikTok, Instagram Reels und YouTube Shorts</li>
          <li><strong>Sales:</strong> Use Cases demonstrieren und Pain Points addressieren</li>
          <li><strong>Branding:</strong> Konsistente Markenbotschaften über alle Kanäle</li>
        </ul>
        
        <div class="mt-4 grid grid-cols-2 md:grid-cols-4 gap-3">
          <div class="p-3 bg-background-card rounded">
            <span class="text-xs text-text-muted block">Success Story</span>
            <span class="text-sm text-status-success font-medium">Erfolgsgeschichten</span>
          </div>
          <div class="p-3 bg-background-card rounded">
            <span class="text-xs text-text-muted block">Problem-Solution</span>
            <span class="text-sm text-primary font-medium">Lösungsansätze</span>
          </div>
          <div class="p-3 bg-background-card rounded">
            <span class="text-xs text-text-muted block">Educational</span>
            <span class="text-sm text-status-info font-medium">Wissensvermittlung</span>
          </div>
          <div class="p-3 bg-background-card rounded">
            <span class="text-xs text-text-muted block">Testimonial</span>
            <span class="text-sm text-accent font-medium">Kundenstimmen</span>
          </div>
        </div>
        
        <div class="mt-4 p-3 bg-status-warning/10 border border-status-warning/30 rounded">
          <p class="text-xs text-status-warning">
            <strong>⚠️ Produktionshinweis:</strong> Stories mit hoher Priorität sollten zuerst produziert werden. 
            Überprüfe die Visual Style Guides für konsistente Charakterdarstellung.
          </p>
        </div>
      </div>
    </div>
  </div>

  <style>
    /* Line clamp for description */
    .line-clamp-2 {
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }
    
    /* Custom shadow for dark theme */
    .hover\:shadow-xl:hover {
      box-shadow: 0 20px 25px -5px rgba(248, 214, 43, 0.1), 0 10px 10px -5px rgba(248, 214, 43, 0.04);
    }
  </style>
</Layout>