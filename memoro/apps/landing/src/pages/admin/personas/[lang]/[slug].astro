---
import { getCollection } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';

// Zugriffskontrolle
const isDev = import.meta.env.DEV;
const hasAccess = isDev || Astro.url.searchParams.has('access');

if (!hasAccess) {
  return Astro.redirect('/404');
}

export async function getStaticPaths() {
  const personas = await getCollection('_personas');
  const stories = await getCollection('_stories');
  
  return personas.map((persona) => {
    // Extract just the filename from the slug (remove language prefix)
    const cleanSlug = persona.slug.includes('/') 
      ? persona.slug.split('/').pop() 
      : persona.slug;
    
    // Find stories for this persona
    const personaStories = stories.filter(story => 
      story.data.persona === cleanSlug && 
      story.data.lang === persona.data.lang
    );
    
    return {
      params: { 
        lang: persona.data.lang,
        slug: cleanSlug 
      },
      props: { persona, stories: personaStories },
    };
  });
}

const { persona, stories } = Astro.props;
const { Content } = await persona.render();

// Status-Farben
function getStatusColor(status: string) {
  const colors = {
    active: 'bg-status-success text-background-page',
    draft: 'bg-status-warning text-background-page',
    archived: 'bg-text-muted text-background-page'
  };
  return colors[status as keyof typeof colors] || colors.draft;
}

// Segment-Farben
function getSegmentColor(segment: string) {
  const colors = {
    primary: 'bg-primary/20 text-primary border-primary/30',
    secondary: 'bg-status-info/20 text-status-info border-status-info/30',
    tertiary: 'bg-text-muted/20 text-text-muted border-text-muted/30'
  };
  return colors[segment as keyof typeof colors] || colors.tertiary;
}
---

<Layout title={`${persona.data.name} - Persona Details | Memoro`} lang={persona.data.lang} noindex={true}>
  <div class="min-h-screen bg-background-page">
    <!-- Header -->
    <header class="bg-background-card border-b border-border">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="py-6">
          <!-- Breadcrumb -->
          <nav class="flex items-center space-x-2 text-sm mb-4">
            <a href="/admin" class="text-text-muted hover:text-primary transition">Admin</a>
            <span class="text-text-muted">/</span>
            <a href="/admin/personas" class="text-text-muted hover:text-primary transition">Personas</a>
            <span class="text-text-muted">/</span>
            <span class="text-text-primary">{persona.data.name}</span>
          </nav>
          
          <!-- Title Section -->
          <div class="flex items-start justify-between">
            <div>
              <h1 class="text-4xl font-bold text-text-primary mb-2">{persona.data.name}</h1>
              <p class="text-xl text-primary">{persona.data.title}</p>
            </div>
            <div class="flex items-center gap-4">
              <span class:list={[
                "px-3 py-1 rounded-full text-sm font-medium",
                getStatusColor(persona.data.status)
              ]}>
                {persona.data.status}
              </span>
              <span class:list={[
                "px-3 py-1 rounded-full text-sm font-medium border",
                getSegmentColor(persona.data.marketing.segment)
              ]}>
                {persona.data.marketing.segment} Segment
              </span>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main>
      
      <!-- Appearance Section - Full Width at Top -->
      {persona.data.appearance && (
        <div class="w-full bg-gradient-to-r from-primary/10 to-primary/5 border-y border-primary/30 py-8 mb-8">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-2xl font-bold text-primary flex items-center">
                <span class="text-3xl mr-3">👤</span>
                Erscheinungsbild & Auftreten
              </h2>
            </div>
            
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
              <!-- Main Description -->
              <div class="lg:col-span-2">
                {persona.data.appearance.prompt && (
                  <div class="bg-gradient-to-r from-primary/20 to-primary/10 rounded-lg p-5 mb-6 border border-primary/30">
                    <h3 class="text-sm font-semibold text-primary mb-3 uppercase tracking-wide">Prompt</h3>
                    <p class="text-base text-text-primary font-medium leading-relaxed">
                      {persona.data.appearance.prompt}
                    </p>
                  </div>
                )}
                
                <p class="text-lg text-text-primary mb-4 leading-relaxed">
                  {persona.data.appearance.description}
                </p>
                
                <!-- Physical Attributes Only -->
                <div class="bg-background-card/50 rounded-lg p-4">
                  <h3 class="text-sm font-semibold text-primary mb-3">Physische Merkmale</h3>
                  <dl class="space-y-2">
                    {persona.data.appearance.height && (
                      <div class="flex">
                        <dt class="text-xs text-text-muted w-20">Größe:</dt>
                        <dd class="text-sm text-text-primary">{persona.data.appearance.height}</dd>
                      </div>
                    )}
                    {persona.data.appearance.build && (
                      <div class="flex">
                        <dt class="text-xs text-text-muted w-20">Statur:</dt>
                        <dd class="text-sm text-text-primary">{persona.data.appearance.build}</dd>
                      </div>
                    )}
                    {persona.data.appearance.hairColor && (
                      <div class="flex">
                        <dt class="text-xs text-text-muted w-20">Haarfarbe:</dt>
                        <dd class="text-sm text-text-primary">{persona.data.appearance.hairColor}</dd>
                      </div>
                    )}
                    {persona.data.appearance.hairStyle && (
                      <div class="flex">
                        <dt class="text-xs text-text-muted w-20">Frisur:</dt>
                        <dd class="text-sm text-text-primary">{persona.data.appearance.hairStyle}</dd>
                      </div>
                    )}
                    {persona.data.appearance.eyeColor && (
                      <div class="flex">
                        <dt class="text-xs text-text-muted w-20">Augenfarbe:</dt>
                        <dd class="text-sm text-text-primary">{persona.data.appearance.eyeColor}</dd>
                      </div>
                    )}
                    {persona.data.appearance.facialFeatures && (
                      <div class="flex">
                        <dt class="text-xs text-text-muted w-20">Merkmale:</dt>
                        <dd class="text-sm text-text-primary">{persona.data.appearance.facialFeatures}</dd>
                      </div>
                    )}
                  </dl>
                </div>
              </div>
              
              <!-- Body Language & First Impression -->
              <div class="lg:col-span-1 space-y-4">
                <div class="bg-background-card/50 rounded-lg p-4">
                  <h3 class="text-sm font-semibold text-primary mb-2">Körpersprache</h3>
                  <p class="text-sm text-text-primary">
                    {persona.data.appearance.bodyLanguage || "Nicht spezifiziert"}
                  </p>
                </div>
                
                <div class="bg-primary/20 rounded-lg p-4 border border-primary/30">
                  <h3 class="text-sm font-semibold text-primary mb-2">Erster Eindruck</h3>
                  <p class="text-sm text-text-primary font-medium">
                    "{persona.data.appearance.firstImpression}"
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      )}
      
      <!-- Outfits Section - Full Width -->
      {persona.data.outfits && persona.data.outfits.length > 0 && (
        <div class="w-full bg-background-card border-y border-border py-8 mb-8">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="text-2xl font-bold text-text-primary mb-6 flex items-center">
              <span class="text-3xl mr-3">👔</span>
              Outfit-Kollektion
            </h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {persona.data.outfits.map((outfit: any, index: number) => (
                <div class="bg-background-cardHover border border-border rounded-lg p-6 hover:border-primary transition-all duration-200">
                  <!-- Outfit Header -->
                  <div class="mb-4">
                    <h3 class="text-xl font-bold text-primary mb-2">{outfit.name}</h3>
                  </div>
                  
                  <!-- Outfit Description -->
                  <p class="text-sm text-text-primary mb-4 italic leading-relaxed">
                    "{outfit.description}"
                  </p>
                  
                  <!-- Outfit Items -->
                  <div class="space-y-3 mb-4">
                    {outfit.items.head && (
                      <div class="flex items-start gap-3">
                        <span class="text-sm text-text-muted min-w-[80px]">Kopf:</span>
                        <span class="text-sm text-text-primary">{outfit.items.head}</span>
                      </div>
                    )}
                    <div class="flex items-start gap-3">
                      <span class="text-sm text-text-muted min-w-[80px]">Oberteil:</span>
                      <span class="text-sm text-text-primary">{outfit.items.top}</span>
                    </div>
                    <div class="flex items-start gap-3">
                      <span class="text-sm text-text-muted min-w-[80px]">Unterteil:</span>
                      <span class="text-sm text-text-primary">{outfit.items.bottom}</span>
                    </div>
                    <div class="flex items-start gap-3">
                      <span class="text-sm text-text-muted min-w-[80px]">Schuhe:</span>
                      <span class="text-sm text-text-primary">{outfit.items.shoes}</span>
                    </div>
                    {outfit.items.outerwear && (
                      <div class="flex items-start gap-3">
                        <span class="text-sm text-text-muted min-w-[80px]">Jacke:</span>
                        <span class="text-sm text-text-primary">{outfit.items.outerwear}</span>
                      </div>
                    )}
                    {outfit.items.accessories && outfit.items.accessories.length > 0 && (
                      <div class="flex items-start gap-3">
                        <span class="text-sm text-text-muted min-w-[80px]">Extras:</span>
                        <span class="text-sm text-text-primary">
                          {outfit.items.accessories.join(', ')}
                        </span>
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      )}
      
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Sidebar -->
        <aside class="lg:col-span-1 space-y-6">
          
          <!-- Demographics Card -->
          <div class="bg-background-card border border-border rounded-lg p-6">
            <h2 class="text-lg font-semibold text-text-primary mb-4">📊 Demografische Daten</h2>
            <dl class="space-y-3">
              <div>
                <dt class="text-xs text-text-muted uppercase tracking-wide">Alter</dt>
                <dd class="text-sm text-text-primary mt-1">{persona.data.demographics.age}</dd>
              </div>
              <div>
                <dt class="text-xs text-text-muted uppercase tracking-wide">Geschlecht</dt>
                <dd class="text-sm text-text-primary mt-1 capitalize">{persona.data.demographics.gender || 'Nicht angegeben'}</dd>
              </div>
              <div>
                <dt class="text-xs text-text-muted uppercase tracking-wide">Standort</dt>
                <dd class="text-sm text-text-primary mt-1">{persona.data.demographics.location}</dd>
              </div>
              <div>
                <dt class="text-xs text-text-muted uppercase tracking-wide">Bildung</dt>
                <dd class="text-sm text-text-primary mt-1">{persona.data.demographics.education}</dd>
              </div>
              {persona.data.demographics.income && (
                <div>
                  <dt class="text-xs text-text-muted uppercase tracking-wide">Einkommen</dt>
                  <dd class="text-sm text-text-primary mt-1">{persona.data.demographics.income}</dd>
                </div>
              )}
              {persona.data.demographics.familyStatus && (
                <div>
                  <dt class="text-xs text-text-muted uppercase tracking-wide">Familienstand</dt>
                  <dd class="text-sm text-text-primary mt-1">{persona.data.demographics.familyStatus}</dd>
                </div>
              )}
            </dl>
          </div>

          <!-- Professional Card -->
          <div class="bg-background-card border border-border rounded-lg p-6">
            <h2 class="text-lg font-semibold text-text-primary mb-4">💼 Berufliches Profil</h2>
            <dl class="space-y-3">
              <div>
                <dt class="text-xs text-text-muted uppercase tracking-wide">Position</dt>
                <dd class="text-sm text-text-primary mt-1 font-medium">{persona.data.professional.jobTitle}</dd>
              </div>
              <div>
                <dt class="text-xs text-text-muted uppercase tracking-wide">Unternehmen</dt>
                <dd class="text-sm text-text-primary mt-1">{persona.data.professional.company || 'Nicht angegeben'}</dd>
              </div>
              <div>
                <dt class="text-xs text-text-muted uppercase tracking-wide">Branche</dt>
                <dd class="text-sm text-text-primary mt-1">{persona.data.professional.industry}</dd>
              </div>
              <div>
                <dt class="text-xs text-text-muted uppercase tracking-wide">Erfahrung</dt>
                <dd class="text-sm text-text-primary mt-1">{persona.data.professional.experience}</dd>
              </div>
              {persona.data.professional.teamSize && (
                <div>
                  <dt class="text-xs text-text-muted uppercase tracking-wide">Teamgröße</dt>
                  <dd class="text-sm text-text-primary mt-1">{persona.data.professional.teamSize}</dd>
                </div>
              )}
            </dl>
          </div>

          <!-- Behavior Card -->
          <div class="bg-background-card border border-border rounded-lg p-6">
            <h2 class="text-lg font-semibold text-text-primary mb-4">🎯 Verhalten</h2>
            <dl class="space-y-3">
              <div>
                <dt class="text-xs text-text-muted uppercase tracking-wide">Tech-Affinität</dt>
                <dd class="text-sm text-text-primary mt-1 capitalize">{persona.data.behavior.techSavviness}</dd>
              </div>
              <div>
                <dt class="text-xs text-text-muted uppercase tracking-wide">Kaufverhalten</dt>
                <dd class="text-sm text-text-primary mt-1">{persona.data.behavior.buyingBehavior || 'Nicht angegeben'}</dd>
              </div>
              <div>
                <dt class="text-xs text-text-muted uppercase tracking-wide">Tools</dt>
                <dd class="mt-1">
                  <div class="flex flex-wrap gap-1">
                    {persona.data.behavior.tools.slice(0, 5).map((tool: string) => (
                      <span class="text-xs bg-background-cardHover text-text-secondary px-2 py-1 rounded">
                        {tool}
                      </span>
                    ))}
                  </div>
                </dd>
              </div>
            </dl>
          </div>

          <!-- Marketing Card -->
          <div class="bg-background-card border border-border rounded-lg p-6">
            <h2 class="text-lg font-semibold text-text-primary mb-4">📈 Marketing</h2>
            <dl class="space-y-3">
              <div>
                <dt class="text-xs text-text-muted uppercase tracking-wide">Kanäle</dt>
                <dd class="mt-1">
                  <div class="flex flex-wrap gap-1">
                    {persona.data.marketing.channels.slice(0, 4).map((channel: string) => (
                      <span class="text-xs bg-primary/10 text-primary px-2 py-1 rounded border border-primary/20">
                        {channel}
                      </span>
                    ))}
                  </div>
                </dd>
              </div>
              <div>
                <dt class="text-xs text-text-muted uppercase tracking-wide">Content-Präferenzen</dt>
                <dd class="mt-1">
                  {persona.data.marketing.contentPreferences.slice(0, 3).map((pref: string) => (
                    <div class="text-xs text-text-secondary mt-1">• {pref}</div>
                  ))}
                </dd>
              </div>
            </dl>
          </div>
        </aside>

        <!-- Main Content Area -->
        <div class="lg:col-span-2 space-y-6">
          
          <!-- User Story -->
          <div class="bg-background-card border border-border rounded-lg p-6">
            <h2 class="text-xl font-semibold text-text-primary mb-4">📖 User Story</h2>
            <div class="prose prose-sm max-w-none">
              <p class="text-text-secondary whitespace-pre-wrap">{persona.data.userStory}</p>
            </div>
          </div>

          <!-- Psychographics -->
          <div class="bg-background-card border border-border rounded-lg p-6">
            <h2 class="text-xl font-semibold text-text-primary mb-4">🧠 Psychografische Merkmale</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              
              <!-- Values -->
              <div>
                <h3 class="text-sm font-medium text-primary mb-2">Werte</h3>
                <ul class="space-y-1">
                  {persona.data.psychographics.values.map((value: string) => (
                    <li class="text-sm text-text-secondary flex items-start">
                      <span class="text-primary mr-2">•</span>
                      {value}
                    </li>
                  ))}
                </ul>
              </div>

              <!-- Motivations -->
              <div>
                <h3 class="text-sm font-medium text-primary mb-2">Motivationen</h3>
                <ul class="space-y-1">
                  {persona.data.psychographics.motivations.map((motivation: string) => (
                    <li class="text-sm text-text-secondary flex items-start">
                      <span class="text-primary mr-2">•</span>
                      {motivation}
                    </li>
                  ))}
                </ul>
              </div>

              <!-- Frustrations -->
              <div>
                <h3 class="text-sm font-medium text-status-error mb-2">Frustrationen</h3>
                <ul class="space-y-1">
                  {persona.data.psychographics.frustrations.map((frustration: string) => (
                    <li class="text-sm text-text-secondary flex items-start">
                      <span class="text-status-error mr-2">×</span>
                      {frustration}
                    </li>
                  ))}
                </ul>
              </div>

              <!-- Goals -->
              <div>
                <h3 class="text-sm font-medium text-status-success mb-2">Ziele</h3>
                <ul class="space-y-1">
                  {persona.data.psychographics.goals.map((goal: string) => (
                    <li class="text-sm text-text-secondary flex items-start">
                      <span class="text-status-success mr-2">✓</span>
                      {goal}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>

          <!-- Memoro Context -->
          <div class="bg-background-card border border-border rounded-lg p-6">
            <h2 class="text-xl font-semibold text-text-primary mb-4">✨ Memoro Kontext</h2>
            
            <!-- Metrics -->
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-6">
              <div class="bg-background-cardHover rounded-lg p-3">
                <div class="text-xs text-text-muted mb-1">Preissensitivität</div>
                <div class="text-lg font-semibold text-primary capitalize">{persona.data.memoroContext.priceSensitivity}</div>
              </div>
              <div class="bg-background-cardHover rounded-lg p-3">
                <div class="text-xs text-text-muted mb-1">Adoption</div>
                <div class="text-lg font-semibold text-primary capitalize">{persona.data.memoroContext.adoptionLikelihood}</div>
              </div>
              <div class="bg-background-cardHover rounded-lg p-3">
                <div class="text-xs text-text-muted mb-1">Tech-Level</div>
                <div class="text-lg font-semibold text-primary capitalize">{persona.data.behavior.techSavviness}</div>
              </div>
            </div>

            <!-- Use Cases -->
            <div class="mb-6">
              <h3 class="text-sm font-medium text-text-primary mb-3">Use Cases</h3>
              <div class="flex flex-wrap gap-2">
                {persona.data.memoroContext.useCase.map((useCase: string) => (
                  <span class="px-3 py-1 bg-primary/10 text-primary rounded-full text-sm border border-primary/20">
                    {useCase}
                  </span>
                ))}
              </div>
            </div>

            <!-- Benefits -->
            <div class="mb-6">
              <h3 class="text-sm font-medium text-text-primary mb-3">Benefits</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                {persona.data.memoroContext.benefits.map((benefit: string) => (
                  <div class="text-sm text-text-secondary flex items-start">
                    <span class="text-status-success mr-2 mt-0.5">✓</span>
                    {benefit}
                  </div>
                ))}
              </div>
            </div>

            <!-- Concerns -->
            <div class="mb-6">
              <h3 class="text-sm font-medium text-text-primary mb-3">Bedenken</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                {persona.data.memoroContext.concerns.map((concern: string) => (
                  <div class="text-sm text-text-secondary flex items-start">
                    <span class="text-status-warning mr-2 mt-0.5">!</span>
                    {concern}
                  </div>
                ))}
              </div>
            </div>

            <!-- Key Features -->
            <div>
              <h3 class="text-sm font-medium text-text-primary mb-3">Wichtigste Features</h3>
              <div class="flex flex-wrap gap-2">
                {persona.data.memoroContext.features.map((feature: string) => (
                  <span class="px-2 py-1 bg-background-cardHover text-text-secondary rounded text-sm">
                    {feature}
                  </span>
                ))}
              </div>
            </div>
          </div>

          <!-- Scenarios -->
          {persona.data.scenarios && persona.data.scenarios.length > 0 && (
            <div class="bg-background-card border border-border rounded-lg p-6">
              <h2 class="text-xl font-semibold text-text-primary mb-4">🎬 Szenarien</h2>
              <div class="space-y-4">
                {persona.data.scenarios.map((scenario: any) => (
                  <div class="border-l-4 border-primary pl-4">
                    <h3 class="font-medium text-text-primary mb-1">{scenario.title}</h3>
                    <p class="text-sm text-text-secondary mb-2">{scenario.description}</p>
                    {scenario.outcome && (
                      <p class="text-sm text-primary">
                        <strong>Outcome:</strong> {scenario.outcome}
                      </p>
                    )}
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Quotes -->
          {persona.data.quotes && persona.data.quotes.length > 0 && (
            <div class="bg-background-card border border-border rounded-lg p-6">
              <h2 class="text-xl font-semibold text-text-primary mb-4">💬 Typische Aussagen</h2>
              <div class="space-y-3">
                {persona.data.quotes.map((quote: string) => (
                  <blockquote class="border-l-4 border-primary pl-4 italic text-text-secondary">
                    "{quote}"
                  </blockquote>
                ))}
              </div>
            </div>
          )}

          <!-- Stories Section -->
          {stories && stories.length > 0 && (
            <div class="bg-background-card border border-border rounded-lg p-6">
              <h2 class="text-xl font-semibold text-text-primary mb-4">🎬 Marketing Stories</h2>
              <div class="space-y-4">
                {stories.map((story) => (
                  <div class="border-l-4 border-primary pl-4 hover:bg-background-cardHover p-4 rounded-r-lg transition-colors">
                    <div class="flex items-start justify-between">
                      <div class="flex-grow">
                        <h3 class="font-medium text-text-primary mb-1">{story.data.title}</h3>
                        <p class="text-sm text-text-secondary mb-2">{story.data.description}</p>
                        <div class="flex items-center gap-4 text-xs text-text-muted">
                          <span class="bg-primary/10 text-primary px-2 py-1 rounded">
                            {story.data.storyType}
                          </span>
                          <span>{story.data.scenes.length} Szenen</span>
                          <span class="capitalize">{story.data.status}</span>
                        </div>
                      </div>
                      <a 
                        href={`/admin/stories/${story.data.lang}/${story.slug.split('/').pop()}`}
                        class="ml-4 px-3 py-1 bg-primary text-background-page rounded text-sm hover:bg-primary-light transition-colors"
                      >
                        Ansehen
                      </a>
                    </div>
                  </div>
                ))}
              </div>
              <div class="mt-4 pt-4 border-t border-border">
                <a 
                  href={`/admin/stories/new?persona=${persona.slug.split('/').pop()}&lang=${persona.data.lang}`}
                  class="text-sm text-primary hover:underline"
                >
                  + Neue Story erstellen
                </a>
              </div>
            </div>
          )}

          <!-- Content from MDX -->
          <div class="bg-background-card border border-border rounded-lg p-6">
            <div class="prose prose-invert max-w-none">
              <Content />
            </div>
          </div>

          <!-- Meta Information -->
          <div class="bg-background-cardHover border border-border rounded-lg p-6">
            <h2 class="text-lg font-semibold text-text-primary mb-4">ℹ️ Meta-Informationen</h2>
            <dl class="grid grid-cols-2 md:grid-cols-3 gap-4">
              <div>
                <dt class="text-xs text-text-muted uppercase">Owner</dt>
                <dd class="text-sm text-text-primary mt-1">{persona.data.owner}</dd>
              </div>
              <div>
                <dt class="text-xs text-text-muted uppercase">Erstellt</dt>
                <dd class="text-sm text-text-primary mt-1">
                  {new Date(persona.data.createdAt).toLocaleDateString('de-DE')}
                </dd>
              </div>
              <div>
                <dt class="text-xs text-text-muted uppercase">Aktualisiert</dt>
                <dd class="text-sm text-text-primary mt-1">
                  {new Date(persona.data.lastUpdated).toLocaleDateString('de-DE')}
                </dd>
              </div>
              {persona.data.validatedAt && (
                <div>
                  <dt class="text-xs text-text-muted uppercase">Validiert</dt>
                  <dd class="text-sm text-text-primary mt-1">
                    {new Date(persona.data.validatedAt).toLocaleDateString('de-DE')}
                  </dd>
                </div>
              )}
              <div>
                <dt class="text-xs text-text-muted uppercase">Sichtbarkeit</dt>
                <dd class="text-sm text-text-primary mt-1 capitalize">{persona.data.visibility}</dd>
              </div>
              {persona.data.contributors && (
                <div>
                  <dt class="text-xs text-text-muted uppercase">Mitwirkende</dt>
                  <dd class="text-sm text-text-primary mt-1">{persona.data.contributors.join(', ')}</dd>
                </div>
              )}
            </dl>
            {persona.data.tags && persona.data.tags.length > 0 && (
              <div class="mt-4">
                <dt class="text-xs text-text-muted uppercase mb-2">Tags</dt>
                <div class="flex flex-wrap gap-1">
                  {persona.data.tags.map((tag: string) => (
                    <span class="text-xs bg-background-page text-text-secondary px-2 py-1 rounded border border-border">
                      #{tag}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
        </div>
      </div>
    </main>
  </div>

  <style>
    .prose {
      color: var(--text-secondary);
    }
    .prose h1,
    .prose h2,
    .prose h3,
    .prose h4 {
      color: var(--text-primary);
    }
    .prose strong {
      color: var(--text-primary);
    }
    .prose a {
      color: var(--primary);
    }
  </style>

</Layout>