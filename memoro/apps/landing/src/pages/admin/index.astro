---
import Layout from "../../layouts/Layout.astro";

// Einfacher Schutz durch obskure URL
const isProtected = import.meta.env.PROD;
const accessToken = Astro.url.searchParams.get('token');
const validToken = 'memoro-team-2025'; // In .env speichern!

if (isProtected && accessToken !== validToken) {
  return Astro.redirect('/404');
}

// Admin-Bereiche
const adminSections = [
  {
    title: 'Content Calendar',
    description: 'Redaktionsplanung und Content-Übersicht',
    icon: '📅',
    href: `/admin/content-calendar${isProtected ? '?token=' + validToken : ''}`,
    stats: 'Monatsplanung'
  },
  {
    title: 'Autoren-Verwaltung',
    description: 'Autorenprofile und Berechtigungen verwalten',
    icon: '👥',
    href: `/admin/authors${isProtected ? '?token=' + validToken : ''}`,
    stats: 'Profile & Rollen'
  },
  {
    title: 'Personas Management',
    description: 'Interne Personas für Marketing und Produktentwicklung',
    icon: '🎭',
    href: `/admin/personas${isProtected ? '?token=' + validToken : ''}`,
    stats: 'Zielgruppen-Profile'
  },
  {
    title: 'User Stories',
    description: 'Interaktive Geschichten und Szenarien',
    icon: '📖',
    href: `/admin/stories${isProtected ? '?token=' + validToken : ''}`,
    stats: 'Nutzer-Szenarien'
  }
];
---

<Layout title="Admin Dashboard - Memoro" noindex={true}>
  <main class="bg-background-page min-h-screen">
    <div class="max-w-7xl mx-auto px-4 py-8">
      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-4xl md:text-5xl font-bold text-text-primary mb-4">Admin Dashboard</h1>
        <p class="text-lg text-text-secondary">
          Verwaltungsbereiche für Memoro
        </p>
        {!isProtected && (
          <div class="mt-2 p-3 bg-primary/10 border border-primary/30 rounded-md">
            <p class="text-sm text-primary-light">
              ⚠️ Development Mode: In Produktion wird diese Seite durch Token geschützt
            </p>
          </div>
        )}
      </div>

      <!-- Admin Sections Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-2 xl:grid-cols-4 gap-6">
        {adminSections.map(section => (
          <a 
            href={section.href}
            class="bg-background-card rounded-lg p-6 border border-border-DEFAULT hover:bg-background-cardHover hover:border-primary/50 transition-all group"
          >
            <div class="flex items-start justify-between mb-4">
              <div class="text-4xl">{section.icon}</div>
              <div class="text-xs text-text-muted bg-background-cardHover px-2 py-1 rounded">
                {section.stats}
              </div>
            </div>
            <h2 class="text-xl font-bold text-text-primary mb-2 group-hover:text-primary transition-colors">
              {section.title}
            </h2>
            <p class="text-text-secondary">
              {section.description}
            </p>
          </a>
        ))}
      </div>

      <!-- Quick Links -->
      <div class="mt-12 bg-background-card rounded-lg p-6 border border-border-DEFAULT">
        <h3 class="text-lg font-semibold text-text-primary mb-4">Schnellzugriff</h3>
        <div class="grid md:grid-cols-3 gap-4">
          <div>
            <h4 class="text-sm font-medium text-text-muted mb-2">Content Collections</h4>
            <ul class="space-y-1 text-sm">
              <li><a href="/de/blog" class="text-text-secondary hover:text-primary transition-colors">→ Blog</a></li>
              <li><a href="/de/changelog" class="text-text-secondary hover:text-primary transition-colors">→ Changelog</a></li>
              <li><a href="/de/statistics" class="text-text-secondary hover:text-primary transition-colors">→ Statistiken</a></li>
              <li><a href="/de/guides" class="text-text-secondary hover:text-primary transition-colors">→ Anleitungen</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-sm font-medium text-text-muted mb-2">Marketing</h4>
            <ul class="space-y-1 text-sm">
              <li><a href="/de/testimonials" class="text-text-secondary hover:text-primary transition-colors">→ Testimonials</a></li>
              <li><a href="/de/features" class="text-text-secondary hover:text-primary transition-colors">→ Features</a></li>
              <li><a href="/de/industries" class="text-text-secondary hover:text-primary transition-colors">→ Branchen</a></li>
              <li><a href="/de/wallpapers" class="text-text-secondary hover:text-primary transition-colors">→ Wallpapers</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-sm font-medium text-text-muted mb-2">Entwicklung</h4>
            <ul class="space-y-1 text-sm">
              <li><span class="text-text-secondary">Build: </span><code class="text-xs bg-background-cardHover px-1 py-0.5 rounded">npm run build</code></li>
              <li><span class="text-text-secondary">Dev: </span><code class="text-xs bg-background-cardHover px-1 py-0.5 rounded">npm run dev</code></li>
              <li><span class="text-text-secondary">Check: </span><code class="text-xs bg-background-cardHover px-1 py-0.5 rounded">npm run astro check</code></li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Info Box -->
      <div class="mt-8 bg-blue-900/20 border border-blue-700 rounded-lg p-4">
        <h3 class="text-sm font-semibold text-blue-400 mb-2">Admin-Bereich Hinweise:</h3>
        <ul class="text-sm text-blue-300 space-y-1">
          <li>• Alle Admin-Seiten sind in Produktion token-geschützt</li>
          <li>• Content wird direkt über MDX-Dateien in <code class="bg-blue-900/30 px-1 py-0.5 rounded">src/content/</code> verwaltet</li>
          <li>• Änderungen erfordern einen Build-Prozess für die Produktion</li>
          <li>• Nutze Git für Versionskontrolle aller Content-Änderungen</li>
        </ul>
      </div>
    </div>
  </main>
</Layout>