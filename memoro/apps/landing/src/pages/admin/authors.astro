---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import AuthorCard from "../../components/AuthorCard.astro";

// Einfacher Schutz durch obskure URL
const isProtected = import.meta.env.PROD;
const accessToken = Astro.url.searchParams.get('token');
const validToken = 'memoro-team-2025'; // In .env speichern!

if (isProtected && accessToken !== validToken) {
  return Astro.redirect('/404');
}

// Lade alle Autoren
const authors = await getCollection('authors');

// Sortiere nach Featured und dann alphabetisch
const sortedAuthors = authors.sort((a, b) => {
  if (a.data.isFeatured && !b.data.isFeatured) return -1;
  if (!a.data.isFeatured && b.data.isFeatured) return 1;
  return a.data.displayName.localeCompare(b.data.displayName);
});

// Gruppiere nach Sprache (nur unterstützte Sprachen)
const authorsByLang: Record<'de' | 'en', typeof sortedAuthors> = {
  de: sortedAuthors.filter(a => a.data.lang === 'de'),
  en: sortedAuthors.filter(a => a.data.lang === 'en')
};

// Verfügbare Sprachen
const availableLanguages = Object.keys(authorsByLang).filter(lang => authorsByLang[lang as keyof typeof authorsByLang].length > 0);
---

<Layout title="Authors & Writing Styles - Memoro" noindex={true}>
  <main class="bg-background-page min-h-screen">
    <!-- Header -->
    <div class="max-w-7xl mx-auto px-4 py-8">
      <div class="mb-8">
        <h1 class="text-4xl md:text-5xl font-bold text-text-primary mb-4">
          Authors & Writing Styles
        </h1>
        <p class="text-lg text-text-secondary max-w-3xl">
          Übersicht aller Autoren mit ihren individuellen Schreibstilen und Voice-Definitionen. 
          Diese Prompts helfen bei der konsistenten Content-Erstellung.
        </p>
        {!isProtected && (
          <div class="mt-2 p-3 bg-primary/10 border border-primary/30 rounded-md">
            <p class="text-sm text-primary-light">
              ⚠️ Development Mode: In Produktion wird diese Seite durch Token geschützt
            </p>
          </div>
        )}
      </div>
    </div>

    <!-- Autoren nach Sprache -->
    {availableLanguages.map(lang => {
      const langInfo = {
        de: { flag: '🇩🇪', name: 'Deutsche Autoren', noAuthors: 'Keine deutschen Autoren vorhanden' },
        en: { flag: '🇬🇧', name: 'English Authors', noAuthors: 'No English authors available' }
      } as const;
      
      return (
        <section class="mb-12">
          <div class="max-w-7xl mx-auto px-4">
            <h2 class="text-2xl font-bold text-text-primary mb-6 flex items-center gap-2">
              <span class="text-3xl">{langInfo[lang as keyof typeof langInfo]?.flag}</span> {langInfo[lang as keyof typeof langInfo]?.name}
            </h2>
          </div>
          
          <!-- Horizontally Scrollable Container -->
          <div class="overflow-x-auto pb-6">
            <div class="flex gap-6 px-4 min-w-max" style="width: max-content;">
              {authorsByLang[lang].map((author) => (
                <AuthorCard
                  name={author.data.name}
                  displayName={author.data.displayName}
                  bio={author.data.bio}
                  role={author.data.role}
                  avatar={author.data.avatar}
                  expertise={author.data.expertise}
                  writingPrompt={author.data.writingPrompt}
                  stats={author.data.stats}
                  social={author.data.social}
                />
              ))}
              
              {authorsByLang[lang].length === 0 && (
                <div class="min-w-[400px] h-[600px] bg-background-card border border-border-DEFAULT rounded-lg flex items-center justify-center">
                  <p class="text-text-muted">{langInfo[lang].noAuthors}</p>
                </div>
              )}
            </div>
          </div>
        </section>
      );
    })}


    <!-- How to Add Authors -->
    <div class="max-w-7xl mx-auto px-4 py-8">
      <div class="bg-blue-900/20 border border-blue-700 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-blue-400 mb-3">Neue Autoren hinzufügen</h3>
        <ol class="text-sm text-blue-300 space-y-2">
          <li>1. Erstelle eine neue .mdx Datei in <code class="bg-blue-900/30 px-1 py-0.5 rounded">src/content/authors/[lang]/</code></li>
          <li>2. Nutze das Authors-Schema mit allen erforderlichen Feldern</li>
          <li>3. Definiere einen aussagekräftigen <code class="bg-blue-900/30 px-1 py-0.5 rounded">writingPrompt</code> für konsistente Inhalte</li>
          <li>4. Füge optional Avatar, Social Links und Expertise hinzu</li>
        </ol>
      </div>
      
      <!-- Quick Links -->
      <div class="mt-6 flex gap-4">
        <a 
          href={`/admin/content-calendar${accessToken ? `?token=${accessToken}` : ''}`}
          class="inline-flex items-center gap-2 px-4 py-2 bg-primary/20 border border-primary text-primary rounded-lg hover:bg-primary/30 transition-colors"
        >
          <span>📅</span> Content Calendar
        </a>
      </div>
    </div>
  </main>

  <style>
    /* Custom scrollbar for horizontal scroll */
    .overflow-x-auto {
      scrollbar-width: thin;
      scrollbar-color: rgba(248, 214, 43, 0.3) rgba(255, 255, 255, 0.1);
    }
    
    .overflow-x-auto::-webkit-scrollbar {
      height: 8px;
    }
    
    .overflow-x-auto::-webkit-scrollbar-track {
      background: rgba(255, 255, 255, 0.1);
      border-radius: 4px;
    }
    
    .overflow-x-auto::-webkit-scrollbar-thumb {
      background: rgba(248, 214, 43, 0.3);
      border-radius: 4px;
    }
    
    .overflow-x-auto::-webkit-scrollbar-thumb:hover {
      background: rgba(248, 214, 43, 0.5);
    }
  </style>
</Layout>