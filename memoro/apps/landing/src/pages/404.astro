---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/utils';
import { Icon } from 'astro-icon/components';

// Default to German since it's the primary language
// Users will see language switch options on the page
const lang = 'de';
const t = useTranslations(lang);

// Popular pages for quick navigation
const popularPages = {
  de: [
    { title: 'Startseite', href: '/', icon: 'mdi:home' },
    { title: 'Features', href: '/features', icon: 'mdi:star' },
    { title: 'Preise', href: '/prices', icon: 'mdi:currency-eur' },
    { title: 'Download', href: '/download', icon: 'mdi:download' },
    { title: 'Blog', href: '/blog', icon: 'mdi:newspaper' },
    { title: 'Kontakt', href: '/contact', icon: 'mdi:email' },
  ],
  en: [
    { title: 'Homepage', href: '/en', icon: 'mdi:home' },
    { title: 'Features', href: '/en/features', icon: 'mdi:star' },
    { title: 'Pricing', href: '/en/prices', icon: 'mdi:currency-eur' },
    { title: 'Download', href: '/en/download', icon: 'mdi:download' },
    { title: 'Blog', href: '/en/blog', icon: 'mdi:newspaper' },
    { title: 'Contact', href: '/en/contact', icon: 'mdi:email' },
  ],
};

const currentPages = popularPages[lang as keyof typeof popularPages];

// SEO
const title = lang === 'de' ? 'Seite nicht gefunden' : 'Page Not Found';
const description = lang === 'de' 
  ? 'Die angeforderte Seite konnte nicht gefunden werden. Nutzen Sie unsere Suche oder Navigation, um die gewünschten Inhalte zu finden.'
  : 'The requested page could not be found. Use our search or navigation to find the content you are looking for.';
---

<Layout title={`404 - ${title}`} description={description} lang={lang} noindex={true}>
  <main class="min-h-screen flex items-center justify-center px-4 py-16 bg-gradient-to-br from-background-page to-background-secondary">
    <div class="max-w-2xl w-full">
      <!-- 404 Animation -->
      <div class="text-center mb-8">
        <div class="relative inline-block">
          <span class="text-9xl font-bold text-primary-600 opacity-20">404</span>
          <div class="absolute inset-0 flex items-center justify-center">
            <Icon name="mdi:compass-off" class="w-24 h-24 text-primary-600 animate-pulse" />
          </div>
        </div>
      </div>

      <!-- Error Message -->
      <div class="text-center mb-8">
        <h1 class="text-3xl md:text-4xl font-bold text-content-primary mb-4">
          {lang === 'de' ? 'Oops! Seite nicht gefunden' : 'Oops! Page not found'}
        </h1>
        <p class="text-lg text-content-secondary max-w-lg mx-auto">
          {lang === 'de' 
            ? 'Die Seite, die Sie suchen, existiert nicht oder wurde verschoben. Aber keine Sorge, wir helfen Ihnen weiter!'
            : 'The page you are looking for doesn\'t exist or has been moved. But don\'t worry, we\'ll help you find your way!'}
        </p>
      </div>

      <!-- Search Box -->
      <div class="mb-12">
        <form action={lang === 'de' ? '/suche' : '/en/search'} method="get" class="relative max-w-md mx-auto">
          <input
            type="search"
            name="q"
            placeholder={lang === 'de' ? 'Nach Inhalten suchen...' : 'Search for content...'}
            class="w-full px-4 py-3 pl-12 pr-4 text-content-primary bg-white border border-ui-border-subtle rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
            id="search-404"
          />
          <Icon name="mdi:magnify" class="absolute left-4 top-1/2 transform -translate-y-1/2 w-5 h-5 text-content-tertiary" />
        </form>
      </div>

      <!-- Popular Pages -->
      <div class="mb-8">
        <h2 class="text-xl font-semibold text-content-primary mb-4 text-center">
          {lang === 'de' ? 'Beliebte Seiten' : 'Popular Pages'}
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {currentPages.map((page) => (
            <a
              href={page.href}
              class="flex items-center space-x-3 p-3 bg-white rounded-lg border border-ui-border-subtle hover:border-primary-500 hover:bg-primary-50 transition-all group"
            >
              <Icon name={page.icon} class="w-5 h-5 text-content-tertiary group-hover:text-primary-600 transition-colors" />
              <span class="text-content-secondary group-hover:text-primary-600 transition-colors">
                {page.title}
              </span>
            </a>
          ))}
        </div>
      </div>

      <!-- Language Switch -->
      <div class="text-center pt-4 border-t border-ui-border-subtle">
        <p class="text-sm text-content-tertiary mb-2">
          {lang === 'de' ? 'Andere Sprache?' : 'Different language?'}
        </p>
        <div class="flex justify-center space-x-4">
          <a 
            href="/"
            class={`px-4 py-2 rounded-lg transition-colors ${
              lang === 'de' 
                ? 'bg-primary-600 text-white' 
                : 'bg-white border border-ui-border-subtle hover:border-primary-500 text-content-secondary hover:text-primary-600'
            }`}
          >
            Deutsch
          </a>
          <a 
            href="/en"
            class={`px-4 py-2 rounded-lg transition-colors ${
              lang === 'en' 
                ? 'bg-primary-600 text-white' 
                : 'bg-white border border-ui-border-subtle hover:border-primary-500 text-content-secondary hover:text-primary-600'
            }`}
          >
            English
          </a>
        </div>
      </div>

      <!-- Support Contact -->
      <div class="text-center mt-8">
        <p class="text-sm text-content-tertiary">
          {lang === 'de' 
            ? 'Brauchen Sie Hilfe? Kontaktieren Sie uns unter' 
            : 'Need help? Contact us at'}
          {' '}
          <a href="mailto:support@memoro.ai" class="text-primary-600 hover:text-primary-700 underline">
            support@memoro.ai
          </a>
        </p>
      </div>
    </div>
  </main>

  <script>
    // Auto-focus search field
    document.addEventListener('DOMContentLoaded', () => {
      const searchField = document.getElementById('search-404') as HTMLInputElement;
      if (searchField) {
        searchField.focus();
      }

      // Track 404 errors in analytics
      if (typeof window !== 'undefined' && window.posthog) {
        window.posthog.capture('404_error', {
          url: window.location.pathname,
          referrer: document.referrer
        });
      }
    });
  </script>
</Layout>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }
</style>