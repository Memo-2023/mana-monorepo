---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from "../../../i18n/utils";
import HeroSection from "../../../components/HeroSection.astro";
import MemoryCard from "../../../components/MemoryCard.astro";
import CallToAction from "../../../components/CallToAction.astro";
import FilterPills from "../../../components/FilterPills.astro";
import EmptyState from "../../../components/EmptyState.astro";

export async function getStaticPaths() {
  return ['de', 'en'].map(lang => ({
    params: { lang },
    props: { lang }
  }));
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Get category from URL query parameter
const url = Astro.url;
const categoryParam = url.searchParams.get('category');

// Alle Memories abrufen und nach Sprache filtern
const allMemories = await getCollection('memories');
const filteredMemories = allMemories.filter(memory => memory.data.lang === lang && memory.data.isActive !== false);

// Sortieren nach Order (falls vorhanden)
const sortedMemories = filteredMemories.sort((a, b) => {
  if (a.data.order !== undefined && b.data.order !== undefined) {
    return a.data.order - b.data.order;
  }
  return 0;
});

// Gruppieren nach Kategorie (normalisiert)
const memoriesByCategory = sortedMemories.reduce((acc, memory) => {
  const category = (memory.data.category || 'Andere').toLowerCase();
  if (!acc[category]) {
    acc[category] = [];
  }
  acc[category].push(memory);
  return acc;
}, {});

// Category labels
const categoryLabels = {
  de: {
    all: 'Alle',
    zusammenfassung: 'Zusammenfassung',
    organisation: 'Organisation',
    analyse: 'Analyse',
    kreativ: 'Kreativ',
    content: 'Content',
    andere: 'Andere'
  },
  en: {
    all: 'All',
    summary: 'Summary',
    organization: 'Organization',
    analysis: 'Analysis',
    creative: 'Creative',
    content: 'Content',
    other: 'Other'
  }
};

// Empty state messages
const emptyStateMessages = {
  de: {
    all: {
      title: "Noch keine Memories",
      message: "Wir arbeiten daran, verschiedene Analyse-Formate für Sie zu erstellen. Schauen Sie bald wieder vorbei!",
      icon: "memory"
    },
    zusammenfassung: {
      title: "Keine Zusammenfassungs-Memories",
      message: "Aktuell sind keine Zusammenfassungs-Memories verfügbar.",
      icon: "summary-brief"
    },
    organisation: {
      title: "Keine Organisations-Memories",
      message: "Organisations-Memories sind in Vorbereitung.",
      icon: "tasks"
    },
    analyse: {
      title: "Keine Analyse-Memories",
      message: "Analyse-Memories werden gerade erstellt.",
      icon: "questions-open"
    },
    kreativ: {
      title: "Keine Kreativ-Memories",
      message: "Kreativ-Memories folgen in Kürze.",
      icon: "ideas"
    },
    content: {
      title: "Keine Content-Memories",
      message: "Content-Memories sind in Entwicklung.",
      icon: "blog"
    },
    andere: {
      title: "Keine weiteren Memories",
      message: "Weitere Memories werden bald hinzugefügt.",
      icon: "memory"
    }
  },
  en: {
    all: {
      title: "No memories yet",
      message: "We're working on creating various analysis formats for you. Check back soon!",
      icon: "memory"
    },
    summary: {
      title: "No summary memories",
      message: "No summary memories are currently available.",
      icon: "summary-brief"
    },
    organization: {
      title: "No organization memories",
      message: "Organization memories are in preparation.",
      icon: "tasks"
    },
    analysis: {
      title: "No analysis memories",
      message: "Analysis memories are being created.",
      icon: "questions-open"
    },
    creative: {
      title: "No creative memories",
      message: "Creative memories will follow shortly.",
      icon: "ideas"
    },
    content: {
      title: "No content memories",
      message: "Content memories are in development.",
      icon: "blog"
    },
    other: {
      title: "No other memories",
      message: "Additional memories will be added soon.",
      icon: "memory"
    }
  }
};

// Determine active filter from URL or default to 'all'
let activeFilter = 'all';
if (categoryParam) {
  // Find matching category (case-insensitive)
  const matchingCategory = Object.keys(memoriesByCategory).find(
    cat => cat.toLowerCase() === categoryParam.toLowerCase()
  );
  if (matchingCategory) {
    activeFilter = matchingCategory;
  }
}

// Übersetzungen
const translations = {
  de: {
    title: 'Memories',
    description: 'Entdecke die verschiedenen Analysen, die Memoro von deinen Gesprächen erstellt',
    heroTitle: 'Deine Gespräche werden zu wertvollen Erinnerungen',
    heroSubtitle: 'Memoro analysiert deine Unterhaltungen und erstellt automatisch strukturierte Zusammenfassungen, Aufgaben und Erkenntnisse',
    introText: 'Wähle die passende Memory-Art für deine Anforderungen und erhalte maßgeschneiderte Analysen deiner Gespräche.',
    features: 'Funktionen',
    readMore: 'Mehr erfahren',
    benefitsTitle: 'Warum Memories nutzen?',
    benefit1Title: 'Zeitersparnis',
    benefit1Text: 'Keine manuellen Notizen mehr - alles wird automatisch erfasst und strukturiert.',
    benefit2Title: 'Nichts vergessen',
    benefit2Text: 'Jeder wichtige Punkt, jede Aufgabe und jede Idee wird dokumentiert.',
    benefit3Title: 'Bessere Entscheidungen',
    benefit3Text: 'Strukturierte Analysen helfen dir, fundierte Entscheidungen zu treffen.',
    ctaTitle: 'Bereit für intelligente Gesprächsanalyse?',
    ctaDescription: 'Lade Memoro herunter und verwandle deine Gespräche in wertvolle Erkenntnisse.',
    ctaButton: 'App herunterladen'
  },
  en: {
    title: 'Memories',
    description: 'Discover the various analyses Memoro creates from your conversations',
    heroTitle: 'Your Conversations Become Valuable Memories',
    heroSubtitle: 'Memoro analyzes your conversations and automatically creates structured summaries, tasks, and insights',
    introText: 'Choose the right memory type for your needs and get tailored analyses of your conversations.',
    features: 'Features',
    readMore: 'Read more',
    benefitsTitle: 'Why use Memories?',
    benefit1Title: 'Save Time',
    benefit1Text: 'No more manual notes - everything is automatically captured and structured.',
    benefit2Title: 'Never Forget',
    benefit2Text: 'Every important point, task, and idea is documented.',
    benefit3Title: 'Better Decisions',
    benefit3Text: 'Structured analyses help you make informed decisions.',
    ctaTitle: 'Ready for intelligent conversation analysis?',
    ctaDescription: 'Download Memoro and transform your conversations into valuable insights.',
    ctaButton: 'Download App'
  }
};

const currentTranslations = translations[lang];

// SEO translations
const seoTitle = lang === 'de' ? 'Memories - KI-gestützte Gesprächsanalyse' : 'Memories - AI-Powered Conversation Analysis';
const seoDescription = currentTranslations.description;
---

<Layout title={seoTitle} description={seoDescription}>
  <main class="bg-background-page">
    <HeroSection
      variant="widescreen"
      title={currentTranslations.heroTitle}
      subtitle={currentTranslations.heroSubtitle}
      image="/images/product_photos/Memoro-App-Smartphone.jpg"
    />
    
    <div class="max-w-7xl mx-auto px-6 sm:px-8 md:px-12 py-8 md:py-12">
      {/* Intro text */}
      <div class="text-center mb-12">
        <p class="text-lg text-text-secondary max-w-3xl mx-auto">
          {currentTranslations.introText}
        </p>
      </div>
      
      {/* Filter Pills */}
      <div class="mb-12">
        <FilterPills 
          filters={[
            { value: 'all', label: categoryLabels[lang].all, count: sortedMemories.length },
            ...Object.entries(memoriesByCategory)
              .filter(([_, items]) => items.length > 0)
              .map(([category, items]) => ({
                value: category,
                label: categoryLabels[lang][category] || category.charAt(0).toUpperCase() + category.slice(1),
                count: items.length
              }))
          ]}
          activeFilter={activeFilter}
          id="memories-filter"
        />
      </div>
      
      {/* Memory Grid */}
      <div class="memories-grid mb-16" data-filter-content="memories-filter">
        {/* All Memories */}
        <div data-type="all" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {sortedMemories.length > 0 ? (
            sortedMemories.map((memory) => (
              <MemoryCard
                title={memory.data.title}
                description={memory.data.description}
                icon={memory.data.icon}
                href={`/${lang}/memories/${memory.slug.replace(`${lang}/`, '')}`}
                lang={lang}
                color={memory.data.color}
                features={memory.data.features}
              />
            ))
          ) : (
            <div class="col-span-full">
              <EmptyState 
                {...emptyStateMessages[lang].all}
              />
            </div>
          )}
        </div>

        {/* Filtered Views */}
        {Object.entries(memoriesByCategory).map(([category, items]) => (
          <div data-type={category} class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {items.length > 0 ? (
              items.map((memory) => (
                <MemoryCard
                  title={memory.data.title}
                  description={memory.data.description}
                  icon={memory.data.icon}
                  href={`/${lang}/memories/${memory.slug.replace(`${lang}/`, '')}`}
                  lang={lang}
                  color={memory.data.color}
                  features={memory.data.features}
                />
              ))
            ) : (
              <div class="col-span-full">
                <EmptyState 
                  {...emptyStateMessages[lang][category] || emptyStateMessages[lang].andere}
                />
              </div>
            )}
          </div>
        ))}
      </div>
      
      {/* Benefits Section */}
      <div class="bg-background-card rounded-2xl p-8 md:p-12 mb-16">
        <h2 class="text-3xl font-bold text-text-primary text-center mb-8">
          {currentTranslations.benefitsTitle}
        </h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-primary-DEFAULT" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-text-primary mb-2">
              {currentTranslations.benefit1Title}
            </h3>
            <p class="text-text-secondary">
              {currentTranslations.benefit1Text}
            </p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-primary-DEFAULT" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-text-primary mb-2">
              {currentTranslations.benefit2Title}
            </h3>
            <p class="text-text-secondary">
              {currentTranslations.benefit2Text}
            </p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-primary-DEFAULT" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-text-primary mb-2">
              {currentTranslations.benefit3Title}
            </h3>
            <p class="text-text-secondary">
              {currentTranslations.benefit3Text}
            </p>
          </div>
        </div>
      </div>
      
      {/* Call to Action */}
      <CallToAction
        title={currentTranslations.ctaTitle}
        description={currentTranslations.ctaDescription}
        buttonText={currentTranslations.ctaButton}
        buttonLink={`/${lang}/download`}
      />
    </div>
  </main>
</Layout>