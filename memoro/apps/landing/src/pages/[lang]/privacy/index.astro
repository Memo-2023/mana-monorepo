---
import { getEntry, getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import { useTranslations } from "../../../i18n/utils";
import PrivacyCard from "../../../components/PrivacyCard.astro";
import PrivacyQuickAction from "../../../components/PrivacyQuickAction.astro";
import { Icon } from "astro-icon/components";

export async function getStaticPaths() {
  return ['de', 'en'].map(lang => ({
    params: { lang },
    props: { lang }
  }));
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Get all privacy documents for current language
const allDocs = await getCollection("dataprotection", ({ data }) => {
  return data.lang === lang && data.isActive && data.showInPrivacyCenter;
});

// Sort by order
const sortedDocs = allDocs.sort((a, b) => (a.data.order || 999) - (b.data.order || 999));

// Separate main documents from privacy center
const mainDocs = sortedDocs.filter(doc => doc.data.category !== 'privacy-center');
const privacyCenter = sortedDocs.find(doc => doc.data.category === 'privacy-center');

// Document icons mapping
const docIcons = {
  'website-privacy': '🌐',
  'app-privacy': '📱',
  'cookie-policy': '🍪',
  'dpa': '📄',
  'security': '🔒',
  'rights': '👤',
  'data-request': '📊',
  'third-party': '🤝',
  'retention': '⏰'
};

// Quick actions data
const quickActions = lang === 'de' ? [
  {
    title: 'Datenauskunft anfordern',
    description: 'Erfahren Sie, welche Daten wir über Sie gespeichert haben',
    icon: '📋',
    href: '/de/privacy/data-request'
  },
  {
    title: 'Daten löschen lassen',
    description: 'Beantragen Sie die Löschung Ihrer personenbezogenen Daten',
    icon: '🗑️',
    href: '/de/privacy/data-deletion'
  },
  {
    title: 'Einstellungen verwalten',
    description: 'Passen Sie Ihre Datenschutz-Präferenzen an',
    icon: '⚙️',
    href: '/de/settings/privacy'
  }
] : [
  {
    title: 'Request Data Access',
    description: 'Find out what data we have stored about you',
    icon: '📋',
    href: '/en/privacy/data-request'
  },
  {
    title: 'Delete Your Data',
    description: 'Request deletion of your personal data',
    icon: '🗑️',
    href: '/en/privacy/data-deletion'
  },
  {
    title: 'Manage Settings',
    description: 'Adjust your privacy preferences',
    icon: '⚙️',
    href: '/en/settings/privacy'
  }
];
---

<Layout title={privacyCenter?.data.title || 'Privacy Center'}>
  <main class="bg-background-page">
    {/* Hero Section */}
    <section class="relative overflow-hidden bg-gradient-to-br from-primary/5 via-background-page to-primary/10">
      <div class="absolute inset-0 bg-grid-pattern opacity-5"></div>
      <div class="max-w-7xl mx-auto px-4 py-20 relative">
        <div class="text-center max-w-3xl mx-auto">
          <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-primary/20 to-primary/10 mb-6">
            <span class="text-4xl">🛡️</span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-text-primary mb-4">
            {lang === 'de' ? 'Datenschutz-Center' : 'Privacy Center'}
          </h1>
          <p class="text-xl text-text-secondary mb-8">
            {lang === 'de' 
              ? 'Ihr zentraler Anlaufpunkt für alle Datenschutz-Informationen bei Memoro' 
              : 'Your central hub for all privacy information at Memoro'}
          </p>
          <div class="flex flex-wrap gap-4 justify-center">
            <div class="flex items-center gap-2 px-4 py-2 bg-background-card rounded-full border border-border">
              <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-sm font-medium text-text-primary">DSGVO-konform</span>
            </div>
            <div class="flex items-center gap-2 px-4 py-2 bg-background-card rounded-full border border-border">
              <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-sm font-medium text-text-primary">ISO 27001</span>
            </div>
            <div class="flex items-center gap-2 px-4 py-2 bg-background-card rounded-full border border-border">
              <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-sm font-medium text-text-primary">
                {lang === 'de' ? 'EU-Server' : 'EU Servers'}
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Main Documents Grid */}
    <section class="max-w-7xl mx-auto px-4 py-16">
      <div class="mb-12">
        <h2 class="text-3xl font-bold text-text-primary mb-4">
          {lang === 'de' ? 'Unsere Datenschutz-Dokumente' : 'Our Privacy Documents'}
        </h2>
        <p class="text-text-secondary">
          {lang === 'de' 
            ? 'Alle wichtigen Dokumente zum Schutz Ihrer Daten auf einen Blick' 
            : 'All important documents for the protection of your data at a glance'}
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {mainDocs.map((doc) => (
          <PrivacyCard
            title={doc.data.title}
            description={doc.data.description}
            icon={docIcons[doc.data.category] || '📄'}
            href={`/${lang}/privacy/${doc.data.category.replace('privacy-', '').replace('-privacy', '')}`}
            version={doc.data.version}
            lastUpdated={doc.data.lastUpdated}
            badge={doc.data.category === 'website-privacy' ? (lang === 'de' ? 'NEU' : 'NEW') : undefined}
            lang={lang}
          />
        ))}
      </div>
    </section>

    {/* Quick Actions */}
    <section class="bg-gradient-to-b from-background-page to-primary/5">
      <div class="max-w-7xl mx-auto px-4 py-16">
        <div class="mb-12 text-center">
          <h2 class="text-3xl font-bold text-text-primary mb-4">
            {lang === 'de' ? 'Schnellzugriff' : 'Quick Access'}
          </h2>
          <p class="text-text-secondary">
            {lang === 'de' 
              ? 'Häufig genutzte Datenschutz-Funktionen' 
              : 'Frequently used privacy features'}
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {quickActions.map((action, index) => (
            <PrivacyQuickAction
              title={action.title}
              description={action.description}
              icon={action.icon}
              href={action.href}
              variant={index === 0 ? 'primary' : 'secondary'}
              lang={lang}
            />
          ))}
        </div>
      </div>
    </section>

    {/* Contact Section */}
    <section class="max-w-7xl mx-auto px-4 py-16">
      <div class="bg-gradient-to-br from-primary/10 to-primary/5 rounded-2xl p-8 md:p-12">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div>
            <h2 class="text-3xl font-bold text-text-primary mb-4">
              {lang === 'de' ? 'Kontakt zum Datenschutzbeauftragten' : 'Contact Our Data Protection Officer'}
            </h2>
            <p class="text-text-secondary mb-6">
              {lang === 'de' 
                ? 'Bei Fragen zum Datenschutz stehen wir Ihnen gerne zur Verfügung' 
                : 'We are happy to assist you with any privacy-related questions'}
            </p>
            <div class="space-y-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-background-card flex items-center justify-center">
                  <span>📧</span>
                </div>
                <div>
                  <p class="text-sm text-text-secondary">
                    {lang === 'de' ? 'E-Mail' : 'Email'}
                  </p>
                  <a href="mailto:datenschutz@memoro.ai" class="text-primary hover:text-primary-hover">
                    datenschutz@memoro.ai
                  </a>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-background-card flex items-center justify-center">
                  <span>📱</span>
                </div>
                <div>
                  <p class="text-sm text-text-secondary">
                    {lang === 'de' ? 'Telefon' : 'Phone'}
                  </p>
                  <a href="tel:+49176444343885" class="text-primary hover:text-primary-hover">
                    +49 176 444 343 85
                  </a>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-background-card flex items-center justify-center">
                  <span>📍</span>
                </div>
                <div>
                  <p class="text-sm text-text-secondary">
                    {lang === 'de' ? 'Adresse' : 'Address'}
                  </p>
                  <p class="text-text-primary">
                    Memoro GmbH<br />
                    Reichenaustraße 11a<br />
                    78464 Konstanz
                  </p>
                </div>
              </div>
            </div>
          </div>
          <div class="flex justify-center">
            <div class="w-64 h-64 rounded-2xl bg-gradient-to-br from-primary/20 to-primary/10 flex items-center justify-center">
              <span class="text-8xl">🛡️</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Footer Links */}
    <section class="border-t border-border">
      <div class="max-w-7xl mx-auto px-4 py-12">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <a href={`/${lang}/faq#datenschutz`} class="flex items-center gap-2 text-text-secondary hover:text-primary transition-colors">
            <span>❓</span>
            <span>{lang === 'de' ? 'Häufige Fragen' : 'FAQ'}</span>
          </a>
          <a href={`/${lang}/security`} class="flex items-center gap-2 text-text-secondary hover:text-primary transition-colors">
            <span>🔐</span>
            <span>{lang === 'de' ? 'Sicherheit' : 'Security'}</span>
          </a>
          <a href={`/${lang}/imprint`} class="flex items-center gap-2 text-text-secondary hover:text-primary transition-colors">
            <span>📝</span>
            <span>{lang === 'de' ? 'Impressum' : 'Imprint'}</span>
          </a>
          <a href={`/${lang}/terms`} class="flex items-center gap-2 text-text-secondary hover:text-primary transition-colors">
            <span>📜</span>
            <span>{lang === 'de' ? 'Nutzungsbedingungen' : 'Terms of Service'}</span>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .bg-grid-pattern {
    background-image: 
      linear-gradient(to right, rgb(var(--color-border)) 1px, transparent 1px),
      linear-gradient(to bottom, rgb(var(--color-border)) 1px, transparent 1px);
    background-size: 40px 40px;
  }
</style>