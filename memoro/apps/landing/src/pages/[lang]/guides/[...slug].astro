---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import DetailLayout from "../../../components/layouts/DetailLayout.astro";
import DifficultyBadge from "../../../components/detail/DifficultyBadge.astro";
import FeedbackButtons from "../../../components/detail/FeedbackButtons.astro";
import LastUpdatedInfo from "../../../components/detail/LastUpdatedInfo.astro";
import { useTranslations } from "../../../i18n/utils";
import ArticleNavigation from "../../../components/ArticleNavigation.astro";

export async function getStaticPaths() {
  const guides = await getCollection("guides");
  
  // Map each guide to a route with the clean slug
  return guides.map((guide) => {
    const lang = guide.data.lang;
    // Entferne den Sprachpräfix aus dem Slug, wenn vorhanden
    const langPrefix = `${lang}/`;
    const cleanSlug = guide.slug.startsWith(langPrefix) 
      ? guide.slug.substring(langPrefix.length)
      : guide.slug;
      
    return {
      params: { 
        lang: lang,
        slug: cleanSlug
      },
      props: { guide },
    };
  });
}

const { guide } = Astro.props;
const { lang } = Astro.params;
const t = useTranslations(lang);

// Holen aller Guides in der gleichen Sprache
const allGuides = await getCollection("guides", (g) => g.data.lang === lang);

// Sortieren der Guides nach Schwierigkeitsgrad und dann alphabetisch nach Titel
const difficultyOrder = { 'beginner': 1, 'intermediate': 2, 'advanced': 3 };
const sortedGuides = allGuides.sort((a, b) => {
  // Zuerst nach Schwierigkeitsgrad sortieren
  const diffA = difficultyOrder[a.data.difficulty as keyof typeof difficultyOrder] || 0;
  const diffB = difficultyOrder[b.data.difficulty as keyof typeof difficultyOrder] || 0;
  
  if (diffA !== diffB) {
    return diffA - diffB;
  }
  
  // Bei gleichem Schwierigkeitsgrad nach Kategorie sortieren
  if (a.data.category !== b.data.category) {
    return a.data.category.localeCompare(b.data.category, lang === 'de' ? 'de-DE' : 'en-US');
  }
  
  // Bei gleicher Kategorie alphabetisch nach Titel sortieren
  return a.data.title.localeCompare(b.data.title, lang === 'de' ? 'de-DE' : 'en-US');
});

// Finden des aktuellen Index
const currentIndex = sortedGuides.findIndex(g => g.id === guide.id);

// Bestimmen des vorherigen Guides
const prevArticle = currentIndex > 0 ? {
  slug: sortedGuides[currentIndex - 1].slug,
  title: sortedGuides[currentIndex - 1].data.title,
  lang: sortedGuides[currentIndex - 1].data.lang,
  collection: "guides"
} : null;

// Bestimmen des nächsten Guides
const nextArticle = currentIndex < sortedGuides.length - 1 ? {
  slug: sortedGuides[currentIndex + 1].slug,
  title: sortedGuides[currentIndex + 1].data.title,
  lang: sortedGuides[currentIndex + 1].data.lang,
  collection: "guides"
} : null;

// Get the Content component from the guide
let Content;
try {
  const rendered = await guide.render();
  Content = rendered.Content;
} catch (error) {
  console.error("Error rendering guide:", error);
}
---

<Layout title={guide.data.title}>
  <DetailLayout 
    title={guide.data.title}
    description={guide.data.description}
    backLink={{
      href: `/${lang}/guides`
    }}
  >
    <Fragment slot="header">
      <header class="mb-8">
        <div class="mb-4">
          <DifficultyBadge 
            difficulty={guide.data.difficulty}
            duration={guide.data.duration}
            category={guide.data.category}
            lang={lang}
          />
        </div>
        
        <h1 class="text-3xl font-bold text-text-primary">{guide.data.title}</h1>
        {
          guide.data.description && (
            <p class="text-xl text-text-secondary mt-2">{guide.data.description}</p>
          )
        }
        
        {guide.data.lastUpdated && (
          <LastUpdatedInfo date={guide.data.lastUpdated} lang={lang} />
        )}
      </header>
    </Fragment>
    
    {Content && <Content />}
    {!Content && <p class="text-red-500">There was an error rendering this guide content.</p>}
    
    <Fragment slot="after-content">
      <div class="mt-12 pt-6 border-t border-border">
        <FeedbackButtons lang={lang} />
      </div>
    </Fragment>
    
    <Fragment slot="footer">
      {/* Navigation zum nächsten Guide */}
      <ArticleNavigation 
        prevArticle={prevArticle} 
        nextArticle={nextArticle} 
        lang={lang} 
        collection="guides" 
      />
    </Fragment>
  </DetailLayout>
</Layout>