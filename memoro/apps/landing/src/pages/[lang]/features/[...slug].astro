---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import DetailLayout from "../../../components/layouts/DetailLayout.astro";
import { useTranslations } from "../../../i18n/utils";
import ArticleNavigation from "../../../components/ArticleNavigation.astro";

export async function getStaticPaths() {
  const features = await getCollection("features");
  
  // Map each feature to a route with the clean slug
  return features.map((feature) => {
    const lang = feature.data.lang;
    // Entferne den Sprachpräfix aus dem Slug, wenn vorhanden
    const langPrefix = `${lang}/`;
    const cleanSlug = feature.slug.startsWith(langPrefix) 
      ? feature.slug.substring(langPrefix.length)
      : feature.slug;
      
    return {
      params: { 
        lang: lang,
        slug: cleanSlug
      },
      props: { feature },
    };
  });
}

const { feature } = Astro.props;
const { lang } = Astro.params;
const t = useTranslations(lang);

// Holen aller Features in der gleichen Sprache
const allFeatures = await getCollection("features", (f) => f.data.lang === lang);

// Sortieren der Features nach order-Property (falls vorhanden) oder alphabetisch nach Titel
const sortedFeatures = allFeatures.sort((a, b) => {
  // Wenn beide Features eine order-Property haben, sortiere danach
  if (a.data.order !== undefined && b.data.order !== undefined) {
    return a.data.order - b.data.order;
  }
  // Wenn nur a eine order-Property hat, zeige a zuerst
  if (a.data.order !== undefined) return -1;
  // Wenn nur b eine order-Property hat, zeige b zuerst
  if (b.data.order !== undefined) return 1;
  // Ansonsten alphabetisch nach Titel sortieren
  return a.data.title.localeCompare(b.data.title, lang === 'de' ? 'de-DE' : 'en-US');
});

// Finden des aktuellen Index
const currentIndex = sortedFeatures.findIndex(f => f.id === feature.id);

// Bestimmen des vorherigen und nächsten Features
const prevArticle = currentIndex > 0 ? {
  slug: sortedFeatures[currentIndex - 1].slug,
  title: sortedFeatures[currentIndex - 1].data.title,
  lang: sortedFeatures[currentIndex - 1].data.lang,
  collection: "features"
} : null;

const nextArticle = currentIndex < sortedFeatures.length - 1 ? {
  slug: sortedFeatures[currentIndex + 1].slug,
  title: sortedFeatures[currentIndex + 1].data.title,
  lang: sortedFeatures[currentIndex + 1].data.lang,
  collection: "features"
} : null;

const { Content } = await feature.render();
---

<Layout title={feature.data.title}>
  <DetailLayout 
    title={feature.data.title}
    description={feature.data.description}
    backLink={{
      href: `/${lang}/features`
    }}
  >
    <Content />
    
    <Fragment slot="footer">
      {/* Navigation zu vorherigen/nächsten Features */}
      <ArticleNavigation 
        prevArticle={prevArticle} 
        nextArticle={nextArticle} 
        lang={lang} 
        collection="features" 
      />
    </Fragment>
  </DetailLayout>
</Layout>