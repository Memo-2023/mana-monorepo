---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';

export async function getStaticPaths() {
  return ['de', 'en'].map(lang => ({
    params: { lang },
    props: { lang }
  }));
}

const { lang } = Astro.params;
const t = useTranslations(lang);

// Get all statistics entries for the current language
const allStatistics = await getCollection('statistics', ({ data }) => {
  return data.lang === lang && !data.draft;
});

// Sort by year and month/week number (newest first)
const sortedStatistics = allStatistics.sort((a, b) => {
  if (a.data.year !== b.data.year) {
    return b.data.year - a.data.year;
  }
  // Sort by month if both have it, otherwise by weekNumber
  if (a.data.month && b.data.month) {
    return b.data.month - a.data.month;
  }
  return (b.data.weekNumber || 0) - (a.data.weekNumber || 0);
});

// Group by year
const statisticsByYear = sortedStatistics.reduce((acc, stat) => {
  const year = stat.data.year;
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(stat);
  return acc;
}, {} as Record<number, typeof sortedStatistics>);

const pageTitle = lang === 'de' ? 'Transparenz & Statistiken' : 'Transparency & Statistics';
const pageDescription = lang === 'de' 
  ? 'Transparente Einblicke in unsere monatlichen Statistiken und Entwicklungen'
  : 'Transparent insights into our monthly statistics and developments';
---

<Layout 
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  <div class="min-h-screen bg-background-page">
    <section class="relative py-20 overflow-hidden">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center mb-16">
          <h1 class="text-5xl md:text-6xl font-bold text-text-primary mb-6">
            {pageTitle}
          </h1>
          <p class="text-xl text-text-secondary">
            {pageDescription}
          </p>
        </div>

        {Object.entries(statisticsByYear).map(([year, stats]) => (
          <div key={year} class="mb-12">
            <h2 class="text-3xl font-bold text-text-primary mb-8 text-center">
              {year}
            </h2>
            
            <div class="grid gap-6 md:gap-8 max-w-4xl mx-auto">
              {stats.map((stat) => {
                const formattedPeriod = lang === 'de' 
                  ? `${new Date(stat.data.period.start).toLocaleDateString('de-DE')} - ${new Date(stat.data.period.end).toLocaleDateString('de-DE')}`
                  : `${new Date(stat.data.period.start).toLocaleDateString('en-US')} - ${new Date(stat.data.period.end).toLocaleDateString('en-US')}`;
                
                return (
                  <a
                    href={`/${lang}/statistics/${stat.slug}`}
                    class="group block bg-background-card rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 overflow-hidden border border-border hover:border-border-light"
                  >
                    <div class="p-8">
                      <div class="flex items-start justify-between mb-4">
                        <div>
                          <h3 class="text-2xl font-bold text-text-primary group-hover:text-primary-light transition-colors">
                            {stat.data.title}
                          </h3>
                          <p class="text-sm text-text-muted mt-1">
                            {formattedPeriod}
                          </p>
                        </div>
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-primary/10 text-primary-light">
                          {stat.data.reportType === 'monthly' 
                            ? new Date(stat.data.period.start).toLocaleDateString(lang === 'de' ? 'de-DE' : 'en-US', { month: 'long', year: 'numeric' })
                            : (lang === 'de' ? `KW ${stat.data.weekNumber}` : `Week ${stat.data.weekNumber}`)}
                        </span>
                      </div>
                      
                      <p class="text-text-secondary mb-6">
                        {stat.data.description}
                      </p>
                      
                      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                        <div class="text-center">
                          <p class="text-3xl font-bold text-text-primary">
                            {stat.data.stats.activeUsers.toLocaleString()}
                          </p>
                          <p class="text-sm text-text-muted">
                            {lang === 'de' ? 'Aktive Nutzer' : 'Active Users'}
                          </p>
                        </div>
                        <div class="text-center">
                          <p class="text-3xl font-bold text-text-primary">
                            {stat.data.stats.totalRecordings.toLocaleString()}
                          </p>
                          <p class="text-sm text-text-muted">
                            {lang === 'de' ? 'Aufnahmen' : 'Recordings'}
                          </p>
                        </div>
                        <div class="text-center">
                          <p class="text-3xl font-bold text-text-primary">
                            {(stat.data.stats.totalMinutes / 60).toFixed(0)}h
                          </p>
                          <p class="text-sm text-text-muted">
                            {lang === 'de' ? 'Verarbeitet' : 'Processed'}
                          </p>
                        </div>
                        <div class="text-center">
                          <p class="text-3xl font-bold text-status-success">
                            +{stat.data.trends?.userGrowth || 0}%
                          </p>
                          <p class="text-sm text-text-muted">
                            {lang === 'de' ? 'Wachstum' : 'Growth'}
                          </p>
                        </div>
                      </div>
                      
                      {stat.data.highlights && stat.data.highlights.length > 0 && (
                        <div class="mt-6 pt-6 border-t border-border">
                          <p class="text-sm font-semibold text-text-primary mb-2">
                            {lang === 'de' ? 'Highlights:' : 'Highlights:'}
                          </p>
                          <ul class="text-sm text-text-secondary space-y-1">
                            {stat.data.highlights.slice(0, 2).map((highlight) => (
                              <li key={highlight} class="flex items-start">
                                <span class="text-primary-light mr-2">•</span>
                                {highlight}
                              </li>
                            ))}
                          </ul>
                        </div>
                      )}
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>