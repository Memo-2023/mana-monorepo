---
import { getCollection, getEntry } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import TestimonialCard from "../../../components/TestimonialCard.astro";
import CallToAction from "../../../components/CallToAction.astro";
import FilterPills from "../../../components/FilterPills.astro";
import EmptyState from "../../../components/EmptyState.astro";
import { useTranslations } from "../../../i18n/utils";

export async function getStaticPaths() {
  return ['de', 'en'].map(lang => ({
    params: { lang },
    props: { lang }
  }));
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Get type from URL query parameter
const url = Astro.url;
const typeParam = url.searchParams.get('type');

// Error handling for content
let renderError = null;
let heroTitle = "";
let heroSubtitle = "";
let ctaData = null;
let testimonials = [];

try {
  // Load testimonials page content
  const page = await getEntry("pages", `${lang}/testimonials`);
  if (page) {
    const { frontmatter } = await page.render();
    heroTitle = frontmatter?.sections?.hero?.title || t('testimonials.title') || "Was unsere Kunden sagen";
    heroSubtitle = frontmatter?.sections?.hero?.subtitle || t('testimonials.description') || "Erfahren Sie, wie Memoro Teams und Unternehmen hilft";
    ctaData = frontmatter?.sections?.callToAction;
  } else {
    heroTitle = t('testimonials.title') || "Was unsere Kunden sagen";
    heroSubtitle = t('testimonials.description') || "Erfahren Sie, wie Memoro Teams und Unternehmen hilft";
  }

  // Get testimonials for the current language, sorted by order
  testimonials = await getCollection("testimonials", ({ data }) => {
    return data.lang === lang;
  });

  testimonials = testimonials.sort(
    (a, b) => (parseInt(a.data.order) || 0) - (parseInt(b.data.order) || 0)
  );
} catch (error) {
  console.error("Error rendering testimonials page:", error);
  renderError = error.message;
}

const pageTitle = heroTitle || t('testimonials.title') || "Testimonials";

// Group testimonials by type
const testimonialsByType = {
  private: testimonials.filter(t => t.data.type === 'private'),
  company: testimonials.filter(t => t.data.type === 'company'),
  network: testimonials.filter(t => t.data.type === 'network'),
  press: testimonials.filter(t => t.data.type === 'press')
};

// Type labels
const typeLabels = {
  de: {
    all: 'Alle',
    private: 'Privatpersonen',
    company: 'Unternehmen',
    network: 'Netzwerke',
    press: 'Presse'
  },
  en: {
    all: 'All',
    private: 'Individuals',
    company: 'Companies',
    network: 'Networks',
    press: 'Press'
  }
};

// Empty state messages
const emptyStateMessages = {
  de: {
    all: {
      title: "Noch keine Referenzen vorhanden",
      message: "Wir sammeln gerade Feedback von unseren zufriedenen Kunden. Schauen Sie bald wieder vorbei!",
      icon: "💬"
    },
    private: {
      title: "Keine Privatpersonen-Referenzen",
      message: "Noch keine Bewertungen von Privatpersonen verfügbar. Seien Sie der Erste!",
      icon: "👤"
    },
    company: {
      title: "Keine Unternehmens-Referenzen", 
      message: "Unternehmensbewertungen werden in Kürze hinzugefügt.",
      icon: "🏢"
    },
    network: {
      title: "Keine Netzwerk-Referenzen",
      message: "Referenzen aus unserem Netzwerk folgen bald.",
      icon: "🌐"
    },
    press: {
      title: "Keine Presse-Referenzen",
      message: "Pressestimmen werden hier bald erscheinen.",
      icon: "📰"
    }
  },
  en: {
    all: {
      title: "No testimonials yet",
      message: "We're gathering feedback from our satisfied customers. Check back soon!",
      icon: "💬"
    },
    private: {
      title: "No individual testimonials",
      message: "No reviews from individuals available yet. Be the first!",
      icon: "👤"
    },
    company: {
      title: "No company testimonials",
      message: "Company reviews will be added shortly.",
      icon: "🏢"
    },
    network: {
      title: "No network testimonials",
      message: "Network testimonials coming soon.",
      icon: "🌐"
    },
    press: {
      title: "No press testimonials",
      message: "Press reviews will appear here soon.",
      icon: "📰"
    }
  }
};

// Determine active filter from URL or default to 'all'
let activeFilter = 'all';
if (typeParam) {
  // Find matching type (case-insensitive)
  const matchingType = Object.keys(testimonialsByType).find(
    type => type.toLowerCase() === typeParam.toLowerCase()
  );
  if (matchingType) {
    activeFilter = matchingType;
  }
}

---

<Layout title={pageTitle}>
  <main class="bg-background-page">
    <div class="max-w-7xl mx-auto px-4 py-16">
    {renderError ? (
      <div class="text-center py-12">
        <p class="text-red-500">Error loading content: {renderError}</p>
      </div>
    ) : (
      <>
        <div class="text-center mb-16">
          <h1 class="text-4xl font-bold text-text-primary mb-4">
            {heroTitle}
          </h1>
          <p class="text-xl text-text-secondary max-w-3xl mx-auto">
            {heroSubtitle}
          </p>
        </div>

        <!-- Filter Pills -->
        <div class="mb-12">
          <FilterPills 
            filters={[
              { value: 'all', label: typeLabels[lang].all, count: testimonials.length },
              ...Object.entries(testimonialsByType).map(([type, items]) => ({
                value: type,
                label: typeLabels[lang][type],
                count: items.length
              }))
            ]}
            activeFilter={activeFilter}
            id="testimonials-filter"
          />
        </div>
        
        {testimonials.length > 0 ? (
          <div class="testimonials-grid" data-filter-content="testimonials-filter">
            {/* All Testimonials */}
            <div data-type="all" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
              {testimonials.length > 0 ? (
                testimonials.map((testimonial) => {
                  // Clean the slug: remove language prefix and type directory
                  let cleanSlug = testimonial.slug;
                  const langPrefix = `${lang}/`;
                  if (cleanSlug.startsWith(langPrefix)) {
                    cleanSlug = cleanSlug.substring(langPrefix.length);
                  }
                  // Remove type directory if it exists
                  const typePrefixes = ['company/', 'private/', 'network/', 'press/'];
                  for (const prefix of typePrefixes) {
                    if (cleanSlug.startsWith(prefix)) {
                      cleanSlug = cleanSlug.substring(prefix.length);
                      break;
                    }
                  }
                    
                  return (
                    <div class="testimonial-item" data-testimonial-type={testimonial.data.type}>
                      <TestimonialCard
                        quote={testimonial.data.text || testimonial.data.quote || ""}
                        author={testimonial.data.name || testimonial.data.author || ""}
                        role={testimonial.data.role || ""}
                        company={testimonial.data.company || ""}
                        image={testimonial.data.image}
                        href={`/${lang}/testimonials/${cleanSlug}`}
                        type={testimonial.data.type}
                        source={testimonial.data.source}
                        lang={lang}
                      />
                    </div>
                  );
                })
              ) : (
                <div class="col-span-full">
                  <EmptyState 
                    {...emptyStateMessages[lang].all}
                  />
                </div>
              )}
            </div>

            {/* Filtered Views */}
            {Object.entries(testimonialsByType).map(([type, items]) => (
              <div data-type={type} class="hidden grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
                {items.length > 0 ? (
                  items.map((testimonial) => {
                    // Clean the slug: remove language prefix and type directory
                    let cleanSlug = testimonial.slug;
                    const langPrefix = `${lang}/`;
                    if (cleanSlug.startsWith(langPrefix)) {
                      cleanSlug = cleanSlug.substring(langPrefix.length);
                    }
                    // Remove type directory if it exists
                    const typePrefixes = ['company/', 'private/', 'network/', 'press/'];
                    for (const prefix of typePrefixes) {
                      if (cleanSlug.startsWith(prefix)) {
                        cleanSlug = cleanSlug.substring(prefix.length);
                        break;
                      }
                    }
                      
                    return (
                      <TestimonialCard
                        quote={testimonial.data.text || testimonial.data.quote || ""}
                        author={testimonial.data.name || testimonial.data.author || ""}
                        role={testimonial.data.role || ""}
                        company={testimonial.data.company || ""}
                        image={testimonial.data.image}
                        href={`/${lang}/testimonials/${cleanSlug}`}
                        type={testimonial.data.type}
                        source={testimonial.data.source}
                        lang={lang}
                      />
                    );
                  })
                ) : (
                  <div class="col-span-full">
                    <EmptyState 
                      {...emptyStateMessages[lang][type]}
                    />
                  </div>
                )}
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center py-12 mb-16">
            <p class="text-text-secondary">{t('testimonials.noTestimonials') || "Noch keine Referenzen verfügbar."}</p>
          </div>
        )}

        {ctaData && (
          <div class="mt-16 text-center">
            <CallToAction
              title={ctaData.title}
              description={ctaData.description}
              buttonText={ctaData.buttonText}
              buttonLink={ctaData.buttonLink}
            />
          </div>
        )}
      </>
    )}
    </div>
  </main>
</Layout>