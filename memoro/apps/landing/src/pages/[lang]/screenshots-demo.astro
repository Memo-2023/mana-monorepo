---
import Layout from '../../layouts/Layout.astro';
import PhoneFrame from '../../components/PhoneFrame.astro';
import { useTranslations } from '../../i18n/utils';

export async function getStaticPaths() {
  return ['de', 'en'].map(lang => ({
    params: { lang },
    props: { lang }
  }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as 'de' | 'en');
---

<Layout title="Screenshots Demo" description="Demo der PhoneFrame Komponente">
  <div class="container mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-12 text-center">PhoneFrame Component Demo</h1>
    
    <section class="mb-16">
      <h2 class="text-2xl font-semibold mb-8">Portrait Screenshots</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="text-center">
          <PhoneFrame 
            src="/images/screenshots/Memoro-Screenshot-RecordingPage.PNG"
            alt="Memoro Recording Page"
            phoneColor="black"
          />
          <p class="mt-4 text-sm text-gray-600">Black iPhone</p>
        </div>
        
        <div class="text-center">
          <PhoneFrame 
            src="/images/screenshots/Memoro-Screenshot-Mana-Page.PNG"
            alt="Memoro Mana Page"
            phoneColor="silver"
          />
          <p class="mt-4 text-sm text-gray-600">Silver iPhone</p>
        </div>
        
        <div class="text-center">
          <PhoneFrame 
            src="/images/screenshots/Memoro-Screenshot-Settings-Page.PNG"
            alt="Memoro Settings Page"
            phoneColor="gold"
          />
          <p class="mt-4 text-sm text-gray-600">Gold iPhone</p>
        </div>
      </div>
    </section>

    <section class="mb-16">
      <h2 class="text-2xl font-semibold mb-8">Mehr Screenshots</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <PhoneFrame 
          src="/images/screenshots/Memoro-Screenshot-AudioArchive-Page.PNG"
          alt="Audio Archive"
          class="mx-auto"
        />
        
        <PhoneFrame 
          src="/images/screenshots/Memoro-Screenshot-Tags-Screen.PNG"
          alt="Tags Screen"
          class="mx-auto"
        />
        
        <PhoneFrame 
          src="/images/screenshots/Memoro-Screenshot-Statistic-Page.PNG"
          alt="Statistics Page"
          class="mx-auto"
        />
      </div>
    </section>

    <section class="mb-16">
      <h2 class="text-2xl font-semibold mb-8">Modal Screenshots</h2>
      <div class="flex flex-wrap justify-center gap-8">
        <PhoneFrame 
          src="/images/screenshots/Memoro-Screenshot-AudioUpload-Modal.PNG"
          alt="Audio Upload Modal"
        />
        
        <PhoneFrame 
          src="/images/screenshots/Memoro-Screenshot-Create-Tag-Modal.PNG"
          alt="Create Tag Modal"
        />
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-semibold mb-8">Detail Pages</h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <PhoneFrame 
          src="/images/screenshots/Memoro-Screenshot-MemoDetailPage-Memo-Headline.PNG"
          alt="Memo Detail - Headline"
          class="mx-auto"
        />
        
        <PhoneFrame 
          src="/images/screenshots/Memoro-Screenshot-MemoDetailPage-Memo-Transcript.PNG"
          alt="Memo Detail - Transcript"
          class="mx-auto"
        />
      </div>
    </section>
  </div>
</Layout>