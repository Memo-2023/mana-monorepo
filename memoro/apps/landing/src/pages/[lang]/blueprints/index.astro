---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';
import { useTranslations } from "../../../i18n/utils";
import HeroSection from "../../../components/HeroSection.astro";
import BlueprintCard from "../../../components/BlueprintCard.astro";
import CallToAction from "../../../components/CallToAction.astro";
import FilterPills from "../../../components/FilterPills.astro";
import EmptyState from "../../../components/EmptyState.astro";

export async function getStaticPaths() {
  return ['de', 'en'].map(lang => ({
    params: { lang },
    props: { lang }
  }));
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Get category from URL query parameter
const url = Astro.url;
const categoryParam = url.searchParams.get('category');

// Alle Blueprints abrufen und nach Sprache filtern
const allBlueprints = await getCollection('blueprints');
const filteredBlueprints = allBlueprints.filter(blueprint => blueprint.data.lang === lang && blueprint.data.isActive !== false);

// Sortieren nach Order (falls vorhanden)
const sortedBlueprints = filteredBlueprints.sort((a, b) => {
  if (a.data.order !== undefined && b.data.order !== undefined) {
    return a.data.order - b.data.order;
  }
  return 0;
});

// Group blueprints by category based on color
const blueprintsByCategory = {
  office: sortedBlueprints.filter(b => b.data.color === 'blue'),
  handwerk: sortedBlueprints.filter(b => b.data.color === 'orange'),
  education: sortedBlueprints.filter(b => b.data.color === 'purple' || b.data.color === 'yellow'),
  business: sortedBlueprints.filter(b => b.data.color === 'red'),
  general: sortedBlueprints.filter(b => b.data.color === 'green')
};

// Category labels
const categoryLabels = {
  de: {
    all: 'Alle',
    office: 'Büro',
    handwerk: 'Handwerk',
    education: 'Bildung',
    business: 'Business',
    general: 'Allgemein'
  },
  en: {
    all: 'All',
    office: 'Office',
    handwerk: 'Craft',
    education: 'Education',
    business: 'Business',
    general: 'General'
  }
};

// Empty state messages
const emptyStateMessages = {
  de: {
    all: {
      title: "Noch keine Vorlagen",
      message: "Wir arbeiten daran, hilfreiche Vorlagen für Sie zu erstellen. Schauen Sie bald wieder vorbei!",
      icon: "📋"
    },
    office: {
      title: "Keine Büro-Vorlagen",
      message: "Vorlagen für den Bürobereich werden gerade erstellt.",
      icon: "💼"
    },
    handwerk: {
      title: "Keine Handwerks-Vorlagen",
      message: "Vorlagen für Handwerksbetriebe werden gerade erstellt.",
      icon: "🔨"
    },
    education: {
      title: "Keine Bildungs-Vorlagen",
      message: "Vorlagen für den Bildungsbereich folgen in Kürze.",
      icon: "🎓"
    },
    business: {
      title: "Keine Business-Vorlagen",
      message: "Business-Vorlagen sind in Vorbereitung.",
      icon: "💼"
    },
    general: {
      title: "Keine allgemeinen Vorlagen",
      message: "Aktuell sind keine allgemeinen Vorlagen verfügbar.",
      icon: "📝"
    }
  },
  en: {
    all: {
      title: "No blueprints yet",
      message: "We're working on creating helpful blueprints for you. Check back soon!",
      icon: "📋"
    },
    office: {
      title: "No office blueprints",
      message: "Office blueprints are being created.",
      icon: "💼"
    },
    handwerk: {
      title: "No craft blueprints",
      message: "Blueprints for craft businesses are being created.",
      icon: "🔨"
    },
    education: {
      title: "No education blueprints",
      message: "Blueprints for education will follow shortly.",
      icon: "🎓"
    },
    business: {
      title: "No business blueprints",
      message: "Business blueprints are in preparation.",
      icon: "💼"
    },
    general: {
      title: "No general blueprints",
      message: "No general blueprints are currently available.",
      icon: "📝"
    }
  }
};

// Determine active filter from URL or default to 'all'
let activeFilter = 'all';
if (categoryParam) {
  // Find matching category (case-insensitive)
  const matchingCategory = Object.keys(blueprintsByCategory).find(
    cat => cat.toLowerCase() === categoryParam.toLowerCase()
  );
  if (matchingCategory) {
    activeFilter = matchingCategory;
  }
}

// Get translations from UI
const currentTranslations = {
  title: t('blueprints.title'),
  description: t('blueprints.description'),
  features: t('blueprints.features'),
  compatibility: t('blueprints.compatibility'),
  readMore: t('blueprints.readMore')
};

// SEO translations
const seoTitle = t('seo.blueprints.title');
const seoDescription = t('seo.blueprints.description');
---

<Layout title={seoTitle} description={seoDescription}>
  <main class="bg-background-page">
    <HeroSection
      variant="widescreen"
      title={lang === 'de' ? 'Vorlagen' : 'Blueprints'}
      subtitle={currentTranslations.description}
      image="/images/product_photos/Memoro-App-Blueprints-Recording.jpg"
    />
    
    <div class="max-w-7xl mx-auto px-6 sm:px-8 md:px-12 py-8 md:py-12">
      {/* Optional intro text */}
      <div class="text-center mb-12">
        <p class="text-lg text-text-secondary max-w-3xl mx-auto">
          {lang === 'de' 
            ? 'Wähle die passende Vorlage für deinen Anwendungsfall und starte sofort mit optimierten Einstellungen.' 
            : 'Choose the right blueprint for your use case and start immediately with optimized settings.'}
        </p>
      </div>
      
      {/* Filter Pills */}
      <div class="mb-12">
        <FilterPills 
          filters={[
            { value: 'all', label: categoryLabels[lang].all, count: sortedBlueprints.length },
            ...Object.entries(blueprintsByCategory)
              .filter(([_, items]) => items.length > 0)
              .map(([category, items]) => ({
                value: category,
                label: categoryLabels[lang][category],
                count: items.length
              }))
          ]}
          activeFilter={activeFilter}
          id="blueprints-filter"
        />
      </div>
      
      {/* Blueprint Grid */}
      <div class="blueprints-grid mb-16" data-filter-content="blueprints-filter">
        {/* All Blueprints */}
        <div data-type="all" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {sortedBlueprints.length > 0 ? (
            sortedBlueprints.map((blueprint) => (
              <BlueprintCard
                title={blueprint.data.title}
                description={blueprint.data.description}
                icon={blueprint.data.icon}
                color={blueprint.data.color}
                href={`/${lang}/blueprints/${blueprint.slug.replace(`${lang}/`, '')}`}
                features={blueprint.data.features}
                compatibility={blueprint.data.compatibility}
                lang={lang}
                industry={blueprint.data.industry}
                showIndustry={true}
              />
            ))
          ) : (
            <div class="col-span-full">
              <EmptyState 
                {...emptyStateMessages[lang].all}
              />
            </div>
          )}
        </div>

        {/* Filtered Views */}
        {Object.entries(blueprintsByCategory).map(([category, items]) => (
          <div data-type={category} class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {items.length > 0 ? (
              items.map((blueprint) => (
                <BlueprintCard
                  title={blueprint.data.title}
                  description={blueprint.data.description}
                  icon={blueprint.data.icon}
                  color={blueprint.data.color}
                  href={`/${lang}/blueprints/${blueprint.slug.replace(`${lang}/`, '')}`}
                  features={blueprint.data.features}
                  compatibility={blueprint.data.compatibility}
                  lang={lang}
                  industry={blueprint.data.industry}
                  showIndustry={false}
                />
              ))
            ) : (
              <div class="col-span-full">
                <EmptyState 
                  {...emptyStateMessages[lang][category]}
                />
              </div>
            )}
          </div>
        ))}
      </div>
      
      {/* Benefits Section */}
      <div class="bg-background-card rounded-2xl p-8 md:p-12 mb-16">
        <h2 class="text-3xl font-bold text-text-primary text-center mb-8">
          {lang === 'de' ? 'Warum Vorlagen nutzen?' : 'Why use blueprints?'}
        </h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <Icon name="mdi:rocket" class="w-8 h-8 text-primary-DEFAULT" />
            </div>
            <h3 class="text-xl font-semibold text-text-primary mb-2">
              {lang === 'de' ? 'Schneller Start' : 'Quick Start'}
            </h3>
            <p class="text-text-secondary">
              {lang === 'de' 
                ? 'Optimale Einstellungen für deinen Anwendungsfall sind bereits vorkonfiguriert.' 
                : 'Optimal settings for your use case are already pre-configured.'}
            </p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <Icon name="mdi:tune" class="w-8 h-8 text-primary-DEFAULT" />
            </div>
            <h3 class="text-xl font-semibold text-text-primary mb-2">
              {lang === 'de' ? 'Anpassbar' : 'Customizable'}
            </h3>
            <p class="text-text-secondary">
              {lang === 'de' 
                ? 'Alle Vorlagen können nach deinen Bedürfnissen angepasst werden.' 
                : 'All blueprints can be customized to your needs.'}
            </p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <Icon name="mdi:lightbulb" class="w-8 h-8 text-primary-DEFAULT" />
            </div>
            <h3 class="text-xl font-semibold text-text-primary mb-2">
              {lang === 'de' ? 'Best Practices' : 'Best Practices'}
            </h3>
            <p class="text-text-secondary">
              {lang === 'de' 
                ? 'Basierend auf bewährten Methoden und Nutzer-Feedback.' 
                : 'Based on proven methods and user feedback.'}
            </p>
          </div>
        </div>
      </div>
      
      {/* Call to Action */}
      <CallToAction
        title={lang === 'de' ? 'Bereit loszulegen?' : 'Ready to get started?'}
        description={lang === 'de' 
          ? 'Lade Memoro herunter und wähle die passende Vorlage für deinen ersten Einsatz.' 
          : 'Download Memoro and choose the right blueprint for your first use.'}
        buttonText={lang === 'de' ? 'App herunterladen' : 'Download App'}
        buttonLink={`/${lang}/download`}
      />
    </div>
  </main>
</Layout>