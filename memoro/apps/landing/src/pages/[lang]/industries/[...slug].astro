---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import DetailLayout from "../../../components/layouts/DetailLayout.astro";
import { useTranslations } from "../../../i18n/utils";
import ArticleNavigation from "../../../components/ArticleNavigation.astro";
import BlueprintCard from "../../../components/BlueprintCard.astro";
import CallToAction from "../../../components/CallToAction.astro";
import HeroSection from "../../../components/HeroSection.astro";
import StatisticsSection from "../../../components/industries/StatisticsSection.astro";
import UseCaseTabs from "../../../components/industries/UseCaseTabs.astro";
import ComparisonTable from "../../../components/industries/ComparisonTable.astro";
import IndustryFAQ from "../../../components/industries/IndustryFAQ.astro";
import TestimonialCards from "../../../components/industries/TestimonialCards.astro";

export async function getStaticPaths() {
  const industries = await getCollection("industries");
  
  // Create routes for industries in all languages
  return industries.map((industry) => {
    // Entferne den Sprachpräfix aus dem Slug, wenn vorhanden
    const langPrefix = `${industry.data.lang}/`;
    const cleanSlug = industry.slug.startsWith(langPrefix) 
      ? industry.slug.substring(langPrefix.length)
      : industry.slug;
      
    return {
      params: { 
        lang: industry.data.lang,
        slug: cleanSlug 
      },
      props: { industry },
    };
  });
}

const { industry } = Astro.props;
const { lang } = Astro.params;
const t = useTranslations(lang);

// Holen aller Industries in der gleichen Sprache
const allIndustries = await getCollection("industries", (i) => i.data.lang === lang);

// Sortieren der Industries nach order-Property (falls vorhanden) oder alphabetisch nach Titel
const sortedIndustries = allIndustries.sort((a, b) => {
  // Wenn beide Industries eine order-Property haben, sortiere danach
  if (a.data.order !== undefined && b.data.order !== undefined) {
    return a.data.order - b.data.order;
  }
  // Wenn nur a eine order-Property hat, zeige a zuerst
  if (a.data.order !== undefined) return -1;
  // Wenn nur b eine order-Property hat, zeige b zuerst
  if (b.data.order !== undefined) return 1;
  // Ansonsten alphabetisch nach Titel sortieren
  return a.data.title.localeCompare(b.data.title, lang === 'de' ? 'de-DE' : 'en-US');
});

// Finden des aktuellen Index
const currentIndex = sortedIndustries.findIndex(i => i.id === industry.id);

// Bestimmen des vorherigen Industry
const prevArticle = currentIndex > 0 ? {
  slug: sortedIndustries[currentIndex - 1].slug,
  title: sortedIndustries[currentIndex - 1].data.title,
  lang: sortedIndustries[currentIndex - 1].data.lang,
  collection: "industries"
} : null;

// Bestimmen des nächsten Industry
const nextArticle = currentIndex < sortedIndustries.length - 1 ? {
  slug: sortedIndustries[currentIndex + 1].slug,
  title: sortedIndustries[currentIndex + 1].data.title,
  lang: sortedIndustries[currentIndex + 1].data.lang,
  collection: "industries"
} : null;

// Map industry slugs to industry keys for blueprint matching
const industryKeyMap = {
  'construction': 'construction',
  'handwerk': 'construction',
  'bau': 'construction',
  'office': 'office',
  'büro': 'office',
  'education': 'education',
  'bildung': 'education',
  'teachers': 'education',
  'lehrer': 'education',
  'consulting': 'office',
  'beratung': 'office',
  'marketing': 'office',
  'healthcare': 'healthcare',
  'gesundheit': 'healthcare',
  'legal': 'legal',
  'recht': 'legal',
  'associations': 'office',
  'vereine': 'office',
  'architecture': 'construction',
  'architektur': 'construction',
  'dentistry': 'healthcare',
  'zahnmedizin': 'healthcare',
  'families': 'personal',
  'familien': 'personal',
  'personal': 'personal',
  'market-research': 'office',
  'marktforschung': 'office'
};

// Get the industry key from the slug
const cleanSlug = industry.slug.replace(`${lang}/`, '');
const industryKey = industryKeyMap[cleanSlug] || cleanSlug;

// Fetch related blueprints for this industry
const allBlueprints = await getCollection('blueprints');

// Map color-based categories to industry keys for backward compatibility
const colorToIndustryMap = {
  'orange': 'construction', // Handwerk
  'blue': 'office',         // Büro
  'purple': 'education',    // Bildung
  'yellow': 'education',    // Bildung (alternativ)
  'red': 'business',        // Business
  'green': 'general'        // Allgemein
};

const relatedBlueprints = allBlueprints.filter(blueprint => {
  if (blueprint.data.lang !== lang || blueprint.data.isActive === false) {
    return false;
  }
  
  // Check if blueprint has explicit industry field
  if (blueprint.data.industry) {
    return blueprint.data.industry === industryKey || 
           blueprint.data.industry === 'general';
  }
  
  // Fallback to color-based matching for older blueprints
  const mappedIndustry = colorToIndustryMap[blueprint.data.color];
  return mappedIndustry === industryKey || mappedIndustry === 'general';
});

// Sort blueprints by order
const sortedBlueprints = relatedBlueprints.sort((a, b) => {
  if (a.data.order !== undefined && b.data.order !== undefined) {
    return a.data.order - b.data.order;
  }
  return 0;
});

const { Content } = await industry.render();

// Translations
const translations = {
  de: {
    relatedBlueprints: 'Passende Vorlagen',
    relatedBlueprintsDescription: 'Nutze diese optimierten Vorlagen für deine Branche:',
    noBlueprints: 'Für diese Branche arbeiten wir noch an passenden Vorlagen.',
    ctaTitle: 'Bereit für intelligente Gesprächsdokumentation?',
    ctaDescription: 'Starte noch heute mit Memoro und revolutioniere deine Arbeitsweise.',
    ctaButton: 'Jetzt kostenlos testen'
  },
  en: {
    relatedBlueprints: 'Related Templates',
    relatedBlueprintsDescription: 'Use these optimized templates for your industry:',
    noBlueprints: 'We are still working on suitable templates for this industry.',
    ctaTitle: 'Ready for intelligent conversation documentation?',
    ctaDescription: 'Start with Memoro today and revolutionize your workflow.',
    ctaButton: 'Try for free'
  }
};

const currentTranslations = translations[lang];
---

<Layout title={industry.data.title}>
  <DetailLayout 
    title={!industry.data.heroImage ? industry.data.title : undefined}
    description={!industry.data.heroImage ? industry.data.description : undefined}
    backLink={{
      href: `/${lang}/industries`
    }}
    noProse={true}
  >
    <!-- Hero Section -->
    {industry.data.heroImage && (
      <HeroSection
        title={industry.data.title}
        subtitle={industry.data.description}
        image={industry.data.heroImage}
        variant="fullwidth"
      />
    )}
    <!-- Statistics Section -->
    {industry.data.statistics && (
      <StatisticsSection statistics={industry.data.statistics} />
    )}
    
    <!-- Main Content with Tabs -->
    <div class="prose prose-lg max-w-none prose-invert my-12">
      <Content />
    </div>
    
    {/* Related Blueprints Section */}
    {sortedBlueprints.length > 0 && (
      <div class="mt-16 pt-16 border-t border-border">
        <h2 class="text-3xl font-bold text-text-primary mb-4">
          {currentTranslations.relatedBlueprints}
        </h2>
        <p class="text-lg text-text-secondary mb-8">
          {currentTranslations.relatedBlueprintsDescription}
        </p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
          {sortedBlueprints.map((blueprint) => (
            <BlueprintCard
              title={blueprint.data.title}
              description={blueprint.data.description}
              icon={blueprint.data.icon}
              color={blueprint.data.color}
              href={`/${lang}/blueprints/${blueprint.slug.replace(`${lang}/`, '')}`}
              features={blueprint.data.features}
              compatibility={blueprint.data.compatibility}
              lang={lang}
            />
          ))}
        </div>
      </div>
    )}
    
    {/* Empty state wenn keine Blueprints */}
    {sortedBlueprints.length === 0 && (
      <div class="mt-16 pt-16 border-t border-border">
        <div class="text-center py-12">
          <p class="text-text-secondary text-lg">
            {currentTranslations.noBlueprints}
          </p>
        </div>
      </div>
    )}
    
    <!-- Comparison Table -->
    {industry.data.comparison && (
      <ComparisonTable comparison={industry.data.comparison} lang={lang} />
    )}
    
    <!-- Testimonials / Case Studies -->
    {(industry.data.testimonialIds || industry.data.industry) && (
      <TestimonialCards 
        testimonialIds={industry.data.testimonialIds}
        industry={industry.data.industry || industryKey}
        lang={lang}
      />
    )}
    
    <!-- FAQ Section -->
    {industry.data.faq && (
      <IndustryFAQ items={industry.data.faq} lang={lang} />
    )}
    
    {/* Call to Action */}
    <div class="mt-16">
      <CallToAction
        title={currentTranslations.ctaTitle}
        description={currentTranslations.ctaDescription}
        buttonText={currentTranslations.ctaButton}
        buttonLink={`/${lang}/download`}
      />
    </div>
    
    <Fragment slot="footer">
      {/* Navigation zur vorherigen und nächsten Branche */}
      <ArticleNavigation 
        prevArticle={prevArticle} 
        nextArticle={nextArticle} 
        lang={lang} 
        collection="industries" 
      />
    </Fragment>
  </DetailLayout>
</Layout>