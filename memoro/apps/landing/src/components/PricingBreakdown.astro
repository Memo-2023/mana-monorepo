---
export interface Props {
  lang: 'de' | 'en';
}

const { lang } = Astro.props;

const pricing = {
  recordingPerMinute: 2,
  questionMemo: 5,
  memoCombine: 5,
  blueprintProcessing: 5
};

const content = {
  de: {
    title: "Mana-Preisübersicht",
    tableHeaders: {
      feature: "Funktion",
      credits: "Mana",
      description: "Beschreibung"
    },
    recordingTitle: "Aufnahme",
    recordingDesc: "Aufzeichnung und Verarbeitung von Gesprächen",
    recordingPerMinute: "Pro Minute",
    questionTitle: "Fragen an Memos",
    questionDesc: "Stellen Sie Fragen zu Ihren gespeicherten Memos",
    combineTitle: "Memos kombinieren",
    combineDesc: "Fassen Sie mehrere Memos zu einem zusammen",
    blueprintTitle: "Blueprint-Verarbeitung",
    blueprintDesc: "Erweiterte Verarbeitung mit benutzerdefinierten Vorlagen"
  },
  en: {
    title: "Mana Pricing Overview",
    tableHeaders: {
      feature: "Feature",
      credits: "Mana",
      description: "Description"
    },
    recordingTitle: "Recording",
    recordingDesc: "Recording and processing of conversations",
    recordingPerMinute: "Per minute",
    questionTitle: "Questions to Memos",
    questionDesc: "Ask questions about your saved memos",
    combineTitle: "Combine Memos",
    combineDesc: "Merge multiple memos into one",
    blueprintTitle: "Blueprint Processing",
    blueprintDesc: "Advanced processing with custom templates"
  }
};

const t = content[lang];
---

<div class="mb-16">
  <div class="max-w-3xl mx-auto bg-background-card rounded-2xl border border-border p-6 hover:bg-background-cardHover transition-all duration-300 relative">
    <div class="absolute top-6 right-6 bg-primary-DEFAULT text-text-button px-4 py-2 rounded-full shadow-lg">
      <p class="text-sm font-bold">1 Mana = 1 Cent</p>
    </div>
    <h2 class="text-2xl font-bold text-text-primary mb-6 text-center">{t.title}</h2>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b border-border">
            <th class="text-left py-3 px-4 text-text-primary font-semibold">{t.tableHeaders.feature}</th>
            <th class="text-left py-3 px-4 text-text-primary font-semibold min-w-[200px]">{t.tableHeaders.credits}</th>
            <th class="text-left py-3 px-4 text-text-secondary font-normal text-sm hidden sm:table-cell">{t.tableHeaders.description}</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-border">
            <td class="py-3 px-4">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-primary-DEFAULT flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path></svg>
                <span class="text-text-primary font-medium">{t.recordingTitle}</span>
              </div>
            </td>
            <td class="text-left py-3 px-4">
              <span class="text-lg font-bold text-primary-DEFAULT">{pricing.recordingPerMinute} <span class="text-sm font-normal text-text-secondary ml-2">{lang === 'de' ? 'Mana pro Minute' : 'Mana per minute'}</span></span>
            </td>
            <td class="py-3 px-4 text-text-secondary text-sm hidden sm:table-cell">{t.recordingDesc}</td>
          </tr>
          <tr class="border-b border-border">
            <td class="py-3 px-4">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-primary-DEFAULT flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 11.885l-3.5-3.5a5 5 0 017.07 0M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span class="text-text-primary font-medium">{t.questionTitle}</span>
              </div>
            </td>
            <td class="text-left py-3 px-4">
              <span class="text-lg font-bold text-primary-DEFAULT">{pricing.questionMemo} <span class="text-sm font-normal text-text-secondary ml-2">Mana</span></span>
            </td>
            <td class="py-3 px-4 text-text-secondary text-sm hidden sm:table-cell">{t.questionDesc}</td>
          </tr>
          <tr class="border-b border-border">
            <td class="py-3 px-4">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-primary-DEFAULT flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 14v6m-3-3h6M6 10h2a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2zm10 0h2a2 2 0 002-2V6a2 2 0 00-2-2h-2a2 2 0 00-2 2v2a2 2 0 002 2zM6 20h2a2 2 0 002-2v-2a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2z"></path></svg>
                <span class="text-text-primary font-medium">{t.combineTitle}</span>
              </div>
            </td>
            <td class="text-left py-3 px-4">
              <span class="text-lg font-bold text-primary-DEFAULT">{pricing.memoCombine} <span class="text-sm font-normal text-text-secondary ml-2">{lang === 'de' ? 'Mana pro Memo' : 'Mana per memo'}</span></span>
            </td>
            <td class="py-3 px-4 text-text-secondary text-sm hidden sm:table-cell">{t.combineDesc}</td>
          </tr>
          <tr class="border-b border-border">
            <td class="py-3 px-4">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-primary-DEFAULT flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                <span class="text-text-primary font-medium">{t.blueprintTitle}</span>
              </div>
            </td>
            <td class="text-left py-3 px-4">
              <span class="text-lg font-bold text-primary-DEFAULT">{pricing.blueprintProcessing} <span class="text-sm font-normal text-text-secondary ml-2">Mana</span></span>
            </td>
            <td class="py-3 px-4 text-text-secondary text-sm hidden sm:table-cell">{t.blueprintDesc}</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>