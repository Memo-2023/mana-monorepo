---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "outline" | "text";
  size?: "sm" | "md" | "lg";
  class?: string;
  target?: string;
  rel?: string;
  download?: boolean | string;
  id?: string;
  onclick?: string;
  'aria-label'?: string;
  [key: string]: any;
}

const {
  href,
  variant = "primary",
  size = "md",
  class: className = "",
  target,
  rel,
  download,
  id,
  onclick,
  'aria-label': ariaLabel,
  ...rest
} = Astro.props;

const variants = {
  primary:
    "bg-primary text-white hover:bg-primary-hover border-2 border-primary hover:border-primary-hover",
  secondary:
    "bg-transparent text-text-primary hover:bg-background-card border-2 border-border hover:border-primary",
  outline:
    "bg-transparent text-text-primary hover:bg-background-cardHover border-2 border-border",
  text: "bg-transparent text-text-primary hover:bg-background-cardHover border-transparent",
};

const sizes = {
  sm: "text-sm px-3 py-1.5",
  md: "text-base px-4 py-2",
  lg: "text-lg px-6 py-3",
};

const baseStyles =
  "inline-flex items-center justify-center rounded-lg transition-all duration-DEFAULT font-medium focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 whitespace-nowrap";
const styles = `${baseStyles} ${variants[variant]} ${sizes[size]} ${className}`;

const Element = href ? "a" : "button";
---

<Element 
  href={href} 
  target={target} 
  rel={rel} 
  download={download} 
  class={styles}
  id={id}
  onclick={onclick}
  aria-label={ariaLabel}
  {...rest}
>
  <slot />
</Element>
