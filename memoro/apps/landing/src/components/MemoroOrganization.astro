---
import StructuredData from './StructuredData.astro';

const { lang } = Astro.props;

const organizationData = {
  name: "Memoro",
  url: "https://memoro.ai",
  logo: "https://memoro.ai/images/brand/memoro-logo.png",
  description: lang === 'de' 
    ? "Memoro ist eine KI-gestützte App zur Gesprächsdokumentation und Notizerfassung. Automatische Transkription, intelligente Zusammenfassung und Aufgabenerkennung."
    : "Memoro is an AI-powered app for conversation documentation and note-taking. Automatic transcription, intelligent summarization and task detection.",
  sameAs: [
    "https://www.linkedin.com/company/memoroai",
    "https://www.instagram.com/memoroai/",
    "https://twitter.com/memoroai"
  ],
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "customer service",
    email: "kontakt@memoro.ai",
    availableLanguage: ["German", "English"]
  },
  address: {
    "@type": "PostalAddress",
    streetAddress: "Reichenaustraße 11a",
    addressLocality: "Konstanz",
    postalCode: "78467",
    addressCountry: "DE"
  },
  founder: [
    {
      "@type": "Person",
      name: "Till Schneider",
      jobTitle: "Co-Founder"
    },
    {
      "@type": "Person", 
      name: "Tobias Müller",
      jobTitle: "Co-Founder"
    }
  ],
  foundingDate: "2023",
  email: "kontakt@memoro.ai"
};
---

<StructuredData type="Organization" data={organizationData} />