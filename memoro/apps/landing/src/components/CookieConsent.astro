---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import Button from './atoms/Button.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!-- Cookie Consent Banner -->
<div id="cookie-consent-banner" class="hidden fixed bottom-0 left-0 right-0 z-50 bg-background-card backdrop-blur-lg border-t border-white/25 shadow-2xl">
  <div class="max-w-7xl mx-auto px-4 py-4 sm:px-6 sm:py-6 md:px-8 md:py-8">
    <div class="flex flex-col lg:flex-row items-start lg:items-center justify-between gap-4 lg:gap-6">
      <div class="flex-1 lg:pr-8">
        <p class="text-text-primary font-semibold mb-1 sm:mb-2 text-base sm:text-lg md:text-xl">
          {t('cookie.title')}
        </p>
        <p class="text-text-secondary text-sm sm:text-base leading-snug sm:leading-relaxed max-w-3xl">
          {t('cookie.description')}
          <a href={`/${lang}/privacy`} class="text-primary hover:text-primary-hover underline ml-1 inline-block">
            {t('cookie.privacy_link')}
          </a>
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-3 mt-3 sm:mt-4 lg:mt-0 lg:flex-shrink-0 w-full sm:w-auto">
        <Button 
          variant="primary" 
          size="md"
          id="cookie-accept-btn"
          aria-label={t('cookie.accept_all_aria')}
          class="w-full sm:w-auto min-h-[48px]"
        >
          {t('cookie.accept_all')}
        </Button>
        <Button 
          variant="outline" 
          size="md"
          id="cookie-reject-btn"
          aria-label={t('cookie.reject_all_aria')}
          class="w-full sm:w-auto min-h-[48px]"
        >
          {t('cookie.reject_all')}
        </Button>
        <button 
          id="cookie-settings-btn"
          aria-label={t('cookie.settings_aria')}
          class="w-full sm:w-auto text-primary hover:text-primary-hover transition-colors flex items-center justify-center gap-2 py-3 px-4"
        >
          <span>{t('cookie.settings')}</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Cookie Settings Modal -->
<div id="cookie-settings-modal" class="hidden fixed inset-0 z-50 overflow-y-auto" aria-labelledby="cookie-settings-title" role="dialog" aria-modal="true">
  <div class="flex items-center justify-center min-h-screen p-4">
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm" id="cookie-modal-backdrop"></div>
    
    <!-- Modal Content -->
    <div class="relative bg-background-card border border-white/20 rounded-lg shadow-xl max-w-2xl w-full max-h-[80vh] overflow-hidden">
      <!-- Header -->
      <div class="p-6 border-b border-white/20">
        <h2 id="cookie-settings-title" class="text-heading-mobile md:text-heading text-text-primary">
          {t('cookie.settings_title')}
        </h2>
        <button 
          id="cookie-modal-close"
          class="absolute top-6 right-6 text-text-tertiary hover:text-text-secondary transition-colors"
          aria-label={t('cookie.close_settings')}
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      
      <!-- Cookie Categories -->
      <div class="p-6 overflow-y-auto max-h-[50vh]">
        <!-- Necessary Cookies (Always Active) -->
        <div class="mb-6">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-subtitle-mobile md:text-subtitle text-text-primary font-medium">
              {t('cookie.necessary_title')}
            </h3>
            <span class="inline-flex items-center justify-center text-sm text-text-tertiary bg-background-cardHover px-4 py-1.5 rounded-full min-w-[100px]">
              {t('cookie.always_active')}
            </span>
          </div>
          <p class="text-sm text-text-secondary">
            {t('cookie.necessary_description')}
          </p>
        </div>
        
        <!-- Analytics Cookies -->
        <div class="mb-6">
          <label for="analytics-cookies" class="flex items-center justify-between mb-2 cursor-pointer">
            <h3 class="text-subtitle-mobile md:text-subtitle text-text-primary font-medium">
              {t('cookie.analytics_title')}
            </h3>
            <div class="relative inline-flex items-center">
              <input 
                type="checkbox" 
                id="analytics-cookies" 
                class="sr-only peer"
                onchange="cookieConsent.toggleCategory('analytics', this.checked)"
              >
              <div class="w-11 h-6 bg-background-cardHover peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
            </div>
          </label>
          <label for="analytics-cookies" class="text-sm text-text-secondary cursor-pointer block">
            {t('cookie.analytics_description')}
          </label>
        </div>
        
        <!-- Marketing Cookies -->
        <div class="mb-6">
          <label for="marketing-cookies" class="flex items-center justify-between mb-2 cursor-pointer">
            <h3 class="text-subtitle-mobile md:text-subtitle text-text-primary font-medium">
              {t('cookie.marketing_title')}
            </h3>
            <div class="relative inline-flex items-center">
              <input 
                type="checkbox" 
                id="marketing-cookies" 
                class="sr-only peer"
                onchange="cookieConsent.toggleCategory('marketing', this.checked)"
              >
              <div class="w-11 h-6 bg-background-cardHover peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
            </div>
          </label>
          <label for="marketing-cookies" class="text-sm text-text-secondary cursor-pointer block">
            {t('cookie.marketing_description')}
          </label>
        </div>
        
        <!-- Functional Cookies -->
        <div>
          <label for="functional-cookies" class="flex items-center justify-between mb-2 cursor-pointer">
            <h3 class="text-subtitle-mobile md:text-subtitle text-text-primary font-medium">
              {t('cookie.functional_title')}
            </h3>
            <div class="relative inline-flex items-center">
              <input 
                type="checkbox" 
                id="functional-cookies" 
                class="sr-only peer"
                onchange="cookieConsent.toggleCategory('functional', this.checked)"
              >
              <div class="w-11 h-6 bg-background-cardHover peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
            </div>
          </label>
          <label for="functional-cookies" class="text-sm text-text-secondary cursor-pointer block">
            {t('cookie.functional_description')}
          </label>
        </div>
      </div>
      
      <!-- Footer -->
      <div class="p-6 border-t border-white/20">
        <div class="flex flex-col sm:flex-row gap-3 justify-end">
          <Button 
            variant="outline" 
            size="md"
            id="cookie-save-selected"
          >
            {t('cookie.save_selected')}
          </Button>
          <Button 
            variant="primary" 
            size="md"
            id="cookie-modal-accept-all"
          >
            {t('cookie.accept_all')}
          </Button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Extend the Window interface
  declare global {
    interface Window {
      cookieConsent: {
        STORAGE_KEY: string;
        CONSENT_VERSION: string;
        categories: {
          necessary: boolean;
          analytics: boolean;
          marketing: boolean;
          functional: boolean;
        };
        init(): void;
        getStoredConsent(): any;
        showBanner(): void;
        applyConsent(): void;
        showSettings(): void;
        closeSettings(): void;
        acceptAll(): void;
        rejectAll(): void;
        saveSelected(): void;
        saveConsent(): void;
      };
    }
  }

  // Cookie Consent Management System
  window.cookieConsent = {
    STORAGE_KEY: 'memoro_cookie_consent',
    CONSENT_VERSION: '1.0',
    
    categories: {
      necessary: true, // Always true
      analytics: false,
      marketing: false,
      functional: false
    },
    
    init() {
      const stored = this.getStoredConsent();
      
      if (!stored || stored.version !== this.CONSENT_VERSION) {
        // Show banner if no consent or version mismatch
        this.showBanner();
      } else {
        // Apply stored preferences
        this.categories = { ...this.categories, ...stored.categories };
        this.applyConsent();
      }
      
      // Initialize settings modal state
      this.updateSettingsModal();
    },
    
    getStoredConsent() {
      try {
        const stored = localStorage.getItem(this.STORAGE_KEY);
        return stored ? JSON.parse(stored) : null;
      } catch {
        return null;
      }
    },
    
    saveConsent() {
      const consent = {
        version: this.CONSENT_VERSION,
        categories: this.categories,
        timestamp: new Date().toISOString()
      };
      
      localStorage.setItem(this.STORAGE_KEY, JSON.stringify(consent));
      this.applyConsent();
      this.hideBanner();
      this.closeSettings();
    },
    
    applyConsent() {
      // Dispatch custom event for other scripts to listen to
      window.dispatchEvent(new CustomEvent('cookieConsentUpdate', {
        detail: this.categories
      }));
      
      // Handle Analytics (PostHog and Umami)
      if (this.categories.analytics) {
        // PostHog and other analytics tools that use cookies
        window.analyticsEnabled = true;
      } else {
        // Disable cookie-based analytics
        window.analyticsEnabled = false;
      }
    },
    
    showBanner() {
      const banner = document.getElementById('cookie-consent-banner');
      if (banner) {
        banner.classList.remove('hidden');
        banner.setAttribute('aria-hidden', 'false');
      }
    },
    
    hideBanner() {
      const banner = document.getElementById('cookie-consent-banner');
      if (banner) {
        banner.classList.add('hidden');
        banner.setAttribute('aria-hidden', 'true');
      }
    },
    
    showSettings() {
      const modal = document.getElementById('cookie-settings-modal');
      if (modal) {
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        this.updateSettingsModal();
      }
    },
    
    closeSettings() {
      const modal = document.getElementById('cookie-settings-modal');
      if (modal) {
        modal.classList.add('hidden');
        document.body.style.overflow = '';
      }
    },
    
    updateSettingsModal() {
      // Update checkbox states
      const analyticsCheckbox = document.getElementById('analytics-cookies');
      const marketingCheckbox = document.getElementById('marketing-cookies');
      const functionalCheckbox = document.getElementById('functional-cookies');
      
      if (analyticsCheckbox) analyticsCheckbox.checked = this.categories.analytics;
      if (marketingCheckbox) marketingCheckbox.checked = this.categories.marketing;
      if (functionalCheckbox) functionalCheckbox.checked = this.categories.functional;
    },
    
    toggleCategory(category: keyof typeof this.categories, enabled: boolean) {
      if (category !== 'necessary') {
        this.categories[category] = enabled;
      }
    },
    
    acceptAll() {
      this.categories = {
        necessary: true,
        analytics: true,
        marketing: true,
        functional: true
      };
      this.saveConsent();
    },
    
    rejectAll() {
      this.categories = {
        necessary: true,
        analytics: false,
        marketing: false,
        functional: false
      };
      this.saveConsent();
    },
    
    saveSelected() {
      this.saveConsent();
    }
  };
  
  // Initialize on DOM load
  document.addEventListener('DOMContentLoaded', () => {
    window.cookieConsent.init();
    
    // Add event listeners for buttons
    document.getElementById('cookie-settings-btn')?.addEventListener('click', () => {
      window.cookieConsent.showSettings();
    });
    
    document.getElementById('cookie-reject-btn')?.addEventListener('click', () => {
      window.cookieConsent.rejectAll();
    });
    
    document.getElementById('cookie-accept-btn')?.addEventListener('click', () => {
      window.cookieConsent.acceptAll();
    });
    
    document.getElementById('cookie-modal-backdrop')?.addEventListener('click', () => {
      window.cookieConsent.closeSettings();
    });
    
    document.getElementById('cookie-modal-close')?.addEventListener('click', () => {
      window.cookieConsent.closeSettings();
    });
    
    document.getElementById('cookie-save-selected')?.addEventListener('click', () => {
      window.cookieConsent.saveSelected();
    });
    
    document.getElementById('cookie-modal-accept-all')?.addEventListener('click', () => {
      window.cookieConsent.acceptAll();
    });
  });
  
  // Handle escape key to close modal
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !document.getElementById('cookie-settings-modal')?.classList.contains('hidden')) {
      window.cookieConsent.closeSettings();
    }
  });
</script>