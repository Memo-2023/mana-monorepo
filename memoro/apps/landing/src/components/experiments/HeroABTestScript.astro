---
// Script component for Hero A/B Test
// This is a separate component to avoid MDX parsing issues
---

<script>
  import { getExperiment, trackEvent } from '../../utils/experiments';
  
  async function applyHeroCTATest() {
    const variant = await getExperiment('hero-cta-test');
    
    // Die neuen CTAs sind bereits in der MDX konfiguriert, daher müssen wir nichts ändern
    // Wir tracken nur noch die Variante
    
    trackEvent('experiment_variant_shown', {
      experiment: 'hero-cta-test',
      variant: variant || 'control'
    });
    
    // Optional: Verschiedene Headlines testen
    if (variant === 'variant-b') {
      const heroTitle = document.querySelector('#hero-experiment h1');
      if (heroTitle) {
        // Alternative Headline für Variante B
        heroTitle.textContent = 'Nie wieder wichtige Details aus Meetings verlieren';
      }
    } else if (variant === 'variant-c') {
      const heroTitle = document.querySelector('#hero-experiment h1');
      if (heroTitle) {
        // Alternative Headline für Variante C
        heroTitle.textContent = '3 Stunden pro Woche zurückgewinnen';
      }
    }
  }
  
  // Apply on load
  document.addEventListener('DOMContentLoaded', applyHeroCTATest);
  
  // Track clicks
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const clickedElement = target.closest('#hero-experiment a') || target.closest('#hero-experiment #video-popup-trigger');
    
    if (clickedElement) {
      const isVideoButton = clickedElement.id === 'video-popup-trigger';
      const link = clickedElement as HTMLAnchorElement;
      const isPrimary = !isVideoButton && (link.href.includes('how-it-works') || link.href.includes('download'));
      
      getExperiment('hero-cta-test').then(variant => {
        trackEvent('hero_cta_clicked', {
          experiment: 'hero-cta-test',
          variant: variant || 'control',
          button_type: isPrimary ? 'primary' : 'secondary',
          destination: isVideoButton ? 'video_popup' : link.href
        });
      });
    }
  });
</script>