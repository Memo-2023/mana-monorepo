---
import PhoneFrame from './PhoneFrame.astro';

export interface Props {
  title?: string;
  emoji?: string;
  imagePosition?: 'left' | 'right';
  imageSrc?: string;
  imageAlt?: string;
  showGlow?: boolean;
  class?: string;
}

const { 
  title, 
  emoji,
  imagePosition = 'right', 
  imageSrc, 
  imageAlt,
  showGlow = true,
  class: className = ''
} = Astro.props;

const textOrder = imagePosition === 'right' ? 'order-2 md:order-1' : '';
const imageOrder = imagePosition === 'right' ? 'order-1 md:order-2' : '';
---

<div class={`grid md:grid-cols-2 gap-8 md:gap-12 items-center my-12 ${className}`}>
  <div class={textOrder}>
    {title && (
      <h3 class="text-xl font-semibold mb-4">
        {emoji && <span>{emoji} </span>}
        {title}
      </h3>
    )}
    <slot name="content" />
  </div>
  {imageSrc && (
    <div class={`flex justify-center items-center ${imageOrder}`}>
      <div class="relative inline-block">
        {showGlow && (
          <div class="absolute inset-0 bg-gradient-radial from-white/20 to-transparent blur-3xl scale-150"></div>
        )}
        <PhoneFrame 
          src={imageSrc}
          alt={imageAlt || ''}
          class={`${showGlow ? 'scale-105 md:scale-110 relative z-10' : ''}`}
        />
      </div>
    </div>
  )}
</div>