---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { Icon } from "astro-icon/components";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const topProblems = [
  {
    text: lang === 'de' ? '45 Minuten Meeting = 2 Stunden Nachbereitung' : '45 minute meeting = 2 hours of follow-up',
    icon: 'mdi:clock-alert'
  },
  {
    text: lang === 'de' ? 'Wichtige Details gehen verloren' : 'Important details get lost',
    icon: 'mdi:file-alert'
  },
  {
    text: lang === 'de' ? 'Gedanken schneller als die Finger' : 'Thoughts faster than fingers',
    icon: 'mdi:head-lightbulb'
  }
];

---

<section class="py-8 md:py-24 bg-background-page">
  <div class="max-w-7xl mx-auto px-4">
    <!-- Problems -->
    <div class="text-center">
      <h2 class="text-heading-mobile md:text-heading text-text-primary mb-4">
        {lang === 'de' ? 'Das kennen Sie sicher...' : 'You probably know this...'}
      </h2>
      <p class="text-subheading-mobile md:text-subheading text-text-secondary max-w-3xl mx-auto mb-12">
        {lang === 'de' ? 'Die häufigsten Produktivitätskiller im Arbeitsalltag' : 'The most common productivity killers in everyday work'}
      </p>
      
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-3 gap-6">
          {topProblems.map((problem) => (
            <div class="bg-background-card rounded-xl p-6 border border-border">
              <div class="flex items-center gap-4">
                <div class="bg-red-500/10 rounded-full p-3 flex-shrink-0">
                  <Icon name={problem.icon} class="w-6 h-6 text-red-500" />
                </div>
                <p class="text-base font-medium text-text-primary">
                  {problem.text}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- CTA Link to Landing Page -->
    <div class="text-center mt-12">
      <a href={`/${lang}/meeting-protokoll-software`} 
         class="inline-flex items-center gap-2 text-primary hover:text-primary-hover font-medium transition-colors">
        <span>{lang === 'de' ? 'Mehr über automatische Meeting-Protokolle erfahren' : 'Learn more about automatic meeting minutes'}</span>
        <Icon name="mdi:arrow-right" class="w-5 h-5" />
      </a>
    </div>

  </div>
</section>