---
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { Icon } from "astro-icon/components";

interface Props {
  limit?: number;
  filterType?: 'private' | 'company' | 'network' | 'press' | 'all';
}

const { limit = 3, filterType = 'all' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Fetch testimonials from content collection
let testimonials = await getCollection('testimonials', ({ data }) => {
  return data.lang === lang && 
    (filterType === 'all' || data.type === filterType);
});

// Sort by order
testimonials.sort((a, b) => (a.data.order || 999) - (b.data.order || 999));

// Apply limit
if (limit > 0) {
  testimonials = testimonials.slice(0, limit);
}

// Get label for testimonial type
function getTypeLabel(type: string) {
  const labels = {
    de: {
      private: 'Privat',
      company: 'Firma',
      network: 'Netzwerk',
      press: 'Presse'
    },
    en: {
      private: 'Private',
      company: 'Company',
      network: 'Network',
      press: 'Press'
    }
  };
  return labels[lang]?.[type] || type;
}

// Get color for testimonial type
function getTypeColor(type: string) {
  switch(type) {
    case 'private': return 'bg-blue-100 text-blue-700 border-blue-200';
    case 'company': return 'bg-green-100 text-green-700 border-green-200';
    case 'network': return 'bg-purple-100 text-purple-700 border-purple-200';
    case 'press': return 'bg-orange-100 text-orange-700 border-orange-200';
    default: return 'bg-primary/10 text-primary border-primary/20';
  }
}
---

<section class="py-16 md:py-24 bg-background-page">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4">
        {t('testimonials.title')}
      </h2>
      <p class="text-lg text-text-secondary max-w-2xl mx-auto">
        {t('testimonials.subtitle')}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      {testimonials.map((testimonial) => {
        // Extract clean slug from testimonial
        let cleanSlug = testimonial.slug;
        
        // Remove language prefix
        const langPrefix = `${lang}/`;
        if (cleanSlug.startsWith(langPrefix)) {
          cleanSlug = cleanSlug.substring(langPrefix.length);
        }
        
        // Remove type directory if it exists (company/, private/, etc.)
        const typePrefixes = ['company/', 'private/', 'network/', 'press/'];
        for (const prefix of typePrefixes) {
          if (cleanSlug.startsWith(prefix)) {
            cleanSlug = cleanSlug.substring(prefix.length);
            break;
          }
        }
        
        return (
          <a 
            href={`/${lang}/testimonials/${cleanSlug}`}
            class="block bg-background-card rounded-xl p-6 border border-border hover:bg-background-cardHover hover:border-primary transition-all duration-300 transform hover:-translate-y-1 cursor-pointer group"
          >
          <div class="flex items-start mb-4">
            <div class="mr-4 flex-shrink-0">
              {testimonial.data.image ? (
                <img 
                  src={testimonial.data.image} 
                  alt={testimonial.data.name}
                  class="w-12 h-12 rounded-full object-cover border-2 border-primary/20"
                  width="48"
                  height="48"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center">
                  <span class="text-xl font-semibold text-primary">
                    {testimonial.data.name.charAt(0)}
                  </span>
                </div>
              )}
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-2 flex-wrap mb-1">
                <h3 class="font-semibold text-text-primary group-hover:text-primary transition-colors">
                  {testimonial.data.name}
                </h3>
                <span class={`text-xs px-2 py-0.5 rounded-full font-medium border ${getTypeColor(testimonial.data.type)}`}>
                  {getTypeLabel(testimonial.data.type)}
                </span>
              </div>
              <p class="text-sm text-text-secondary">{testimonial.data.role}</p>
              {testimonial.data.company && (
                <p class="text-sm text-text-muted">{testimonial.data.company}</p>
              )}
              {testimonial.data.type === 'press' && testimonial.data.source && (
                <p class="text-xs text-text-muted mt-1">
                  {lang === 'de' ? 'Quelle: ' : 'Source: '}{testimonial.data.source}
                </p>
              )}
            </div>
          </div>
          
          <blockquote class="text-text-secondary italic mb-4">
            "{testimonial.data.text}"
          </blockquote>
          
          <div class="flex items-center justify-between">
            <div class="flex">
              {[...Array(5)].map((_, i) => (
                <Icon name="mdi:star" class="w-5 h-5 text-primary" />
              ))}
            </div>
            <span class="text-xs text-primary opacity-0 group-hover:opacity-100 transition-opacity flex items-center">
              {lang === 'de' ? 'Mehr lesen' : 'Read more'}
              <Icon name="mdi:arrow-right" class="w-4 h-4 ml-1" />
            </span>
          </div>
        </a>
        );
      })}
    </div>

    {testimonials.length > 3 && (
      <div class="text-center mt-8">
        <a 
          href={`/${lang}/testimonials`}
          class="inline-flex items-center text-primary hover:text-primary-hover transition-colors"
        >
          {lang === 'de' ? 'Alle Kundenstimmen ansehen' : 'View all testimonials'}
          <Icon name="mdi:arrow-right" class="w-5 h-5 ml-2" />
        </a>
      </div>
    )}
  </div>
</section>