---
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  thumbnail: string;
  slug: string;
  formats: Array<{
    type: string;
    device?: string;
    resolution: string;
  }>;
  lang: string;
}

const { 
  title, 
  thumbnail, 
  slug, 
  formats = [],
  lang
} = Astro.props;

// Translations
const translations = {
  de: {
    desktop: "Desktop",
    mobile: "iPhone",
    tablet: "iPad",
    ultrawide: "Ultrawide"
  },
  en: {
    desktop: "Desktop",
    mobile: "iPhone", 
    tablet: "iPad",
    ultrawide: "Ultrawide"
  }
};

const t = translations[lang as keyof typeof translations];
---

<a href={`/${lang}/wallpapers/${slug}`} class="block group">
  <div class="bg-background-card rounded-xl overflow-hidden border border-border hover:border-primary hover:shadow-lg transition-all duration-300 cursor-pointer">
    <div class="relative aspect-video overflow-hidden">
      <img
        src={thumbnail}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
        width="400"
        height="225"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="p-4">
      <h3 class="font-semibold text-text-primary mb-3 text-lg">{title}</h3>
      <div class="flex flex-wrap gap-2">
        {formats.map((format) => (
          <span class="inline-flex items-center px-3 py-1 bg-primary/10 text-primary rounded-full text-sm font-medium">
            {format.device ? format.device : t[format.type as keyof typeof t] || format.type}
          </span>
        ))}
      </div>
    </div>
  </div>
</a>

