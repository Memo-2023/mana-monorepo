---
import { getCollection } from "astro:content";
import { getLangFromUrl } from "../i18n/utils";
import TestimonialCard from "./TestimonialCard.astro";

const lang = getLangFromUrl(Astro.url);
const testimonials = await getCollection("testimonials", ({ data }) => {
  return data.lang === lang;
});

// Sortiere nach order und nimm die ersten 3
const sortedTestimonials = testimonials
  .sort((a, b) => (a.data.order || 0) - (b.data.order || 0))
  .slice(0, 3);
---

<section class="py-16">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-12">
      {lang === "de" ? "Das sagen unsere Kunden" : "What our customers say"}
    </h2>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        sortedTestimonials.map((testimonial) => {
          // Extract clean slug from testimonial
          let cleanSlug = testimonial.slug;
          
          // Remove language prefix
          const langPrefix = `${lang}/`;
          if (cleanSlug.startsWith(langPrefix)) {
            cleanSlug = cleanSlug.substring(langPrefix.length);
          }
          
          // Remove type directory if it exists (company/, private/, etc.)
          const typePrefixes = ['company/', 'private/', 'network/', 'press/'];
          for (const prefix of typePrefixes) {
            if (cleanSlug.startsWith(prefix)) {
              cleanSlug = cleanSlug.substring(prefix.length);
              break;
            }
          }
          
          return (
            <TestimonialCard
              quote={testimonial.data.text}
              author={testimonial.data.name}
              role={testimonial.data.role}
              company={testimonial.data.company}
              image={testimonial.data.image}
              href={`/${lang}/testimonials/${cleanSlug}`}
            />
          );
        })
      }
    </div>

    <div class="text-center mt-8">
      <a
        href={`/${lang}/testimonials`}
        class="inline-flex items-center text-primary-DEFAULT hover:text-primary-hover transition-colors"
      >
        <span>
          {lang === "de" ? "Alle Referenzen ansehen" : "View all testimonials"}
        </span>
        <svg
          class="w-4 h-4 ml-2"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
