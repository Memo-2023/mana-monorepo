---
export interface Props {
  features?: string[];
  competitors?: { name: string; features: Record<string, boolean | string> }[];
}

const { features = [], competitors = [] } = Astro.props;
---

<div class="overflow-x-auto">
  <table class="w-full bg-white rounded-lg shadow-md">
    <thead>
      <tr class="bg-gray-100">
        <th class="p-4 text-left font-semibold">Feature</th>
        {competitors.map(competitor => (
          <th class="p-4 text-center font-semibold">{competitor.name}</th>
        ))}
      </tr>
    </thead>
    <tbody>
      {features.map((feature, index) => (
        <tr class={index % 2 === 0 ? 'bg-gray-50' : 'bg-white'}>
          <td class="p-4 font-medium">{feature}</td>
          {competitors.map(competitor => (
            <td class="p-4 text-center">
              {typeof competitor.features[feature] === 'boolean' ? (
                competitor.features[feature] ? (
                  <span class="text-green-600">✓</span>
                ) : (
                  <span class="text-red-600">✗</span>
                )
              ) : (
                <span>{competitor.features[feature] || '-'}</span>
              )}
            </td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
</div>