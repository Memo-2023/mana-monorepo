---
interface Props {
  name: string;
  displayName: string;
  bio: string;
  role: string;
  avatar?: string;
  expertise?: string[];
  writingPrompt?: string;
  stats?: {
    totalPosts?: number;
    totalViews?: number;
  };
  social?: {
    email?: string;
    linkedin?: string;
    twitter?: string;
    github?: string;
  };
}

const { 
  name, 
  displayName, 
  bio, 
  role, 
  avatar, 
  expertise = [], 
  writingPrompt,
  stats,
  social 
} = Astro.props;
---

<article class="bg-background-card border border-border-DEFAULT rounded-lg p-8 min-w-[400px] max-w-[500px] h-[600px] flex flex-col hover:border-primary/50 transition-all duration-300">
  <!-- Header mit Avatar -->
  <div class="flex items-start gap-4 mb-6">
    {avatar ? (
      <img 
        src={avatar} 
        alt={displayName}
        class="w-20 h-20 rounded-full object-cover border-2 border-primary/20"
        width="80"
        height="80"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="w-20 h-20 rounded-full bg-primary/20 flex items-center justify-center">
        <span class="text-2xl font-bold text-primary">
          {displayName.split(' ').map(n => n[0]).join('')}
        </span>
      </div>
    )}
    
    <div class="flex-1">
      <h3 class="text-xl font-bold text-text-primary">{displayName}</h3>
      <p class="text-sm text-primary">{role}</p>
      
      <!-- Social Links -->
      {social && (
        <div class="flex gap-3 mt-2">
          {social.email && (
            <a href={`mailto:${social.email}`} class="text-text-muted hover:text-primary transition-colors">
              <span class="text-lg">✉️</span>
            </a>
          )}
          {social.linkedin && (
            <a href={`https://linkedin.com/in/${social.linkedin}`} target="_blank" class="text-text-muted hover:text-primary transition-colors">
              <span class="text-lg">💼</span>
            </a>
          )}
          {social.twitter && (
            <a href={`https://twitter.com/${social.twitter}`} target="_blank" class="text-text-muted hover:text-primary transition-colors">
              <span class="text-lg">🐦</span>
            </a>
          )}
          {social.github && (
            <a href={`https://github.com/${social.github}`} target="_blank" class="text-text-muted hover:text-primary transition-colors">
              <span class="text-lg">🐙</span>
            </a>
          )}
        </div>
      )}
    </div>
  </div>

  <!-- Bio -->
  <p class="text-text-secondary text-sm mb-4 line-clamp-3">{bio}</p>

  <!-- Expertise Tags -->
  {expertise.length > 0 && (
    <div class="mb-4">
      <div class="flex flex-wrap gap-2">
        {expertise.map(exp => (
          <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-primary/10 text-primary border border-primary/30">
            {exp}
          </span>
        ))}
      </div>
    </div>
  )}

  <!-- Writing Prompt Section -->
  {writingPrompt && (
    <div class="flex-1 overflow-hidden bg-background-cardHover rounded-lg p-4 border border-border-light">
      <h4 class="text-sm font-semibold text-text-primary mb-2 flex items-center gap-2">
        <span>✍️</span> Schreibstil & Voice
      </h4>
      <div class="text-xs text-text-secondary overflow-y-auto max-h-[200px] space-y-1">
        <pre class="whitespace-pre-wrap font-sans">{writingPrompt}</pre>
      </div>
    </div>
  )}

  <!-- Stats -->
  {stats && (
    <div class="mt-4 pt-4 border-t border-border-DEFAULT flex justify-around">
      {stats.totalPosts !== undefined && (
        <div class="text-center">
          <div class="text-lg font-bold text-text-primary">{stats.totalPosts}</div>
          <div class="text-xs text-text-muted">Beiträge</div>
        </div>
      )}
      {stats.totalViews !== undefined && (
        <div class="text-center">
          <div class="text-lg font-bold text-text-primary">{stats.totalViews.toLocaleString()}</div>
          <div class="text-xs text-text-muted">Views</div>
        </div>
      )}
    </div>
  )}
</article>

<style>
  /* Scrollbar für Writing Prompt */
  .overflow-y-auto::-webkit-scrollbar {
    width: 6px;
  }
  
  .overflow-y-auto::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 3px;
  }
  
  .overflow-y-auto::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.2);
    border-radius: 3px;
  }
  
  .overflow-y-auto::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.3);
  }
</style>