---
export interface Props {
  color: 'blue' | 'red' | 'green' | 'purple' | 'orange' | 'yellow' | 'gray';
  icon?: string;
  variant?: 'bar' | 'icon' | 'both';
}

const { color, icon, variant = 'both' } = Astro.props;

// Color mappings
const colorClasses = {
  blue: 'bg-primary-DEFAULT',
  red: 'bg-red-500',
  green: 'bg-green-500',
  purple: 'bg-purple-500',
  orange: 'bg-orange-500',
  yellow: 'bg-yellow-500',
  gray: 'bg-gray-500'
};

const bgColor = colorClasses[color] || colorClasses.gray;
---

{(variant === 'bar' || variant === 'both') && (
  <div class={`h-2 ${bgColor}`}></div>
)}

{(variant === 'icon' || variant === 'both') && icon && (
  <div class={`w-14 h-14 rounded-lg flex items-center justify-center text-white ${bgColor}`}>
    <span class="text-3xl">{icon}</span>
  </div>
)}

<style>
  /* Ensure proper color rendering */
  .bg-primary-DEFAULT { background-color: var(--color-primary); }
  .bg-red-500 { background-color: #ef4444; }
  .bg-green-500 { background-color: #10b981; }
  .bg-purple-500 { background-color: #8b5cf6; }
  .bg-orange-500 { background-color: #f97316; }
  .bg-yellow-500 { background-color: #eab308; }
  .bg-gray-500 { background-color: #6b7280; }
</style>