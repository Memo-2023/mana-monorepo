---
export interface Props {
  author: string;
  date: Date;
  lang: string;
  authorSlug?: string;
}

const { author, date, lang, authorSlug } = Astro.props;

// Generate author slug if not provided
const finalAuthorSlug = authorSlug || author.toLowerCase().replace(/\s+/g, '-');
---

<div class="flex items-center text-sm text-text-secondary">
  <span class="font-medium hover:text-text-primary transition-colors">
    <a href={`/${lang}/team/${finalAuthorSlug}`}>
      {author}
    </a>
  </span>
  <span class="mx-2 text-primary-DEFAULT">•</span>
  <time datetime={date.toISOString()} class="italic">
    {date.toLocaleDateString(lang === "de" ? "de-DE" : "en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })}
  </time>
</div>