---
import { useTranslations } from '../../i18n/utils';

export interface Props {
  lang: string;
  questionText?: string;
  yesText?: string;
  noText?: string;
  onYesClick?: string;
  onNoClick?: string;
}

const { 
  lang, 
  questionText,
  yesText,
  noText,
  onYesClick = "console.log('Feedback: Yes')",
  onNoClick = "console.log('Feedback: No')"
} = Astro.props;

const t = useTranslations(lang);

// Default texts
const defaultQuestion = t('guides.wasFeedbackHelpful') || 'Was this guide helpful?';
const defaultYes = t('common.yes') || 'Yes';
const defaultNo = t('common.no') || 'No';

const finalQuestion = questionText || defaultQuestion;
const finalYes = yesText || defaultYes;
const finalNo = noText || defaultNo;
---

<div class="feedback-section">
  <p class="text-text-secondary text-center mb-4">{finalQuestion}</p>
  <div class="flex justify-center gap-4">
    <button 
      class="feedback-btn feedback-yes px-6 py-2 bg-background-cardHover text-text-primary hover:bg-primary-DEFAULT hover:text-white font-medium rounded-md transition-colors"
      data-feedback="yes"
    >
      {finalYes}
    </button>
    <button 
      class="feedback-btn feedback-no px-6 py-2 bg-background-cardHover text-text-primary hover:bg-background-card hover:border hover:border-border font-medium rounded-md transition-colors"
      data-feedback="no"
    >
      {finalNo}
    </button>
  </div>
</div>

<script define:vars={{ onYesClick, onNoClick }}>
  document.addEventListener('DOMContentLoaded', () => {
    const feedbackBtns = document.querySelectorAll('.feedback-btn');
    
    feedbackBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const feedback = e.currentTarget.dataset.feedback;
        
        // Visual feedback
        const section = e.currentTarget.closest('.feedback-section');
        section.innerHTML = `
          <p class="text-text-secondary text-center">
            ${feedback === 'yes' ? '✅ ' : ''}
            ${feedback === 'yes' ? 'Danke für dein Feedback!' : 'Danke für dein Feedback. Wir arbeiten daran!'}
          </p>
        `;
        
        // Execute custom handlers
        if (feedback === 'yes') {
          eval(onYesClick);
        } else {
          eval(onNoClick);
        }
      });
    });
  });
</script>