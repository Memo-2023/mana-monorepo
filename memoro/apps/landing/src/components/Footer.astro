---
import Button from "./atoms/Button.astro";
import { Icon } from "astro-icon/components";
import packageJson from "../../package.json";
import { defaultLang } from "../i18n/ui";

const currentYear = new Date().getFullYear();
const version = packageJson.version;
const currentPath = Astro.url.pathname;
const pathSegments = currentPath.split("/").filter(Boolean);
const currentLang = (pathSegments[0] === 'de' || pathSegments[0] === 'en') ? pathSegments[0] : defaultLang;
const isGerman = currentLang === 'de';

// Function to check if the current page matches the link
const isActive = (href: string) => {
  const cleanPath = currentPath.endsWith('/') ? currentPath.slice(0, -1) : currentPath;
  const cleanHref = href.endsWith('/') ? href.slice(0, -1) : href;
  return cleanPath === cleanHref;
};

// Übersetzungen
const translations = {
  de: {
    memories: {
      title: "Memories",
      insights: "Erkenntnisse",
      summary: "Zusammenfassung",
      tasks: "Aufgaben",
      all: "Alle Memories anzeigen",
    },
    wallpapers: {
      title: "Wallpapers",
      abstract: "Abstrakt",
      nature: "Natur",
      city: "Stadt",
      all: "Alle Wallpapers anzeigen",
    },
    downloadApp: "App herunterladen",
    downloads: "Downloads",
    appDownload: "App herunterladen",
    contracts: "Verträge",
  },
  en: {
    memories: {
      title: "Memories",
      insights: "Insights",
      summary: "Summary",
      tasks: "Tasks",
      all: "View all memories",
    },
    wallpapers: {
      title: "Wallpapers",
      abstract: "Abstract",
      nature: "Nature",
      city: "City",
      all: "View all wallpapers",
    },
    downloadApp: "Download App",
    downloads: "Downloads",
    appDownload: "Download App",
    contracts: "Contracts",
  },
};
---

<footer class="bg-background-page text-white py-8 sm:py-12 pb-32 md:pb-8">
  <div class="w-full px-4 sm:px-6 md:px-8 lg:px-12 max-w-7xl mx-auto">
    <div class="w-full">
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 sm:gap-6 lg:gap-8 lg:max-w-6xl lg:mx-auto">
        {/* Produkt */}
        <div class="flex flex-col h-full">
          <h3 class="text-xs sm:text-base font-medium opacity-50 uppercase tracking-wider mb-3">
            Produkt
          </h3>
          <ul class="flex-1 flex flex-col justify-start space-y-2 sm:space-y-2">
            <li>
              <a
                href={`/${isGerman ? "de" : "en"}/features`}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(`/${isGerman ? "de" : "en"}/features`) ? 'bg-white/10 text-white' : 'text-gray-300'}`}
                >
                  <Icon name="mdi:sparkles" class="w-4 h-4" />
                  {isGerman ? "Funktionen" : "Features"}
                </a
              >
            </li>
            <li>
              <a
                href={`/${isGerman ? "de" : "en"}/industries`}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(`/${isGerman ? "de" : "en"}/industries`) ? 'bg-white/10 text-white' : 'text-gray-300'}`}
                >
                  <Icon name="mdi:office-building" class="w-4 h-4" />
                  {isGerman ? "Branchen" : "Industries"}
                </a
              >
            </li>
            <li>
              <a
                href={`/${isGerman ? "de" : "en"}/testimonials`}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(`/${isGerman ? "de" : "en"}/testimonials`) ? 'bg-white/10 text-white' : 'text-gray-300'}`}
                >
                  <Icon name="mdi:star" class="w-4 h-4" />
                  {isGerman ? "Referenzen" : "References"}
                </a
              >
            </li>
            <li>
              <a
                href={`/${isGerman ? "de" : "en"}/prices`}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(`/${isGerman ? "de" : "en"}/prices`) ? 'bg-white/10 text-white' : 'text-gray-300'}`}
                >
                  <Icon name="mdi:tag" class="w-4 h-4" />
                  {isGerman ? "Preise" : "Prices"}
                </a
              >
            </li>
            <li>
              <a
                href={`/${isGerman ? "de" : "en"}/changelog`}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(`/${isGerman ? "de" : "en"}/changelog`) ? 'bg-white/10 text-white' : 'text-gray-300'}`}
                >
                  <Icon name="mdi:source-commit" class="w-4 h-4" />
                  Changelog
                </a
              >
            </li>
          </ul>
        </div>

        {/* Hilfe */}
        <div class="flex flex-col h-full">
          <h3 class="text-xs sm:text-base font-medium opacity-50 uppercase tracking-wider mb-3">
            {isGerman ? "Hilfe" : "Help"}
          </h3>
          <ul class="flex-1 flex flex-col justify-start space-y-2 sm:space-y-2">
            <li>
              <a
                href={`/${isGerman ? "de" : "en"}/guides`}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(`/${isGerman ? "de" : "en"}/guides`) ? 'bg-white/10 text-white' : 'text-gray-300'}`}
                >
                  <Icon name="mdi:book-open-variant" class="w-4 h-4" />
                  {isGerman ? "Anleitungen" : "Guides"}
                </a
              >
            </li>
            <li>
              <a
                href={`/${isGerman ? "de" : "en"}/blueprints`}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(`/${isGerman ? "de" : "en"}/blueprints`) ? 'bg-white/10 text-white' : 'text-gray-300'}`}
                >
                  <Icon name="mdi:file-document-outline" class="w-4 h-4" />
                  {isGerman ? "Vorlagen" : "Blueprints"}
                </a
              >
            </li>
            <li>
              <a
                href={`/${isGerman ? "de" : "en"}/memories`}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(`/${isGerman ? "de" : "en"}/memories`) ? 'bg-white/10 text-white' : 'text-gray-300'}`}
                >
                  <Icon name="mdi:brain" class="w-4 h-4" />
                  {translations[isGerman ? "de" : "en"].memories.title}
                </a
              >
            </li>
            <li>
              <a
                href={`/${isGerman ? "de" : "en"}/faq`}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(`/${isGerman ? "de" : "en"}/faq`) ? 'bg-white/10 text-white' : 'text-gray-300'}`}
                >
                  <Icon name="mdi:help-circle-outline" class="w-4 h-4" />
                  FAQ
                </a
              >
            </li>
          </ul>
        </div>

        {/* Downloads */}
        <div class="flex flex-col h-full">
          <h3 class="text-xs sm:text-base font-medium opacity-50 uppercase tracking-wider mb-3">
            {translations[isGerman ? "de" : "en"].downloads}
          </h3>
          <ul class="flex-1 flex flex-col justify-start space-y-2 sm:space-y-2">
            <li>
              <a
                href={`/${isGerman ? "de" : "en"}/download`}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(`/${isGerman ? "de" : "en"}/download`) ? 'bg-white/10 text-white' : 'text-gray-300'}`}
                >
                  <Icon name="mdi:download" class="w-4 h-4" />
                  {isGerman ? "App laden" : "Get App"}
                </a
              >
            </li>
            <li>
              <a
                href={`/${isGerman ? "de" : "en"}/wallpapers`}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(`/${isGerman ? "de" : "en"}/wallpapers`) ? 'bg-white/10 text-white' : 'text-gray-300'}`}
                >
                  <Icon name="mdi:image" class="w-4 h-4" />
                  {translations[isGerman ? "de" : "en"].wallpapers.title}
                </a
              >
            </li>
            <li>
              <a
                href={`/${isGerman ? "de" : "en"}/presskit`}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(`/${isGerman ? "de" : "en"}/presskit`) ? 'bg-white/10 text-white' : 'text-gray-300'}`}
                >
                  <Icon name="mdi:newspaper" class="w-4 h-4" />
                  {isGerman ? "Presse" : "Press"}
                </a
              >
            </li>
          </ul>
        </div>


        {/* Firma */}
        <div class="flex flex-col h-full">
          <h3 class="text-xs sm:text-base font-medium opacity-50 uppercase tracking-wider mb-3">
            {isGerman ? "Firma" : "Company"}
          </h3>
          <ul class="flex-1 flex flex-col justify-start space-y-2 sm:space-y-2">
            <li>
              <a
                href={`/${isGerman ? "de" : "en"}/team`}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(`/${isGerman ? "de" : "en"}/team`) ? 'bg-white/10 text-white' : 'text-gray-300'}`}
                >
                  <Icon name="mdi:account-group" class="w-4 h-4" />
                  Team
                </a
              >
            </li>
            <li>
              <a
                href={`/${isGerman ? "de" : "en"}/contact`}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(`/${isGerman ? "de" : "en"}/contact`) ? 'bg-white/10 text-white' : 'text-gray-300'}`}
                >
                  <Icon name="mdi:email-outline" class="w-4 h-4" />
                  {isGerman ? "Kontakt" : "Contact"}
                </a
              >
            </li>
            <li>
              <a
                href={`/${isGerman ? "de" : "en"}/blog`}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(`/${isGerman ? "de" : "en"}/blog`) ? 'bg-white/10 text-white' : 'text-gray-300'}`}
                >
                  <Icon name="mdi:pencil-box-outline" class="w-4 h-4" />
                  Blog
                </a
              >
            </li>
            <li>
              <a
                href={`/${isGerman ? "de" : "en"}/about`}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(`/${isGerman ? "de" : "en"}/about`) ? 'bg-white/10 text-white' : 'text-gray-300'}`}
                >
                  <Icon name="mdi:information-outline" class="w-4 h-4" />
                  {isGerman ? "Über uns" : "About"}
                </a
              >
            </li>
            <li>
              <a
                href={`/${isGerman ? "de" : "en"}/statistics`}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(`/${isGerman ? "de" : "en"}/statistics`) ? 'bg-white/10 text-white' : 'text-gray-300'}`}
                >
                  <Icon name="mdi:chart-bar" class="w-4 h-4" />
                  {isGerman ? "Stats" : "Stats"}
                </a
              >
            </li>
          </ul>
        </div>

        {/* Rechtlich */}
        <div class="flex flex-col h-full">
          <h3 class="text-xs sm:text-base font-medium opacity-50 uppercase tracking-wider mb-3">
            {isGerman ? "Rechtlich" : "Legal"}
          </h3>
          <ul class="flex-1 flex flex-col justify-start space-y-2 sm:space-y-2">
            <li>
              <a
                href={isGerman ? "/de/privacy" : "/en/privacy"}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(isGerman ? "/de/privacy" : "/en/privacy") ? 'bg-white/10 text-white' : 'text-gray-300'}`}
              >
                <Icon name="mdi:shield-check" class="w-4 h-4" />
                {isGerman ? "Datenschutz" : "Privacy"}
              </a>
            </li>
            <li>
              <a
                href={isGerman ? "/de/imprint" : "/en/imprint"}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(isGerman ? "/de/imprint" : "/en/imprint") ? 'bg-white/10 text-white' : 'text-gray-300'}`}
              >
                <Icon name="mdi:scale-balance" class="w-4 h-4" />
                {isGerman ? "Impressum" : "Imprint"}
              </a>
            </li>
            <li>
              <a
                href={isGerman ? "/de/terms" : "/en/terms"}
                class={`flex items-center gap-2 px-3 py-2.5 bg-white/5 hover:bg-white/10 rounded-lg text-sm sm:text-base transition-all ${isActive(isGerman ? "/de/terms" : "/en/terms") ? 'bg-white/10 text-white' : 'text-gray-300'}`}
              >
                <Icon name="mdi:file-check-outline" class="w-4 h-4" />
                {isGerman ? "AGB" : "Terms"}
              </a>
            </li>
          </ul>
        </div>

      </div>
    </div>

    <div class="mt-8 sm:mt-12 pt-6 sm:pt-8 border-t border-border">
      <div class="flex justify-center">
        <div class="flex space-x-6">
          <a
            href="https://linkedin.com/company/memoroai"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-muted hover:text-[#0077b5] transition-colors"
          >
            <span class="sr-only">LinkedIn</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
              ></path>
            </svg>
          </a>
          <a
            href="https://twitter.com/memoroai"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-muted hover:text-white transition-colors"
          >
            <span class="sr-only">X (Twitter)</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path>
            </svg>
          </a>
          <a
            href="https://www.facebook.com/people/Memoro/61553276416367/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-muted hover:text-[#1877f2] transition-colors"
          >
            <span class="sr-only">Facebook</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
              ></path>
            </svg>
          </a>
          <a
            href="https://instagram.com/memoroai"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-muted hover:text-[#E4405F] transition-colors"
          >
            <span class="sr-only">Instagram</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zM5.838 12a6.162 6.162 0 1112.324 0 6.162 6.162 0 01-12.324 0zM12 16a4 4 0 110-8 4 4 0 010 8zm4.965-10.405a1.44 1.44 0 112.881.001 1.44 1.44 0 01-2.881-.001z"
              ></path>
            </svg>
          </a>
          <a
            href="https://youtube.com/@memoroai"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-muted hover:text-[#FF0000] transition-colors"
          >
            <span class="sr-only">YouTube</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
              ></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-8 sm:mt-16 flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center items-center">
      <Button
        href="https://app.memoro.ai"
        variant="secondary"
        size="md"
        target="_blank"
        class="w-full sm:w-auto"
      >
        Login
      </Button>
      <Button
        href={`/${isGerman ? "de" : "en"}/download`}
        variant="primary"
        size="md"
        class="w-full sm:w-auto"
      >
        {isGerman ? translations.de.downloadApp : translations.en.downloadApp}
      </Button>
    </div>

    <div class="mt-6 sm:mt-8 text-center">
      <div class="text-text-muted text-xs sm:text-sm">
        © {currentYear} Memoro GmbH · Memoro Website · v{version}
      </div>
    </div>
  </div>
</footer>
