---
interface Props {
  title: string;
  description: string;
  icon: string;
  href: string;
  version?: string;
  lastUpdated?: Date;
  badge?: string;
  lang?: string;
}

const { title, description, icon, href, version, lastUpdated, badge, lang = 'de' } = Astro.props;

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat(lang, { 
    year: 'numeric', 
    month: 'short' 
  }).format(date);
};
---

<a
  href={href}
  class="block p-6 rounded-xl bg-background-card border border-border hover:bg-background-cardHover hover:border-primary/20 transition-all duration-300 group relative overflow-hidden"
>
  {/* Version Badge */}
  {version && (
    <div class="absolute top-4 right-4">
      <span class="px-2 py-1 text-xs font-medium bg-primary/10 text-primary rounded-full">
        v{version}
      </span>
    </div>
  )}
  
  {/* Icon */}
  <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-primary/20 to-primary/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
    <span class="text-2xl">{icon}</span>
  </div>
  
  {/* Content */}
  <h3 class="text-lg font-semibold text-text-primary mb-2 group-hover:text-primary transition-colors">
    {title}
  </h3>
  <p class="text-sm text-text-secondary mb-3 line-clamp-2">
    {description}
  </p>
  
  {/* Footer */}
  <div class="flex items-center justify-between mt-4 pt-4 border-t border-border/50">
    {lastUpdated && (
      <span class="text-xs text-text-muted">
        {lang === 'de' ? 'Stand:' : 'Updated:'} {formatDate(lastUpdated)}
      </span>
    )}
    <span class="text-sm font-medium text-primary opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center gap-1">
      {lang === 'de' ? 'Ansehen' : 'View'}
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </span>
  </div>
  
  {/* Badge */}
  {badge && (
    <div class="absolute -top-1 -left-1">
      <span class="bg-gradient-to-r from-green-500 to-green-600 text-white text-xs font-bold px-3 py-1 rounded-br-xl rounded-tl-xl">
        {badge}
      </span>
    </div>
  )}
</a>