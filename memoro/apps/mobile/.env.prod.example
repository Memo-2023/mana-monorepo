EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_production_ios_client_id
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_production_android_client_id

# Analytics Production
EXPO_PUBLIC_UMAMI_WEBSITE_ID=your_production_umami_id
EXPO_PUBLIC_UMAMI_API_URL=https://your-analytics-domain.com