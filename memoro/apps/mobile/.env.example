# EXPO_PUBLIC_UMAMI_SCRIPT_URL=https://umami.manacore.ai/script.js

# Example configurations:

# Full migration enabled:
# EXPO_PUBLIC_USE_CENTRALIZED_REALTIME=true
# EXPO_PUBLIC_MIGRATE_DIRECT_MEMO_TITLE=true

# 50% rollout:
# EXPO_PUBLIC_MIGRATION_ROLLOUT_PERCENTAGE=50

# Debug mode:
# EXPO_PUBLIC_DEBUG_REALTIME_CONNECTIONS=true