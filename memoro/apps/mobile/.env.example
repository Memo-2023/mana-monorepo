# Realtime Migration Feature Flags
# Copy to .env.local and modify as needed

# Enable centralized realtime service migration
# EXPO_PUBLIC_USE_CENTRALIZED_REALTIME=false

# Enable DirectMemoTitle migration specifically (default: true)
# EXPO_PUBLIC_MIGRATE_DIRECT_MEMO_TITLE=true

# Gradual rollout percentage (0-100)
# EXPO_PUBLIC_MIGRATION_ROLLOUT_PERCENTAGE=0

# Debug realtime connections
# EXPO_PUBLIC_DEBUG_REALTIME_CONNECTIONS=false

# Analytics Configuration
# PostHog (Mobile)
# EXPO_PUBLIC_POSTHOG_KEY=phc_SdmYfeCIZDgIfj87SNCpId18a5edPqtnmam6f0H4dWJ
# EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Umami (Web)
