			"gridPos": { "h": 14, "w": 12, "x": 0, "y": 6 },
			"fieldConfig": {
				"defaults": {
					"custom": {
						"align": "left",
						"displayMode": "color-background"
					},
					"mappings": [
						{
							"type": "value",
							"options": {
								"0": { "text": "DOWN", "color": "red" },
								"1": { "text": "UP", "color": "green" }
							}
						}
					],
					"thresholds": {
						"mode": "absolute",
