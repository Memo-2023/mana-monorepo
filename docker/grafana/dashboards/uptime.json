							{ "color": "red", "value": null },
							{ "color": "green", "value": 1 }
						]
					}
				},
				"overrides": [
					{
						"matcher": { "id": "byName", "options": "instance" },
						"properties": [
							{ "id": "displayName", "value": "URL" },
							{ "id": "custom.width", "value": 260 }
						]
					},
					{
						"matcher": { "id": "byName", "options": "Value" },
						"properties": [
							{ "id": "displayName", "value": "Status" },
							{ "id": "custom.width", "value": 80 }
						]
