				]
			},
			"options": {
				"sortBy": [{ "displayName": "Status", "desc": false }],
				"footer": { "show": false }
			},
			"transformations": [
				{ "id": "labelsToFields", "options": { "mode": "columns", "keepLabels": ["instance"] } },
				{
					"id": "organize",
					"options": {
						"excludeByName": { "Time": true, "job": true, "__name__": true },
						"indexByName": { "instance": 0, "Value": 1 }
