{
	"name": "@manacore/nutriphi-database",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./schema": {
			"types": "./dist/schema/index.d.ts",
			"import": "./dist/schema/index.js",
			"require": "./dist/schema/index.js",
			"default": "./dist/schema/index.js"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"import": "./dist/client.js",
			"require": "./dist/client.js",
			"default": "./dist/client.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"clean": "rm -rf dist",
		"prepare": "pnpm build",
		"docker:up": "docker compose up -d",
		"docker:down": "docker compose down",
		"docker:logs": "docker compose logs -f postgres",
		"db:generate": "dotenv -- drizzle-kit generate",
		"db:migrate": "dotenv -- drizzle-kit migrate",
		"db:push": "dotenv -- drizzle-kit push --force",
		"db:studio": "dotenv -- drizzle-kit studio",
		"db:reset": "docker compose down -v && docker compose up -d && sleep 3 && pnpm db:push",
		"db:test": "dotenv -- tsx src/test-connection.ts",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"drizzle-orm": "^0.36.0",
		"postgres": "^3.4.5"
	},
	"devDependencies": {
		"dotenv-cli": "^7.4.0",
		"drizzle-kit": "^0.28.0",
		"tsx": "^4.19.0",
		"typescript": "^5.7.3",
		"@types/node": "^22.10.0"
	}
}
