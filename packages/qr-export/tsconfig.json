{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022", "DOM"],
		"types": ["node"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"noEmit": true
	},
	"include": ["src/**/*.ts", "src/**/*.d.ts", "vitest.config.ts"],
	"exclude": ["node_modules", "src/**/*.svelte"]
}
