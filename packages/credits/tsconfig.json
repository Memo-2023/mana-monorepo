{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"jsx": "react-jsx",
		"outDir": "dist",
		"declaration": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.svelte"]
}
