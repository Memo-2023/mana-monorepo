{
	"$schema": "https://turbo.build/schema.json",
	"concurrency": "5",
	"globalEnv": [
		"NODE_ENV",
		"MANA_AUTH_URL",
		"JWT_PUBLIC_KEY",
		"AZURE_OPENAI_ENDPOINT",
		"AZURE_OPENAI_API_KEY"
	],
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", "build/**", ".next/**", ".svelte-kit/**", ".astro/**"]
		},
		"lint": {
			"dependsOn": ["^lint"],
			"outputs": []
		},
		"type-check": {
			"dependsOn": ["^type-check", "^build"],
			"outputs": []
		},
		"test": {
			"dependsOn": ["^build"],
			"outputs": ["coverage/**"]
		},
		"clean": {
			"cache": false
		}
	}
}
