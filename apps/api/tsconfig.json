{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"types": ["bun-types"]
	},
	"include": ["src/**/*.ts", "scripts/**/*.ts", "drizzle.*.config.ts"]
}
