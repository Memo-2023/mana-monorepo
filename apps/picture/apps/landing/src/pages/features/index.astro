---
import Layout from '@layouts/Layout.astro';
import { t } from '../../i18n';
import { getFeatures, getFeaturedFeatures, getAllFeatureCategories } from '@/utils/features';
import FeatureCard from '@components/features/FeatureCard.astro';
import { localizePath } from '../../i18n';

const allFeatures = await getFeatures();
const featuredFeatures = await getFeaturedFeatures();
const categories = getAllFeatureCategories();
---

<Layout title={t('features.title')} description={t('features.description')}>
	<div class="min-h-screen bg-dark-bg">
		<!-- Hero Section -->
		<section class="relative py-24 overflow-hidden">
			<div class="absolute inset-0 bg-gradient-to-br from-primary-900/20 via-dark-surface to-secondary-900/20"></div>

			<div class="relative z-10 container mx-auto px-4">
				<div class="max-w-3xl mx-auto text-center mb-16">
					<div class="inline-flex items-center px-4 py-2 mb-6 bg-primary/10 border border-primary/20 rounded-full">
						<span class="text-sm text-primary-300">{t('features.badge')}</span>
					</div>
					<h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
						{t('features.title')}
					</h1>
					<p class="text-xl text-gray-400">
						{t('features.subtitle')}
					</p>
				</div>
			</div>
		</section>

		<!-- Featured Features -->
		{featuredFeatures.length > 0 && (
			<section class="py-16 bg-dark-surface">
				<div class="container mx-auto px-4">
					<h2 class="text-3xl font-bold text-white mb-8">{t('features.featured_features')}</h2>
					<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
						{featuredFeatures.map(feature => (
							<FeatureCard feature={feature} />
						))}
					</div>
				</div>
			</section>
		)}

		<!-- Category Filters -->
		<section class="py-8 bg-dark-bg border-b border-dark-border">
			<div class="container mx-auto px-4">
				<div class="flex flex-wrap justify-center gap-3">
					<a
						href={localizePath('/features')}
						class="px-4 py-2 bg-primary text-white rounded-lg font-medium hover:bg-primary-600 transition-colors"
					>
						{t('features.all_features')}
					</a>
					{categories.map(category => (
						<a
							href={localizePath(`/features/category/${category}`)}
							class="px-4 py-2 bg-dark-elevated text-gray-300 rounded-lg font-medium hover:bg-dark-surface hover:text-white transition-colors border border-dark-border"
						>
							{t(`features.categories.${category}`)}
						</a>
					))}
				</div>
			</div>
		</section>

		<!-- All Features -->
		<section class="py-16">
			<div class="container mx-auto px-4">
				<h2 class="text-3xl font-bold text-white mb-8">{t('features.all_features')}</h2>
				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
					{allFeatures.map(feature => (
						<FeatureCard feature={feature} />
					))}
				</div>

				{allFeatures.length === 0 && (
					<div class="text-center py-16">
						<p class="text-xl text-gray-400">{t('features.no_features')}</p>
					</div>
				)}
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-24 bg-gradient-to-r from-primary-900/30 via-secondary-900/30 to-primary-900/30">
			<div class="container mx-auto px-4 text-center">
				<h2 class="text-4xl font-bold text-white mb-6">
					{t('features.cta_title')}
				</h2>
				<p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
					{t('features.cta_subtitle')}
				</p>
				<a
					href="#"
					class="inline-block px-8 py-4 bg-gradient-to-r from-primary-600 to-secondary-600 hover:from-primary-700 hover:to-secondary-700 text-white rounded-lg font-semibold text-lg transition-all duration-300 shadow-lg shadow-primary/50 hover:shadow-primary/70 hover:scale-105"
				>
					{t('features.cta_button')}
				</a>
			</div>
		</section>
	</div>
</Layout>
