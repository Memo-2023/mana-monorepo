---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import { formatDate, calculateReadingTime, getRelatedPosts } from '@/utils/blog';
import { t } from '../../i18n';
import i18next from '../../i18n';
import { localizePath } from '../../i18n';
import BlogCard from '@components/blog/BlogCard.astro';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog');
	return allPosts.map(post => ({
		params: { slug: post.id },
		props: { post },
	}));
}

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, description, publishedAt, updatedAt, coverImage, author, category, tags } = post.data;

const readingTime = calculateReadingTime(post.body);
const relatedPosts = await getRelatedPosts(post, 3);
---

<Layout title={title} description={description}>
	<article class="min-h-screen bg-dark-bg">
		<!-- Hero Section -->
		<div class="relative h-[60vh] overflow-hidden">
			<img
				src={coverImage}
				alt={title}
				class="w-full h-full object-cover"
			/>
			<div class="absolute inset-0 bg-gradient-to-t from-dark-bg via-dark-bg/50 to-transparent"></div>

			<div class="absolute bottom-0 left-0 right-0 container mx-auto px-4 pb-12">
				<div class="max-w-4xl mx-auto">
					<!-- Category Badge -->
					<span class="inline-block px-3 py-1 bg-primary text-white text-sm font-medium rounded-full capitalize mb-4">
						{t(`blog.categories.${category}`)}
					</span>

					<!-- Title -->
					<h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4">
						{title}
					</h1>

					<!-- Meta Info -->
					<div class="flex flex-wrap items-center gap-4 text-gray-300">
						<span class="flex items-center gap-2">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
							</svg>
							{author}
						</span>
						<span>•</span>
						<time datetime={publishedAt.toISOString()}>
							{formatDate(publishedAt, post.data.language)}
						</time>
						<span>•</span>
						<span>{readingTime} {t('blog.min_read')}</span>
					</div>
				</div>
			</div>
		</div>

		<!-- Content -->
		<div class="container mx-auto px-4 py-16">
			<div class="max-w-4xl mx-auto">
				<!-- Back Button -->
				<a
					href={localizePath('/blog')}
					class="inline-flex items-center gap-2 text-primary hover:text-primary-400 transition-colors mb-8"
				>
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
					</svg>
					<span>{t('blog.back_to_blog')}</span>
				</a>

				<!-- Article Content -->
				<div class="prose prose-invert prose-primary prose-lg max-w-none mb-12">
					<Content />
				</div>

				<!-- Tags -->
				<div class="flex flex-wrap gap-2 mb-12 pb-12 border-b border-dark-border">
					<span class="text-gray-400 font-medium">{t('blog.tags')}:</span>
					{tags.map(tag => (
						<a
							href={localizePath(`/blog/tag/${tag}`)}
							class="px-3 py-1 bg-dark-elevated text-gray-300 hover:text-primary hover:bg-dark-surface rounded-full text-sm transition-colors"
						>
							#{tag}
						</a>
					))}
				</div>

				<!-- Author Box -->
				<div class="bg-dark-elevated border border-dark-border rounded-2xl p-8 mb-16">
					<div class="flex items-start gap-4">
						<div class="w-16 h-16 bg-gradient-to-br from-primary to-secondary rounded-full flex items-center justify-center text-white text-2xl font-bold">
							{author.charAt(0)}
						</div>
						<div class="flex-1">
							<h3 class="text-xl font-bold text-white mb-2">{author}</h3>
							<p class="text-gray-400">
								{t('blog.author_bio')}
							</p>
						</div>
					</div>
				</div>

				<!-- Related Posts -->
				{relatedPosts.length > 0 && (
					<div>
						<h2 class="text-3xl font-bold text-white mb-8">{t('blog.related_posts')}</h2>
						<div class="grid md:grid-cols-3 gap-8">
							{relatedPosts.map(relatedPost => (
								<BlogCard post={relatedPost} />
							))}
						</div>
					</div>
				)}
			</div>
		</div>
	</article>
</Layout>

<style is:global>
	/* Blog Post Styles */
	.prose {
		@apply text-gray-300;
	}

	.prose h2 {
		@apply text-3xl font-bold text-white mt-12 mb-6;
	}

	.prose h3 {
		@apply text-2xl font-semibold text-white mt-8 mb-4;
	}

	.prose p {
		@apply mb-6 leading-relaxed;
	}

	.prose ul, .prose ol {
		@apply mb-6 space-y-2;
	}

	.prose li {
		@apply text-gray-300;
	}

	.prose a {
		@apply text-primary hover:text-primary-400 transition-colors underline;
	}

	.prose strong {
		@apply text-white font-semibold;
	}

	.prose code {
		@apply bg-dark-elevated px-2 py-1 rounded text-primary-300 text-sm;
	}

	.prose pre {
		@apply bg-dark-elevated border border-dark-border rounded-xl p-4 overflow-x-auto mb-6;
	}

	.prose pre code {
		@apply bg-transparent p-0;
	}

	.prose blockquote {
		@apply border-l-4 border-primary pl-6 italic text-gray-400 my-6;
	}

	.prose img {
		@apply rounded-xl my-8;
	}

	.prose table {
		@apply w-full mb-6;
	}

	.prose th {
		@apply bg-dark-elevated text-white font-semibold p-3 text-left;
	}

	.prose td {
		@apply border-t border-dark-border p-3;
	}
</style>
