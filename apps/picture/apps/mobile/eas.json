{
	"cli": {
		"version": ">= 16.17.4",
		"appVersionSource": "remote"
	},
	"build": {
		"base": {
			"node": "22.15.0",
			"pnpm": "10.18.1",
			"env": {
				"PNPM_WORKSPACE_ROOT": "../..",
				"EAS_BUILD": "true"
			},
			"cache": {
				"disabled": false,
				"key": "v1",
				"cacheDefaultPaths": true,
				"customPaths": ["node_modules", "../../node_modules", "../../packages/design-tokens/dist"]
			}
		},
		"development": {
			"extends": "base",
			"developmentClient": true,
			"distribution": "internal"
		},
		"preview": {
			"extends": "base",
			"distribution": "internal"
		},
		"production": {
			"extends": "base",
			"autoIncrement": true
		}
	},
	"submit": {
		"production": {}
	}
}
