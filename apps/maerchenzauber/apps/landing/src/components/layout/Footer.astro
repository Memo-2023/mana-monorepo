---
// Footer component with dark theme
---

<footer class="bg-bg-dark border-t border-border/20">
  <div class="container-custom py-12 md:py-16">
    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <!-- Logo & Description -->
      <div class="md:col-span-1">
        <div class="flex items-center space-x-2 mb-4">
          <img 
            src="/logo.png" 
            alt="Märchenzauber" 
            class="h-8 w-auto"
          />
          <span class="font-grandstander font-bold text-xl text-text-primary">
            Märchenzauber
          </span>
        </div>
        <p class="text-text-secondary text-sm">
          Wo jedes Kind zum Helden seiner eigenen Geschichte wird.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-semibold text-text-primary mb-4">Links</h3>
        <ul class="space-y-2">
          <li>
            <a href="#features" class="text-text-secondary hover:text-yellow-light transition-colors text-sm">
              Features
            </a>
          </li>
          <li>
            <a href="#how-it-works" class="text-text-secondary hover:text-yellow-light transition-colors text-sm">
              So funktioniert's
            </a>
          </li>
          <li>
            <a href="#pricing" class="text-text-secondary hover:text-yellow-light transition-colors text-sm">
              Preise
            </a>
          </li>
          <li>
            <a href="#faq" class="text-text-secondary hover:text-yellow-light transition-colors text-sm">
              FAQ
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="font-semibold text-text-primary mb-4">Rechtliches</h3>
        <ul class="space-y-2">
          <li>
            <a href="/imprint" class="text-text-secondary hover:text-yellow-light transition-colors text-sm">
              Impressum
            </a>
          </li>
          <li>
            <a href="/privacy" class="text-text-secondary hover:text-yellow-light transition-colors text-sm">
              Datenschutz
            </a>
          </li>
          <li>
            <a href="/terms" class="text-text-secondary hover:text-yellow-light transition-colors text-sm">
              AGB
            </a>
          </li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="font-semibold text-text-primary mb-4">Newsletter</h3>
        <p class="text-text-secondary text-sm mb-4">
          Erhalte Updates zu neuen Features und Geschichten.
        </p>
        <form class="space-y-2">
          <input 
            type="email" 
            placeholder="Deine E-Mail" 
            class="input w-full text-sm"
            required
          />
          <button type="submit" class="btn-primary w-full text-sm">
            Anmelden
          </button>
        </form>
      </div>
    </div>

    <!-- App Download Section -->
    <div class="border-t border-border/20 pt-8 mb-8">
      <div class="flex flex-col md:flex-row items-center justify-between">
        <div class="mb-4 md:mb-0">
          <h3 class="font-semibold text-text-primary mb-2">Jetzt herunterladen</h3>
          <p class="text-text-secondary text-sm">Verfügbar für iOS und Android</p>
        </div>
        <div class="flex space-x-4">
          <a href="/download" class="transition-opacity hover:opacity-80">
            <img
              src="/app-store-badge.svg"
              alt="Download on App Store"
              class="h-10"
            />
          </a>
          <a href="/download" class="transition-opacity hover:opacity-80">
            <img
              src="/google-play-badge.svg"
              alt="Get it on Google Play"
              class="h-10"
            />
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom Footer -->
    <div class="border-t border-border/20 pt-8">
      <div class="flex flex-col md:flex-row items-center justify-between">
        <p class="text-text-muted text-sm mb-4 md:mb-0">
          © 2024 Märchenzauber. Alle Rechte vorbehalten.
        </p>
        
        <!-- Social Links -->
        <div class="flex space-x-4">
          <a href="#" class="text-text-secondary hover:text-yellow-light transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="#" class="text-text-secondary hover:text-yellow-light transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zM5.838 12a6.162 6.162 0 1112.324 0 6.162 6.162 0 01-12.324 0zM12 16a4 4 0 110-8 4 4 0 010 8zm4.965-10.405a1.44 1.44 0 112.881.001 1.44 1.44 0 01-2.881-.001z"/>
            </svg>
          </a>
          <a href="#" class="text-text-secondary hover:text-yellow-light transition-colors" aria-label="Twitter">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>