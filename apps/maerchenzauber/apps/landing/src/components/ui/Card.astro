---
export interface Props {
  variant?: 'default' | 'hover' | 'glow';
  className?: string;
  padding?: 'none' | 'sm' | 'md' | 'lg';
}

const { 
  variant = 'default',
  className = '',
  padding = 'md'
} = Astro.props;

const paddingStyles = {
  none: '',
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8'
};

const variantStyles = {
  default: 'bg-bg-card',
  hover: 'bg-bg-card hover:shadow-xl hover:scale-[1.02] transition-all duration-300',
  glow: 'bg-bg-card hover:shadow-[0_0_30px_rgba(248,214,43,0.3)] transition-all duration-300'
};
---

<div class={`rounded-lg shadow-card ${variantStyles[variant]} ${paddingStyles[padding]} ${className}`}>
  <slot />
</div>