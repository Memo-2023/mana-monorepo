---
import Card from '../ui/Card.astro';
---

<section class="section bg-bg-primary">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center mb-12 md:mb-16">
      <h2 class="font-grandstander font-bold text-3xl md:text-4xl lg:text-5xl text-text-primary mb-4">
        Erlebe die Magie von Märchenzauber
      </h2>
      <p class="text-text-secondary text-lg max-w-3xl mx-auto">
        Erschaffe einzigartige Geschichten, die dein Kind begeistern werden
      </p>
    </div>

    <!-- Feature Highlights -->
    <div class="grid md:grid-cols-3 gap-6 md:gap-8">
      <Card variant="hover" padding="lg">
        <div class="flex flex-col h-full text-center">
          <div class="text-5xl mb-4">✨</div>
          <h3 class="font-semibold text-xl text-text-primary mb-3">
            KI-generierte Geschichten
          </h3>
          <p class="text-text-secondary leading-relaxed">
            Jede Geschichte wird individuell für dein Kind erstellt - mit seinen Lieblingscharakteren und -themen.
          </p>
        </div>
      </Card>

      <Card variant="hover" padding="lg">
        <div class="flex flex-col h-full text-center">
          <div class="text-5xl mb-4">🎨</div>
          <h3 class="font-semibold text-xl text-text-primary mb-3">
            Wunderschöne Illustrationen
          </h3>
          <p class="text-text-secondary leading-relaxed">
            Hochwertige, KI-generierte Bilder im 3D-Pixar-Stil machen jede Geschichte zum visuellen Erlebnis.
          </p>
        </div>
      </Card>

      <Card variant="hover" padding="lg">
        <div class="flex flex-col h-full text-center">
          <div class="text-5xl mb-4">📱</div>
          <h3 class="font-semibold text-xl text-text-primary mb-3">
            Immer verfügbar
          </h3>
          <p class="text-text-secondary leading-relaxed">
            Greife von jedem Gerät auf deine Geschichten zu - perfekt für unterwegs oder die Gute-Nacht-Geschichte.
          </p>
        </div>
      </Card>
    </div>
  </div>
</section>