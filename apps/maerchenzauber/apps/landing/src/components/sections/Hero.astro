---
// Hero section for landing page
---

<section
	class="relative min-h-screen flex items-center justify-center overflow-hidden py-20 md:py-24"
>
	<!-- Background gradient overlay -->
	<div class="absolute inset-0 bg-gradient-overlay opacity-30"></div>

	<!-- Animated particles background -->
	<div class="absolute inset-0">
		<div class="particle particle-1"></div>
		<div class="particle particle-2"></div>
		<div class="particle particle-3"></div>
		<div class="particle particle-4"></div>
	</div>

	<div class="container-custom relative z-10">
		<div class="grid lg:grid-cols-2 gap-8 md:gap-12 lg:gap-16 items-center">
			<!-- Text Content -->
			<div class="text-center lg:text-left animate-fadeIn order-2 lg:order-1">
				<h1
					class="font-grandstander font-bold text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-text-primary mb-4 md:mb-6 leading-tight px-4 lg:px-0"
				>
					Wo jedes Kind zum
					<span class="text-gradient">Helden</span>
					seiner eigenen Geschichte wird
				</h1>

				<p
					class="text-text-secondary text-base sm:text-lg md:text-xl mb-6 md:mb-8 leading-relaxed px-4 lg:px-0 max-w-xl mx-auto lg:mx-0"
				>
					Erschaffe einzigartige Charaktere und erlebe magische Geschichten. Märchenzauber
					verwandelt deine Ideen in wunderschöne, personalisierte Kindergeschichten mit
					KI-generierten Illustrationen.
				</p>

				<!-- CTA Buttons -->
				<div
					class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center lg:justify-start px-4 lg:px-0"
				>
					<a
						href="/download"
						class="btn-primary inline-flex items-center justify-center gap-2 text-base sm:text-lg px-6 sm:px-8 py-3 sm:py-4 w-full sm:w-auto"
					>
						App herunterladen
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
						</svg>
					</a>

					<a
						href="#features"
						class="btn-secondary inline-flex items-center justify-center gap-2 text-base sm:text-lg px-6 sm:px-8 py-3 sm:py-4 w-full sm:w-auto"
					>
						Mehr erfahren
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
						</svg>
					</a>
				</div>
			</div>

			<!-- Hero Illustration -->
			<div class="relative animate-fadeIn order-1 lg:order-2">
				<div class="relative w-full h-[300px] sm:h-[400px] md:h-[500px] lg:h-[600px] mx-4 lg:mx-0">
					<!-- Login screen image -->
					<div class="absolute inset-0 flex items-center justify-center">
						<div class="w-full h-full rounded-2xl md:rounded-3xl overflow-hidden shadow-2xl">
							<img
								src="/marchenzauber-dadgirl.jpg"
								alt="Märchenzauber - Vater und Tochter lesen zusammen"
								class="w-full h-full object-cover animate-float"
							/>
						</div>
					</div>

					<!-- Decorative elements -->
					<div
						class="absolute -top-10 -right-10 w-32 h-32 bg-yellow-light/20 rounded-full blur-3xl"
					>
					</div>
					<div
						class="absolute -bottom-10 -left-10 w-40 h-40 bg-yellow-dark/20 rounded-full blur-3xl"
					>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Scroll indicator -->
	<div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
		<svg class="w-6 h-6 text-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			<path
				stroke-linecap="round"
				stroke-linejoin="round"
				stroke-width="2"
				d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
		</svg>
	</div>
</section>

<style>
	.particle {
		position: absolute;
		width: 4px;
		height: 4px;
		background: #f8d62b;
		border-radius: 50%;
		opacity: 0.5;
		animation: float-particle 20s infinite;
	}

	.particle-1 {
		top: 20%;
		left: 10%;
		animation-delay: 0s;
	}

	.particle-2 {
		top: 60%;
		left: 80%;
		animation-delay: 5s;
	}

	.particle-3 {
		top: 40%;
		left: 60%;
		animation-delay: 10s;
	}

	.particle-4 {
		top: 80%;
		left: 20%;
		animation-delay: 15s;
	}

	@keyframes float-particle {
		0%,
		100% {
			transform: translateY(0) translateX(0);
			opacity: 0;
		}
		10% {
			opacity: 0.5;
		}
		90% {
			opacity: 0.5;
		}
		100% {
			transform: translateY(-100vh) translateX(100px);
			opacity: 0;
		}
	}
</style>
