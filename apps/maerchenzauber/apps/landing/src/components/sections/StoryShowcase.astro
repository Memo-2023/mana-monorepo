---
// In the future, this will fetch from API
// For now, we show an empty state
const stories: any[] = [];
---

<section id="stories" class="section bg-bg-darker overflow-hidden pb-16 md:pb-20 lg:pb-24">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center mb-12 md:mb-16">
      <h2 class="font-grandstander font-bold text-3xl md:text-4xl lg:text-5xl text-text-primary mb-4">
        Entdecke magische Geschichten
      </h2>
      <p class="text-text-secondary text-lg max-w-3xl mx-auto">
        Lass dich von den Abenteuern anderer kleiner Helden inspirieren
      </p>
    </div>
  </div>

  <!-- Story Carousel Container -->
  <div class="relative">
    {stories.length > 0 ? (
      <>
        <!-- Gradient Overlays for edge fade effect -->
        <div class="absolute left-0 top-0 bottom-0 w-20 bg-gradient-to-r from-bg-darker to-transparent z-10 pointer-events-none"></div>
        <div class="absolute right-0 top-0 bottom-0 w-20 bg-gradient-to-l from-bg-darker to-transparent z-10 pointer-events-none"></div>

        <!-- Scrollable Container -->
        <div class="overflow-x-auto scrollbar-hide pb-4">
          <div class="flex gap-6 px-4 md:px-8 lg:px-16 min-w-max">
            {stories.map((story) => (
              <div class="flex-shrink-0 w-60 h-90">
                <div class="relative bg-bg-card rounded-lg overflow-hidden shadow-card hover:shadow-xl transition-all duration-300 h-80 group cursor-pointer">
                  {/* Image */}
                  <div class="relative h-full bg-bg-darker">
                    <img
                      src={story.image}
                      alt={story.title}
                      class="w-full h-full object-cover"
                    />

                    {/* Gradient Overlay */}
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>

                    {/* Content Overlay */}
                    <div class="absolute bottom-0 left-0 right-0 p-4">
                      <h3 class="font-grandstander font-bold text-lg text-white mb-1">
                        {story.title}
                      </h3>
                      <p class="text-text-light text-sm mb-2">
                        mit {story.character}
                      </p>
                      <p class="text-text-secondary text-xs line-clamp-2">
                        {story.excerpt}
                      </p>
                    </div>
                  </div>

                  {/* Play Button Overlay */}
                  <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/50">
                    <div class="w-16 h-16 bg-yellow-dark rounded-full flex items-center justify-center transform hover:scale-110 transition-transform">
                      <svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z" />
                      </svg>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </>
    ) : (
      <!-- Empty State: Beautiful placeholder with call to action -->
      <div class="max-w-4xl mx-auto px-4">
        <div class="bg-gradient-to-br from-bg-card to-bg-darker rounded-2xl p-12 md:p-16 text-center relative overflow-hidden">
          <!-- Decorative background elements -->
          <div class="absolute inset-0 opacity-10">
            <div class="absolute top-10 left-10 w-32 h-32 bg-yellow-light rounded-full blur-3xl"></div>
            <div class="absolute bottom-10 right-10 w-40 h-40 bg-blue-400 rounded-full blur-3xl"></div>
          </div>

          <!-- Content -->
          <div class="relative z-10">
            <!-- Icon -->
            <div class="mb-6 flex justify-center">
              <div class="w-24 h-24 bg-gradient-to-br from-yellow-light to-yellow-dark rounded-full flex items-center justify-center shadow-lg">
                <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                </svg>
              </div>
            </div>

            <!-- Title -->
            <h3 class="font-grandstander font-bold text-3xl md:text-4xl text-text-primary mb-4">
              Die ersten Geschichten entstehen gerade!
            </h3>

            <!-- Description -->
            <p class="text-text-secondary text-lg md:text-xl mb-8 max-w-2xl mx-auto leading-relaxed">
              Bald findest du hier magische Geschichten von anderen Kindern.
              <span class="text-yellow-light font-semibold">Sei einer der Ersten</span> und erstelle deine eigene Geschichte!
            </p>

            <!-- Call to Action Button -->
            <a href="#download" class="inline-flex items-center gap-3 bg-gradient-to-r from-yellow-light to-yellow-dark hover:from-yellow-dark hover:to-yellow-light text-white font-bold py-4 px-8 rounded-full text-lg transition-all duration-300 shadow-xl hover:shadow-2xl hover:scale-105">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
              </svg>
              Jetzt Geschichte erstellen
            </a>

            <!-- Additional info -->
            <div class="mt-8 flex items-center justify-center gap-2 text-text-secondary text-sm">
              <svg class="w-5 h-5 text-yellow-light" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span>Kostenlos starten • 10 Credits geschenkt • Keine Kreditkarte erforderlich</span>
            </div>
          </div>
        </div>
      </div>
    )}
  </div>

  <!-- Navigation Hint - Only show when there are stories -->
  {stories.length > 0 && (
    <div class="text-center mt-8">
      <p class="text-text-secondary text-sm flex items-center justify-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
        Wische für mehr Geschichten
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
      </p>
    </div>
  )}
</section>

<style>
  /* Hide scrollbar for Chrome, Safari and Opera */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  /* Hide scrollbar for IE, Edge and Firefox */
  .scrollbar-hide {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>