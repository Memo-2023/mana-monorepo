{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@storyteller/shared-types": ["./packages/shared-types/src"],
      "@storyteller/api-client": ["./packages/api-client/src"],
      "@storyteller/config": ["./packages/config/src"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".expo",
    "coverage",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}