---
import Layout from './Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import { getLangFromUrl, useTranslations } from '../utils/i18n';
import type { CollectionEntry } from 'astro:content';

interface Props {
  vision: CollectionEntry<'vision'>;
}

const { vision } = Astro.props;
const { data } = vision;
const lang = getLangFromUrl(Astro.url);

// Format date based on language
const formattedDate = new Intl.DateTimeFormat(lang === 'de' ? 'de-DE' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}).format(data.pubDate);

// Get translations
const t = useTranslations(lang);
const categoryKey = `vision.category.${data.category}` as const;
const statusKey = `vision.status.${data.status}` as const;
---

<Layout title={data.title} description={data.description}>
  <HeroSection
    title={data.title}
    description={data.description}
    image={data.image}
    imageAlt={data.title}
  >
    <div slot="content" class="status-badge" data-status={data.status}>
      {t(statusKey)}
    </div>
  </HeroSection>
  
<style>
  .status-badge {
    display: inline-block;
    padding: 0.4rem 1rem;
    border-radius: 2rem;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    color: white;
    margin-bottom: 1.5rem;
  }
  
  .status-badge[data-status="current"] {
    background-color: #10b981; /* Green */
  }
  
  .status-badge[data-status="planned"] {
    background-color: #6366f1; /* Purple */
  }
  
  .status-badge[data-status="exploring"] {
    background-color: #f59e0b; /* Amber */
  }
</style>
    
    <div class="meta-grid">
      <div class="meta-item">
        <div class="meta-label">{t(categoryKey)}</div>
        <div class="category-badge" data-category={data.category}>
          {t(categoryKey)}
        </div>
      </div>
      
      <div class="meta-item">
        <div class="meta-label">{t('vision.timeline')}</div>
        <div class="meta-value">{data.timeline}</div>
      </div>
      
      <div class="meta-item">
        <div class="meta-label">Date</div>
        <div class="meta-value">{formattedDate}</div>
      </div>
    </div>
  </div>
  
  <article class="vision-content">
    <slot />
  </article>
  
  <div class="related-links-section">
    {data.relatedLinks && data.relatedLinks.length > 0 && (
      <div class="related-links">
        <h2>{t('vision.relatedLinks')}</h2>
        <ul>
          {data.relatedLinks.map(link => (
            <li>
              <a href={link.url} target="_blank" rel="noopener noreferrer">{link.title}</a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
  
  {data.contributors && data.contributors.length > 0 && (
    <div class="contributors-section">
      <h2>{t('vision.contributors')}</h2>
      <div class="contributors-list">
        {data.contributors.map(contributor => (
          <div class="contributor-item">
            <div class="contributor-avatar">
              {contributor.charAt(0).toUpperCase()}
            </div>
            <div class="contributor-name">{contributor}</div>
          </div>
        ))}
      </div>
    </div>
  )}
</Layout>

<style>
  .vision-header {
    margin-top: 80px; /* More space for navigation */
    margin-bottom: 3rem;
    position: relative;
    padding-top: 1rem;
  }
  
  .status-badge {
    display: inline-block;
    padding: 0.4rem 1rem;
    border-radius: 2rem;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    color: white;
    margin-bottom: 1.5rem;
  }
  
  .status-badge[data-status="current"] {
    background-color: #10b981; /* Green */
  }
  
  .status-badge[data-status="planned"] {
    background-color: #6366f1; /* Purple */
  }
  
  .status-badge[data-status="exploring"] {
    background-color: #f59e0b; /* Amber */
  }
  
  h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }
  
  .description {
    font-size: 1.25rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    line-height: 1.6;
  }
  
  .meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  
  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .meta-label {
    font-size: 0.875rem;
    color: var(--text-muted);
    font-weight: 500;
  }
  
  .meta-value {
    font-size: 1.125rem;
  }
  
  .category-badge {
    display: inline-block;
    font-weight: 600;
    padding: 0.35rem 0.75rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
  }
  
  .category-badge[data-category="product"] {
    background-color: #dcfce7; /* Light green */
    color: #16a34a;
  }
  
  .category-badge[data-category="technology"] {
    background-color: #e0f2fe; /* Light blue */
    color: #0284c7;
  }
  
  .category-badge[data-category="community"] {
    background-color: #fef3c7; /* Light yellow */
    color: #b45309;
  }
  
  .category-badge[data-category="future"] {
    background-color: #ede9fe; /* Light purple */
    color: #7c3aed;
  }
  
  .featured-image {
    width: 100%;
    max-height: 500px;
    object-fit: cover;
    border-radius: 0.75rem;
    margin-bottom: 2rem;
  }
  
  .vision-content {
    line-height: 1.8;
    font-size: 1.125rem;
  }
  
  .vision-content :global(h2) {
    font-size: 1.75rem;
    margin: 2.5rem 0 1rem 0;
  }
  
  .vision-content :global(h3) {
    font-size: 1.5rem;
    margin: 2rem 0 1rem 0;
  }
  
  .vision-content :global(p) {
    margin: 1.5rem 0;
  }
  
  .vision-content :global(ul), 
  .vision-content :global(ol) {
    padding-left: 1.5rem;
    margin: 1.5rem 0;
  }
  
  .vision-content :global(li) {
    margin-bottom: 0.5rem;
  }
  
  .vision-content :global(blockquote) {
    border-left: 4px solid var(--accent-color);
    padding-left: 1rem;
    margin-left: 0;
    font-style: italic;
    color: var(--text-muted);
  }
  
  .related-links-section,
  .contributors-section {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
  }
  
  .related-links-section h2,
  .contributors-section h2 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }
  
  .related-links ul {
    list-style: none;
    padding: 0;
  }
  
  .related-links li {
    margin-bottom: 0.75rem;
  }
  
  .related-links a {
    display: inline-block;
    color: var(--accent-color);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s;
  }
  
  .related-links a:hover {
    text-decoration: underline;
  }
  
  .contributors-list {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .contributor-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  
  .contributor-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--accent-color);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
  }
  
  .contributor-name {
    font-size: 1rem;
    font-weight: 500;
  }
  
  @media (max-width: 768px) {
    .vision-header {
      margin-top: 20px; /* Less space on mobile */
      padding-top: 2rem;
    }
    
    h1 {
      font-size: 2rem;
      margin-top: 1rem;
    }
  }
</style>