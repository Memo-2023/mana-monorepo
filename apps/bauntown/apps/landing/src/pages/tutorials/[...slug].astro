---
import { getCollection } from 'astro:content';
import TutorialLayout from '../../layouts/TutorialLayout.astro';
import { defaultLang } from '../../i18n/ui';

export async function getStaticPaths() {
  const tutorials = await getCollection('tutorials', ({ id }) => {
    return id.startsWith('de/'); // Only default language (German)
  });
  
  return tutorials.map(tutorial => {
    // Get just the filename part from the slug
    const slugParts = tutorial.slug.split('/');
    const fileName = slugParts[slugParts.length - 1];
    
    return {
      params: { slug: fileName },
      props: { tutorial },
    };
  });
}

// In template logic - redirect to /de/tutorials/...
const { tutorial, slug } = Astro.props;
const redirectUrl = new URL(`/de/tutorials/${Astro.params.slug}`, Astro.url);
return Astro.redirect(redirectUrl.toString());

// This code won't execute due to the redirect
const { Content } = await tutorial.render();
---

<TutorialLayout tutorial={tutorial}>
  <Content />
</TutorialLayout>