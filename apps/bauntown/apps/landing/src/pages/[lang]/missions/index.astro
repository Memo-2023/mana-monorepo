---
import { languages } from '../../../i18n/ui';
import { getLangFromUrl, useTranslations } from '../../../utils/i18n';
import Layout from '../../../layouts/Layout.astro';
import MissionCard from '../../../components/MissionCard.astro';
import ContentSubmission from '../../../components/ContentSubmission.astro';
import Newsletter from '../../../components/Newsletter.astro';
import { getCollection } from 'astro:content';

// Define static paths for ALL supported languages
export function getStaticPaths() {
  return Object.keys(languages)
    .map(lang => ({ params: { lang } }));
}

// Get current language from URL
const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);

// Get missions in current language
const allMissions = await getCollection('missions', ({ id }) => {
  return id.startsWith(lang + '/');
});

// Sort by date with newest first
const sortedMissions = allMissions.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Group by difficulty
const difficulties = ['beginner', 'intermediate', 'advanced'] as const;
const missionsByDifficulty = difficulties.reduce((acc, difficulty) => {
  acc[difficulty] = sortedMissions.filter(mission => mission.data.difficulty === difficulty);
  return acc;
}, {} as Record<(typeof difficulties)[number], typeof sortedMissions>);

// Group by category
const categories = ['UI & UX', 'Business', 'Users', 'Branding', 'Marketing'] as const;
const missionsByCategory = categories.reduce((acc, category) => {
  acc[category] = sortedMissions.filter(mission => mission.data.category === category);
  return acc;
}, {} as Record<(typeof categories)[number], typeof sortedMissions>);

// Group by status (keep for backward compatibility)
const statuses = ['active', 'upcoming', 'completed'] as const;
const missionsByStatus = statuses.reduce((acc, status) => {
  acc[status] = sortedMissions.filter(mission => mission.data.status === status);
  return acc;
}, {} as Record<(typeof statuses)[number], typeof sortedMissions>);

// Get active missions
const activeMissions = missionsByStatus['active'];
---

<Layout title={`${t('nav.missions')} - BaunTown`}>
  <div class="hero-section">
    <div class="hero-text">
      <h1>{t('missions.headerDescription')}</h1>
    </div>
    <div class="hero-image">
      <img src="/images/bauntown-buildtogether.png" alt="Missions illustration" />
    </div>
  </div>
  
  <div class="sticky-wrapper">
    <header class="page-header">
      <div class="filter-container">
        <a href="#all" class="filter-btn active">
          {t('missions.filterAll')}
        </a>
        {categories.map(category => (
          <a href={`#${category.toLowerCase().replace(/\s+&\s+/g, '-')}`} class="filter-btn">
            {t(`missions.categories.${category}` as const)}
          </a>
        ))}
      </div>
    </header>
  </div>

  {activeMissions.length > 0 && (
    <section class="section">
      <div class="section-header">
        <h2>{t('missions.featured')}</h2>
      </div>
      <div class="grid">
        {activeMissions.filter(mission => mission.data.featured).map(mission => (
          <MissionCard mission={mission} />
        ))}
      </div>
    </section>
  )}

  {sortedMissions.length > 0 ? (
    <section id="all" class="section">
      <div class="section-header">
        <h2>{t('missions.allMissions')}</h2>
      </div>
      <div class="grid">
        {sortedMissions.map(mission => (
          <MissionCard mission={mission} />
        ))}
      </div>
    </section>
  ) : (
    <section id="coming-soon" class="section coming-soon-section">
      <div class="coming-soon-content">
        <h2>Missionen kommen bald!</h2>
        <p>Wir arbeiten gerade an spannenden Coding-Missionen für dich. Die ersten Missionen werden in Kürze veröffentlicht.</p>
        <p>Trage dich in unseren Newsletter ein, um benachrichtigt zu werden, sobald neue Missionen verfügbar sind.</p>
        
        <div class="newsletter-wrapper">
          <Newsletter 
            customTitle="Erhalte Updates zu neuen Missionen" 
            customDescription="Wir benachrichtigen dich, sobald neue Missionen verfügbar sind. Kein Spam, versprochen!" 
          />
        </div>
        
        <div class="mission-preview">
          <h3>Kommende Missionen umfassen:</h3>
          <ul>
            <li>
              <span class="mission-title">Vibecoding Generator</span>
              <span class="mission-desc">Entwickle einen Code-Generator, der auf Basis von Stimmungen ("Vibes") kreative Codevorschläge liefert.</span>
            </li>
            <li>
              <span class="mission-title">Astro Blog Builder</span>
              <span class="mission-desc">Erstelle einen Personal Blog mit Astro und lerne moderne Web-Entwicklung.</span>
            </li>
            <li>
              <span class="mission-title">KI-gestützte Web App</span>
              <span class="mission-desc">Baue eine Webanwendung, die KI-Modelle für kreative Inhalte nutzt.</span>
            </li>
          </ul>
        </div>
      </div>
    </section>
  )}

  {categories.map(category => 
    missionsByCategory[category].length > 0 && (
      <section id={category.toLowerCase().replace(/\s+&\s+/g, '-')} class="section">
        <div class="section-header">
          <h2>{t(`missions.categories.${category}` as const)}</h2>
        </div>
        <div class="grid">
          {missionsByCategory[category].map(mission => (
            <MissionCard mission={mission} />
          ))}
        </div>
      </section>
    )
  )}

  <section class="section submission-section">
    <div class="section-header">
      <h2>{t('join.addToPage')}</h2>
    </div>
    <div class="submission-container">
      <ContentSubmission defaultType="mission" showTitle={false} />
    </div>
  </section>
</Layout>

<style>
  .submission-section {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
  }
  
  .submission-container {
    max-width: 800px;
    margin: 0 auto;
  }
  .hero-section {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: 110px 0 2rem; /* Increased margin for fixed header */
    padding: 0.5rem 0 2rem;
    gap: 4rem;
  }
  
  .hero-text {
    flex: 1;
  }
  
  .hero-text h1 {
    font-size: 3.5rem;
    line-height: 1.2;
    font-weight: 700;
    margin-bottom: 1rem;
    background: linear-gradient(90deg, var(--accent-color), #fb923c);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-fill-color: transparent;
  }
  
  .hero-image {
    flex: 0 0 300px;
  }
  
  .hero-image img {
    width: 100%;
    height: 300px;
    object-fit: cover;
    border-radius: 1rem;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  }
  
  @media (max-width: 1024px) {
    .hero-section {
      gap: 2rem;
    }
    
    .hero-image {
      flex: 0 0 250px;
    }
    
    .hero-image img {
      height: 250px;
    }
  }
  
  @media (max-width: 768px) {
    .hero-section {
      flex-direction: column;
      margin: 40px 0 2rem; /* More space on mobile */
      gap: 2rem;
    }
    
    .hero-text {
      width: 100%;
    }
    
    .hero-text h1 {
      font-size: 2.5rem;
    }
    
    .hero-image {
      width: 100%;
      flex: 0 0 auto;
    }
    
    .hero-image img {
      width: 100%;
      height: auto;
      aspect-ratio: 1/1;
    }
  }
  
  .sticky-wrapper {
    position: relative;
    z-index: 900;
  }

  .page-header {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 0;
    margin: 0;
    position: -webkit-sticky;
    position: sticky;
    top: 64px; /* Exactly under the navbar */
    background-color: rgba(var(--background-color-rgb, 255, 255, 255), 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 10; /* Lower than the wrapper */
    border-bottom: 1px solid rgba(var(--border-color-rgb, 229, 231, 235), 0.5);
    transition: background-color 0.3s ease, border-color 0.3s ease;
    width: 100%;
    height: 60px; /* Fixed height */
  }
  
  .filter-container {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.5rem;
    padding-bottom: 0.5rem;
    overflow-x: auto;
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    justify-content: center;
    padding-left: 1rem;
    padding-right: 1rem;
  }
  
  @media (max-width: 1100px) {
    .filter-container {
      width: 100vw;
      margin-left: calc(-50vw + 50%);
      margin-right: calc(-50vw + 50%);
      padding-left: 0;
      padding-right: 0;
      justify-content: flex-start;
    }
    
    .filter-container::before,
    .filter-container::after {
      content: "";
      min-width: 16px;
    }
    
    .filter-btn:first-child {
      margin-left: 16px;
    }
    
    .filter-btn:last-child {
      margin-right: 16px;
    }
  }
  
  .filter-container::-webkit-scrollbar {
    height: 4px;
  }
  
  .filter-container::-webkit-scrollbar-track {
    background: rgba(var(--border-color-rgb), 0.1);
    border-radius: 4px;
  }
  
  .filter-container::-webkit-scrollbar-thumb {
    background: rgba(var(--accent-color-rgb), 0.6);
    border-radius: 4px;
  }
  
  .filter-btn {
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    background-color: var(--card-bg);
    color: var(--text-color);
    text-decoration: none;
    font-size: 0.875rem;
    transition: all 0.2s ease-in-out;
    border: 1px solid var(--border-color);
    white-space: nowrap;
  }
  
  .filter-btn:hover, .filter-btn.active {
    background-color: var(--accent-color);
    color: white;
    border-color: var(--accent-color);
  }
  
  .section {
    scroll-margin-top: 10rem;
    padding-top: 1rem;
    margin-top: 1rem;
  }
  
  /* Coming Soon Section Styles */
  .coming-soon-section {
    margin: 3rem auto;
    max-width: 900px;
    padding: 2rem;
  }
  
  .coming-soon-content {
    text-align: center;
    padding: 2rem;
    background-color: var(--card-bg);
    border-radius: 1rem;
    border: 1px solid var(--border-color);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
  }
  
  .coming-soon-content h2 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
  }
  
  .coming-soon-content p {
    font-size: 1.125rem;
    margin-bottom: 1.5rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .newsletter-wrapper {
    max-width: 600px;
    margin: 2.5rem auto;
  }
  
  .mission-preview {
    margin-top: 3rem;
    text-align: left;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .mission-preview h3 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    position: relative;
    display: inline-block;
  }
  
  .mission-preview h3::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: var(--accent-color);
    border-radius: 3px;
  }
  
  .mission-preview ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  
  .mission-preview li {
    padding: 1.25rem;
    border: 1px solid var(--border-color);
    border-radius: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: transform 0.2s, box-shadow 0.2s;
    background-color: rgba(var(--background-color-rgb), 0.7);
  }
  
  .mission-preview li:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 15px -3px rgba(0, 0, 0, 0.1);
  }
  
  .mission-title {
    font-weight: 600;
    font-size: 1.25rem;
    color: var(--accent-color);
  }
  
  .mission-desc {
    color: var(--text-muted);
    font-size: 1rem;
  }
  
  @media (max-width: 1024px) {
    .section {
      scroll-margin-top: 8rem; /* Adjusted for mobile view */
      padding-bottom: 6rem; /* Add space at bottom for mobile tab bar */
      margin-top: 2rem;
    }
    
    .coming-soon-content {
      padding: 1.5rem;
    }
    
    .coming-soon-content h2 {
      font-size: 2rem;
    }
    
    .mission-preview ul {
      gap: 1rem;
    }
    
    .mission-preview li {
      padding: 1rem;
    }
  }
  
  @media (max-width: 1024px) {
    .sticky-wrapper .page-header {
      top: 0; /* On mobile, stick to the top instead */
    }
  }

  @media (max-width: 768px) {
    .page-header {
      padding-bottom: 1rem;
    }
    
    .coming-soon-content {
      padding: 1rem;
    }
    
    .coming-soon-content h2 {
      font-size: 1.75rem;
    }
    
    .coming-soon-content p {
      font-size: 1rem;
    }
    
    .mission-title {
      font-size: 1.125rem;
    }
    
    .mission-desc {
      font-size: 0.875rem;
    }
  }
</style>

<script>
  // Handle filter button clicks
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.filter-btn');
    
    // Update active state based on hash
    function updateActiveButton() {
      const hash = window.location.hash || '#all';
      
      filterButtons.forEach(btn => {
        const href = btn.getAttribute('href');
        btn.classList.toggle('active', href === hash);
      });
    }
    
    // Initial update
    updateActiveButton();
    
    // Listen for hash changes
    window.addEventListener('hashchange', updateActiveButton);
  });
</script>