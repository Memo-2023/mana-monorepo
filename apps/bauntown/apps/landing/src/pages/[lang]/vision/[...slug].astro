---
import { getCollection } from 'astro:content';
import VisionLayout from '../../../layouts/VisionLayout.astro';
import { languages } from '../../../i18n/ui';

export const prerender = true;

export async function getStaticPaths() {
	const visionEntries = [];

	for (const lang of Object.keys(languages)) {
		const langVisions = await getCollection('vision', ({ id }) => {
			return id.startsWith(`${lang}/`);
		});

		for (const vision of langVisions) {
			// Get just the filename part from the slug
			const slugParts = vision.slug.split('/');
			const fileName = slugParts[slugParts.length - 1];

			visionEntries.push({
				params: {
					lang,
					slug: fileName,
				},
				props: { vision },
			});
		}
	}

	// Log generated paths for debugging
	console.log(
		'Generated Vision Paths:',
		visionEntries.map((entry) => `/${entry.params.lang}/vision/${entry.params.slug}`)
	);

	return visionEntries;
}

const { vision } = Astro.props;

// Sicherheitsabfrage für Vision
if (!vision) {
	return Astro.redirect('/404');
}

const { Content } = await vision.render();
---

<VisionLayout vision={vision}>
	<Content />
</VisionLayout>
