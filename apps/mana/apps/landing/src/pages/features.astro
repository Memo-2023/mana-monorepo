<Layout title="Mana Features - Was Mana besonders macht">
	<div class="page-wrapper">
		<section class="hero-section">
			<div class="hero-glow"></div>
			<div class="hero-content">
				<div class="hero-badge">12 Gründe für Mana</div>
				<h1 class="hero-title">
					Was Mana <span class="gradient-text">besonders macht</span>
				</h1>
				<p class="hero-subtitle" id="hero-subtitle-simple">
					Alle Vorteile auf einen Blick — ehrlich bewertet, verständlich erklärt.
				</p>
				<p class="hero-subtitle hidden" id="hero-subtitle-tech">
					Architektur, Stack und technische Entscheidungen — im Detail.
				</p>

				<div class="mode-toggle">
					<button class="toggle-btn active" id="btn-simple" type="button">
						<svg class="toggle-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
							></path>
						</svg>
						Für alle
					</button>
					<button class="toggle-btn" id="btn-tech" type="button">
						<svg class="toggle-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path
								stroke-linecap="round"
