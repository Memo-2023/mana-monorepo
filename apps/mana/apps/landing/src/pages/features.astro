<script>
	document.addEventListener('DOMContentLoaded', () => {
		const btnSimple = document.getElementById('btn-simple');
		const btnTech = document.getElementById('btn-tech');
		const viewSimple = document.getElementById('view-simple');
		const viewTech = document.getElementById('view-tech');
		const subtitleSimple = document.getElementById('hero-subtitle-simple');
		const subtitleTech = document.getElementById('hero-subtitle-tech');

		function setMode(mode: 'simple' | 'tech') {
			if (mode === 'simple') {
				btnSimple?.classList.add('active');
				btnTech?.classList.remove('active');
				viewSimple?.classList.remove('hidden');
				viewTech?.classList.add('hidden');
				subtitleSimple?.classList.remove('hidden');
				subtitleTech?.classList.add('hidden');
			} else {
				btnTech?.classList.add('active');
				btnSimple?.classList.remove('active');
				viewTech?.classList.remove('hidden');
				viewSimple?.classList.add('hidden');
				subtitleTech?.classList.remove('hidden');
				subtitleSimple?.classList.add('hidden');
			}
			localStorage.setItem('features-mode', mode);
		}

		btnSimple?.addEventListener('click', () => setMode('simple'));
		btnTech?.addEventListener('click', () => setMode('tech'));

		// Restore saved preference
		const saved = localStorage.getItem('features-mode');
		if (saved === 'tech') {
			setMode('tech');
		}
	});
</script>
