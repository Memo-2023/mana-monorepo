<script>
	document.addEventListener('DOMContentLoaded', () => {
		const toggleBtns = document.querySelectorAll('.toggle-btn');
		const monthlySection = document.getElementById('monthly-pricing');
		const yearlySection = document.getElementById('yearly-pricing');

		toggleBtns.forEach((btn) => {
			btn.addEventListener('click', () => {
				const type = btn.dataset.type;

				// Update active state
				toggleBtns.forEach((b) => b.classList.remove('active'));
				btn.classList.add('active');

				// Toggle sections
				if (type === 'monthly') {
					monthlySection?.classList.remove('hidden');
					yearlySection?.classList.add('hidden');
				} else {
					monthlySection?.classList.add('hidden');
					yearlySection?.classList.remove('hidden');
				}
			});
		});
	});
</script>
