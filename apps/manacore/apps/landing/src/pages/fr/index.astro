---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/navigation/Footer.astro';
import { getLangFromUrl, useTranslations } from '../../lib/i18n/config';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// App-Daten für den Scroller
const apps = [
	{
		name: 'Memoro',
		descriptionKey: 'app.memoro.description',
		logo: '/logos/Memoro-Logo-V1.png',
		categoryKey: 'app.category.productivity',
		color: 'from-blue-500 to-cyan-500',
		href: '/apps/memoro',
	},
	{
		name: 'Märchenzauber',
		descriptionKey: 'app.maerchenzauber.description',
		logo: '/logos/Märchenzauber-logo.png',
		categoryKey: 'app.category.creative',
		color: 'from-purple-500 to-pink-500',
		href: '/apps/maerchenzauber',
	},
	{
		name: 'Moodlit',
		descriptionKey: 'app.moodlit.description',
		logo: '🌙',
		categoryKey: 'app.category.wellness',
		color: 'from-indigo-500 to-purple-500',
		href: '/apps/moodlit',
	},
	{
		name: 'Zitare',
		descriptionKey: 'app.zitare.description',
		logo: '📚',
		categoryKey: 'app.category.research',
		color: 'from-emerald-500 to-teal-500',
		href: '/apps/zitare',
	},
	{
		name: 'Cards',
		descriptionKey: 'app.cards.description',
		logo: '⚪',
		categoryKey: 'app.category.productivity',
		color: 'from-blue-500 to-indigo-500',
		href: '/apps/cards',
	},
	{
		name: 'Pictus',
		descriptionKey: 'app.pictus.description',
		logo: '🎨',
		categoryKey: 'app.category.creative',
		color: 'from-pink-500 to-rose-500',
		href: '/apps/pictus',
	},
	{
		name: 'Orakel',
		descriptionKey: 'app.orakel.description',
		logo: '🔮',
		categoryKey: 'app.category.productivity',
		color: 'from-violet-500 to-purple-500',
		href: '/apps/orakel',
	},
	{
		name: 'Nutriphi',
		descriptionKey: 'app.nutriphi.description',
		logo: '🥗',
		categoryKey: 'app.category.wellness',
		color: 'from-green-500 to-emerald-500',
		href: '/apps/nutriphi',
	},
	{
		name: 'Traces',
		descriptionKey: 'app.traces.description',
		logo: '🗺️',
		categoryKey: 'app.category.wellness',
		color: 'from-amber-500 to-orange-500',
		href: '/apps/traces',
	},
];
---

<Layout title="Manacore - Intelligente KI-Plattform mit flexiblem Creditsystem">
	<!-- Hero Section -->
	<section class="hero">
		<div class="hero-overlay"></div>

		<div class="hero-content">
			<div class="hero-text">
				<h1 class="hero-title">
					{t('home.hero.title')}
					<span class="gradient-text">{t('home.hero.titleHighlight')}</span>
				</h1>

				<p class="hero-subtitle">
					{t('home.hero.subtitle')}
				</p>

				<div class="hero-cta">
					<a href="/start" class="btn-primary">
						{t('button.startFree')}
					</a>
					<a href="#mehr" class="btn-secondary">
						{t('button.learnMore')}
					</a>
				</div>
			</div>

			<div class="hero-image">
				<img
					src="/images/Mana_Landscape_Manacore_AI_Credits_16x9.jpg"
					alt={t('home.hero.imageAlt')}
					loading="eager"
				/>
			</div>
		</div>
	</section>

	<!-- App Scroller Section -->
	<section class="apps-section">
		<div class="apps-container">
			<div class="apps-header">
				<h2 class="apps-title">
					{t('home.apps.title')}
					<span class="gradient-text">{t('home.apps.titleHighlight')}</span>
				</h2>
				<p class="apps-subtitle">
					{t('home.apps.subtitle')}
				</p>
			</div>

			<div class="apps-scroller">
				<div class="apps-track">
					{
						apps.map((app) => (
							<a href={app.href} class="app-card">
								<div class="app-card-inner">
									<div class="app-icon-wrapper">
										<div class={`app-icon-bg bg-gradient-to-br ${app.color}`} />
										{app.logo.startsWith('/') ? (
											<img src={app.logo} alt={app.name} class="app-logo" />
										) : (
											<span class="app-emoji">{app.logo}</span>
										)}
									</div>

									<div class="app-content">
										<div class="app-category">{t(app.categoryKey)}</div>
										<h3 class="app-name">{app.name}</h3>
										<p class="app-description">{t(app.descriptionKey)}</p>
									</div>

									<div class="app-footer">
										<span class="app-button">
											{t('button.learnMore')}
											<svg class="app-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path
													stroke-linecap="round"
													stroke-linejoin="round"
													stroke-width="2"
													d="M9 5l7 7-7 7"
												/>
											</svg>
										</span>
									</div>
								</div>
							</a>
						))
					}
				</div>
			</div>

			<!-- Scroll Hint -->
			<div class="scroll-hint">
				<span>{t('home.apps.scrollHint')}</span>
				<svg class="scroll-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
				</svg>
			</div>
		</div>
	</section>

	<!-- Footer -->
	<Footer />
</Layout>

<style>
	.hero {
		position: relative;
		min-height: 100vh;
		width: 100%;
		display: grid;
		place-items: center;
		overflow: hidden;
		background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%);
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(circle at 20% 50%, rgba(59, 130, 246, 0.15) 0%, transparent 50%),
			radial-gradient(circle at 80% 50%, rgba(37, 99, 235, 0.1) 0%, transparent 50%);
		pointer-events: none;
	}

	.hero-content {
		position: relative;
		z-index: 10;
		display: grid;
		grid-template-columns: repeat(12, 1fr);
		gap: var(--grid-unit);
		max-width: 1400px;
		width: 100%;
		padding: 0 calc(var(--grid-unit) * 2);
		align-items: center;
	}

	.hero-text {
		grid-column: 1 / 7;
		display: flex;
		flex-direction: column;
		gap: calc(var(--grid-unit) * 0.75);
	}

	.hero-title {
		font-size: clamp(2.5rem, 5vw, 4rem);
		font-weight: 800;
		line-height: 1.1;
		color: #f8fafc;
		margin: 0;
		letter-spacing: -0.02em;
	}

	.gradient-text {
		background: linear-gradient(135deg, #3b82f6 0%, #2563eb 50%, #60a5fa 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		display: inline-block;
	}

	.hero-subtitle {
		font-size: clamp(1.125rem, 2vw, 1.375rem);
		line-height: 1.6;
		color: #cbd5e1;
		margin: 0;
		max-width: 540px;
	}

	.hero-cta {
		display: flex;
		gap: calc(var(--grid-unit) * 0.5);
		margin-top: calc(var(--grid-unit) * 0.5);
		flex-wrap: wrap;
	}

	.btn-primary,
	.btn-secondary {
		padding: 0 calc(var(--grid-unit) * 0.75);
		height: calc(var(--grid-unit) * 1.25);
		font-size: 1.125rem;
		font-weight: 600;
		border-radius: 12px;
		border: none;
		cursor: pointer;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		white-space: nowrap;
	}

	.btn-primary {
		background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
		color: white;
		box-shadow:
			0 4px 20px rgba(59, 130, 246, 0.4),
			0 0 0 0 rgba(59, 130, 246, 0.5);
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow:
			0 8px 30px rgba(59, 130, 246, 0.5),
			0 0 0 4px rgba(59, 130, 246, 0.2);
	}

	.btn-primary:active {
		transform: translateY(0);
	}

	.btn-secondary {
		background: rgba(248, 250, 252, 0.1);
		color: #f8fafc;
		border: 2px solid rgba(248, 250, 252, 0.2);
		backdrop-filter: blur(10px);
	}

	.btn-secondary:hover {
		background: rgba(248, 250, 252, 0.15);
		border-color: rgba(248, 250, 252, 0.3);
		transform: translateY(-2px);
	}

	.btn-secondary:active {
		transform: translateY(0);
	}

	.hero-image {
		grid-column: 7 / 13;
		position: relative;
		border-radius: 20px;
		overflow: hidden;
		box-shadow:
			0 25px 50px -12px rgba(0, 0, 0, 0.5),
			0 0 0 1px rgba(248, 250, 252, 0.1);
		transform: perspective(1000px) rotateY(-5deg);
		transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.hero-image:hover {
		transform: perspective(1000px) rotateY(0deg) scale(1.02);
	}

	.hero-image img {
		width: 100%;
		height: auto;
		display: block;
		object-fit: cover;
	}

	/* Large Tablet/Small Desktop Layout */
	@media (max-width: 1200px) {
		.hero-content {
			max-width: 1100px;
			gap: calc(var(--grid-unit) * 0.75);
		}

		.hero-text {
			grid-column: 1 / 6;
		}

		.hero-image {
			grid-column: 6 / 13;
		}
	}

	/* Tablet Layout */
	@media (max-width: 1024px) {
		.hero-content {
			grid-template-columns: 1fr;
			gap: calc(var(--grid-unit) * 2);
			padding: calc(var(--grid-unit) * 1.5);
		}

		.hero-text {
			grid-column: 1 / -1;
			text-align: center;
			align-items: center;
			order: 2;
		}

		.hero-title {
			font-size: clamp(2rem, 6vw, 3rem);
		}

		.hero-subtitle {
			max-width: 600px;
			font-size: clamp(1rem, 2.5vw, 1.25rem);
		}

		.hero-cta {
			justify-content: center;
			margin-top: calc(var(--grid-unit) * 0.75);
		}

		.hero-image {
			grid-column: 1 / -1;
			max-width: 650px;
			width: 100%;
			margin: 0 auto;
			order: 1;
			transform: perspective(1000px) rotateY(0deg);
		}
	}

	/* Small Tablet Layout */
	@media (max-width: 768px) {
		.hero {
			min-height: auto;
			padding: calc(var(--grid-unit) * 1.5) 0;
		}

		.hero-content {
			gap: calc(var(--grid-unit) * 1.5);
			padding: calc(var(--grid-unit) * 1);
		}

		.hero-text {
			gap: calc(var(--grid-unit) * 0.6);
		}

		.hero-title {
			font-size: clamp(1.75rem, 5.5vw, 2.5rem);
		}

		.hero-subtitle {
			font-size: clamp(0.95rem, 2.2vw, 1.125rem);
			max-width: 500px;
		}

		.hero-image {
			max-width: 550px;
			border-radius: 16px;
		}

		.btn-primary,
		.btn-secondary {
			height: calc(var(--grid-unit) * 1.15);
			font-size: 1.0625rem;
			padding: 0 calc(var(--grid-unit) * 0.6);
		}
	}

	/* Mobile Layout */
	@media (max-width: 640px) {
		.hero {
			min-height: auto;
			padding: calc(var(--grid-unit) * 1.25) 0;
		}

		.hero-content {
			padding: 0 calc(var(--grid-unit) * 0.6);
			gap: calc(var(--grid-unit) * 1.25);
		}

		.hero-text {
			gap: calc(var(--grid-unit) * 0.5);
		}

		.hero-title {
			font-size: 1.75rem;
			line-height: 1.15;
		}

		.hero-subtitle {
			font-size: 0.9375rem;
			line-height: 1.5;
			max-width: 100%;
		}

		.hero-cta {
			flex-direction: column;
			width: 100%;
			gap: calc(var(--grid-unit) * 0.35);
			margin-top: calc(var(--grid-unit) * 0.6);
		}

		.btn-primary,
		.btn-secondary {
			width: 100%;
			height: calc(var(--grid-unit) * 1.15);
			font-size: 1rem;
		}

		.hero-image {
			border-radius: 12px;
			max-width: 100%;
		}
	}

	/* Extra Small Mobile */
	@media (max-width: 400px) {
		.hero {
			padding: calc(var(--grid-unit) * 1) 0;
		}

		.hero-content {
			padding: 0 calc(var(--grid-unit) * 0.5);
			gap: var(--grid-unit);
		}

		.hero-title {
			font-size: 1.5rem;
		}

		.hero-subtitle {
			font-size: 0.875rem;
		}

		.btn-primary,
		.btn-secondary {
			height: var(--grid-unit);
			font-size: 0.9375rem;
		}
	}

	/* Animation für Page Load */
	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.hero-text > * {
		animation: fadeInUp 0.8s cubic-bezier(0.4, 0, 0.2, 1) backwards;
	}

	.hero-title {
		animation-delay: 0.1s;
	}

	.hero-subtitle {
		animation-delay: 0.2s;
	}

	.hero-cta {
		animation-delay: 0.3s;
	}

	.hero-image {
		animation: fadeInUp 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.4s backwards;
	}

	/* ========================
     APP SCROLLER SECTION
     ======================== */

	.apps-section {
		position: relative;
		background: linear-gradient(180deg, #0f172a 0%, #1e293b 100%);
		padding: calc(var(--grid-unit) * 3) 0;
		overflow: hidden;
	}

	.apps-container {
		max-width: 100%;
		margin: 0 auto;
	}

	.apps-header {
		text-align: center;
		margin-bottom: calc(var(--grid-unit) * 2);
		padding: 0 calc(var(--grid-unit) * 2);
	}

	.apps-title {
		font-size: clamp(2rem, 4vw, 2.75rem);
		font-weight: 800;
		color: #f8fafc;
		margin: 0 0 calc(var(--grid-unit) * 0.5) 0;
		line-height: 1.2;
	}

	.apps-subtitle {
		font-size: clamp(1rem, 2vw, 1.25rem);
		color: #cbd5e1;
		margin: 0;
		max-width: 700px;
		margin-left: auto;
		margin-right: auto;
	}

	.apps-scroller {
		position: relative;
		padding: calc(var(--grid-unit) * 0.5) calc(var(--grid-unit) * 2);
		overflow-x: auto;
		overflow-y: hidden;
		scroll-behavior: smooth;
		-webkit-overflow-scrolling: touch;
		scrollbar-width: thin;
		scrollbar-color: rgba(59, 130, 246, 0.3) rgba(30, 41, 59, 0.3);
	}

	.apps-scroller::-webkit-scrollbar {
		height: 8px;
	}

	.apps-scroller::-webkit-scrollbar-track {
		background: rgba(30, 41, 59, 0.3);
		border-radius: 4px;
	}

	.apps-scroller::-webkit-scrollbar-thumb {
		background: rgba(59, 130, 246, 0.5);
		border-radius: 4px;
		transition: background 0.3s ease;
	}

	.apps-scroller::-webkit-scrollbar-thumb:hover {
		background: rgba(59, 130, 246, 0.7);
	}

	.apps-track {
		display: flex;
		gap: calc(var(--grid-unit) * 0.75);
		padding-bottom: calc(var(--grid-unit) * 0.5);
	}

	.app-card {
		flex: 0 0 auto;
		width: 320px;
		height: 380px;
		text-decoration: none;
		display: block;
		cursor: pointer;
	}

	.app-card-inner {
		height: 100%;
		background: linear-gradient(135deg, rgba(30, 41, 59, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%);
		border: 1px solid rgba(248, 250, 252, 0.1);
		border-radius: 20px;
		padding: calc(var(--grid-unit) * 0.75);
		display: flex;
		flex-direction: column;
		gap: calc(var(--grid-unit) * 0.5);
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		backdrop-filter: blur(10px);
		position: relative;
		overflow: hidden;
	}

	.app-card-inner::before {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, transparent 0%, rgba(59, 130, 246, 0.05) 100%);
		opacity: 0;
		transition: opacity 0.4s ease;
		pointer-events: none;
	}

	.app-card:hover .app-card-inner {
		transform: translateY(-8px);
		border-color: rgba(59, 130, 246, 0.3);
		box-shadow:
			0 20px 40px -15px rgba(0, 0, 0, 0.5),
			0 0 0 1px rgba(59, 130, 246, 0.2);
	}

	.app-card:hover .app-card-inner::before {
		opacity: 1;
	}

	.app-icon-wrapper {
		position: relative;
		width: 80px;
		height: 80px;
		margin-bottom: calc(var(--grid-unit) * 0.25);
	}

	.app-icon-bg {
		position: absolute;
		inset: 0;
		border-radius: 18px;
		opacity: 0.15;
		transition: all 0.4s ease;
	}

	.app-card:hover .app-icon-bg {
		opacity: 0.25;
		transform: scale(1.1);
	}

	.app-logo {
		position: relative;
		width: 100%;
		height: 100%;
		object-fit: contain;
		padding: 12px;
		z-index: 1;
	}

	.app-emoji {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		height: 100%;
		font-size: 3rem;
		z-index: 1;
	}

	.app-content {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: calc(var(--grid-unit) * 0.25);
	}

	.app-category {
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #3b82f6;
		margin-bottom: calc(var(--grid-unit) * 0.125);
	}

	.app-name {
		font-size: 1.5rem;
		font-weight: 700;
		color: #f8fafc;
		margin: 0;
		line-height: 1.3;
	}

	.app-description {
		font-size: 0.9375rem;
		line-height: 1.5;
		color: #cbd5e1;
		margin: 0;
	}

	.app-footer {
		padding-top: calc(var(--grid-unit) * 0.25);
	}

	.app-button {
		width: 100%;
		padding: 0;
		height: auto;
		font-size: 0.875rem;
		font-weight: 500;
		color: #94a3b8;
		background: transparent;
		border: none;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		display: flex;
		align-items: center;
		justify-content: flex-start;
		gap: calc(var(--grid-unit) * 0.15);
		pointer-events: none;
	}

	.app-card:hover .app-button {
		color: #cbd5e1;
	}

	.app-arrow {
		width: 14px;
		height: 14px;
		transition: transform 0.3s ease;
	}

	.app-card:hover .app-arrow {
		transform: translateX(3px);
	}

	.scroll-hint {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: calc(var(--grid-unit) * 0.25);
		margin-top: calc(var(--grid-unit) * 1.5);
		padding: 0 calc(var(--grid-unit) * 2);
		font-size: 0.875rem;
		color: #94a3b8;
		animation: pulse 2s ease-in-out infinite;
	}

	.scroll-arrow {
		width: 20px;
		height: 20px;
	}

	@keyframes pulse {
		0%,
		100% {
			opacity: 0.5;
		}
		50% {
			opacity: 1;
		}
	}

	/* Responsive App Scroller */
	@media (max-width: 1024px) {
		.apps-section {
			padding: calc(var(--grid-unit) * 2.5) 0;
		}

		.app-card {
			width: 300px;
			height: 360px;
		}
	}

	@media (max-width: 768px) {
		.apps-section {
			padding: calc(var(--grid-unit) * 2) 0;
		}

		.apps-header {
			margin-bottom: calc(var(--grid-unit) * 1.5);
			padding: 0 calc(var(--grid-unit) * 1);
		}

		.app-card {
			width: 280px;
			height: 350px;
		}

		.apps-scroller {
			padding: calc(var(--grid-unit) * 0.5) calc(var(--grid-unit) * 1);
		}

		.scroll-hint {
			padding: 0 calc(var(--grid-unit) * 1);
		}
	}

	@media (max-width: 640px) {
		.apps-section {
			padding: calc(var(--grid-unit) * 1.5) 0;
		}

		.apps-header {
