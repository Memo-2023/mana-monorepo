		"@mana/shared-theme": "workspace:*",
		"@mana/shared-theme-ui": "workspace:*",
		"@mana/shared-types": "workspace:*",
		"@mana/shared-ui": "workspace:*",
		"@mana/shared-utils": "workspace:*",
		"@manavoxel/shared": "workspace:*",
