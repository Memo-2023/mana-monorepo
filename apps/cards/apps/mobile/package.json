		"@react-native-segmented-control/segmented-control": "2.5.7",
		"@react-navigation/native": "^7.0.3",
		"base64-js": "^1.5.1",
		"class-variance-authority": "^0.7.1",
		"expo": "~55.0.5",
		"expo-blur": "~15.0.7",
		"expo-build-properties": "~1.0.9",
