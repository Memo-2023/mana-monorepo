{
	"name": "@todo/server",
	"version": "0.1.0",
	"private": true,
	"description": "Todo server-side compute (Hono + Bun) — RRULE, reminders, admin",
	"type": "module",
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"start": "bun run src/index.ts",
		"type-check": "bun x tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@manacore/shared-hono": "workspace:*",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.7.0",
		"postgres": "^3.4.5",
		"rrule": "^2.8.1",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"@types/bun": "^1.2.0",
		"typescript": "^5.9.3",
		"vitest": "^3.0.0"
	}
}
