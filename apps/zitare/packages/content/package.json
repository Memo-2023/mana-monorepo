{
	"name": "@zitare/content",
	"version": "0.2.0",
	"description": "Static quote content for Zitare",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"build": "tsup",
		"type-check": "tsc --noEmit"
	},
	"devDependencies": {
		"tsup": "^8.0.0",
		"typescript": "^5.3.0"
	}
}
