		"@tailwindcss/vite": "^4.1.7",
		"@types/node": "^22.15.21",
		"@vite-pwa/sveltekit": "^1.1.0",
		"prettier": "^3.5.3",
		"prettier-plugin-svelte": "^3.4.0",
		"sharp": "^0.33.5",
		"svelte": "^5.41.0",
		"svelte-check": "^4.3.3",
		"tailwindcss": "^4.1.7",
