---
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import Umami from '../components/Umami.astro';
import UmamiTracking from '../components/UmamiTracking.astro';
import BaseHead from '../components/BaseHead.astro';
import MemoroOrganization from '../components/MemoroOrganization.astro';
import MemoroSoftwareApp from '../components/MemoroSoftwareApp.astro';
import { ui } from '../i18n/ui';
import '../styles/base.css';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: 'website' | 'article' | 'profile';
	lang?: 'de' | 'en';
	noindex?: boolean;
}

// Get language from URL
const pathname = Astro.url.pathname;
const segments = pathname.split('/').filter(Boolean);
const lang = segments[0] === 'en' || segments[0] === 'de' ? (segments[0] as 'de' | 'en') : 'de';

// Get page key from URL to determine SEO content
const pageKey = segments[1] || 'home';
const seoTitleKey = `seo.${pageKey}.title`;
const seoDescKey = `seo.${pageKey}.description`;

const {
	title = ui[lang][seoTitleKey] || 'Memoro',
	description = ui[lang][seoDescKey] || 'Memoro - KI-gestützte Gesprächsdokumentation',
	image,
	type = 'website',
	noindex = false,
} = Astro.props;
---

<!doctype html>
<html lang={lang} class="bg-background-global scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<BaseHead
			title={title}
			description={description}
			image={image}
			type={type}
			lang={lang}
			noindex={noindex}
		/>
		<Umami />
		<UmamiTracking />
		{/* Structured Data for Organization and SoftwareApp */}
		{
			pageKey === 'home' && (
				<>
					<MemoroOrganization lang={lang} />
					<MemoroSoftwareApp lang={lang} />
				</>
			)
		}
	</head>
	<body class="min-h-screen bg-background-global text-white">
		<Nav />
		<div class="w-full max-w-full overflow-x-hidden">
			<slot />
			<Footer />
		</div>
	</body>
</html>
