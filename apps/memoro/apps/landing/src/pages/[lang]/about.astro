---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/utils';

export async function getStaticPaths() {
	return ['de', 'en'].map((lang) => ({
		params: { lang },
		props: { lang },
	}));
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const aboutPage = await getEntry('pages', `${lang}/about`);
if (!aboutPage) throw new Error(`About page content not found for language: ${lang}`);
const { Content } = await aboutPage.render();
---

<Layout title={aboutPage.data.title}>
	<main class="bg-background-page">
		<div class="max-w-4xl mx-auto px-4 py-12">
			<article
				class="prose prose-lg max-w-none dark:prose-invert
        prose-h1:text-3xl prose-h1:font-bold
        prose-h2:text-2xl prose-h2:font-semibold
        prose-h3:text-xl prose-h3:font-semibold
        prose-headings:text-text-primary
        prose-p:text-text-secondary
        prose-a:text-primary-DEFAULT hover:prose-a:text-primary-hover
        prose-strong:text-text-primary
        prose-code:text-primary-DEFAULT
        prose-pre:bg-background-cardHover prose-pre:border prose-pre:border-border
        prose-blockquote:border-primary-DEFAULT prose-blockquote:bg-background-cardHover prose-blockquote:text-text-secondary
        prose-li:text-text-secondary"
			>
				<Content />
			</article>
		</div>
	</main>
</Layout>
