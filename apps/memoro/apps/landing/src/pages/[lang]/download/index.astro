---
import Layout from '../../../layouts/Layout.astro';
import { useTranslations } from '../../../i18n/utils';
import Button from '../../../components/atoms/Button.astro';
import { Icon } from 'astro-icon/components';

export async function getStaticPaths() {
	return ['de', 'en'].map((lang) => ({
		params: { lang },
		props: { lang },
	}));
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const pageTitle = lang === 'de' ? 'Memoro App herunterladen' : 'Download Memoro App';
const pageDescription =
	lang === 'de'
		? 'Laden Sie Memoro für iOS und Android herunter und erleben Sie die Zukunft der Gesprächsdokumentation.'
		: 'Download Memoro for iOS and Android and experience the future of conversation documentation.';
---

<Layout title={pageTitle} description={pageDescription}>
	<main class="min-h-screen bg-background-page">
		<!-- Hero Section -->
		<section class="max-w-7xl mx-auto px-4 py-16 md:py-24">
			<div class="text-center mb-16">
				<img src="/images/brand/logo.svg" alt="Memoro Logo" class="h-20 w-20 mx-auto mb-8" />
				<h1 class="text-5xl md:text-6xl font-bold text-text-primary mb-6">{pageTitle}</h1>
			</div>

			<!-- Download buttons section -->
			<div class="max-w-4xl mx-auto grid gap-8 md:grid-cols-2">
				<!-- iOS App Store -->
				<div
					class="bg-gradient-to-br from-background-card to-background-cardHover rounded-2xl border border-border p-8 hover:shadow-2xl transition-all duration-300 hover:scale-[1.02]"
				>
					<div class="flex flex-col items-center text-center">
						<div class="w-24 h-24 bg-primary/10 rounded-2xl flex items-center justify-center mb-6">
							<svg class="w-14 h-14 text-primary" viewBox="0 0 24 24" fill="currentColor">
								<path
									d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
								></path>
							</svg>
						</div>
						<h2 class="text-2xl font-bold text-text-primary mb-3">
							{lang === 'de' ? 'Für iPhone & iPad' : 'For iPhone & iPad'}
						</h2>
						<p class="text-text-secondary mb-8 text-lg">
							{
								lang === 'de'
									? 'Optimiert für iOS 15 und höher. Nutzen Sie alle Features auf Ihrem Apple-Gerät.'
									: 'Optimized for iOS 15 and higher. Use all features on your Apple device.'
							}
						</p>
						{/* TODO: App Store Badge hier später einfügen wenn Bilder verfügbar sind */}
						<Button
							href="https://apps.apple.com/de/app/memoro/id6451258411"
							target="_blank"
							rel="noopener noreferrer"
							variant="primary"
							size="lg"
							class="!px-8"
							data-download-platform="ios"
						>
							<Icon name="mdi:apple" class="w-6 h-6 mr-2" />
							{lang === 'de' ? 'Im App Store laden' : 'Download on App Store'}
						</Button>
					</div>
				</div>

				<!-- Google Play Store -->
				<div
					class="bg-gradient-to-br from-background-card to-background-cardHover rounded-2xl border border-border p-8 hover:shadow-2xl transition-all duration-300 hover:scale-[1.02]"
				>
					<div class="flex flex-col items-center text-center">
						<div class="w-24 h-24 bg-primary/10 rounded-2xl flex items-center justify-center mb-6">
							<svg class="w-14 h-14 text-primary" viewBox="0 0 24 24" fill="currentColor">
								<path
									d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.6 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"
								></path>
							</svg>
						</div>
						<h2 class="text-2xl font-bold text-text-primary mb-3">
							{lang === 'de' ? 'Für Android' : 'For Android'}
						</h2>
						<p class="text-text-secondary mb-8 text-lg">
							{
								lang === 'de'
									? 'Kompatibel mit Android 8.0 und höher. Perfekt für alle Android-Geräte.'
									: 'Compatible with Android 8.0 and higher. Perfect for all Android devices.'
							}
						</p>
						{/* TODO: Google Play Badge hier später einfügen wenn Bilder verfügbar sind */}
						<Button
							href="https://play.google.com/store/apps/details?id=com.memo.beta"
							target="_blank"
							rel="noopener noreferrer"
							variant="primary"
							size="lg"
							class="!px-8"
							data-download-platform="android"
						>
							<Icon name="mdi:google-play" class="w-6 h-6 mr-2" />
							{lang === 'de' ? 'Bei Google Play laden' : 'Get it on Google Play'}
						</Button>
					</div>
				</div>
			</div>

			<!-- Web App Section -->
			<div class="max-w-2xl mx-auto mt-12">
				<div
					class="bg-gradient-to-br from-background-card to-background-cardHover rounded-2xl border border-border p-8 hover:shadow-2xl transition-all duration-300 hover:scale-[1.02]"
				>
					<div class="flex flex-col items-center text-center">
						<div class="w-24 h-24 bg-primary/10 rounded-2xl flex items-center justify-center mb-6">
							<svg
								class="w-14 h-14 text-primary"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"
								></path>
							</svg>
						</div>
						<h2 class="text-2xl font-bold text-text-primary mb-3">
							{lang === 'de' ? 'Web App' : 'Web App'}
						</h2>
						<p class="text-text-secondary mb-8 text-lg">
							{
								lang === 'de'
									? 'Nutzen Sie Memoro direkt im Browser. Keine Installation erforderlich.'
									: 'Use Memoro directly in your browser. No installation required.'
							}
						</p>
						<Button
							href="https://web.memoro.ai"
							target="_blank"
							rel="noopener noreferrer"
							variant="primary"
							size="lg"
							class="!px-8"
							data-download-platform="web"
						>
							<Icon name="mdi:login" class="w-6 h-6 mr-2" />
							{lang === 'de' ? 'Web App öffnen' : 'Open Web App'}
						</Button>
					</div>
				</div>
			</div>

			<!-- Features Section -->
			<div class="mt-20 text-center">
				<h3 class="text-2xl font-semibold text-text-primary mb-8">
					{lang === 'de' ? 'Was Sie erwartet' : 'What to expect'}
				</h3>
				<div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
					<div class="text-center">
						<div
							class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4"
						>
							<Icon name="mdi:microphone" class="w-8 h-8 text-primary" />
						</div>
						<h4 class="font-semibold text-text-primary mb-2">
							{lang === 'de' ? 'KI-Transkription' : 'AI Transcription'}
						</h4>
						<p class="text-text-secondary text-sm">
							{
								lang === 'de'
									? 'Automatische Umwandlung von Gesprächen in Text'
									: 'Automatic conversion of conversations to text'
							}
						</p>
					</div>
					<div class="text-center">
						<div
							class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4"
						>
							<Icon name="mdi:file-document-outline" class="w-8 h-8 text-primary" />
						</div>
						<h4 class="font-semibold text-text-primary mb-2">
							{lang === 'de' ? 'Smart Summaries' : 'Smart Summaries'}
						</h4>
						<p class="text-text-secondary text-sm">
							{
								lang === 'de'
									? 'Intelligente Zusammenfassungen Ihrer Gespräche'
									: 'Intelligent summaries of your conversations'
							}
						</p>
					</div>
					<div class="text-center">
						<div
							class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4"
						>
							<Icon name="mdi:shield-check" class="w-8 h-8 text-primary" />
						</div>
						<h4 class="font-semibold text-text-primary mb-2">
							{lang === 'de' ? 'Datenschutz' : 'Privacy'}
						</h4>
						<p class="text-text-secondary text-sm">
							{
								lang === 'de'
									? 'Ihre Daten sind sicher und verschlüsselt'
									: 'Your data is safe and encrypted'
							}
						</p>
					</div>
				</div>
			</div>

			<!-- Help Section -->
			<div class="mt-20 text-center bg-background-card rounded-2xl p-8 max-w-2xl mx-auto">
				<Icon name="mdi:help-circle-outline" class="w-12 h-12 text-primary mx-auto mb-4" />
				<p class="text-text-secondary text-lg mb-6">
					{
						lang === 'de'
							? 'Benötigen Sie Hilfe bei der Installation oder haben Fragen zur App?'
							: 'Need help with installation or have questions about the app?'
					}
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<Button href={`/${lang}/guides`} variant="primary" size="md">
						<Icon name="mdi:book-open-variant" class="w-5 h-5 mr-2" />
						{lang === 'de' ? 'Anleitungen' : 'Guides'}
					</Button>
					<Button href={`/${lang}/contact`} variant="outline" size="md">
						<Icon name="mdi:email-outline" class="w-5 h-5 mr-2" />
						{lang === 'de' ? 'Kontakt' : 'Contact'}
					</Button>
				</div>
			</div>
		</section>
	</main>
</Layout>

<script>
	import { getExperiment, trackEvent } from '../../../utils/experiments';

	// Track page view
	document.addEventListener('DOMContentLoaded', () => {
		trackEvent('download_page_viewed', {
			lang: document.documentElement.lang,
		});
	});

	// Track download button clicks
	document.addEventListener('click', async (e) => {
		const target = e.target as HTMLElement;
		const button = target.closest('[data-download-platform]') as HTMLElement;

		if (button) {
			const platform = button.dataset.downloadPlatform;

			// Get current experiment variant if user came from homepage
			const heroVariant = await getExperiment('hero-cta-test');

			// Track download click in PostHog
			trackEvent('download_button_clicked', {
				platform: platform,
				source: 'download_page',
				lang: document.documentElement.lang,
				hero_experiment_variant: heroVariant || 'none',
				is_beta: platform?.includes('beta') || false,
			});

			// Track as Plausible Goal
			if (window.plausible) {
				// Define specific goal names for each button
				let goalName = '';
				switch (platform) {
					case 'ios-beta':
						goalName = 'Download iOS Beta';
						break;
					case 'android-beta':
						goalName = 'Download Android Beta';
						break;
					case 'ios':
						goalName = 'Download iOS';
						break;
					case 'android':
						goalName = 'Download Android';
						break;
				}

				if (goalName) {
					window.plausible(goalName, {
						props: {
							platform: platform,
							source: 'download_page',
							lang: document.documentElement.lang,
						},
					});
				}
			}

			// Track as experiment conversion if user is in A/B test
			if (heroVariant) {
				trackEvent('experiment_conversion', {
					experiment: 'hero-cta-test',
					variant: heroVariant,
					conversion_type: 'download_click',
					platform: platform,
				});
			}
		}
	});
</script>
