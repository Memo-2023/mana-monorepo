---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import DetailLayout from '../../../components/layouts/DetailLayout.astro';
import AuthorInfo from '../../../components/detail/AuthorInfo.astro';
import TagsList from '../../../components/detail/TagsList.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import ArticleNavigation from '../../../components/ArticleNavigation.astro';
import StructuredData from '../../../components/StructuredData.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => !data.draft);

	// Create routes for all blog posts in all languages
	return posts.map((post) => ({
		params: {
			lang: post.data.lang,
			slug: post.slug,
		},
		props: { post },
	}));
}

const { post } = Astro.props;
const { lang } = Astro.params;
const t = useTranslations(lang);

// No need to check for language mismatch anymore, as we only generate
// pages for the proper language/slug combinations

// Holen aller Blog-Artikel in der gleichen Sprache
const allPosts = await getCollection('blog', (post) => post.data.lang === lang && !post.data.draft);

// Sortieren der Artikel nach Datum (neueste zuerst)
const sortedPosts = allPosts.sort((a, b) => {
	return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
});

// Finden des aktuellen Index
const currentIndex = sortedPosts.findIndex((p) => p.id === post.id);

// Bestimmen des vorherigen und nächsten Artikels
const prevArticle =
	currentIndex < sortedPosts.length - 1
		? {
				slug: sortedPosts[currentIndex + 1].slug,
				title: sortedPosts[currentIndex + 1].data.title,
				lang: sortedPosts[currentIndex + 1].data.lang,
				collection: 'blog',
			}
		: null;

const nextArticle =
	currentIndex > 0
		? {
				slug: sortedPosts[currentIndex - 1].slug,
				title: sortedPosts[currentIndex - 1].data.title,
				lang: sortedPosts[currentIndex - 1].data.lang,
				collection: 'blog',
			}
		: null;

const { Content } = await post.render();

// Article structured data
const articleData = {
	headline: post.data.title,
	description: post.data.description,
	author: {
		'@type': 'Person',
		name: post.data.author,
		url: `https://memoro.ai/${lang}/team/${post.data.author.toLowerCase().replace(' ', '-')}`,
	},
	datePublished: post.data.pubDate.toISOString(),
	dateModified: post.data.lastUpdated
		? post.data.lastUpdated.toISOString()
		: post.data.pubDate.toISOString(),
	image: post.data.image
		? `https://memoro.ai${post.data.image}`
		: `https://memoro.ai/images/og-default.jpg`,
	publisher: {
		'@type': 'Organization',
		name: 'Memoro',
		logo: {
			'@type': 'ImageObject',
			url: 'https://memoro.ai/images/brand/memoro-logo.png',
		},
	},
	url: `https://memoro.ai/${lang}/blog/${post.slug}`,
	inLanguage: lang === 'de' ? 'de-DE' : 'en-US',
	keywords: post.data.tags || [],
};
---

<Layout
	title={post.data.title}
	description={post.data.description}
	type="article"
	lang={lang}
	publishDate={post.data.pubDate}
	author={post.data.author}
>
	<StructuredData type="Article" data={articleData} />
	<DetailLayout
		title={post.data.title}
		backLink={{
			href: `/${lang}/blog`,
		}}
	>
		<Fragment slot="header">
			<header class="mb-8">
				{
					post.data.image && (
						<img
							src={post.data.image}
							alt={post.data.title}
							class="w-full h-64 sm:h-80 md:h-96 object-cover rounded-lg mb-8"
						/>
					)
				}
				<h1 class="text-3xl font-bold text-text-primary mb-4">{post.data.title}</h1>
				<AuthorInfo author={post.data.author} date={post.data.pubDate} lang={lang} />
			</header>
		</Fragment>

		<Content />

		<Fragment slot="after-content">
			<TagsList tags={post.data.tags} linkBase={`/${lang}/blog`} />
		</Fragment>

		<Fragment slot="footer">
			{/* Navigation zu vorherigen/nächsten Artikeln */}
			<ArticleNavigation
				prevArticle={prevArticle}
				nextArticle={nextArticle}
				lang={lang}
				collection="blog"
			/>
		</Fragment>
	</DetailLayout>
</Layout>
