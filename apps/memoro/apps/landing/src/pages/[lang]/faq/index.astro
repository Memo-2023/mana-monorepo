---
import { getCollection, getEntry } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import FAQSection from "../../../components/FAQSection.astro";
import CallToAction from "../../../components/CallToAction.astro";
import FilterPills from "../../../components/FilterPills.astro";
import EmptyState from "../../../components/EmptyState.astro";
import { useTranslations } from "../../../i18n/utils";

export async function getStaticPaths() {
  return ['de', 'en'].map(lang => ({
    params: { lang },
    props: { lang }
  }));
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Get category from URL query parameter
const url = Astro.url;
const categoryParam = url.searchParams.get('category');

// Try to get the FAQ page metadata (if it exists)
let pageData = null;
let frontmatter = null;
try {
  const page = await getEntry("pages", `${lang}/faq`);
  if (page) {
    pageData = page.data;
    const rendered = await page.render();
    frontmatter = rendered.frontmatter;
  }
} catch (e) {
  // Page metadata doesn't exist yet, use defaults
}

// Get all FAQs for the current language, sorted by order
const faqs = await getCollection("faqs", ({ data }) => {
  return data.lang === lang;
});

const sortedFaqs = faqs.sort((a, b) => a.data.order - b.data.order);

// Group FAQs by category
const faqsByCategory = sortedFaqs.reduce((acc, faq) => {
  const category = faq.data.category;
  if (!acc[category]) {
    acc[category] = [];
  }
  acc[category].push(faq);
  return acc;
}, {} as Record<string, typeof faqs>);

// Category translations
const categoryNames = {
  de: {
    general: "Allgemeine Fragen",
    features: "Funktionen",
    technical: "Technische Fragen",
    pricing: "Preise & Pläne",
    security: "Sicherheit & Datenschutz",
    business: "Business & Enterprise",
    industries: "Branchenspezifisch",
    guides: "Anleitungen"
  },
  en: {
    general: "General Questions",
    features: "Features",
    technical: "Technical Questions",
    pricing: "Pricing & Plans",
    security: "Security & Privacy",
    business: "Business & Enterprise",
    industries: "Industry-specific",
    guides: "Guides"
  }
};

const categories = Object.keys(faqsByCategory) as Array<keyof typeof categoryNames.de>;

// Prepare filter data
const allFaqsCount = sortedFaqs.length;
const filterOptions = [
  { value: 'all', label: lang === 'de' ? 'Alle' : 'All', count: allFaqsCount },
  ...categories.map(category => ({
    value: category,
    label: categoryNames[lang as 'de' | 'en'][category],
    count: faqsByCategory[category].length
  }))
];

// Empty state messages
const emptyStateMessages = {
  de: {
    all: {
      title: "Noch keine FAQs vorhanden",
      message: "Wir arbeiten daran, häufig gestellte Fragen für Sie zusammenzustellen.",
      icon: "❓"
    },
    general: {
      title: "Keine allgemeinen Fragen",
      message: "Allgemeine Fragen werden bald hinzugefügt.",
      icon: "💭"
    },
    features: {
      title: "Keine Funktions-FAQs",
      message: "Fragen zu unseren Funktionen folgen in Kürze.",
      icon: "⚙️"
    },
    technical: {
      title: "Keine technischen Fragen",
      message: "Technische FAQs werden bald verfügbar sein.",
      icon: "🔧"
    },
    pricing: {
      title: "Keine Preis-FAQs",
      message: "Fragen zu Preisen und Plänen kommen bald.",
      icon: "💰"
    },
    security: {
      title: "Keine Sicherheits-FAQs",
      message: "Sicherheits- und Datenschutzfragen werden ergänzt.",
      icon: "🔒"
    },
    business: {
      title: "Keine Business-FAQs",
      message: "Enterprise-Fragen werden bald beantwortet.",
      icon: "💼"
    },
    industries: {
      title: "Keine Branchen-FAQs",
      message: "Branchenspezifische Fragen folgen.",
      icon: "🏭"
    },
    guides: {
      title: "Keine Anleitungs-FAQs",
      message: "Anleitungen werden bald hinzugefügt.",
      icon: "📚"
    }
  },
  en: {
    all: {
      title: "No FAQs available yet",
      message: "We're working on compiling frequently asked questions for you.",
      icon: "❓"
    },
    general: {
      title: "No general questions",
      message: "General questions will be added soon.",
      icon: "💭"
    },
    features: {
      title: "No feature FAQs",
      message: "Questions about our features coming soon.",
      icon: "⚙️"
    },
    technical: {
      title: "No technical questions",
      message: "Technical FAQs will be available soon.",
      icon: "🔧"
    },
    pricing: {
      title: "No pricing FAQs",
      message: "Questions about pricing and plans coming soon.",
      icon: "💰"
    },
    security: {
      title: "No security FAQs",
      message: "Security and privacy questions will be added.",
      icon: "🔒"
    },
    business: {
      title: "No business FAQs",
      message: "Enterprise questions will be answered soon.",
      icon: "💼"
    },
    industries: {
      title: "No industry FAQs",
      message: "Industry-specific questions to follow.",
      icon: "🏭"
    },
    guides: {
      title: "No guide FAQs",
      message: "Guides will be added soon.",
      icon: "📚"
    }
  }
};

// Determine active filter from URL or default to 'all'
let activeFilter = 'all';
if (categoryParam) {
  // Find matching category (case-insensitive)
  const matchingCategory = categories.find(
    cat => cat.toLowerCase() === categoryParam.toLowerCase()
  );
  if (matchingCategory) {
    activeFilter = matchingCategory;
  }
}
---

<Layout title={pageData?.title || t('faq.title') || 'FAQ'}>
  <main class="bg-background-page">
    <div class="max-w-7xl mx-auto px-4 py-16">
    <div class="text-center mb-16">
      <h1 class="text-4xl font-bold text-text-primary mb-4">
        {frontmatter?.sections?.hero?.title || t('faq.title') || 'Häufig gestellte Fragen'}
      </h1>
      <p class="text-xl text-text-secondary max-w-2xl mx-auto">
        {frontmatter?.sections?.hero?.subtitle || t('faq.description') || 'Finden Sie Antworten auf die häufigsten Fragen zu Memoro'}
      </p>
    </div>

    <!-- Filter Pills -->
    <div class="mb-12">
      <FilterPills 
        filters={filterOptions}
        activeFilter={activeFilter}
        id="faq-filter"
      />
    </div>

    <div class="space-y-16" data-filter-content="faq-filter">
      {sortedFaqs.length > 0 ? (
        <>
          <!-- All FAQs -->
          <div data-type="all" class="space-y-16">
            {categories.length > 0 ? (
              categories.map((category) => (
                <FAQSection
                  key={category}
                  title={categoryNames[lang as 'de' | 'en'][category]}
                  categories={[category]}
                  limit={100}
                  class="mb-16"
                />
              ))
            ) : (
              <EmptyState 
                {...emptyStateMessages[lang].all}
              />
            )}
          </div>
          
          <!-- Filtered FAQs by Category -->
          {categories.map((category) => (
            <div data-type={category} class="hidden">
              {faqsByCategory[category].length > 0 ? (
                <FAQSection
                  key={category}
                  title={categoryNames[lang as 'de' | 'en'][category]}
                  categories={[category]}
                  limit={100}
                  showTitle={false}
                />
              ) : (
                <EmptyState 
                  {...emptyStateMessages[lang][category]}
                />
              )}
            </div>
          ))}
        </>
      ) : (
        <div data-type="all">
          <EmptyState 
            {...emptyStateMessages[lang].all}
          />
        </div>
      )}
    </div>

    <div class="text-center mt-20">
      <CallToAction
        title={frontmatter?.sections?.callToAction?.title || (lang === 'de' ? "Noch Fragen?" : "Still have questions?")}
        description={frontmatter?.sections?.callToAction?.description || (lang === 'de' ? "Unser Support-Team hilft Ihnen gerne weiter." : "Our support team is here to help.")}
        buttonText={frontmatter?.sections?.callToAction?.buttonText || (lang === 'de' ? "Kontakt aufnehmen" : "Contact us")}
        buttonLink={frontmatter?.sections?.callToAction?.buttonLink || `/${lang}/contact`}
      />
    </div>
    </div>
  </main>
</Layout>