---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import DetailLayout from '../../../components/layouts/DetailLayout.astro';
import FeaturesList from '../../../components/detail/FeaturesList.astro';
import LastUpdatedInfo from '../../../components/detail/LastUpdatedInfo.astro';
import { useTranslations } from "../../../i18n/utils";
import CallToAction from "../../../components/CallToAction.astro";
import { Icon } from 'astro-icon/components';

export async function getStaticPaths() {
  const blueprintsEntries = await getCollection('blueprints');
  
  // Map each blueprint to routes with language handling
  return blueprintsEntries.map((blueprint) => {
    const lang = blueprint.data.lang;
    let slugWithoutLang = blueprint.slug;
    
    // Remove language prefix if present
    if (blueprint.slug.startsWith(`${lang}/`)) {
      slugWithoutLang = blueprint.slug.replace(`${lang}/`, '');
    }
    
    return {
      params: { 
        lang: lang,
        slug: slugWithoutLang
      },
      props: { blueprint }
    };
  });
}

const { blueprint } = Astro.props;
const { lang } = Astro.params;
const t = useTranslations(lang);

// Get the Content component from the blueprint
let Content;
try {
  const rendered = await blueprint.render();
  Content = rendered.Content;
} catch (error) {
  console.error("Error rendering blueprint:", error);
}

// Extract emoji from title (assumes emoji is at the beginning)
const emojiMatch = blueprint.data.title.match(/^(\p{Emoji}+)/u);
const emoji = emojiMatch ? emojiMatch[1] : '📄';
const titleWithoutEmoji = blueprint.data.title.replace(/^(\p{Emoji}+)\s*/, '');

// Get translations from UI
const currentTranslations = {
  back: t('blueprints.backToOverview'),
  features: t('blueprints.features'),
  compatibility: t('blueprints.compatibility'),
  lastUpdated: t('blueprints.lastUpdated')
};

// Color schemes for different blueprint types
const colorSchemes = {
  blue: {
    bg: 'bg-blue-500',
    text: 'text-blue-600',
    border: 'border-blue-500',
    light: 'bg-blue-50',
  },
  red: {
    bg: 'bg-red-500',
    text: 'text-red-600',
    border: 'border-red-500',
    light: 'bg-red-50',
  },
  purple: {
    bg: 'bg-purple-500',
    text: 'text-purple-600',
    border: 'border-purple-500',
    light: 'bg-purple-50',
  },
  green: {
    bg: 'bg-green-500',
    text: 'text-green-600',
    border: 'border-green-500',
    light: 'bg-green-50',
  },
  orange: {
    bg: 'bg-orange-500',
    text: 'text-orange-600',
    border: 'border-orange-500',
    light: 'bg-orange-50',
  },
  yellow: {
    bg: 'bg-yellow-500',
    text: 'text-yellow-600',
    border: 'border-yellow-500',
    light: 'bg-yellow-50',
  }
};

const scheme = colorSchemes[blueprint.data.color] || colorSchemes.blue;
---

<Layout title={`${blueprint.data.title} - ${lang === 'de' ? 'Vorlage' : 'Blueprint'}`}>
  <DetailLayout
    containerClass="max-w-4xl mx-auto px-6 sm:px-8 py-6 sm:py-8"
    articleClass=""
    noProse={true}
    backLink={{
      href: `/${lang}/blueprints`
    }}
  >
    <Fragment slot="before-content">
      {/* Header */}
      <div class="bg-background-card rounded-2xl p-8 md:p-12 mb-8">
        <div class="flex items-start gap-6 mb-6">
          <div class={`w-20 h-20 rounded-2xl ${scheme.bg} flex items-center justify-center text-white shadow-lg flex-shrink-0 text-4xl`}>
            {emoji}
          </div>
          <div class="flex-1">
            <h1 class="text-3xl md:text-4xl font-bold text-text-primary mb-4">
              {titleWithoutEmoji}
            </h1>
            <p class="text-lg text-text-secondary">
              {blueprint.data.description}
            </p>
          </div>
        </div>
        
        {/* Features and Compatibility Grid */}
        <div class="grid md:grid-cols-2 gap-8 mt-8">
          {blueprint.data.features && (
            <FeaturesList 
              features={blueprint.data.features}
              title={currentTranslations.features}
              icon="•"
              iconColor={scheme.text}
              columns={1}
            />
          )}
          
          {blueprint.data.compatibility && blueprint.data.compatibility.length > 0 && (
            <div>
              <h3 class="text-lg font-semibold text-text-primary mb-4 flex items-center">
                <Icon name="mdi:power-plug" class="w-4 h-4 text-primary-DEFAULT mr-2" />
                {currentTranslations.compatibility}
              </h3>
              <div class="flex flex-wrap gap-2">
                {blueprint.data.compatibility.map(item => (
                  <span class={`px-3 py-1 rounded-full ${scheme.light} ${scheme.text} text-sm font-medium`}>
                    {item}
                  </span>
                ))}
              </div>
            </div>
          )}
        </div>
        
        {blueprint.data.lastUpdated && (
          <LastUpdatedInfo 
            date={blueprint.data.lastUpdated} 
            lang={lang} 
            variant="footer"
          />
        )}
      </div>
    </Fragment>
      
    {/* Content */}
    {Content && (
      <div class="bg-background-card rounded-2xl p-8 md:p-12 mb-8">
        <div class="prose prose-lg max-w-none prose-headings:text-text-primary prose-p:text-text-secondary prose-strong:text-text-primary prose-li:text-text-secondary">
          <Content />
        </div>
      </div>
    )}
    
    {!Content && (
      <div class="bg-background-card rounded-2xl p-8 md:p-12 mb-8">
        <p class="text-red-500">
          {lang === 'de' 
            ? 'Fehler beim Laden des Inhalts dieser Vorlage.' 
            : 'Error loading this blueprint\'s content.'}
        </p>
      </div>
    )}
    
    <Fragment slot="outside-article">
      {/* Call to Action */}
      <CallToAction
        title={lang === 'de' ? `${blueprint.data.title} verwenden` : `Use ${blueprint.data.title}`}
        description={lang === 'de' 
          ? 'Lade Memoro herunter und starte direkt mit dieser Vorlage.' 
          : 'Download Memoro and start directly with this blueprint.'}
        buttonText={lang === 'de' ? 'Jetzt loslegen' : 'Get Started'}
        buttonLink={`/${lang}/download`}
      />
    </Fragment>
  </DetailLayout>
</Layout>