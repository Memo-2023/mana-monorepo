---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import FeatureCard from '../../../components/FeatureCard.astro';
import CallToAction from '../../../components/CallToAction.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import FAQ from '../../../components/FAQ.astro';
import HeroSection from '../../../components/HeroSection.astro';

export async function getStaticPaths() {
	// Generate a page for each language
	return ['de', 'en'].map((lang) => {
		return {
			params: { lang },
			props: { lang },
		};
	});
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Attempt to get language-specific content
const features = await getEntry('pages', `${lang}/features`);
if (!features) throw new Error(`Features page content not found for language: ${lang}`);
const { Content } = await features.render();

// Get features in current language, sorted by order
const featureEntries = await getCollection('features', ({ data }) => {
	return data.lang === lang;
});

const sortedFeatures = featureEntries.sort(
	(a, b) => (parseInt(a.data.order) || 0) - (parseInt(b.data.order) || 0)
);
---

<Layout title={features.data.title}>
	<main class="bg-background-page">
		<HeroSection
			variant="fullwidth"
			title={lang === 'de' ? 'Funktionen' : 'Features'}
			subtitle={lang === 'de'
				? 'Entdecke alle Funktionen, die Memoro zu deinem perfekten Meeting-Begleiter machen'
				: 'Discover all the features that make Memoro your perfect meeting companion'}
			image="/images/product_photos/Memoro-App-Smartphone.jpg"
		/>
		<div class="max-w-7xl mx-auto px-4 py-16">
			<Content features={sortedFeatures} />
		</div>
	</main>
</Layout>
