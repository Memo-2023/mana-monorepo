---
import { getEntry } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
	return ['de', 'en'].map((lang) => ({
		params: { lang },
		props: { lang },
	}));
}

const { lang } = Astro.props;

const dpa = await getEntry('dataprotection', `${lang}/dpa`);
if (!dpa) throw new Error(`DPA content not found for language: ${lang}`);
const { Content } = await dpa.render();
---

<Layout title={dpa.data.title}>
	<main class="bg-background-page">
		<div class="max-w-4xl mx-auto px-4 py-12">
			<nav class="mb-8">
				<a href={`/${lang}/privacy`} class="text-primary hover:text-primary-hover">
					← {lang === 'de' ? 'Zurück zum Datenschutz-Center' : 'Back to Privacy Center'}
				</a>
			</nav>
			<article
				class="prose prose-lg max-w-none
        prose-headings:!text-text-primary
        prose-h1:!text-3xl prose-h1:!font-bold prose-h1:!text-text-primary
        prose-h2:!text-2xl prose-h2:!font-semibold prose-h2:!text-text-primary
        prose-h3:!text-xl prose-h3:!font-semibold prose-h3:!text-text-primary
        prose-h4:!text-lg prose-h4:!font-semibold prose-h4:!text-text-primary
        prose-p:!text-text-secondary prose-p:!leading-relaxed
        prose-a:!text-primary prose-a:!no-underline hover:prose-a:!text-primary-hover hover:prose-a:!underline
        prose-strong:!text-text-primary prose-strong:!font-semibold
        prose-em:!text-text-secondary
        prose-code:!text-primary prose-code:!bg-background-cardHover prose-code:!px-1 prose-code:!py-0.5 prose-code:!rounded
        prose-pre:!bg-background-cardHover prose-pre:!border prose-pre:!border-border prose-pre:!text-text-secondary
        prose-blockquote:!border-l-4 prose-blockquote:!border-primary prose-blockquote:!bg-background-cardHover prose-blockquote:!text-text-secondary prose-blockquote:!italic
        prose-ul:!text-text-secondary prose-ul:!list-disc
        prose-ol:!text-text-secondary prose-ol:!list-decimal
        prose-li:!text-text-secondary prose-li:marker:!text-primary
        prose-hr:!border-border
        prose-table:!text-text-secondary prose-table:!border-collapse
        prose-th:!text-text-primary prose-th:!font-semibold prose-th:!border prose-th:!border-border prose-th:!bg-background-cardHover prose-th:!p-3
        prose-td:!text-text-secondary prose-td:!border prose-td:!border-border prose-td:!p-3
        prose-img:!rounded-lg prose-img:!border prose-img:!border-border"
			>
				<Content />
			</article>
		</div>
	</main>
</Layout>
