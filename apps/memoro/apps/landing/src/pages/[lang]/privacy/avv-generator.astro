---
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
	return ['de', 'en'].map((lang) => ({
		params: { lang },
		props: { lang },
	}));
}

const { lang } = Astro.props;

const content = {
	de: {
		title: 'AVV-Generator',
		subtitle: 'Erstellen Sie Ihren Auftragsverarbeitungsvertrag in 2 Minuten',
		description:
			'Füllen Sie 6 kurze Felder aus und laden Sie Ihren individuellen AVV als PDF herunter. Senden Sie das unterschriebene Dokument anschließend an enterprise@memoro.ai',
		backLink: '← Zurück zum Datenschutz-Center',
		formTitle: 'AVV-Daten',
		companyName: 'Firmenname',
		companyNamePlaceholder: 'Ihre Firma GmbH',
		contactPerson: 'Ansprechpartner',
		contactPersonPlaceholder: 'Max Mustermann',
		email: 'E-Mail-Adresse',
		emailPlaceholder: 'kontakt@ihre-firma.de',
		address: 'Vollständige Adresse',
		addressPlaceholder: 'Musterstraße 123, 12345 Musterstadt',
		contractStart: 'Vertragsbeginn',
		acceptanceLabel:
			'Ich akzeptiere den Standard-AVV von Memoro und bestätige, dass die Angaben korrekt sind.',
		generateButton: 'AVV als PDF herunterladen',
		emailInfo: 'Nach dem Download senden Sie das unterschriebene PDF bitte an:',
		emailAddress: 'enterprise@memoro.ai',
		emailNote: 'Sie erhalten das gegengezeichnete Dokument innerhalb von 2 Werktagen zurück.',
		required: 'Pflichtfeld',
		formTime: '⏱️ Ausfüllzeit: ca. 2 Minuten',
	},
	en: {
		title: 'DPA Generator',
		subtitle: 'Create your Data Processing Agreement in 2 minutes',
		description:
			'Fill out 6 short fields and download your individual DPA as PDF. Then send the signed document to enterprise@memoro.ai',
		backLink: '← Back to Privacy Center',
		formTitle: 'DPA Data',
		companyName: 'Company Name',
		companyNamePlaceholder: 'Your Company Ltd.',
		contactPerson: 'Contact Person',
		contactPersonPlaceholder: 'John Doe',
		email: 'Email Address',
		emailPlaceholder: 'contact@yourcompany.com',
		address: 'Full Address',
		addressPlaceholder: 'Sample Street 123, 12345 Sample City',
		contractStart: 'Contract Start Date',
		acceptanceLabel: "I accept Memoro's standard DPA and confirm that the information is correct.",
		generateButton: 'Download DPA as PDF',
		emailInfo: 'After downloading, please send the signed PDF to:',
		emailAddress: 'enterprise@memoro.ai',
		emailNote: 'You will receive the countersigned document within 2 business days.',
		required: 'Required',
		formTime: '⏱️ Time to complete: approx. 2 minutes',
	},
};

const t = content[lang];
---

<Layout title={t.title}>
	<main class="bg-background-page">
		<div class="max-w-4xl mx-auto px-4 py-12">
			<nav class="mb-8">
				<a href={`/${lang}/privacy`} class="text-primary hover:text-primary-hover">
					{t.backLink}
				</a>
			</nav>

			<div class="mb-12">
				<h1 class="text-4xl font-bold text-text-primary mb-4">{t.title}</h1>
				<p class="text-xl text-text-secondary mb-4">{t.subtitle}</p>
				<p class="text-text-secondary">{t.description}</p>
			</div>

			<!-- Info Box -->
			<div class="mb-8 p-6 bg-background-card border border-border rounded-xl">
				<div class="flex items-start gap-4">
					<svg
						class="w-6 h-6 text-primary flex-shrink-0 mt-1"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
					</svg>
					<div>
						<p class="text-text-secondary mb-2">{t.emailInfo}</p>
						<a
							href="mailto:enterprise@memoro.ai"
							class="text-primary hover:text-primary-hover font-semibold"
						>
							{t.emailAddress}
						</a>
					</div>
				</div>
			</div>

			<form id="avv-form" class="space-y-6">
				<!-- Single simplified form section -->
				<section class="bg-background-card p-6 rounded-xl border border-border">
					<h2 class="text-2xl font-semibold text-text-primary mb-6">{t.formTitle}</h2>

					<div class="space-y-4">
						<div>
							<label for="companyName" class="block text-sm font-medium text-text-primary mb-2">
								{t.companyName}
								<span class="text-red-500">*</span>
							</label>
							<input
								type="text"
								id="companyName"
								name="companyName"
								required
								placeholder={t.companyNamePlaceholder}
								class="w-full px-4 py-2 bg-background-input border border-border rounded-lg text-text-primary placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary"
							/>
						</div>

						<div>
							<label for="contactPerson" class="block text-sm font-medium text-text-primary mb-2">
								{t.contactPerson}
								<span class="text-red-500">*</span>
							</label>
							<input
								type="text"
								id="contactPerson"
								name="contactPerson"
								required
								placeholder={t.contactPersonPlaceholder}
								class="w-full px-4 py-2 bg-background-input border border-border rounded-lg text-text-primary placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary"
							/>
						</div>

						<div>
							<label for="email" class="block text-sm font-medium text-text-primary mb-2">
								{t.email}
								<span class="text-red-500">*</span>
							</label>
							<input
								type="email"
								id="email"
								name="email"
								required
								placeholder={t.emailPlaceholder}
								class="w-full px-4 py-2 bg-background-input border border-border rounded-lg text-text-primary placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary"
							/>
						</div>

						<div>
							<label for="address" class="block text-sm font-medium text-text-primary mb-2">
								{t.address}
								<span class="text-red-500">*</span>
							</label>
							<input
								type="text"
								id="address"
								name="address"
								required
								placeholder={t.addressPlaceholder}
								class="w-full px-4 py-2 bg-background-input border border-border rounded-lg text-text-primary placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary"
							/>
						</div>

						<div>
							<label for="contractStart" class="block text-sm font-medium text-text-primary mb-2">
								{t.contractStart}
								<span class="text-red-500">*</span>
							</label>
							<input
								type="date"
								id="contractStart"
								name="contractStart"
								required
								class="w-full px-4 py-2 bg-background-input border border-border rounded-lg text-text-primary focus:outline-none focus:ring-2 focus:ring-primary"
							/>
						</div>

						<div class="flex items-start gap-3 pt-4">
							<input
								type="checkbox"
								id="acceptance"
								name="acceptance"
								required
								class="mt-1 w-4 h-4 text-primary bg-background-input border-border rounded focus:ring-2 focus:ring-primary"
							/>
							<label for="acceptance" class="text-sm text-text-secondary">
								{t.acceptanceLabel}
							</label>
						</div>
					</div>
				</section>

				<!-- Submit Buttons -->
				<div class="flex justify-center gap-4">
					<button
						type="button"
						id="clear-form"
						class="inline-flex items-center gap-2 px-6 py-3 bg-gray-600 text-white font-semibold rounded-lg hover:bg-gray-700 transition-all duration-200"
					>
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
							></path>
						</svg>
						{lang === 'de' ? 'Formular leeren' : 'Clear form'}
					</button>
					<button
						type="submit"
						class="inline-flex items-center gap-3 px-8 py-4 bg-primary text-white font-semibold rounded-lg hover:bg-primary-hover transition-all duration-200 shadow-lg hover:shadow-xl"
					>
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
							></path>
						</svg>
						{t.generateButton}
					</button>
				</div>
			</form>
		</div>
	</main>
</Layout>

<script>
	// @ts-ignore
	import jsPDF from 'jspdf';

	// Clear form button
	document.getElementById('clear-form')?.addEventListener('click', () => {
		const form = document.getElementById('avv-form') as HTMLFormElement;
		if (form) {
			form.reset();
			localStorage.removeItem('avv-form-data');
			const currentLang = window.location.pathname.split('/')[1] === 'en' ? 'en' : 'de';
			alert(currentLang === 'de' ? 'Formular wurde geleert' : 'Form has been cleared');
		}
	});

	// Load saved form data on page load
	document.addEventListener('DOMContentLoaded', () => {
		const savedData = localStorage.getItem('avv-form-data');
		if (savedData) {
			try {
				const data = JSON.parse(savedData);
				Object.keys(data).forEach((key) => {
					const element = document.getElementById(key) as HTMLInputElement;
					if (element) {
						if (element.type === 'checkbox') {
							element.checked = data[key] === 'true';
						} else {
							element.value = data[key];
						}
					}
				});
			} catch (e) {
				console.error('Error loading saved data:', e);
			}
		}
	});

	// Save form data on input or change
	const saveFormData = () => {
		const form = document.getElementById('avv-form') as HTMLFormElement;
		if (!form) return;

		const formData = new FormData(form);
		const data: Record<string, string> = {};

		formData.forEach((value, key) => {
			data[key] = value.toString();
		});

		// Also save checkbox state
		const acceptance = document.getElementById('acceptance') as HTMLInputElement;
		if (acceptance) {
			data['acceptance'] = acceptance.checked.toString();
		}

		localStorage.setItem('avv-form-data', JSON.stringify(data));
	};

	document.getElementById('avv-form')?.addEventListener('input', saveFormData);
	document.getElementById('avv-form')?.addEventListener('change', saveFormData);

	document.getElementById('avv-form')?.addEventListener('submit', async (e) => {
		e.preventDefault();

		const formData = new FormData(e.target as HTMLFormElement);
		const data = Object.fromEntries(formData.entries());

		// Get current language from URL
		const currentLang = window.location.pathname.split('/')[1] === 'en' ? 'en' : 'de';

		// Create PDF
		const doc = new jsPDF();
		const pageWidth = doc.internal.pageSize.getWidth();
		const margin = 20;
		const lineHeight = 7;
		let yPos = 20;

		// Helper function to add text with word wrap
		const addText = (text: string, fontSize = 11, isBold = false) => {
			doc.setFontSize(fontSize);
			if (isBold) doc.setFont('helvetica', 'bold');
			else doc.setFont('helvetica', 'normal');

			const lines = doc.splitTextToSize(text, pageWidth - 2 * margin);
			lines.forEach((line: string) => {
				if (yPos > 280) {
					doc.addPage();
					yPos = 20;
				}
				doc.text(line, margin, yPos);
				yPos += lineHeight;
			});
		};

		const addSpace = (lines = 1) => {
			yPos += lineHeight * lines;
		};

		// Title (language-aware)
		if (currentLang === 'de') {
			addText('Auftragsverarbeitungsvertrag (AVV)', 16, true);
			addText('Version 2.2.0 vom 15.07.2025 nach DSGVO', 10);
		} else {
			addText('Data Processing Agreement (DPA)', 16, true);
			addText('Version 2.2.0 dated July 15, 2025 according to GDPR', 10);
		}
		addSpace(2);

		// Parties
		if (currentLang === 'de') {
			addText('Vertrag über die Auftragsverarbeitung personenbezogener Daten', 12, true);
			addSpace();
			addText('zwischen', 11, true);
			addSpace();
			addText(data.companyName as string);
			addText(`vertreten durch ${data.contactPerson}`);
			addText(data.address as string);
			addText(`E-Mail: ${data.email}`);
			addText('im Folgenden: Auftraggeber', 11, true);
			addSpace();
			addText('und', 11, true);
			addSpace();
			addText('Memoro GmbH');
			addText('Münzgasse 19, 78462 Konstanz, Deutschland');
			addText('vertreten durch Till Schneider, Geschäftsführer');
			addText('E-Mail: kontakt@memoro.ai');
			addText('im Folgenden: Auftragnehmer', 11, true);
			addSpace(2);
		} else {
			addText('Data Processing Agreement', 12, true);
			addSpace();
			addText('between', 11, true);
			addSpace();
			addText(data.companyName as string);
			addText(`represented by ${data.contactPerson}`);
			addText(data.address as string);
			addText(`Email: ${data.email}`);
			addText('hereinafter: Controller', 11, true);
			addSpace();
			addText('and', 11, true);
			addSpace();
			addText('Memoro GmbH');
			addText('Münzgasse 19, 78462 Konstanz, Germany');
			addText('represented by Till Schneider, Managing Director');
			addText('Email: kontakt@memoro.ai');
			addText('hereinafter: Processor', 11, true);
			addSpace(2);
		}

		// Section 1
		if (currentLang === 'de') {
			addText('1. Vertragsgegenstand und Geltungsbereich', 12, true);
			addSpace();
			addText(
				'Dieser Auftragsverarbeitungsvertrag (AVV) regelt die Verarbeitung personenbezogener Daten durch die Memoro GmbH als Auftragsverarbeiter im Auftrag des Kunden (Verantwortlicher) gemäß Art. 28 der Datenschutz-Grundverordnung (DSGVO).'
			);
			addSpace();
			addText(
				`Vertragsbeginn: ${new Date(data.contractStart as string).toLocaleDateString('de-DE')}`
			);
			addSpace(2);

			addText('2. Art und Zweck der Datenverarbeitung', 12, true);
			addSpace();
			addText('Memoro verarbeitet folgende Arten personenbezogener Daten:');
			addText('• Sprachaufnahmen und deren Transkriptionen');
			addText('• KI-generierte Zusammenfassungen (Memories)');
			addText('• Nutzerdaten (E-Mail, Name, Nutzungsdaten)');
			addSpace();
			addText(
				'Zweck: Bereitstellung der Memoro App zur Transkription und KI-gestützten Analyse von Gesprächsaufnahmen.'
			);
			addSpace(2);

			addText('3. Technische und organisatorische Maßnahmen', 12, true);
			addSpace();
			addText('Memoro setzt umfassende technische und organisatorische Maßnahmen um:');
			addText('• Verschlüsselung: TLS 1.3 für Übertragungen, AES-256 für Speicherung');
			addText('• Zugriffskontrolle: Rollenbasiert (RBAC) mit Zwei-Faktor-Authentifizierung');
			addText('• Infrastruktur: EU-Server (primär Frankfurt, Deutschland)');
			addText('• Backup: Tägliche verschlüsselte Backups mit Geo-Redundanz');
			addSpace();
			addText('Vollständige TOMs verfügbar unter: https://memoro.ai/de/privacy/security');
			addSpace(2);

			addText('Hinweis: Dieses PDF enthält eine Zusammenfassung des AVV.', 10);
			addText('Den vollständigen Vertrag mit allen 14 Kapiteln finden Sie unter:', 10);
			addText('https://memoro.ai/de/privacy/dpa', 10);
		} else {
			addText('1. Subject Matter and Scope', 12, true);
			addSpace();
			addText(
				'This Data Processing Agreement (DPA) governs the processing of personal data by Memoro GmbH as a processor on behalf of the customer (controller) in accordance with Art. 28 of the General Data Protection Regulation (GDPR).'
			);
			addSpace();
			addText(
				`Contract Start: ${new Date(data.contractStart as string).toLocaleDateString('en-US')}`
			);
			addSpace(2);

			addText('2. Nature and Purpose of Processing', 12, true);
			addSpace();
			addText('Memoro processes the following types of personal data:');
			addText('• Voice recordings and their transcriptions');
			addText('• AI-generated summaries (Memories)');
			addText('• User data (email, name, usage data)');
			addSpace();
			addText(
				'Purpose: Provision of the Memoro App for transcription and AI-assisted analysis of voice recordings.'
			);
			addSpace(2);

			addText('3. Technical and Organizational Measures', 12, true);
			addSpace();
			addText('Memoro implements comprehensive technical and organizational measures:');
			addText('• Encryption: TLS 1.3 for transmission, AES-256 for storage');
			addText('• Access Control: Role-based (RBAC) with two-factor authentication');
			addText('• Infrastructure: EU servers (primarily Frankfurt, Germany)');
			addText('• Backup: Daily encrypted backups with geo-redundancy');
			addSpace();
			addText('Complete TOMs available at: https://memoro.ai/en/privacy/security');
			addSpace(2);

			addText('Note: This PDF contains a summary of the DPA.', 10);
			addText('The complete agreement with all 14 chapters can be found at:', 10);
			addText('https://memoro.ai/en/privacy/dpa', 10);
		}
		addSpace(2);

		// Signatures
		doc.addPage();
		yPos = 20;
		if (currentLang === 'de') {
			addText('Unterschriften', 14, true);
			addSpace(3);
			doc.text('Für den Auftraggeber:', margin, yPos);
			doc.text('Für den Auftragnehmer:', pageWidth / 2 + 10, yPos);
		} else {
			addText('Signatures', 14, true);
			addSpace(3);
			doc.text('For the Controller:', margin, yPos);
			doc.text('For the Processor:', pageWidth / 2 + 10, yPos);
		}
		yPos += lineHeight * 4;

		doc.line(margin, yPos, margin + 70, yPos);
		doc.line(pageWidth / 2 + 10, yPos, pageWidth / 2 + 80, yPos);
		yPos += lineHeight;

		doc.text(`${data.contactPerson}`, margin, yPos);
		doc.text('Till Schneider', pageWidth / 2 + 10, yPos);
		yPos += lineHeight;

		if (currentLang === 'de') {
			doc.text('Geschäftsführer', pageWidth / 2 + 10, yPos);
		} else {
			doc.text('Managing Director', pageWidth / 2 + 10, yPos);
		}

		// Save PDF
		try {
			const fileName = `${currentLang === 'de' ? 'AVV' : 'DPA'}_Memoro_${data.companyName}_${new Date().toISOString().split('T')[0]}.pdf`;
			doc.save(fileName);

			// Show success message
			const button = (e.target as HTMLFormElement).querySelector('button[type="submit"]');
			if (button) {
				const originalText = button.innerHTML;
				button.innerHTML =
					currentLang === 'de'
						? '<svg class="w-6 h-6 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> PDF wurde heruntergeladen!'
						: '<svg class="w-6 h-6 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> PDF downloaded!';
				button.classList.add('bg-green-600');

				setTimeout(() => {
					button.innerHTML = originalText;
					button.classList.remove('bg-green-600');
				}, 3000);
			}
		} catch (error) {
			console.error('Error generating PDF:', error);
			alert(
				currentLang === 'de'
					? 'Fehler beim Erstellen des PDFs. Bitte versuchen Sie es erneut.'
					: 'Error creating PDF. Please try again.'
			);
		}
	});
</script>
