---
import { getEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import MemoroSoftwareApp from "../../components/MemoroSoftwareApp.astro";
import MemoroOrganization from "../../components/MemoroOrganization.astro";

export async function getStaticPaths() {
  return [{
    params: { lang: 'de' },
    props: { lang: 'de' }
  }];
}

const { lang } = Astro.props;

const page = await getEntry("pages", `${lang}/sprachaufnahme-app-business`);

if (!page) {
  return Astro.redirect("/404");
}

const { Content } = await page.render();

const mobileAppSchema = {
  "@context": "https://schema.org",
  "@type": "MobileApplication",
  "name": "Memoro Business Sprachaufnahme",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "iOS, Android",
  "offers": {
    "@type": "Offer",
    "price": "19",
    "priceCurrency": "EUR",
    "description": "Business Sprachaufnahme App ab 19€/Monat"
  },
  "aggregateRating": {
    "@type": "AggregateRating", 
    "ratingValue": "4.9",
    "reviewCount": "856"
  },
  "description": "Professionelle Business Sprachaufnahme App mit automatischer Transkription, Offline-Modus und Enterprise-Security für deutsche Unternehmen."
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Ist die Aufnahme von Geschäftsgesprächen rechtlich zulässig?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In Deutschland ist die Aufnahme eigener Gespräche grundsätzlich erlaubt. Bei Gesprächen mit Dritten sollten Sie diese vorher informieren. Wir bieten rechtssichere Templates für Einverständniserklärungen."
      }
    },
    {
      "@type": "Question",
      "name": "Funktioniert die App auch ohne Internetverbindung?", 
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ja, alle Aufnahmen funktionieren vollständig offline. Die Synchronisation und Transkription erfolgt automatisch, sobald wieder eine Internetverbindung verfügbar ist."
      }
    }
  ]
};
---

<Layout 
  title={page.data.title}
  description={page.data.description}
  lang={lang}
>
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify(mobileAppSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <MemoroSoftwareApp />
    <MemoroOrganization />
  </Fragment>

  <article className="max-w-none">
    <div className="prose prose-lg max-w-none
                prose-headings:font-semibold 
                prose-headings:text-text-heading 
                prose-p:text-text-body
                prose-a:text-primary-600 hover:prose-a:text-primary-700
                prose-strong:text-text-heading
                prose-img:rounded-lg prose-img:shadow-xl">
      <Content />
    </div>
  </article>
</Layout>