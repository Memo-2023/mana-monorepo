---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { useTranslations } from '../../../i18n/utils';
import ChangelogCard from '../../../components/ChangelogCard.astro';

export async function getStaticPaths() {
	return ['de', 'en'].map((lang) => ({
		params: { lang },
		props: { lang },
	}));
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Get changelog entries for the current language, sorted by release date
const entries = (
	await getCollection('changelog', ({ data }) => {
		return data.lang === lang && !data.draft;
	})
).sort((a, b) => {
	return b.data.releaseDate.valueOf() - a.data.releaseDate.valueOf();
});

// Group entries by year
const entriesByYear = entries.reduce(
	(acc, entry) => {
		const year = entry.data.releaseDate.getFullYear();
		if (!acc[year]) {
			acc[year] = [];
		}
		acc[year].push(entry);
		return acc;
	},
	{} as Record<number, typeof entries>
);

// Sort years in descending order
const sortedYears = Object.keys(entriesByYear).sort((a, b) => Number(b) - Number(a));

const pageTitle = t('changelog.title') || (lang === 'de' ? 'Changelog' : 'Changelog');
const pageDescription =
	t('changelog.description') ||
	(lang === 'de' ? 'Alle Updates und Verbesserungen' : 'All updates and improvements');
---

<Layout title={pageTitle}>
	<main class="bg-background-page">
		<div class="max-w-4xl mx-auto px-4 py-16">
			<div class="text-center mb-16">
				<h1 class="text-4xl md:text-5xl font-bold text-text-primary mb-4">
					{pageTitle}
				</h1>
				<p class="text-lg text-text-secondary max-w-2xl mx-auto">
					{pageDescription}
				</p>
			</div>

			{
				sortedYears.length > 0 ? (
					<div class="space-y-12">
						{sortedYears.map((year) => (
							<div>
								<h2 class="text-2xl font-bold text-text-primary mb-6 pb-2 border-b border-accent-DEFAULT/20">
									{year}
								</h2>
								<div class="space-y-8">
									{entriesByYear[Number(year)].map((entry) => (
										<ChangelogCard
											title={entry.data.title}
											description={entry.data.description}
											version={entry.data.version}
											releaseDate={entry.data.releaseDate}
											type={entry.data.type}
											category={entry.data.category}
											highlights={entry.data.highlights}
											breaking={entry.data.breaking}
											platforms={entry.data.platforms}
											slug={entry.slug}
											lang={lang}
										/>
									))}
								</div>
							</div>
						))}
					</div>
				) : (
					<div class="text-center py-12">
						<p class="text-text-secondary">
							{lang === 'de'
								? 'Noch keine Changelog-Einträge verfügbar.'
								: 'No changelog entries available yet.'}
						</p>
					</div>
				)
			}
		</div>
	</main>
</Layout>
