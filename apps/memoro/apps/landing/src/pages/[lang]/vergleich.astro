---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import MemoroSoftwareApp from '../../components/MemoroSoftwareApp.astro';
import MemoroOrganization from '../../components/MemoroOrganization.astro';

export async function getStaticPaths() {
	// Only create German version for now
	return [
		{
			params: { lang: 'de' },
			props: { lang: 'de' },
		},
	];
}

const { lang } = Astro.props;

// Redirect English users to features page for now until EN version is ready
if (lang === 'en') {
	return Astro.redirect('/en/features', 301);
}

const page = await getEntry('pages', `${lang}/vergleich`);

if (!page) {
	return Astro.redirect(`/${lang}`, 404);
}

const { Content } = await page.render();

// Schema.org structured data for comparison hub
const comparisonHubSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	'@id': `https://memoro.ai/${lang}/vergleich`,
	url: `https://memoro.ai/${lang}/vergleich`,
	name: page.data.title,
	description: page.data.description,
	inLanguage: lang === 'de' ? 'de-DE' : 'en-US',
	isPartOf: {
		'@type': 'WebSite',
		'@id': 'https://memoro.ai/#website',
		url: 'https://memoro.ai',
		name: 'Memoro',
	},
	mainEntity: {
		'@type': 'ItemList',
		name: 'Meeting Software Vergleich 2025',
		description: 'Vergleich der besten Meeting-Protokoll Software für deutsche Unternehmen',
		numberOfItems: 10,
		itemListElement: [
			{
				'@type': 'SoftwareApplication',
				position: 1,
				name: 'Memoro',
				applicationCategory: 'BusinessApplication',
				operatingSystem: 'Web, iOS, Android, Windows, macOS',
				offers: {
					'@type': 'Offer',
					price: '12.99',
					priceCurrency: 'EUR',
				},
				aggregateRating: {
					'@type': 'AggregateRating',
					ratingValue: '4.9',
					reviewCount: '1247',
				},
				featureList: [
					'100% DSGVO-konform',
					'Deutsche Server',
					'98% Genauigkeit',
					'50+ Sprachen',
					'600 kostenlose Minuten',
				],
			},
			{
				'@type': 'SoftwareApplication',
				position: 2,
				name: 'Otter.ai',
				applicationCategory: 'BusinessApplication',
				offers: {
					'@type': 'Offer',
					price: '16.99',
					priceCurrency: 'USD',
				},
				aggregateRating: {
					'@type': 'AggregateRating',
					ratingValue: '4.2',
					reviewCount: '2000',
				},
			},
			{
				'@type': 'SoftwareApplication',
				position: 3,
				name: 'Fireflies.ai',
				applicationCategory: 'BusinessApplication',
				offers: {
					'@type': 'Offer',
					price: '18',
					priceCurrency: 'USD',
				},
				aggregateRating: {
					'@type': 'AggregateRating',
					ratingValue: '4.1',
					reviewCount: '1500',
				},
			},
		],
	},
};

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: [
		{
			'@type': 'Question',
			name: 'Welche Software ist wirklich DSGVO-konform?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Nur Memoro bietet 100% DSGVO-Konformität mit deutschen Servern und vollständiger Datenverarbeitung in Deutschland. Alle US-Anbieter haben rechtliche Risiken durch den CLOUD Act.',
			},
		},
		{
			'@type': 'Question',
			name: 'Was ist die beste kostenlose Option?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: "Memoro bietet mit 600 Minuten/Monat das großzügigste kostenlose Kontingent. Fathom und tl;dv werben mit 'unlimited', haben aber versteckte Einschränkungen.",
			},
		},
		{
			'@type': 'Question',
			name: 'Welche Software hat die beste deutsche Spracherkennung?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Memoro wurde speziell für die deutsche Sprache optimiert und erreicht 98%+ Genauigkeit. Otter.ai unterstützt gar kein Deutsch, andere Anbieter nur mit mäßiger Qualität.',
			},
		},
	],
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Memoro',
			item: 'https://memoro.ai',
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Software Vergleich',
			item: `https://memoro.ai/${lang}/vergleich`,
		},
	],
};
---

<Layout title={page.data.title} description={page.data.description} lang={lang}>
	<Fragment slot="structured-data">
		<script type="application/ld+json" set:html={JSON.stringify(comparisonHubSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		<MemoroSoftwareApp />
		<MemoroOrganization />
	</Fragment>

	<article class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 lg:py-20">
		<div
			class="prose prose-lg max-w-none
                prose-headings:text-text-heading
                prose-p:text-text-body
                prose-a:text-primary-600 hover:prose-a:text-primary-700
                prose-strong:text-text-heading
                prose-img:rounded-lg prose-img:shadow-xl
                prose-table:text-sm"
		>
			<Content />
		</div>
	</article>
</Layout>
