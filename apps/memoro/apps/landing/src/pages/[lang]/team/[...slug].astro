---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import DetailLayout from "../../../components/layouts/DetailLayout.astro";
import SocialLinks from "../../../components/detail/SocialLinks.astro";
import LastUpdatedInfo from "../../../components/detail/LastUpdatedInfo.astro";
import { useTranslations } from "../../../i18n/utils";
import ArticleNavigation from "../../../components/ArticleNavigation.astro";
import StructuredData from "../../../components/StructuredData.astro";

export async function getStaticPaths() {
  const teamMembers = await getCollection("team");
  
  // List of team members with existing images
  const existingTeamImages = [
    'AlexVasileva',
    'DennisBauer',
    'DirkZimanky',
    'FlorianKoenig',
    'LucasMag',
    'NilsWeiser',
    'TillSchneider',
    'TobiasMueller'
  ];
  
  // Filter out team members without existing images
  const filteredMembers = teamMembers.filter(member => {
    if (!member.data.image) return false;
    
    // Check if the image path contains any of the existing team images
    const hasExistingImage = existingTeamImages.some(imageName => 
      member.data.image.includes(imageName)
    );
    
    return hasExistingImage;
  });
  
  // Map each team member to a route with the clean slug
  return filteredMembers.map((member) => {
    const lang = member.data.lang;
    // Entferne den Sprachpräfix aus dem Slug, wenn vorhanden
    const langPrefix = `${lang}/`;
    const cleanSlug = member.slug.startsWith(langPrefix) 
      ? member.slug.substring(langPrefix.length)
      : member.slug;
      
    return {
      params: { 
        lang: lang,
        slug: cleanSlug
      },
      props: { member },
    };
  });
}

const { member } = Astro.props;
const { lang } = Astro.params;
const t = useTranslations(lang);

// List of team members with existing images (same as above)
const existingTeamImages = [
  'AlexVasileva',
  'DennisBauer',
  'DirkZimanky',
  'FlorianKoenig',
  'LucasMag',
  'NilsWeiser',
  'TillSchneider',
  'TobiasMueller'
];

// Holen aller Teammitglieder in der gleichen Sprache und Kategorie
const allTeamMembers = await getCollection("team", (t) => {
  // Check if team member has a valid image
  if (!t.data.image) return false;
  const hasExistingImage = existingTeamImages.some(imageName => 
    t.data.image.includes(imageName)
  );
  
  return hasExistingImage && t.data.lang === lang && t.data.category === member.data.category;
});

// Sortieren der Teammitglieder nach Kategorie und dann alphabetisch nach Name/Titel
const categoryOrder = {
  'kernteam': 1,
  'freelance': 2,
  'mentoren': 3,
  'unterstuetzer': 4,
  'alumni': 5
};

const sortedTeamMembers = allTeamMembers.sort((a, b) => {
  // Wenn beide Mitglieder in verschiedenen Kategorien sind, sortiere nach Kategorie
  if (a.data.category !== b.data.category) {
    return (categoryOrder[a.data.category as keyof typeof categoryOrder] || 99) - 
           (categoryOrder[b.data.category as keyof typeof categoryOrder] || 99);
  }
  
  // Ansonsten alphabetisch nach Titel sortieren
  const nameA = a.data.title || "";
  const nameB = b.data.title || "";
  return nameA.localeCompare(nameB, lang === 'de' ? 'de-DE' : 'en-US');
});

// Finden des aktuellen Index
const currentIndex = sortedTeamMembers.findIndex(t => t.id === member.id);

// Bestimmen des vorherigen Teammitglieds
const prevArticle = currentIndex > 0 ? {
  slug: sortedTeamMembers[currentIndex - 1].slug,
  title: sortedTeamMembers[currentIndex - 1].data.title || "",
  lang: sortedTeamMembers[currentIndex - 1].data.lang,
  collection: "team"
} : null;

// Bestimmen des nächsten Teammitglieds
const nextArticle = currentIndex < sortedTeamMembers.length - 1 ? {
  slug: sortedTeamMembers[currentIndex + 1].slug,
  title: sortedTeamMembers[currentIndex + 1].data.title || "",
  lang: sortedTeamMembers[currentIndex + 1].data.lang,
  collection: "team"
} : null;

// Get the Content component from the team member
let Content;
try {
  const rendered = await member.render();
  Content = rendered.Content;
} catch (error) {
  console.error("Error rendering team member:", error);
}

// Get the name from title
const memberName = member.data.title || "";
const memberRole = member.data.role || "";

// Create Person structured data
const personData = {
  name: memberName,
  jobTitle: memberRole,
  description: member.data.description,
  image: member.data.image ? `https://memoro.ai${member.data.image}` : undefined,
  url: `https://memoro.ai/${lang}/team/${member.slug}`,
  worksFor: {
    "@type": "Organization",
    name: "Memoro",
    url: "https://memoro.ai"
  },
  sameAs: member.data.social ? [
    member.data.social.linkedin,
    member.data.social.github,
    member.data.social.twitter
  ].filter(Boolean) : []
};
---

<Layout title={memberName} description={member.data.description} type="profile" lang={lang}>
  <StructuredData type="Person" data={personData} />
  <DetailLayout 
    backLink={{
      href: `/${lang}/team`
    }}
  >
    <Fragment slot="header">
      <header class="mb-8 pt-12 md:pt-0 flex flex-col md:flex-row items-center gap-6">
        {
          member.data.image && (
            <div class="w-40 h-40 rounded-full overflow-hidden bg-background-cardHover">
              <img
                src={member.data.image}
                alt={memberName}
                class="w-full h-full object-cover"
              />
            </div>
          )
        }
        
        <div class="text-center md:text-left">
          <h1 class="text-3xl font-bold text-text-primary">{memberName}</h1>
          {
            memberRole && (
              <p class="text-lg text-text-secondary mt-2">{memberRole}</p>
            )
          }
          
          {member.data.lastUpdated && (
            <LastUpdatedInfo date={member.data.lastUpdated} lang={lang} />
          )}
        </div>
      </header>
    </Fragment>

    {Content && <Content />}
    {!Content && <p class="text-red-500">There was an error rendering this team member's content.</p>}

    <Fragment slot="after-content">
      <SocialLinks 
        social={member.data.social} 
        lang={lang}
        title={t('team.connect') || 'Connect'}
      />
    </Fragment>
    
    <Fragment slot="footer">
      {/* Navigation zum nächsten Teammitglied */}
      <ArticleNavigation 
        prevArticle={prevArticle} 
        nextArticle={nextArticle} 
        lang={lang} 
        collection="team" 
      />
    </Fragment>
  </DetailLayout>
</Layout>