---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import TeamMemberCard from '../../../components/TeamMemberCard.astro';
import FAQSection from '../../../components/FAQSection.astro';
import HeroSection from '../../../components/HeroSection.astro';
import { useTranslations } from '../../../i18n/utils';
import fs from 'fs';
import path from 'path';

export async function getStaticPaths() {
	return ['de', 'en'].map((lang) => ({
		params: { lang },
		props: { lang },
	}));
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Error handling for content
let renderError = null;
let heroTitle = '';
let heroSubtitle = '';
let categoryNames = {};
let faqItems = [];
let teamMembers = [];

// List of team members with existing images
const existingTeamImages = [
	'AlexVasileva',
	'DennisBauer',
	'DirkZimanky',
	'FlorianKoenig',
	'LucasMag',
	'NilsWeiser',
	'TillSchneider',
	'TobiasMueller',
];

try {
	// Default category names as fallback
	const defaultCategoryNames = {
		kernteam: {
			title: lang === 'de' ? 'Kernteam' : 'Core Team',
			description:
				lang === 'de' ? 'Die treibende Kraft hinter Memoro' : 'The driving force behind Memoro',
		},
		freelance: {
			title: 'Freelance',
			description: lang === 'de' ? 'Externe Experten' : 'External experts',
		},
		mentoren: {
			title: lang === 'de' ? 'Mentoren' : 'Mentors',
			description: lang === 'de' ? 'Erfahrene Berater' : 'Experienced advisors',
		},
		unterstuetzer: {
			title: lang === 'de' ? 'Unterstützer' : 'Supporters',
			description: lang === 'de' ? 'Partner und Förderer' : 'Partners and sponsors',
		},
		alumni: {
			title: 'Alumni',
			description: lang === 'de' ? 'Ehemalige Teammitglieder' : 'Former team members',
		},
	};

	// Load team page content
	const page = await getEntry('pages', `${lang}/team`);
	if (page) {
		heroTitle = page.data?.sections?.hero?.title || t('team.title') || 'Team';
		heroSubtitle =
			page.data?.sections?.hero?.subtitle || t('team.description') || 'Das Team hinter Memoro';
		categoryNames = page.data?.sections?.categories || defaultCategoryNames;
		faqItems = page.data?.sections?.faq?.items || [];
	} else {
		heroTitle = t('team.title') || 'Team';
		heroSubtitle = t('team.description') || 'Das Team hinter Memoro';
		categoryNames = defaultCategoryNames;
	}

	// Get team members for the current language, sorted by order
	teamMembers = await getCollection('team', ({ data }) => {
		return data.lang === lang;
	});

	// Filter out team members without existing images
	teamMembers = teamMembers.filter((member) => {
		if (!member.data.image) return false;

		// Check if the image path contains any of the existing team images
		const hasExistingImage = existingTeamImages.some((imageName) =>
			member.data.image.includes(imageName)
		);

		return hasExistingImage;
	});

	teamMembers = teamMembers.sort(
		(a, b) => (parseInt(a.data.order) || 0) - (parseInt(b.data.order) || 0)
	);
} catch (error) {
	console.error('Error rendering team page:', error);
	renderError = error.message;
}

const pageTitle = heroTitle || t('team.title') || 'Team';

// Group team members by category and sort within each category
const teamByCategory = {};
teamMembers.forEach((member) => {
	const category = member.data.category || 'other';
	if (!teamByCategory[category]) {
		teamByCategory[category] = [];
	}
	teamByCategory[category].push(member);
});

// Sort members within each category by categoryOrder
Object.keys(teamByCategory).forEach((category) => {
	teamByCategory[category].sort(
		(a, b) => (a.data.categoryOrder || 999) - (b.data.categoryOrder || 999)
	);
});
---

<Layout title={pageTitle}>
	<main class="bg-background-page">
		<HeroSection
			variant="fullwidth"
			title={heroTitle}
			subtitle={heroSubtitle}
			image="/images/product_photos/Memoro-App-Office-Recording.jpg"
		/>
		<div class="max-w-7xl mx-auto px-4 py-16">
			{
				renderError ? (
					<div class="text-center py-12">
						<p class="text-red-500">Error loading content: {renderError}</p>
					</div>
				) : (
					<>
						{teamMembers.length > 0 ? (
							<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
								{teamMembers.map((member) => {
									const category = member.data.category || 'other';
									const categoryName =
										categoryNames[category]?.title || categoryNames[category] || category;
									return (
										<TeamMemberCard
											name={member.data.name || member.data.title}
											role={member.data.role}
											description={member.data.description}
											image={member.data.image}
											slug={member.slug.replace(`${lang}/`, '')}
											lang={lang}
											social={member.data.social}
											category={categoryName}
										/>
									);
								})}
							</div>
						) : (
							<div class="text-center py-12">
								<p class="text-text-secondary">
									{t('team.noMembers') || 'Noch keine Teammitglieder verfügbar.'}
								</p>
							</div>
						)}

						{faqItems.length > 0 && (
							<FAQSection
								class="mt-20"
								title={t('team.faq') || 'Häufig gestellte Fragen zum Team'}
								categories={['team']}
							/>
						)}
					</>
				)
			}
		</div>
	</main>
</Layout>
