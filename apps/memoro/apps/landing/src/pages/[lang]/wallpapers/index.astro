---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../../i18n/utils';
import { Icon } from 'astro-icon/components';
import WallpaperCard from '../../../components/WallpaperCard.astro';

export async function getStaticPaths() {
	return ['de', 'en'].map((lang) => ({
		params: { lang },
		props: { lang },
	}));
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Alle Wallpapers abrufen und nach Sprache filtern
const allWallpapers = await getCollection('wallpapers');
const filteredWallpapers = allWallpapers.filter(
	(wallpaper) => wallpaper.data.lang === lang && wallpaper.data.isActive !== false
);

// Sortieren nach Order (falls vorhanden)
const sortedWallpapers = filteredWallpapers.sort((a, b) => {
	if (a.data.order !== undefined && b.data.order !== undefined) {
		return a.data.order - b.data.order;
	}
	return 0;
});

// Gruppieren nach Kategorie
const wallpapersByCategory = sortedWallpapers.reduce((acc, wallpaper) => {
	const category = wallpaper.data.category;
	if (!acc[category]) {
		acc[category] = [];
	}
	acc[category].push(wallpaper);
	return acc;
}, {});

// Get newest wallpaper based on lastUpdated date
const newestWallpaper = sortedWallpapers.sort((a, b) => {
	const dateA = a.data.lastUpdated ? new Date(a.data.lastUpdated).getTime() : 0;
	const dateB = b.data.lastUpdated ? new Date(b.data.lastUpdated).getTime() : 0;
	return dateB - dateA;
})[0];

// Übersetzungen
const translations = {
	de: {
		title: 'Memoro Wallpapers',
		subtitle: 'Verschönern Sie Ihren Bildschirm',
		description: 'Hochwertige Wallpapers für Desktop und Smartphone - kostenlos zum Download',
		featured: 'Neues Wallpaper',
		categories: {
			nature: 'Natur',
			abstract: 'Abstrakt',
			city: 'Stadt',
			technology: 'Technologie',
			other: 'Sonstige',
		},
		resolution: 'Auflösung',
		download: 'Download',
		downloads: 'Downloads',
		viewDetails: 'Details & Download',
		availableIn: 'Verfügbar in',
		formats: 'Formaten',
	},
	en: {
		title: 'Memoro Wallpapers',
		subtitle: 'Beautify Your Screen',
		description: 'High-quality wallpapers for desktop and smartphone - free to download',
		featured: 'New Wallpaper',
		categories: {
			nature: 'Nature',
			abstract: 'Abstract',
			city: 'City',
			technology: 'Technology',
			other: 'Other',
		},
		resolution: 'Resolution',
		download: 'Download',
		downloads: 'Downloads',
		viewDetails: 'Details & Download',
		availableIn: 'Available in',
		formats: 'formats',
	},
};

const currentTranslations = translations[lang];
---

<Layout title={currentTranslations.title} description={currentTranslations.description}>
	<main class="bg-background-page">
		<!-- Hero Section -->
		<section class="max-w-7xl mx-auto px-4 pt-8 pb-16 md:pt-12 md:pb-20">
			<div class="text-center">
				<h1 class="text-hero text-text-primary mb-4 leading-tight">
					{currentTranslations.title}
				</h1>
				<p class="text-subheading text-text-secondary mb-2">
					{currentTranslations.subtitle}
				</p>
				<p class="text-lg text-text-secondary max-w-3xl mx-auto">
					{currentTranslations.description}
				</p>
			</div>
		</section>

		<!-- Newest Wallpaper -->
		{
			newestWallpaper && (
				<section class="py-8 md:py-12">
					<div class="max-w-7xl mx-auto px-4">
						<h2 class="text-heading text-text-primary text-center mb-12">
							{currentTranslations.featured}
						</h2>

						<div class="max-w-2xl mx-auto">
							<WallpaperCard
								title={newestWallpaper.data.title}
								thumbnail={newestWallpaper.data.thumbnail}
								slug={newestWallpaper.slug.replace(`${lang}/`, '')}
								formats={newestWallpaper.data.formats}
								lang={lang}
							/>
							<p class="text-text-secondary text-center mt-4 max-w-xl mx-auto">
								{newestWallpaper.data.description}
							</p>
						</div>
					</div>
				</section>
			)
		}

		<!-- Categories -->
		{
			Object.entries(wallpapersByCategory).map(([category, wallpapers]) => (
				<section class="py-12 md:py-16">
					<div class="max-w-7xl mx-auto px-4">
						<h2 class="text-heading text-text-primary mb-8">
							{currentTranslations.categories[category] || category}
						</h2>

						<div class="grid md:grid-cols-2 gap-6">
							{wallpapers.map((wallpaper) => (
								<WallpaperCard
									title={wallpaper.data.title}
									thumbnail={wallpaper.data.thumbnail}
									slug={wallpaper.slug.replace(`${lang}/`, '')}
									formats={wallpaper.data.formats}
									lang={lang}
								/>
							))}
						</div>
					</div>
				</section>
			))
		}
	</main>
</Layout>

<style>
	/* Custom styles for text classes that match the theme */
	.text-hero {
		font-size: clamp(2.5rem, 5vw, 3.5rem);
		font-weight: 700;
	}

	.text-heading {
		font-size: clamp(2rem, 4vw, 2.5rem);
		font-weight: 600;
	}

	.text-subheading {
		font-size: clamp(1.25rem, 2vw, 1.5rem);
		font-weight: 400;
	}
</style>
