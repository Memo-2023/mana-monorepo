---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import MemoroSoftwareApp from '../../components/MemoroSoftwareApp.astro';
import MemoroOrganization from '../../components/MemoroOrganization.astro';

export async function getStaticPaths() {
	return [
		{
			params: { lang: 'de' },
			props: { lang: 'de' },
		},
	];
}

const { lang } = Astro.props;

const page = await getEntry('pages', `${lang}/automatische-meetingnotizen`);

if (!page) {
	return Astro.redirect('/404');
}

const { Content } = await page.render();

const softwareAppSchema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Memoro - Automatische Meetingnotizen',
	applicationCategory: 'BusinessApplication',
	operatingSystem: 'Web, iOS, Android',
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'EUR',
		description: '600 Minuten kostenlos',
	},
	aggregateRating: {
		'@type': 'AggregateRating',
		ratingValue: '4.8',
		reviewCount: '1247',
	},
	description:
		'KI-basierte automatische Meetingnotizen mit Action Item Erkennung für deutsche Unternehmen. DSGVO-konform auf deutschen Servern.',
};

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: [
		{
			'@type': 'Question',
			name: 'Wie genau erkennt die KI Action Items und Entscheidungen?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: "Unsere KI ist speziell auf deutsche Meetings trainiert und erkennt Phrasen wie 'übernimmt', 'bis zum', 'verantwortlich', 'beschlossen', 'entschieden'. Die Genauigkeit liegt bei über 95% für Action Items.",
			},
		},
		{
			'@type': 'Question',
			name: 'Werden die Meetingnotizen automatisch an alle Teilnehmer versendet?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Ja, Sie können einstellen, dass Notizen automatisch per Email versendet oder in Slack/Teams gepostet werden. Individual oder als Gruppe - wie Sie möchten.',
			},
		},
	],
};
---

<Layout title={page.data.title} description={page.data.description} lang={lang}>
	<Fragment slot="structured-data">
		<script type="application/ld+json" set:html={JSON.stringify(softwareAppSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
		<MemoroSoftwareApp />
		<MemoroOrganization />
	</Fragment>

	<article className="max-w-none">
		<div
			className="prose prose-lg max-w-none
                prose-headings:font-semibold 
                prose-headings:text-text-heading 
                prose-p:text-text-body
                prose-a:text-primary-600 hover:prose-a:text-primary-700
                prose-strong:text-text-heading
                prose-img:rounded-lg prose-img:shadow-xl"
		>
			<Content />
		</div>
	</article>
</Layout>
