---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const statistics = await getCollection('statistics');
  
  return statistics.map((stat) => ({
    params: { 
      lang: stat.data.lang,
      slug: stat.slug
    },
    props: { stat },
  }));
}) satisfies GetStaticPaths;

const { stat } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { Content } = await stat.render();

// Format dates
const formattedPeriod = lang === 'de' 
  ? `${new Date(stat.data.period.start).toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' })} - ${new Date(stat.data.period.end).toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' })}`
  : `${new Date(stat.data.period.start).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })} - ${new Date(stat.data.period.end).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}`;

// Calculate percentage changes with proper formatting
const formatTrend = (value: number | undefined) => {
  if (!value) return '0';
  return value > 0 ? `+${value}` : `${value}`;
};
---

<Layout 
  title={stat.data.title}
  description={stat.data.description}
  lang={lang}
>
  <article class="min-h-screen bg-background-page">
    <section class="relative py-20 overflow-hidden">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <!-- Header -->
          <div class="mb-12 text-center">
            <a 
              href={`/${lang}/statistics`}
              class="inline-flex items-center text-primary-light hover:text-primary mb-6"
            >
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
              </svg>
              {lang === 'de' ? 'Zurück zu allen Berichten' : 'Back to all reports'}
            </a>
            
            <h1 class="text-4xl md:text-5xl font-bold text-text-primary mb-4">
              {stat.data.title}
            </h1>
            
            <p class="text-xl text-text-secondary mb-2">
              {stat.data.description}
            </p>
            
            <p class="text-sm text-text-muted">
              {formattedPeriod}
            </p>
          </div>

          <!-- Key Metrics -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
            <div class="bg-background-card rounded-xl p-6 text-center border border-border">
              <p class="text-4xl font-bold text-text-primary mb-2">
                {stat.data.stats.totalUsers.toLocaleString()}
              </p>
              <p class="text-sm text-text-muted">
                {lang === 'de' ? 'Gesamtnutzer' : 'Total Users'}
              </p>
            </div>
            
            <div class="bg-background-card rounded-xl p-6 text-center border border-border">
              <p class="text-4xl font-bold text-text-primary mb-2">
                {stat.data.stats.activeUsers.toLocaleString()}
              </p>
              <p class="text-sm text-text-muted">
                {lang === 'de' ? 'Aktive Nutzer' : 'Active Users'}
              </p>
            </div>
            
            <div class="bg-background-card rounded-xl p-6 text-center border border-border">
              <p class="text-4xl font-bold text-text-primary mb-2">
                {stat.data.stats.totalRecordings.toLocaleString()}
              </p>
              <p class="text-sm text-text-muted">
                {lang === 'de' ? 'Aufnahmen' : 'Recordings'}
              </p>
            </div>
            
            <div class="bg-background-card rounded-xl p-6 text-center border border-border">
              <p class="text-4xl font-bold text-text-primary mb-2">
                {(stat.data.stats.totalMinutes / 60).toFixed(0)}h
              </p>
              <p class="text-sm text-text-muted">
                {lang === 'de' ? 'Verarbeitet' : 'Processed'}
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>
</Layout>