---
import { getEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import MemoroSoftwareApp from "../../components/MemoroSoftwareApp.astro";
import MemoroOrganization from "../../components/MemoroOrganization.astro";

export async function getStaticPaths() {
  // Only create German version for now
  return [{
    params: { lang: 'de' },
    props: { lang: 'de' }
  }];
}

const { lang } = Astro.props;

// Redirect English users to features page for now
if (lang === "en") {
  return Astro.redirect("/en/features", 301);
}

const page = await getEntry("pages", `${lang}/fireflies-ai-alternative`);

if (!page) {
  return Astro.redirect(`/${lang}`, 404);
}

const { Content } = await page.render();

// Schema.org structured data for comparison and compliance
const comparisonSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `https://memoro.ai/${lang}/fireflies-ai-alternative`,
  "url": `https://memoro.ai/${lang}/fireflies-ai-alternative`,
  "name": page.data.title,
  "description": page.data.description,
  "inLanguage": lang === "de" ? "de-DE" : "en-US",
  "isPartOf": {
    "@type": "WebSite",
    "@id": "https://memoro.ai/#website",
    "url": "https://memoro.ai",
    "name": "Memoro"
  },
  "mainEntity": {
    "@type": "SoftwareApplication",
    "name": "Memoro",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web, iOS, Android, Windows, macOS",
    "offers": {
      "@type": "Offer",
      "price": "14.99",
      "priceCurrency": "EUR"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "1247"
    },
    "featureList": [
      "100% DSGVO-konform",
      "Deutsche Server",
      "Ende-zu-Ende Verschlüsselung",
      "ISO 27001 zertifiziert",
      "Betriebsrat-konform"
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Ist Fireflies.ai wirklich nicht DSGVO-konform?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Fireflies behauptet GDPR-Compliance, aber die Datenverarbeitung in den USA ist rechtlich problematisch. Nach dem Schrems-II-Urteil des EuGH sind US-Transfers ohne zusätzliche Schutzmaßnahmen nicht zulässig."
      }
    },
    {
      "@type": "Question",
      "name": "Welche Bußgelder drohen bei Nutzung von Fireflies.ai?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Bei DSGVO-Verstößen drohen Bußgelder bis zu 20 Mio. € oder 4% des weltweiten Jahresumsatzes. Zusätzlich können Betroffene Schadensersatz fordern."
      }
    },
    {
      "@type": "Question",
      "name": "Wie schnell kann ich von Fireflies zu Memoro wechseln?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Der Wechsel dauert nur 30 Minuten. Sie können alle Fireflies-Daten exportieren und in Memoro importieren. Wir unterstützen Sie kostenlos beim Migrationsprozess."
      }
    }
  ]
};
---

<Layout 
  title={page.data.title}
  description={page.data.description}
  lang={lang}
>
  <Fragment slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify(comparisonSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <MemoroSoftwareApp />
    <MemoroOrganization />
  </Fragment>

  <article class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 lg:py-20">
    <div class="prose prose-lg max-w-none 
                prose-headings:text-text-heading 
                prose-p:text-text-body
                prose-a:text-primary-600 hover:prose-a:text-primary-700
                prose-strong:text-text-heading
                prose-img:rounded-lg prose-img:shadow-xl">
      <Content />
    </div>
  </article>
</Layout>