---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import MemoroSoftwareApp from '../../components/MemoroSoftwareApp.astro';
import MemoroOrganization from '../../components/MemoroOrganization.astro';

export async function getStaticPaths() {
	// Only create German version for now
	return [
		{
			params: { lang: 'de' },
			props: { lang: 'de' },
		},
	];
}

const { lang } = Astro.props;

// Redirect English users to comparison page for now
if (lang === 'en') {
	return Astro.redirect('/en/features', 301);
}

const page = await getEntry('pages', `${lang}/otter-ai-alternative`);

if (!page) {
	return Astro.redirect(`/${lang}`, 404);
}

const { Content } = await page.render();

// Schema.org structured data for comparison page
const comparisonSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	'@id': `https://memoro.ai/${lang}/otter-ai-alternative`,
	url: `https://memoro.ai/${lang}/otter-ai-alternative`,
	name: page.data.title,
	description: page.data.description,
	inLanguage: lang === 'de' ? 'de-DE' : 'en-US',
	isPartOf: {
		'@type': 'WebSite',
		'@id': 'https://memoro.ai/#website',
		url: 'https://memoro.ai',
		name: 'Memoro',
	},
	mainEntity: {
		'@type': 'SoftwareApplication',
		name: 'Memoro',
		applicationCategory: 'BusinessApplication',
		operatingSystem: 'Web, iOS, Android, Windows, macOS',
		offers: {
			'@type': 'Offer',
			price: '12.99',
			priceCurrency: 'EUR',
		},
		aggregateRating: {
			'@type': 'AggregateRating',
			ratingValue: '4.9',
			reviewCount: '1247',
		},
	},
};

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: [
		{
			'@type': 'Question',
			name: 'Kann ich meine Otter.ai Daten zu Memoro migrieren?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Ja, absolut! Wir bieten einen kostenlosen Migrations-Service. Exportieren Sie einfach Ihre Daten aus Otter.ai und wir importieren alles automatisch in Memoro.',
			},
		},
		{
			'@type': 'Question',
			name: 'Wie viel genauer ist Memoro im Vergleich zu Otter.ai?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Memoro erreicht eine Genauigkeit von über 98% bei deutschen Gesprächen, während Otter.ai nur etwa 90% schafft - und das nur bei Englisch.',
			},
		},
		{
			'@type': 'Question',
			name: 'Warum ist DSGVO-Konformität so wichtig?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Mit Otter.ai riskieren Sie Bußgelder bis zu 20 Millionen Euro. Ihre Meeting-Daten werden in den USA verarbeitet, was nach dem Schrems-II-Urteil problematisch ist. Memoro speichert alles in Deutschland.',
			},
		},
	],
};
---

<Layout title={page.data.title} description={page.data.description} lang={lang}>
	<Fragment slot="structured-data">
		<script type="application/ld+json" set:html={JSON.stringify(comparisonSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
		<MemoroSoftwareApp />
		<MemoroOrganization />
	</Fragment>

	<article class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 lg:py-20">
		<div
			class="prose prose-lg max-w-none
                prose-headings:text-text-heading
                prose-p:text-text-body
                prose-a:text-primary-600 hover:prose-a:text-primary-700
                prose-strong:text-text-heading
                prose-img:rounded-lg prose-img:shadow-xl"
		>
			<Content />
		</div>
	</article>
</Layout>
