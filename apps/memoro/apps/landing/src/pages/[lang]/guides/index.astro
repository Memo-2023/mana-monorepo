---
import { getCollection, getEntry } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import GuideCard from "../../../components/GuideCard.astro";
import FAQSection from "../../../components/FAQSection.astro";
import CallToAction from "../../../components/CallToAction.astro";
import HeroSection from "../../../components/HeroSection.astro";
import FilterPills from "../../../components/FilterPills.astro";
import EmptyState from "../../../components/EmptyState.astro";
import { useTranslations } from "../../../i18n/utils";

export async function getStaticPaths() {
  return ['de', 'en'].map(lang => ({
    params: { lang },
    props: { lang }
  }));
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Get category from URL query parameter
const url = Astro.url;
const categoryParam = url.searchParams.get('category');

const page = await getEntry("pages", `${lang}/guides`);
if (!page) throw new Error(`Guides page content not found for language: ${lang}`);
const { frontmatter } = await page.render();

// Get guides for the current language, sorted by order
const guides = await getCollection("guides", ({ data }) => {
  return data.lang === lang;
});

const sortedGuides = guides.sort(
  (a, b) => {
    const orderA = a.data.order !== undefined ? parseInt(a.data.order) : 999;
    const orderB = b.data.order !== undefined ? parseInt(b.data.order) : 999;
    return orderA - orderB;
  }
);

// Group guides by category
const guidesByCategory = sortedGuides.reduce((acc, guide) => {
  const category = guide.data.category;
  if (!acc[category]) {
    acc[category] = [];
  }
  acc[category].push(guide);
  return acc;
}, {} as Record<string, typeof guides>);

// Get unique categories
const categories = Object.keys(guidesByCategory);

// Category labels - dynamisch basierend auf vorhandenen Kategorien
const categoryLabels = {
  de: {
    all: 'Alle',
    grundlagen: 'Grundlagen',
    aufnahme: 'Aufnahme',
    organisation: 'Organisation',
    zusammenarbeit: 'Zusammenarbeit',
    erweitert: 'Erweitert'
  },
  en: {
    all: 'All',
    basics: 'Basics',
    recording: 'Recording',
    organization: 'Organization',
    collaboration: 'Collaboration',
    advanced: 'Advanced'
  }
};

// Empty state messages
const emptyStateMessages = {
  de: {
    all: {
      title: "Noch keine Anleitungen vorhanden",
      message: "Wir arbeiten daran, hilfreiche Anleitungen für Sie zu erstellen.",
      icon: "📚"
    },
    grundlagen: {
      title: "Keine Grundlagen-Anleitungen",
      message: "Grundlegende Anleitungen werden bald hinzugefügt.",
      icon: "📖"
    },
    aufnahme: {
      title: "Keine Aufnahme-Anleitungen",
      message: "Anleitungen zur Aufnahme folgen in Kürze.",
      icon: "🎙️"
    },
    organisation: {
      title: "Keine Organisations-Anleitungen",
      message: "Anleitungen zur Organisation werden bald verfügbar sein.",
      icon: "📁"
    },
    zusammenarbeit: {
      title: "Keine Zusammenarbeits-Anleitungen",
      message: "Anleitungen zur Zusammenarbeit kommen bald.",
      icon: "👥"
    },
    erweitert: {
      title: "Keine erweiterten Anleitungen",
      message: "Erweiterte Anleitungen werden bald hinzugefügt.",
      icon: "🚀"
    }
  },
  en: {
    all: {
      title: "No guides available yet",
      message: "We're working on creating helpful guides for you.",
      icon: "📚"
    },
    basics: {
      title: "No basic guides",
      message: "Basic guides will be added soon.",
      icon: "📖"
    },
    recording: {
      title: "No recording guides",
      message: "Recording guides coming soon.",
      icon: "🎙️"
    },
    organization: {
      title: "No organization guides",
      message: "Organization guides will be available soon.",
      icon: "📁"
    },
    collaboration: {
      title: "No collaboration guides",
      message: "Collaboration guides coming soon.",
      icon: "👥"
    },
    advanced: {
      title: "No advanced guides",
      message: "Advanced guides will be added soon.",
      icon: "🚀"
    }
  }
};

// Prepare filter data
const filterOptions = [
  { value: 'all', label: categoryLabels[lang].all || 'All', count: sortedGuides.length },
  ...categories.map(category => ({
    value: category,
    label: categoryLabels[lang][category] || category,
    count: guidesByCategory[category].length
  }))
];

// Determine active filter from URL or default to 'all'
let activeFilter = 'all';
if (categoryParam) {
  // Find matching category (case-insensitive)
  const matchingCategory = categories.find(
    cat => cat.toLowerCase() === categoryParam.toLowerCase()
  );
  if (matchingCategory) {
    activeFilter = matchingCategory;
  }
}
---

<Layout title={page.data.title}>
  <main class="bg-background-page">
    <HeroSection
      variant="fullwidth"
      title={frontmatter?.sections?.hero?.title || t('guides.title')}
      subtitle={frontmatter?.sections?.hero?.subtitle || t('guides.description')}
      image="/images/product_photos/Memoro-App-Students-University-Recording.jpg"
    />
    
    <div class="max-w-7xl mx-auto px-4 py-16">
    
    <!-- Filter Pills -->
    <div class="mb-12">
      <FilterPills 
        filters={filterOptions}
        activeFilter={activeFilter}
        id="guides-filter"
      />
    </div>

    <div class="guides-grid" data-filter-content="guides-filter">
      {sortedGuides.length > 0 ? (
        <>
          <!-- All Guides -->
          <div data-type="all" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {sortedGuides.length > 0 ? (
              sortedGuides.map((guide) => (
                <GuideCard
                  title={guide.data.title}
                  description={guide.data.description}
                  difficulty={guide.data.difficulty}
                  duration={guide.data.duration}
                  category={guide.data.category}
                  slug={guide.slug.replace(`${lang}/`, '')}
                  lang={lang}
                />
              ))
            ) : (
              <div class="col-span-full">
                <EmptyState 
                  {...emptyStateMessages[lang].all}
                />
              </div>
            )}
          </div>

          <!-- Filtered Views by Category -->
          {categories.map((category) => (
            <div data-type={category} class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {guidesByCategory[category].length > 0 ? (
                guidesByCategory[category].map((guide) => (
                  <GuideCard
                    title={guide.data.title}
                    description={guide.data.description}
                    difficulty={guide.data.difficulty}
                    duration={guide.data.duration}
                    category={guide.data.category}
                    slug={guide.slug.replace(`${lang}/`, '')}
                    lang={lang}
                  />
                ))
              ) : (
                <div class="col-span-full">
                  <EmptyState 
                    {...(emptyStateMessages[lang][category] || {
                      title: `${categoryLabels[lang][category] || category} - ${lang === 'de' ? 'Keine Anleitungen' : 'No guides'}`,
                      message: lang === 'de' ? 'Anleitungen für diese Kategorie folgen bald.' : 'Guides for this category coming soon.',
                      icon: '📚'
                    })}
                  />
                </div>
              )}
            </div>
          ))}
        </>
      ) : (
        <EmptyState 
          {...emptyStateMessages[lang].all}
        />
      )}
    </div>

    <FAQSection
      class="mt-20"
      title={frontmatter?.sections?.faq?.title || "Häufig gestellte Fragen"}
      categories={['general', 'features']}
      limit={10}
    />

    <div class="text-center mt-12">
      <CallToAction
        title={frontmatter?.sections?.callToAction?.title || "Bereit loszulegen?"}
        description={frontmatter?.sections?.callToAction?.description || "Entdecke wie Memoro dir helfen kann."}
        buttonText={frontmatter?.sections?.callToAction?.buttonText || "Jetzt starten"}
        buttonLink={frontmatter?.sections?.callToAction?.buttonLink || `/${lang}/download`}
      />
    </div>
  </div>
  </main>
</Layout>