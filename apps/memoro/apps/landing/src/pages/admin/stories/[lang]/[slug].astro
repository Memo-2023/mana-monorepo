---
import { getCollection } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';

// Zugriffskontrolle
const isDev = import.meta.env.DEV;
const hasAccess = isDev || Astro.url.searchParams.has('access');

if (!hasAccess) {
  return Astro.redirect('/404');
}

export async function getStaticPaths() {
  const stories = await getCollection('_stories');
  
  return stories.map((story) => {
    const cleanSlug = story.slug.includes('/') 
      ? story.slug.split('/').pop() 
      : story.slug;
    
    return {
      params: { 
        lang: story.data.lang,
        slug: cleanSlug 
      },
      props: { story },
    };
  });
}

const { story } = Astro.props;
const { Content } = await story.render();

// Get the persona for this story
const personas = await getCollection('_personas');
const persona = personas.find(p => 
  p.slug.includes(story.data.persona) && p.data.lang === story.data.lang
);

// Status colors
function getStatusColor(status: string) {
  const colors = {
    concept: 'bg-gray-500 text-white',
    draft: 'bg-status-warning text-background-page',
    review: 'bg-status-info text-white',
    approved: 'bg-status-success text-white',
    produced: 'bg-primary text-white',
    archived: 'bg-text-muted text-white'
  };
  return colors[status as keyof typeof colors] || colors.draft;
}

// Story type colors
function getStoryTypeColor(type: string) {
  const colors = {
    'problem-solution': 'bg-green-500/20 text-green-400 border-green-500/30',
    'day-in-life': 'bg-blue-500/20 text-blue-400 border-blue-500/30',
    'transformation': 'bg-purple-500/20 text-purple-400 border-purple-500/30',
    'tutorial': 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30',
    'testimonial': 'bg-pink-500/20 text-pink-400 border-pink-500/30'
  };
  return colors[type as keyof typeof colors] || colors['problem-solution'];
}
---

<Layout title={`${story.data.title} - Story Details | Memoro`} lang={story.data.lang} noindex={true}>
  <div class="min-h-screen bg-background-page">
    <!-- Header -->
    <header class="bg-background-card border-b border-border">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="py-6">
          <!-- Breadcrumb -->
          <nav class="flex items-center space-x-2 text-sm mb-4">
            <a href="/admin" class="text-text-muted hover:text-primary transition">Admin</a>
            <span class="text-text-muted">/</span>
            <a href="/admin/stories" class="text-text-muted hover:text-primary transition">Stories</a>
            <span class="text-text-muted">/</span>
            <span class="text-text-primary">{story.data.title}</span>
          </nav>
          
          <!-- Title Section -->
          <div class="flex items-start justify-between">
            <div>
              <h1 class="text-4xl font-bold text-text-primary mb-2">{story.data.title}</h1>
              <p class="text-xl text-text-secondary">{story.data.description}</p>
              {persona && (
                <a href={`/admin/personas/${persona.data.lang}/${story.data.persona}`} 
                   class="inline-flex items-center gap-2 mt-2 text-primary hover:underline">
                  <span>Persona: {persona.data.name}</span>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              )}
            </div>
            <div class="flex items-center gap-4">
              <span class:list={[
                "px-3 py-1 rounded-full text-sm font-medium",
                getStatusColor(story.data.status)
              ]}>
                {story.data.status}
              </span>
              <span class:list={[
                "px-3 py-1 rounded-full text-sm font-medium border",
                getStoryTypeColor(story.data.storyType)
              ]}>
                {story.data.storyType}
              </span>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      
      <!-- Guidelines -->
      {story.data.visualStyle && (
        <div class="bg-gradient-to-r from-primary/10 to-primary/5 border border-primary/30 rounded-lg p-6 mb-8">
          <h2 class="text-2xl font-bold text-primary mb-4 flex items-center">
            <span class="text-3xl mr-3">📋</span>
            Guidelines
          </h2>
          
          <!-- Visual Guidelines -->
          <div class="mb-6">
            <h3 class="text-lg font-semibold text-primary mb-3">🎨 Visual Guidelines</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              <div>
                <h4 class="text-sm font-semibold text-primary mb-2">Character</h4>
                <p class="text-sm text-text-secondary">{story.data.visualStyle.characterDescription}</p>
              </div>
              <div>
                <h4 class="text-sm font-semibold text-primary mb-2">Setting</h4>
                <p class="text-sm text-text-secondary">{story.data.visualStyle.setting}</p>
              </div>
              <div>
                <h4 class="text-sm font-semibold text-primary mb-2">Mood</h4>
                <p class="text-sm text-text-secondary">{story.data.visualStyle.mood}</p>
              </div>
              {story.data.visualStyle.colorPalette && (
                <div>
                  <h4 class="text-sm font-semibold text-primary mb-2">Colors</h4>
                  <div class="flex gap-2">
                    {story.data.visualStyle.colorPalette.map((color: string) => (
                      <div 
                        class="w-8 h-8 rounded border border-border" 
                        style={`background-color: ${color}`}
                        title={color}
                      />
                    ))}
                  </div>
                </div>
              )}
              {story.data.visualStyle.lightingStyle && (
                <div>
                  <h4 class="text-sm font-semibold text-primary mb-2">Lighting</h4>
                  <p class="text-sm text-text-secondary">{story.data.visualStyle.lightingStyle}</p>
                </div>
              )}
              <div>
                <h4 class="text-sm font-semibold text-primary mb-2">Art Style</h4>
                <p class="text-sm text-text-secondary">{story.data.visualStyle.artStyle}</p>
              </div>
            </div>
          </div>
          
          <!-- Voice Guidelines -->
          <div class="border-t border-primary/20 pt-6">
            <h3 class="text-lg font-semibold text-primary mb-3">🎙️ Sprach-Guidelines</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              <div class="bg-background-card/50 rounded-lg p-4">
                <h4 class="text-sm font-semibold text-primary mb-2">Länge</h4>
                <p class="text-sm text-text-secondary">Maximal 1-2 kurze Sätze pro Szene</p>
              </div>
              <div class="bg-background-card/50 rounded-lg p-4">
                <h4 class="text-sm font-semibold text-primary mb-2">Perspektive</h4>
                <p class="text-sm text-text-secondary">Aus der Ich-Perspektive geschrieben</p>
              </div>
              <div class="bg-background-card/50 rounded-lg p-4">
                <h4 class="text-sm font-semibold text-primary mb-2">USP betonen</h4>
                <p class="text-sm text-text-secondary">Memoro's Alleinstellungsmerkmal hervorheben</p>
              </div>
              <div class="bg-primary/20 rounded-lg p-4 border border-primary/30 lg:col-span-3">
                <h4 class="text-sm font-semibold text-primary mb-2">🎯 Standard-Endsatz</h4>
                <p class="text-sm text-text-primary font-medium italic">"Darum empfehle ich: Mach ne Memo"</p>
                <p class="text-xs text-text-muted mt-1">Dieser Satz soll am Ende jeder Story gesprochen werden</p>
              </div>
            </div>
          </div>
        </div>
      )}

      <!-- Scenes -->
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-text-primary flex items-center mb-6">
          <span class="text-3xl mr-3">🎬</span>
          Szenen ({story.data.scenes.length})
        </h2>
        
        <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6">
        {story.data.scenes.map((scene: any, index: number) => (
          <div class="bg-background-card border border-border rounded-lg overflow-hidden">
            <!-- Scene Header -->
            <div class="bg-primary/10 border-b border-primary/30 p-4">
              <div class="flex items-center justify-between">
                <h3 class="text-xl font-bold text-primary">
                  Szene {scene.sceneNumber}: {scene.title}
                </h3>
                <span class="text-sm text-text-muted">
                  {scene.videoDuration || 5} Sekunden
                </span>
              </div>
            </div>
            
            <!-- Scene Content -->
            <div class="p-6 space-y-4">
              <!-- Image Prompt -->
              <div>
                <h4 class="text-sm font-semibold text-primary mb-2">📸 Image Prompt</h4>
                <div class="bg-background-cardHover rounded-lg p-4 cursor-pointer hover:bg-primary/10 transition-colors copy-field" data-content={scene.imagePrompt}>
                  <p class="text-sm text-text-secondary italic">{scene.imagePrompt}</p>
                  <span class="text-xs text-primary opacity-0 hover-text mt-2 block">Klicken zum Kopieren</span>
                </div>
              </div>
              
              <!-- Video Prompt -->
              <div>
                <h4 class="text-sm font-semibold text-primary mb-2">🎥 Video Prompt</h4>
                <div class="bg-background-cardHover rounded-lg p-4 cursor-pointer hover:bg-primary/10 transition-colors copy-field" data-content={scene.videoPrompt}>
                  <p class="text-sm text-text-secondary italic">{scene.videoPrompt}</p>
                  <span class="text-xs text-primary opacity-0 hover-text mt-2 block">Klicken zum Kopieren</span>
                </div>
              </div>
              
              <!-- Voice-Over -->
              <div>
                <h4 class="text-sm font-semibold text-primary mb-2">🎙️ Voice-Over (Deutsch)</h4>
                <div class="bg-background-cardHover rounded-lg p-4 cursor-pointer hover:bg-primary/10 transition-colors copy-field" data-content={scene.voiceOver}>
                  <p class="text-sm text-text-primary">{scene.voiceOver}</p>
                  <span class="text-xs text-primary opacity-0 hover-text mt-2 block">Klicken zum Kopieren</span>
                </div>
              </div>
              
              <!-- Text Overlay -->
              {scene.textOverlay && (
                <div>
                  <h4 class="text-sm font-semibold text-primary mb-2">📝 Text Overlay</h4>
                  <div class="bg-background-cardHover rounded-lg p-4 cursor-pointer hover:bg-primary/10 transition-colors copy-field" data-content={scene.textOverlay}>
                    <p class="text-sm text-text-secondary">{scene.textOverlay}</p>
                    <span class="text-xs text-primary opacity-0 hover-text mt-2 block">Klicken zum Kopieren</span>
                  </div>
                </div>
              )}
            </div>
          </div>
        ))}
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Sidebar -->
        <aside class="lg:col-span-1 space-y-6">
          <!-- Objectives -->
          {story.data.objectives && story.data.objectives.length > 0 && (
            <div class="bg-background-card border border-border rounded-lg p-6">
              <h3 class="text-lg font-semibold text-text-primary mb-4">🎯 Ziele</h3>
              <ul class="space-y-2">
                {story.data.objectives.map((objective: string) => (
                  <li class="text-sm text-text-secondary flex items-start">
                    <span class="text-status-success mr-2 mt-0.5">✓</span>
                    {objective}
                  </li>
                ))}
              </ul>
            </div>
          )}
          
          <!-- Key Takeaways -->
          {story.data.keyTakeaways && story.data.keyTakeaways.length > 0 && (
            <div class="bg-background-card border border-border rounded-lg p-6">
              <h3 class="text-lg font-semibold text-text-primary mb-4">💡 Key Takeaways</h3>
              <ul class="space-y-2">
                {story.data.keyTakeaways.map((takeaway: string) => (
                  <li class="text-sm text-text-secondary flex items-start">
                    <span class="text-primary mr-2">•</span>
                    {takeaway}
                  </li>
                ))}
              </ul>
            </div>
          )}
          
          <!-- Production -->
          {story.data.production && (
            <div class="bg-background-card border border-border rounded-lg p-6">
              <h3 class="text-lg font-semibold text-text-primary mb-4">🎬 Produktion</h3>
              <dl class="space-y-3">
                <div>
                  <dt class="text-xs text-text-muted uppercase">Formate</dt>
                  <dd class="mt-1">
                    <div class="flex flex-wrap gap-1">
                      {story.data.production.format.map((format: string) => (
                        <span class="text-xs bg-background-cardHover px-2 py-1 rounded">
                          {format}
                        </span>
                      ))}
                    </div>
                  </dd>
                </div>
                {story.data.production.duration && (
                  <div>
                    <dt class="text-xs text-text-muted uppercase">Dauer</dt>
                    <dd class="text-sm text-text-primary mt-1">{story.data.production.duration}</dd>
                  </div>
                )}
                {story.data.production.budget && (
                  <div>
                    <dt class="text-xs text-text-muted uppercase">Budget</dt>
                    <dd class="text-sm text-text-primary mt-1 capitalize">{story.data.production.budget}</dd>
                  </div>
                )}
                <div>
                  <dt class="text-xs text-text-muted uppercase">Priorität</dt>
                  <dd class="text-sm text-text-primary mt-1 capitalize">{story.data.production.priority}</dd>
                </div>
              </dl>
            </div>
          )}
          
          <!-- Usage -->
          {story.data.usage && (
            <div class="bg-background-card border border-border rounded-lg p-6">
              <h3 class="text-lg font-semibold text-text-primary mb-4">📢 Verwendung</h3>
              <dl class="space-y-3">
                <div>
                  <dt class="text-xs text-text-muted uppercase">Kanäle</dt>
                  <dd class="mt-1">
                    <div class="flex flex-wrap gap-1">
                      {story.data.usage.channels.map((channel: string) => (
                        <span class="text-xs bg-primary/10 text-primary px-2 py-1 rounded">
                          {channel}
                        </span>
                      ))}
                    </div>
                  </dd>
                </div>
                {story.data.usage.campaigns && story.data.usage.campaigns.length > 0 && (
                  <div>
                    <dt class="text-xs text-text-muted uppercase">Kampagnen</dt>
                    <dd class="text-sm text-text-secondary mt-1">
                      {story.data.usage.campaigns.join(', ')}
                    </dd>
                  </div>
                )}
              </dl>
            </div>
          )}
        </aside>

        <!-- Main Content Area -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Content from MDX -->
          <div class="bg-background-card border border-border rounded-lg p-6">
            <div class="prose prose-invert max-w-none">
              <Content />
            </div>
          </div>
          
          <!-- Variants -->
          {story.data.variants && story.data.variants.length > 0 && (
            <div class="bg-background-card border border-border rounded-lg p-6">
              <h3 class="text-xl font-semibold text-text-primary mb-4">🔄 Varianten</h3>
              <div class="space-y-4">
                {story.data.variants.map((variant: any) => (
                  <div class="border-l-4 border-primary pl-4">
                    <h4 class="font-medium text-text-primary mb-1">{variant.name}</h4>
                    <p class="text-sm text-text-secondary mb-2">{variant.description}</p>
                    <p class="text-xs text-text-muted">
                      Szenen: {variant.scenes.join(', ')}
                      {variant.modifications && ` | ${variant.modifications}`}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          )}
          
          <!-- Target Audience -->
          {story.data.targetAudience && story.data.targetAudience.length > 0 && (
            <div class="bg-background-card border border-border rounded-lg p-6">
              <h3 class="text-xl font-semibold text-text-primary mb-4">👥 Zielgruppe</h3>
              <div class="flex flex-wrap gap-2">
                {story.data.targetAudience.map((audience: string) => (
                  <span class="px-3 py-1 bg-background-cardHover text-text-secondary rounded-full text-sm">
                    {audience}
                  </span>
                ))}
              </div>
            </div>
          )}
          
          <!-- Meta Information -->
          <div class="bg-background-cardHover border border-border rounded-lg p-6">
            <h3 class="text-lg font-semibold text-text-primary mb-4">ℹ️ Meta-Informationen</h3>
            <dl class="grid grid-cols-2 gap-4">
              <div>
                <dt class="text-xs text-text-muted uppercase">Owner</dt>
                <dd class="text-sm text-text-primary mt-1">{story.data.owner}</dd>
              </div>
              <div>
                <dt class="text-xs text-text-muted uppercase">Autor</dt>
                <dd class="text-sm text-text-primary mt-1">{story.data.author}</dd>
              </div>
              <div>
                <dt class="text-xs text-text-muted uppercase">Erstellt</dt>
                <dd class="text-sm text-text-primary mt-1">
                  {new Date(story.data.createdAt).toLocaleDateString('de-DE')}
                </dd>
              </div>
              <div>
                <dt class="text-xs text-text-muted uppercase">Aktualisiert</dt>
                <dd class="text-sm text-text-primary mt-1">
                  {new Date(story.data.lastUpdated).toLocaleDateString('de-DE')}
                </dd>
              </div>
              {story.data.approvedAt && (
                <div>
                  <dt class="text-xs text-text-muted uppercase">Genehmigt</dt>
                  <dd class="text-sm text-text-primary mt-1">
                    {new Date(story.data.approvedAt).toLocaleDateString('de-DE')}
                  </dd>
                </div>
              )}
              <div>
                <dt class="text-xs text-text-muted uppercase">Sichtbarkeit</dt>
                <dd class="text-sm text-text-primary mt-1 capitalize">{story.data.visibility}</dd>
              </div>
            </dl>
            {story.data.tags && story.data.tags.length > 0 && (
              <div class="mt-4">
                <dt class="text-xs text-text-muted uppercase mb-2">Tags</dt>
                <div class="flex flex-wrap gap-1">
                  {story.data.tags.map((tag: string) => (
                    <span class="text-xs bg-background-page text-text-secondary px-2 py-1 rounded border border-border">
                      #{tag}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </div>
          
          <!-- Notes -->
          {story.data.notes && (
            <div class="bg-background-card border border-border rounded-lg p-6">
              <h3 class="text-lg font-semibold text-text-primary mb-4">📝 Notizen</h3>
              <div class="prose prose-sm prose-invert max-w-none">
                <p class="whitespace-pre-wrap text-text-secondary">{story.data.notes}</p>
              </div>
            </div>
          )}
        </div>
      </div>
    </main>
  </div>

  <style>
    .prose {
      color: var(--text-secondary);
    }
    .prose h1,
    .prose h2,
    .prose h3,
    .prose h4 {
      color: var(--text-primary);
    }
    .prose strong {
      color: var(--text-primary);
    }
    .prose a {
      color: var(--primary);
    }
    
    /* Copy field styles */
    .copy-field {
      position: relative;
    }
    
    .copy-field:hover .hover-text {
      opacity: 1 !important;
    }
    
    .copy-field.copied {
      background-color: rgba(34, 197, 94, 0.1) !important;
      border-color: rgba(34, 197, 94, 0.3);
    }
    
    .copy-field.copied .hover-text {
      color: rgb(34, 197, 94) !important;
      opacity: 1 !important;
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const copyFields = document.querySelectorAll('.copy-field');
      
      copyFields.forEach(field => {
        field.addEventListener('click', async function() {
          const content = this.getAttribute('data-content');
          const hoverText = this.querySelector('.hover-text');
          
          try {
            await navigator.clipboard.writeText(content || '');
            
            // Add success feedback
            this.classList.add('copied');
            if (hoverText) {
              hoverText.textContent = '✓ Kopiert!';
            }
            
            // Reset after 2 seconds
            setTimeout(() => {
              this.classList.remove('copied');
              if (hoverText) {
                hoverText.textContent = 'Klicken zum Kopieren';
              }
            }, 2000);
          } catch (err) {
            console.error('Failed to copy:', err);
            if (hoverText) {
              hoverText.textContent = 'Fehler beim Kopieren';
              hoverText.style.color = 'rgb(239, 68, 68)';
            }
          }
        });
      });
    });
  </script>
</Layout>