---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// Nur im Development-Modus oder mit speziellem Query-Parameter zugänglich
const isDev = import.meta.env.DEV;
const hasAccess = isDev || Astro.url.searchParams.has('access');

if (!hasAccess) {
  return Astro.redirect('/404');
}

// Lade alle Personas
let allPersonas = [];
try {
  allPersonas = await getCollection('_personas');
} catch (error) {
  // Collection existiert noch nicht oder ist leer
  console.log('Personas collection not found or empty');
}

// Gruppiere Personas nach Sprache
const personasByLang = allPersonas.reduce((acc, persona) => {
  const lang = persona.data.lang;
  if (!acc[lang]) acc[lang] = [];
  acc[lang].push(persona);
  return acc;
}, {} as Record<string, typeof allPersonas>);

// Sortiere Personas nach Status und Name
Object.keys(personasByLang).forEach(lang => {
  personasByLang[lang].sort((a, b) => {
    // Erst nach Status (active > draft > archived)
    const statusOrder = { active: 0, draft: 1, archived: 2 };
    const statusDiff = statusOrder[a.data.status] - statusOrder[b.data.status];
    if (statusDiff !== 0) return statusDiff;
    
    // Dann nach Name
    return a.data.name.localeCompare(b.data.name);
  });
});

// Funktion zur Farbzuweisung basierend auf Segment
function getSegmentColor(segment: string) {
  const colors = {
    primary: 'bg-primary/20 text-primary border-primary/30',
    secondary: 'bg-status-info/20 text-status-info border-status-info/30',
    tertiary: 'bg-text-muted/20 text-text-muted border-text-muted/30'
  };
  return colors[segment as keyof typeof colors] || colors.tertiary;
}

// Funktion zur Status-Farbzuweisung
function getStatusColor(status: string) {
  const colors = {
    active: 'bg-status-success',
    draft: 'bg-status-warning',
    archived: 'bg-text-muted'
  };
  return colors[status as keyof typeof colors] || colors.draft;
}
---

<Layout title="Personas Management | Memoro Admin" lang="de" noindex={true}>
  <div class="min-h-screen bg-background-page">
    <!-- Header -->
    <header class="bg-background-card border-b border-border">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center py-6">
          <div>
            <h1 class="text-3xl font-bold text-text-primary">Personas Management</h1>
            <p class="mt-1 text-sm text-text-secondary">Interne Personas für Marketing und Produktentwicklung</p>
          </div>
          <div class="flex gap-4">
            <a href="/admin" class="px-4 py-2 bg-background-cardHover text-text-primary rounded-lg hover:bg-primary hover:text-background-page transition duration-200">
              ← Zurück zum Admin
            </a>
          </div>
        </div>
      </div>
    </header>

    <!-- Statistiken -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="bg-background-card border border-border rounded-lg p-6">
          <dt class="text-sm font-medium text-text-secondary">Gesamt</dt>
          <dd class="mt-2 text-3xl font-semibold text-text-primary">{allPersonas.length}</dd>
        </div>
        <div class="bg-background-card border border-border rounded-lg p-6">
          <dt class="text-sm font-medium text-text-secondary">Aktiv</dt>
          <dd class="mt-2 text-3xl font-semibold text-status-success">
            {allPersonas.filter(p => p.data.status === 'active').length}
          </dd>
        </div>
        <div class="bg-background-card border border-border rounded-lg p-6">
          <dt class="text-sm font-medium text-text-secondary">Entwurf</dt>
          <dd class="mt-2 text-3xl font-semibold text-status-warning">
            {allPersonas.filter(p => p.data.status === 'draft').length}
          </dd>
        </div>
        <div class="bg-background-card border border-border rounded-lg p-6">
          <dt class="text-sm font-medium text-text-secondary">Archiviert</dt>
          <dd class="mt-2 text-3xl font-semibold text-text-muted">
            {allPersonas.filter(p => p.data.status === 'archived').length}
          </dd>
        </div>
      </div>
    </div>

    <!-- Personas Liste -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8 mb-12">
      {Object.entries(personasByLang).map(([lang, personas]) => (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-text-primary mb-6">
            {lang === 'de' ? 'Deutsche Personas' : 'English Personas'}
          </h2>
          
          <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-4">
            {personas.map((persona) => {
              // Extract just the filename from the slug (remove language prefix if present)
              const cleanSlug = persona.slug.includes('/') 
                ? persona.slug.split('/').pop() 
                : persona.slug;
              
              return (
              <a 
                href={`/admin/personas/${lang}/${cleanSlug}`}
                class="group bg-background-card border border-border rounded-lg p-6 hover:border-primary transition-all duration-200 hover:shadow-lg hover:shadow-primary/10 cursor-pointer"
              >
                <!-- Status Indicator -->
                <div class="flex items-start justify-between mb-4">
                  <div class="w-2 h-2 rounded-full" class:list={[getStatusColor(persona.data.status)]}></div>
                  <span class:list={[
                    "text-xs px-2 py-0.5 rounded-full border",
                    getSegmentColor(persona.data.marketing.segment)
                  ]}>
                    {persona.data.marketing.segment}
                  </span>
                </div>
                
                <!-- Minimal Info -->
                <div>
                  <h3 class="text-lg font-bold text-text-primary group-hover:text-primary transition-colors">
                    {persona.data.name}
                  </h3>
                  <p class="text-sm text-text-secondary mt-1">
                    {persona.data.professional.jobTitle}
                  </p>
                  <p class="text-xs text-text-muted mt-2">
                    {persona.data.professional.industry}
                  </p>
                </div>
                
                <!-- Hover Indicator -->
                <div class="mt-4 text-xs text-primary opacity-0 group-hover:opacity-100 transition-opacity">
                  → Details anzeigen
                </div>
              </a>
            )})}
          </div>
        </div>
      ))}
    </div>

    <!-- Info Box -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
      <div class="bg-primary/10 border border-primary/30 rounded-lg p-6">
        <h3 class="text-lg font-semibold text-primary mb-2">💡 Über Personas</h3>
        <p class="text-sm text-text-primary mb-4">
          Personas sind fiktive, aber datenbasierte Darstellungen unserer Zielkunden. Sie helfen uns bei:
        </p>
        <ul class="list-disc list-inside text-sm text-text-primary space-y-1">
          <li>Produktentwicklung: Features priorisieren basierend auf echten Bedürfnissen</li>
          <li>Marketing: Zielgerichtete Kampagnen und Messaging entwickeln</li>
          <li>Sales: Besseres Verständnis für Customer Pain Points</li>
          <li>Customer Success: Proaktive Unterstützung basierend auf Use Cases</li>
        </ul>
        <div class="mt-4 p-3 bg-status-warning/10 border border-status-warning/30 rounded">
          <p class="text-xs text-status-warning">
            <strong>⚠️ Vertraulich:</strong> Diese Personas sind nur für interne Zwecke bestimmt und 
            dürfen nicht öffentlich geteilt werden.
          </p>
        </div>
      </div>
    </div>
  </div>

  <style>
    /* Custom shadow for dark theme */
    .hover\:shadow-xl:hover {
      box-shadow: 0 20px 25px -5px rgba(248, 214, 43, 0.1), 0 10px 10px -5px rgba(248, 214, 43, 0.04);
    }
  </style>
</Layout>