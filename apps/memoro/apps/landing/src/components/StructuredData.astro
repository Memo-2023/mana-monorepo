---
export interface Props {
  type: 'Organization' | 'Article' | 'Person' | 'SoftwareApplication' | 'BreadcrumbList' | 'FAQPage' | 'LocalBusiness';
  data: any;
}

const { type, data } = Astro.props;

// Helper function to ensure proper JSON-LD formatting
function createJsonLd(schemaData: any) {
  return {
    "@context": "https://schema.org",
    ...schemaData
  };
}

let jsonLd: any;

switch (type) {
  case 'Organization':
    jsonLd = createJsonLd({
      "@type": "Organization",
      name: data.name,
      url: data.url,
      logo: data.logo,
      description: data.description,
      sameAs: data.sameAs || [],
      contactPoint: data.contactPoint,
      address: data.address,
      founder: data.founder,
      foundingDate: data.foundingDate,
      email: data.email,
      telephone: data.telephone
    });
    break;

  case 'Article':
    jsonLd = createJsonLd({
      "@type": "Article",
      headline: data.headline,
      description: data.description,
      author: data.author,
      datePublished: data.datePublished,
      dateModified: data.dateModified || data.datePublished,
      image: data.image,
      publisher: data.publisher,
      mainEntityOfPage: data.url,
      inLanguage: data.inLanguage,
      keywords: data.keywords
    });
    break;

  case 'Person':
    jsonLd = createJsonLd({
      "@type": "Person",
      name: data.name,
      jobTitle: data.jobTitle,
      description: data.description,
      image: data.image,
      url: data.url,
      worksFor: data.worksFor,
      sameAs: data.sameAs || [],
      email: data.email
    });
    break;

  case 'SoftwareApplication':
    jsonLd = createJsonLd({
      "@type": "SoftwareApplication",
      name: data.name,
      applicationCategory: data.applicationCategory,
      operatingSystem: data.operatingSystem,
      description: data.description,
      offers: data.offers,
      aggregateRating: data.aggregateRating,
      downloadUrl: data.downloadUrl,
      screenshot: data.screenshot,
      featureList: data.featureList,
      softwareVersion: data.softwareVersion,
      applicationSubCategory: data.applicationSubCategory,
      permissions: data.permissions,
      creator: data.creator
    });
    break;

  case 'BreadcrumbList':
    jsonLd = createJsonLd({
      "@type": "BreadcrumbList",
      itemListElement: data.items.map((item: any, index: number) => ({
        "@type": "ListItem",
        position: index + 1,
        name: item.name,
        item: item.url
      }))
    });
    break;

  case 'FAQPage':
    jsonLd = createJsonLd({
      "@type": "FAQPage",
      mainEntity: data.questions.map((faq: any) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer
        }
      }))
    });
    break;

  case 'LocalBusiness':
    jsonLd = createJsonLd({
      "@type": "LocalBusiness",
      name: data.name,
      image: data.image,
      url: data.url,
      telephone: data.telephone,
      address: data.address,
      geo: data.geo,
      openingHoursSpecification: data.openingHours,
      priceRange: data.priceRange
    });
    break;
}

// Remove undefined values
const cleanedJsonLd = JSON.parse(
  JSON.stringify(jsonLd, (key, value) => 
    value === undefined ? undefined : value
  )
);
---

<script type="application/ld+json" set:html={JSON.stringify(cleanedJsonLd, null, 2)} />