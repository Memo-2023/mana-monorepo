---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { Icon } from "astro-icon/components";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Only show use cases that have corresponding industry articles
const useCases = [
  {
    id: "education",
    icon: "mdi:school",
    color: "blue",
    link: `/${lang}/industries/education`
  },
  {
    id: "office",
    icon: "mdi:briefcase",
    color: "purple",
    link: `/${lang}/industries/office`
  }
];

const colorClasses = {
  blue: "bg-primary/20 text-primary",
  green: "bg-primary/20 text-primary",
  purple: "bg-primary/20 text-primary",
  yellow: "bg-primary/20 text-primary",
  pink: "bg-primary/20 text-primary",
  indigo: "bg-primary/20 text-primary"
};
---

<section class="py-20 bg-background-page">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-heading-mobile md:text-heading text-text-primary mb-4">
        {t("useCases.title")}
      </h2>
      <p class="text-subheading-mobile md:text-subheading text-text-secondary max-w-3xl mx-auto">
        {t("useCases.subtitle")}
      </p>
    </div>

    <!-- Use Case Image -->
    <div class="max-w-5xl mx-auto mt-8 mb-12">
      <div class="relative w-full" style="padding-bottom: 56.25%;">
        <img 
          src="/images/product_photos/Memoro-App-Recording-Outdoor-WalknTalk.jpg"
          alt={lang === 'de' ? 'Memoro App - Vielseitige Nutzung' : 'Memoro App - Versatile Usage'}
          class="absolute inset-0 w-full h-full object-cover rounded-2xl shadow-xl"
          width="1200"
          height="675"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>

    <!-- Grid Layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {useCases.map((useCase) => (
        <a 
          href={useCase.link}
          class="block bg-background-card rounded-xl border border-border p-6 hover:bg-background-cardHover hover:border-primary transition-all duration-300 transform hover:-translate-y-1 cursor-pointer group"
        >
          <div class={`${colorClasses[useCase.color]} rounded-full w-16 h-16 flex items-center justify-center mb-4`}>
            <Icon name={useCase.icon} class="w-8 h-8" />
          </div>
          <h3 class="text-xl font-semibold mb-3 text-text-primary group-hover:text-primary transition-colors">
            {t(`useCases.${useCase.id}.title`)}
          </h3>
          <p class="text-text-secondary mb-4 text-sm leading-relaxed">
            {t(`useCases.${useCase.id}.description`)}
          </p>
          <div class="space-y-2">
            <div class="flex items-start">
              <Icon name="mdi:check" class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" />
              <span class="text-sm text-text-secondary">{t(`useCases.${useCase.id}.benefit1`)}</span>
            </div>
            <div class="flex items-start">
              <Icon name="mdi:check" class="w-5 h-5 text-primary mr-2 flex-shrink-0 mt-0.5" />
              <span class="text-sm text-text-secondary">{t(`useCases.${useCase.id}.benefit2`)}</span>
            </div>
          </div>
          <div class="mt-4 flex items-center text-primary opacity-0 group-hover:opacity-100 transition-opacity">
            <span class="text-sm font-medium">{lang === 'de' ? 'Mehr erfahren' : 'Learn more'}</span>
            <Icon name="mdi:arrow-right" class="w-4 h-4 ml-1" />
          </div>
        </a>
      ))}
    </div>

    <!-- CTA Section -->
    <div class="text-center mt-12">
      <a href={`/${lang}/industries`} class="bg-primary text-white px-8 py-3 rounded-lg hover:bg-primary-hover transition-colors duration-DEFAULT inline-flex items-center font-medium">
        {lang === 'de' ? 'Zu allen Anwendungsfällen' : 'View all use cases'}
        <Icon name="mdi:arrow-right" class="w-5 h-5 ml-2" />
      </a>
    </div>
  </div>
</section>

