---

interface Props {
  src: string;
  alt: string;
  class?: string;
  orientation?: 'portrait' | 'landscape';
  cropTop?: number;
}

const {
  src,
  alt,
  class: className = '',
  orientation = 'portrait',
  cropTop = 40
} = Astro.props;
---

<div class={`phone-container ${orientation} ${className}`}>
  <div class="phone-frame">
    <div class="phone-speaker"></div>
    <div class="phone-screen">
      <img
        src={src}
        alt={alt}
        width="320"
        height="640"
        loading="lazy"
        decoding="async"
        style={`margin-top: -${cropTop}px;`}
      />
    </div>
  </div>
</div>

<style>
  .phone-container {
    @apply inline-block;
  }

  .phone-container.portrait .phone-frame {
    @apply relative mx-auto;
    width: 320px;
    height: 620px;
    background-color: #0a0a0a;
    border-radius: 36px;
    padding: 12px;
    box-shadow:
      0 0 0 2px #000,
      0 20px 40px rgba(0, 0, 0, 0.3),
      inset 0 0 0 1px rgba(255, 255, 255, 0.05);
  }

  .phone-container.landscape .phone-frame {
    @apply relative mx-auto;
    width: 640px;
    height: 320px;
    background-color: #0a0a0a;
    border-radius: 36px;
    padding: 12px;
    box-shadow:
      0 0 0 2px #000,
      0 20px 40px rgba(0, 0, 0, 0.3),
      inset 0 0 0 1px rgba(255, 255, 255, 0.05);
  }

  .phone-speaker {
    @apply absolute left-1/2 transform -translate-x-1/2;
    top: 24px;
    width: 60px;
    height: 5px;
    background-color: #000;
    border-radius: 3px;
  }

  .phone-container.landscape .phone-speaker {
    @apply hidden;
  }

  .phone-screen {
    @apply relative w-full h-full overflow-hidden;
    background-color: #000;
    border-radius: 36px;
    box-shadow: inset 0 0 15px rgba(0, 0, 0, 0.8);
  }

  .phone-screen img {
    @apply w-full h-full object-cover;
    border-radius: 36px;
    object-position: center;
  }


  /* Power Button */
  .phone-frame::before {
    content: '';
    @apply absolute;
    right: -3px;
    top: 120px;
    width: 3px;
    height: 60px;
    background-color: #0a0a0a;
    border-radius: 0 2px 2px 0;
    box-shadow: 1px 0 0 #000;
  }

  /* Volume Buttons */
  .phone-frame::after {
    content: '';
    @apply absolute;
    left: -3px;
    top: 120px;
    width: 3px;
    height: 40px;
    background-color: #0a0a0a;
    border-radius: 2px 0 0 2px;
    box-shadow: -1px 0 0 #000;
  }

  /* Volume Down Button */
  .phone-container.portrait .phone-frame {
    position: relative;
  }

  .phone-container.portrait .phone-frame::before {
    box-shadow: 
      1px 0 0 #000,
      0 80px 0 #0a0a0a,
      1px 80px 0 #000;
  }

  /* Responsive Scaling */
  @media (max-width: 768px) {
    .phone-container.portrait .phone-frame {
      transform: scale(0.8);
      margin: -64px auto;
    }
    
    .phone-container.landscape .phone-frame {
      transform: scale(0.6);
      margin: -96px auto;
    }
  }
</style>