---
import { getCollection } from 'astro:content';
import { getLangFromUrl } from '../i18n/utils';
import { Icon } from 'astro-icon/components';
import { marked } from 'marked';

export interface Props {
	title?: string;
	categories?: string[];
	limit?: number;
	showFeaturedOnly?: boolean;
	class?: string;
}

const {
	title,
	categories = ['general', 'features'],
	limit,
	showFeaturedOnly = false,
	class: className = '',
} = Astro.props;
const lang = getLangFromUrl(Astro.url);

// Fetch FAQs from content collection
let faqs = await getCollection('faqs', ({ data }) => {
	return data.lang === lang && categories.includes(data.category);
});

// Filter featured if requested
if (showFeaturedOnly) {
	faqs = faqs.filter((faq) => faq.data.featured);
}

// Sort by order
faqs.sort((a, b) => a.data.order - b.data.order);

// Apply limit if specified
if (limit) {
	faqs = faqs.slice(0, limit);
}

// Process markdown in answers
const processedFaqs = await Promise.all(
	faqs.map(async (faq) => {
		// Process the answer field with marked
		const processedAnswer = await marked.parse(faq.data.answer);

		// If there's MDX body content, render it
		let Content = null;
		if (faq.body && faq.body.trim()) {
			const rendered = await faq.render();
			Content = rendered.Content;
		}

		return {
			...faq,
			processedAnswer,
			Content,
		};
	})
);
---

<div class:list={['text-center', className]}>
	<div class="max-w-7xl mx-auto px-4">
		<h2 class="text-3xl font-bold mb-10 text-text-primary">
			{title || (lang === 'de' ? 'Häufig gestellte Fragen' : 'Frequently Asked Questions')}
		</h2>
		<div class="max-w-3xl mx-auto space-y-4 text-left">
			{
				processedFaqs.map((faq, index) => (
					<button class="w-full text-left" aria-expanded="false" aria-controls={`faq-${index}`}>
						<div class="group bg-background-card rounded-xl p-6 border border-border hover:bg-background-cardHover hover:border-border-hover transition-all duration-DEFAULT">
							<div class="flex justify-between items-center gap-4">
								<span class="text-lg font-semibold text-text-primary">{faq.data.question}</span>
								<svg
									class="w-5 h-5 text-primary-DEFAULT transform transition-transform duration-DEFAULT flex-shrink-0"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M19 9l-7 7-7-7"
									/>
								</svg>
							</div>
							<div
								id={`faq-${index}`}
								class="max-h-0 overflow-hidden transition-all duration-DEFAULT"
							>
								{faq.Content ? (
									<div class="mt-4">
										<faq.Content />
									</div>
								) : (
									<div
										class="mt-4 text-text-primary prose prose-sm max-w-none
                            prose-headings:text-text-primary prose-headings:font-semibold
                            prose-p:text-text-primary prose-p:leading-relaxed
                            prose-strong:text-text-primary prose-strong:font-semibold
                            prose-em:text-text-primary
                            prose-a:text-primary-DEFAULT prose-a:no-underline hover:prose-a:underline hover:prose-a:text-primary-hover
                            prose-li:text-text-primary prose-ul:text-text-primary prose-ol:text-text-primary
                            prose-li:marker:text-primary-DEFAULT
                            prose-code:text-primary-DEFAULT prose-code:bg-background-cardHover prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm
                            prose-blockquote:text-text-primary prose-blockquote:border-primary-DEFAULT prose-blockquote:bg-background-cardHover prose-blockquote:italic"
										set:html={faq.processedAnswer}
									/>
								)}
								{faq.data.relatedLinks && faq.data.relatedLinks.length > 0 && (
									<div class="mt-4 pt-4 border-t border-border">
										<p class="text-sm font-medium text-text-secondary mb-2">
											{lang === 'de' ? 'Weiterführende Links:' : 'Related links:'}
										</p>
										<div class="flex flex-wrap gap-2">
											{faq.data.relatedLinks.map((link) => (
												<a
													href={link.url}
													class="inline-flex items-center text-sm text-primary-DEFAULT hover:text-primary-hover transition-colors"
												>
													{link.title}
													<Icon name="mdi:arrow-right" class="w-4 h-4 ml-1" />
												</a>
											))}
										</div>
									</div>
								)}
							</div>
						</div>
					</button>
				))
			}
		</div>

		{
			processedFaqs.length === 0 && (
				<div class="text-center py-12">
					<p class="text-text-secondary text-base">
						{lang === 'de'
							? 'Keine FAQs für diese Kategorie gefunden.'
							: 'No FAQs found for this category.'}
					</p>
				</div>
			)
		}

		{
			limit && processedFaqs.length > 0 && (
				<div class="text-center mt-8 px-4 sm:px-0">
					<a
						href={`/${lang}/faq`}
						class="inline-flex items-center text-primary-DEFAULT hover:underline transition-all"
					>
						{lang === 'de' ? 'Alle Fragen' : 'All questions'}
						<svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M9 5l7 7-7 7"
							/>
						</svg>
					</a>
				</div>
			)
		}
	</div>
</div>

<script>
	function setupFAQ() {
		document.querySelectorAll<HTMLButtonElement>('[aria-controls^="faq-"]').forEach((button) => {
			button.addEventListener('click', () => {
				const isExpanded = button.getAttribute('aria-expanded') === 'true';
				const controlId = button.getAttribute('aria-controls');
				if (!controlId) return;

				const content = document.getElementById(controlId);
				const arrow = button.querySelector('svg');

				// Close all other FAQs
				document
					.querySelectorAll<HTMLButtonElement>('[aria-controls^="faq-"]')
					.forEach((otherButton) => {
						if (otherButton !== button) {
							otherButton.setAttribute('aria-expanded', 'false');
							const otherId = otherButton.getAttribute('aria-controls');
							if (!otherId) return;

							const otherContent = document.getElementById(otherId);
							const otherArrow = otherButton.querySelector('svg');
							if (otherContent) {
								otherContent.style.maxHeight = '0';
								otherArrow?.classList.remove('rotate-180');
							}
						}
					});

				// Toggle current FAQ
				if (content) {
					if (isExpanded) {
						button.setAttribute('aria-expanded', 'false');
						content.style.maxHeight = '0';
						arrow?.classList.remove('rotate-180');
					} else {
						button.setAttribute('aria-expanded', 'true');
						content.style.maxHeight = content.scrollHeight + 'px';
						arrow?.classList.add('rotate-180');
					}
				}
			});
		});
	}

	// Setup on initial load
	setupFAQ();

	// Setup on view transitions
	document.addEventListener('astro:page-load', setupFAQ);
</script>
