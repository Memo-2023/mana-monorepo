---
// A/B Test for Navigation Download Button
// Experiment: nav-download-button-test
// Variants:
// - control: "App herunterladen" (normal)
// - variant-b: "Kostenlos testen" (with "Neu!" badge)
// - variant-c: Pulsing button with download icon
---

<script>
	import { getExperiment, trackEvent } from '../../utils/experiments';

	async function applyNavButtonTest() {
		const variant = await getExperiment('nav-download-button-test');

		// Find the download button
		const downloadButton = document.querySelector('nav a[href*="/download"]');

		if (!downloadButton) return;

		// Track impression
		trackEvent('nav_download_button_shown', {
			experiment: 'nav-download-button-test',
			variant: variant || 'control',
		});

		if (variant === 'variant-b') {
			// Variant B: "Kostenlos testen" with "Neu!" badge
			const buttonSpan = downloadButton.querySelector('span');
			if (buttonSpan) {
				buttonSpan.innerHTML = `
          Kostenlos testen
          <span class="ml-2 bg-accent text-white text-xs px-2 py-0.5 rounded-full animate-pulse">
            Neu!
          </span>
        `;
			} else {
				downloadButton.innerHTML = `
          Kostenlos testen
          <span class="ml-2 bg-accent text-white text-xs px-2 py-0.5 rounded-full animate-pulse">
            Neu!
          </span>
        `;
			}
		} else if (variant === 'variant-c') {
			// Variant C: Pulsing button with icon
			downloadButton.classList.add('animate-pulse-slow');

			const buttonSpan = downloadButton.querySelector('span');
			if (buttonSpan) {
				buttonSpan.innerHTML = `
          <svg class="w-5 h-5 mr-2 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
          </svg>
          App herunterladen
        `;
			} else {
				downloadButton.innerHTML = `
          <svg class="w-5 h-5 mr-2 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
          </svg>
          App herunterladen
        `;
			}
		}

		// Add click tracking
		downloadButton.addEventListener('click', () => {
			trackEvent('nav_download_button_clicked', {
				experiment: 'nav-download-button-test',
				variant: variant || 'control',
				page: window.location.pathname,
			});
		});
	}

	// Apply on load
	document.addEventListener('DOMContentLoaded', applyNavButtonTest);

	// Reapply on page navigation (for Astro View Transitions)
	document.addEventListener('astro:page-load', applyNavButtonTest);
</script>

<style>
	@keyframes pulse-slow {
		0%,
		100% {
			opacity: 1;
		}
		50% {
			opacity: 0.8;
		}
	}

	.animate-pulse-slow {
		animation: pulse-slow 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
	}
</style>
