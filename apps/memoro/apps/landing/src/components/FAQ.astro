---
export interface Props {
  items?: { question: string; answer: string }[];
}

const { items = [] } = Astro.props;
---

<div class="space-y-4">
  {items.map((item) => (
    <details class="group bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
      <summary class="flex justify-between items-center cursor-pointer p-6 hover:bg-gray-50 transition-colors">
        <h3 class="font-semibold text-lg pr-4">{item.question}</h3>
        <svg
          class="w-5 h-5 text-gray-500 transition-transform group-open:rotate-180"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 9l-7 7-7-7"
          />
        </svg>
      </summary>
      <div class="px-6 pb-6">
        <p class="text-gray-600">{item.answer}</p>
      </div>
    </details>
  ))}
</div>