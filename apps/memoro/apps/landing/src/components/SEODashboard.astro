---
// SEO Dashboard Component
// Zeigt die gesammelten SEO-Daten in einem übersichtlichen Dashboard

interface Props {
  dataFile?: string;
}

const { dataFile = 'aggregated-seo-data.json' } = Astro.props;

// In Production würdest du die Daten vom Server laden
// Für Demo-Zwecke zeigen wir Mock-Daten
const mockData = {
  lastUpdate: new Date().toISOString(),
  summary: {
    totalClicks: 1247,
    totalImpressions: 45632,
    avgCTR: 2.73,
    avgPosition: 18.4,
    trendsWeek: {
      clicks: +23,
      impressions: +12,
      position: -2.3
    }
  },
  trackedKeywords: [
    {
      keyword: "meeting protokoll software",
      position: 8.2,
      clicks: 342,
      impressions: 5421,
      trend: "improving",
      change: -3.1
    },
    {
      keyword: "ki transkription",
      position: 15.7,
      clicks: 89,
      impressions: 2341,
      trend: "stable",
      change: +0.2
    },
    {
      keyword: "automatische protokollierung",
      position: 22.4,
      clicks: 45,
      impressions: 1876,
      trend: "improving",
      change: -5.2
    },
    {
      keyword: "gesprächsprotokoll app",
      position: 31.2,
      clicks: 12,
      impressions: 892,
      trend: "new",
      change: null
    }
  ],
  topPages: [
    {
      page: "/de/meeting-protokoll-software",
      clicks: 423,
      impressions: 8921,
      ctr: 4.74,
      avgPosition: 12.3
    },
    {
      page: "/de/",
      clicks: 567,
      impressions: 15234,
      ctr: 3.72,
      avgPosition: 24.1
    },
    {
      page: "/de/features",
      clicks: 234,
      impressions: 6789,
      ctr: 3.45,
      avgPosition: 28.7
    }
  ],
  weeklyProgress: [
    { date: "Mo", clicks: 156, position: 19.2 },
    { date: "Di", clicks: 189, position: 18.7 },
    { date: "Mi", clicks: 201, position: 18.4 },
    { date: "Do", clicks: 178, position: 18.9 },
    { date: "Fr", clicks: 213, position: 17.8 },
    { date: "Sa", clicks: 145, position: 18.2 },
    { date: "So", clicks: 165, position: 18.4 }
  ]
};
---

<div class="seo-dashboard bg-background-page rounded-2xl p-6 my-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-2xl font-bold text-text-primary">SEO Performance Dashboard</h2>
      <p class="text-text-secondary">Letzte Aktualisierung: {new Date(mockData.lastUpdate).toLocaleString('de-DE')}</p>
    </div>
    <button class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-hover transition-colors flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
      </svg>
      Aktualisieren
    </button>
  </div>

  {/* Haupt-Metriken */}
  <div class="grid md:grid-cols-4 gap-4 mb-8">
    <div class="bg-background-card border border-border rounded-xl p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-text-secondary text-sm">Klicks (7 Tage)</span>
        <span class={`text-xs px-2 py-1 rounded-full ${mockData.summary.trendsWeek.clicks > 0 ? 'bg-green-500/20 text-green-500' : 'bg-red-500/20 text-red-500'}`}>
          {mockData.summary.trendsWeek.clicks > 0 ? '+' : ''}{mockData.summary.trendsWeek.clicks}%
        </span>
      </div>
      <p class="text-2xl font-bold text-text-primary">{mockData.summary.totalClicks.toLocaleString('de-DE')}</p>
    </div>

    <div class="bg-background-card border border-border rounded-xl p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-text-secondary text-sm">Impressionen</span>
        <span class={`text-xs px-2 py-1 rounded-full ${mockData.summary.trendsWeek.impressions > 0 ? 'bg-green-500/20 text-green-500' : 'bg-red-500/20 text-red-500'}`}>
          {mockData.summary.trendsWeek.impressions > 0 ? '+' : ''}{mockData.summary.trendsWeek.impressions}%
        </span>
      </div>
      <p class="text-2xl font-bold text-text-primary">{mockData.summary.totalImpressions.toLocaleString('de-DE')}</p>
    </div>

    <div class="bg-background-card border border-border rounded-xl p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-text-secondary text-sm">Ø CTR</span>
      </div>
      <p class="text-2xl font-bold text-text-primary">{mockData.summary.avgCTR.toFixed(2)}%</p>
    </div>

    <div class="bg-background-card border border-border rounded-xl p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-text-secondary text-sm">Ø Position</span>
        <span class={`text-xs px-2 py-1 rounded-full ${mockData.summary.trendsWeek.position < 0 ? 'bg-green-500/20 text-green-500' : 'bg-red-500/20 text-red-500'}`}>
          {mockData.summary.trendsWeek.position > 0 ? '+' : ''}{mockData.summary.trendsWeek.position.toFixed(1)}
        </span>
      </div>
      <p class="text-2xl font-bold text-text-primary">{mockData.summary.avgPosition.toFixed(1)}</p>
    </div>
  </div>

  <div class="grid lg:grid-cols-2 gap-6">
    {/* Tracked Keywords */}
    <div class="bg-background-card border border-border rounded-xl p-5">
      <h3 class="text-lg font-semibold text-text-primary mb-4">Überwachte Keywords</h3>
      <div class="space-y-3">
        {mockData.trackedKeywords.map((keyword) => (
          <div class="flex items-center justify-between p-3 bg-background-page rounded-lg">
            <div class="flex-1">
              <p class="font-medium text-text-primary">{keyword.keyword}</p>
              <div class="flex items-center gap-4 mt-1">
                <span class="text-xs text-text-secondary">Position: {keyword.position.toFixed(1)}</span>
                <span class="text-xs text-text-secondary">Klicks: {keyword.clicks}</span>
              </div>
            </div>
            <div class="flex items-center gap-2">
              {keyword.trend === 'improving' && (
                <div class="flex items-center gap-1 text-green-500">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                  </svg>
                  <span class="text-xs">{Math.abs(keyword.change).toFixed(1)}</span>
                </div>
              )}
              {keyword.trend === 'stable' && (
                <div class="text-yellow-500">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14" />
                  </svg>
                </div>
              )}
              {keyword.trend === 'new' && (
                <span class="text-xs px-2 py-1 bg-blue-500/20 text-blue-500 rounded-full">NEU</span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    {/* Top Pages */}
    <div class="bg-background-card border border-border rounded-xl p-5">
      <h3 class="text-lg font-semibold text-text-primary mb-4">Top Seiten</h3>
      <div class="space-y-3">
        {mockData.topPages.map((page, index) => (
          <div class="p-3 bg-background-page rounded-lg">
            <div class="flex items-start justify-between">
              <div class="flex-1">
                <p class="font-medium text-text-primary text-sm truncate">{page.page}</p>
                <div class="grid grid-cols-2 gap-2 mt-2">
                  <div>
                    <span class="text-xs text-text-secondary">Klicks</span>
                    <p class="text-sm font-semibold text-text-primary">{page.clicks}</p>
                  </div>
                  <div>
                    <span class="text-xs text-text-secondary">CTR</span>
                    <p class="text-sm font-semibold text-text-primary">{page.ctr.toFixed(2)}%</p>
                  </div>
                </div>
              </div>
              <div class="text-right">
                <span class="text-xs text-text-secondary">Position</span>
                <p class="text-lg font-bold text-text-primary">{page.avgPosition.toFixed(1)}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  {/* Wochenverlauf */}
  <div class="mt-6 bg-background-card border border-border rounded-xl p-5">
    <h3 class="text-lg font-semibold text-text-primary mb-4">Wochenverlauf</h3>
    <div class="grid grid-cols-7 gap-2">
      {mockData.weeklyProgress.map((day) => (
        <div class="text-center">
          <p class="text-xs text-text-secondary mb-2">{day.date}</p>
          <div class="bg-background-page rounded-lg p-3">
            <p class="text-lg font-bold text-text-primary">{day.clicks}</p>
            <p class="text-xs text-text-secondary">Klicks</p>
          </div>
          <div class="mt-2 text-xs text-text-secondary">
            Pos: {day.position.toFixed(1)}
          </div>
        </div>
      ))}
    </div>
  </div>

  {/* Action Items */}
  <div class="mt-6 bg-gradient-to-r from-yellow-500/10 to-amber-500/10 border border-yellow-500/20 rounded-xl p-4">
    <h4 class="font-semibold text-text-primary mb-2">🎯 Empfohlene Aktionen</h4>
    <ul class="space-y-1 text-sm text-text-secondary">
      <li>• "meeting protokoll software" rankt auf Platz 8 - optimiere Meta-Description für höhere CTR</li>
      <li>• Neue Chance: "gesprächsprotokoll app" - erstelle dedizierte Landing Page</li>
      <li>• Homepage CTR nur 3.72% - A/B Test für Title Tag starten</li>
    </ul>
  </div>
</div>

<style>
  .seo-dashboard {
    font-family: system-ui, -apple-system, sans-serif;
  }
</style>