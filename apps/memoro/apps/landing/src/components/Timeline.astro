---
export interface Props {
  items: Array<{
    date: string;
    title: string;
    description: string;
  }>;
}

const { items } = Astro.props;
---

<div class="relative">
  <div class="absolute left-8 top-0 bottom-0 w-0.5 bg-border-subtle"></div>
  
  <div class="space-y-12">
    {items.map((item, index) => (
      <div class="relative flex items-start gap-8">
        <div class="relative z-10 flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-background-card border-2 border-accent-primary">
          <div class="h-3 w-3 rounded-full bg-accent-primary"></div>
        </div>
        
        <div class="flex-1 pb-8">
          <time class="text-sm font-medium text-accent-primary">{item.date}</time>
          <h3 class="mt-1 text-lg font-semibold text-text-primary">{item.title}</h3>
          <p class="mt-2 text-text-secondary">{item.description}</p>
        </div>
      </div>
    ))}
  </div>
</div>