---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { Icon } from 'astro-icon/components';
import PhoneFrame from './PhoneFrame.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-20 bg-background-page">
	<div class="max-w-7xl mx-auto px-4">
		<div class="text-center mb-12">
			<h2 class="text-heading-mobile md:text-heading text-text-primary mb-4">
				{t('howItWorks.title')}
			</h2>
			<p class="text-subheading-mobile md:text-subheading text-text-secondary max-w-3xl mx-auto">
				{t('howItWorks.subtitle')}
			</p>
		</div>

		<!-- Content -->
		<div class="max-w-6xl mx-auto space-y-16 md:space-y-24">
			<!-- Step 1: Text Left, Phone Right -->
			<div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center mt-8 md:mt-16 lg:mt-20">
				<div
					class="text-center md:text-left max-w-md mx-auto md:mx-0 md:ml-auto flex flex-col justify-center h-full"
				>
					<div class="">
						<div
							class="bg-primary rounded-full w-20 h-20 flex items-center justify-center mx-auto md:mx-0 mb-4"
						>
							<Icon name="mdi:microphone" class="w-10 h-10 text-white" />
						</div>
						<h3 class="text-2xl font-semibold mb-2 text-text-primary">
							{t('howItWorks.meetings.step1.title')}
						</h3>
						<p class="text-lg text-text-secondary max-w-sm mx-auto md:mx-0">
							{t('howItWorks.meetings.step1.description')}
						</p>
					</div>
				</div>
				<div class="flex justify-center items-center max-w-md mx-auto md:mx-0 md:mr-auto">
					<div class="relative inline-block">
						<div
							class="absolute inset-0 bg-gradient-radial from-white/20 to-transparent blur-3xl scale-150"
						>
						</div>
						<PhoneFrame
							src="/images/screenshots/Memoro-Screenshot-RecordingScreen-RecordingRunning.PNG"
							alt="Aufnahme läuft"
							class="scale-105 md:scale-110 relative z-10"
						/>
					</div>
				</div>
			</div>

			<!-- Step 2: Phone Left, Text Right -->
			<div class="grid md:grid-cols-2 gap-12 md:gap-32 items-center">
				<div
					class="flex justify-center items-center order-2 md:order-1 max-w-md mx-auto md:mx-0 md:ml-auto"
				>
					<div class="relative inline-block">
						<div
							class="absolute inset-0 bg-gradient-radial from-white/20 to-transparent blur-3xl scale-150"
						>
						</div>
						<PhoneFrame
							src="/images/screenshots/Memoro-Screenshot-MemoDetailPage-Memo-Transcript.PNG"
							alt="Transkription"
							class="scale-105 md:scale-110 relative z-10"
						/>
					</div>
				</div>
				<div
					class="text-center md:text-left order-1 md:order-2 max-w-md mx-auto md:mx-0 md:mr-auto flex flex-col justify-center h-full"
				>
					<div class="">
						<div
							class="bg-primary rounded-full w-20 h-20 flex items-center justify-center mx-auto md:mx-0 mb-4"
						>
							<Icon name="mdi:brain" class="w-10 h-10 text-white" />
						</div>
						<h3 class="text-2xl font-semibold mb-2 text-text-primary">
							{t('howItWorks.meetings.step2.title')}
						</h3>
						<p class="text-lg text-text-secondary max-w-sm mx-auto md:mx-0">
							{t('howItWorks.meetings.step2.description')}
						</p>
					</div>
				</div>
			</div>

			<!-- Step 3: Text Left, Phone Right -->
			<div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
				<div
					class="text-center md:text-left max-w-md mx-auto md:mx-0 md:ml-auto flex flex-col justify-center h-full"
				>
					<div>
						<div
							class="bg-primary rounded-full w-20 h-20 flex items-center justify-center mx-auto md:mx-0 mb-4"
						>
							<Icon name="mdi:file-document-outline" class="w-10 h-10 text-white" />
						</div>
						<h3 class="text-2xl font-semibold mb-2 text-text-primary">
							{t('howItWorks.meetings.step3.title')}
						</h3>
						<p class="text-lg text-text-secondary max-w-sm mx-auto md:mx-0">
							{t('howItWorks.meetings.step3.description')}
						</p>
					</div>
				</div>
				<div class="flex justify-center items-center max-w-md mx-auto md:mx-0 md:mr-auto">
					<div class="relative inline-block">
						<div
							class="absolute inset-0 bg-gradient-radial from-white/20 to-transparent blur-3xl scale-150"
						>
						</div>
						<PhoneFrame
							src="/images/screenshots/Memoro-Screenshot-MemoDetailPage-TableOfContent-Memories.PNG"
							alt="Strukturierte Zusammenfassung"
							class="scale-105 md:scale-110 relative z-10"
						/>
					</div>
				</div>
			</div>
		</div>

		<!-- CTA Button to Meeting-Protokoll Landing Page -->
		<div class="text-center mt-16">
			<a
				href={`/${lang}/meeting-protokoll-software`}
				class="inline-flex items-center gap-2 px-8 py-4 bg-primary hover:bg-primary-hover text-white font-semibold rounded-lg transition-all duration-300 shadow-lg hover:shadow-xl"
			>
				<Icon name="mdi:file-document-check" class="w-5 h-5" />
				<span
					>{
						lang === 'de'
							? 'Automatische Meeting-Protokolle entdecken'
							: 'Discover Automatic Meeting Minutes'
					}</span
				>
			</a>
			<p class="text-sm text-text-secondary mt-3">
				{
					lang === 'de'
						? 'Erfahren Sie, wie Sie 3+ Stunden pro Woche sparen'
						: 'Learn how to save 3+ hours per week'
				}
			</p>
		</div>
	</div>
</section>
