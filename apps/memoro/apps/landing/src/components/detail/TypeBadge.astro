---
export interface Props {
	type: 'private' | 'company' | 'network' | 'press';
	lang: string;
}

const { type, lang } = Astro.props;

// Color schemes for testimonial types
const typeColors = {
	private: 'bg-blue-100 text-blue-700 border-blue-200',
	company: 'bg-green-100 text-green-700 border-green-200',
	network: 'bg-purple-100 text-purple-700 border-purple-200',
	press: 'bg-orange-100 text-orange-700 border-orange-200',
};

// Labels for testimonial types
const typeLabels = {
	de: {
		private: 'Privat',
		company: 'Unternehmen',
		network: 'Netzwerk',
		press: 'Presse',
	},
	en: {
		private: 'Private',
		company: 'Company',
		network: 'Network',
		press: 'Press',
	},
};

const color = typeColors[type] || 'bg-primary/10 text-primary border-primary/20';
const label = typeLabels[lang]?.[type] || type;
---

<span class={`text-sm px-3 py-1 rounded-full font-medium border ${color}`}>
	{label}
</span>
