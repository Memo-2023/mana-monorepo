---
import { useTranslations } from '../../i18n/utils';

export interface Props {
	difficulty: 'beginner' | 'intermediate' | 'advanced';
	duration?: string;
	category?: string;
	lang: string;
}

const { difficulty, duration, category, lang } = Astro.props;
const t = useTranslations(lang);

// Color schemes for difficulty levels
const difficultyColors = {
	beginner: 'bg-success/30 text-success border border-success',
	intermediate: 'bg-primary/30 text-primary border border-primary',
	advanced: 'bg-danger/30 text-danger border border-danger',
};
---

<div class="flex flex-wrap items-center gap-3">
	<span class={`px-3 py-1 rounded-full text-sm font-medium ${difficultyColors[difficulty]}`}>
		{t(`guides.difficulty.${difficulty}`) || difficulty}
	</span>

	{duration && <span class="text-sm text-text-secondary">⏱️ {duration}</span>}

	{category && <span class="text-sm text-text-secondary">📂 {category}</span>}
</div>
