---
export interface Props {
	href: string;
	title: string;
	class?: string;
}

const { href, title, class: className = '' } = Astro.props;
---

<style>
	.scroll-progress-indicator {
		background: conic-gradient(
			from -90deg at 50% 50%,
			var(--progress-color, #ef4444) calc(var(--scroll-progress, 0) * 360deg),
			transparent calc(var(--scroll-progress, 0) * 360deg)
		);
	}
</style>

<!-- Desktop: Platzhalter für den fixed Header -->
<div class="hidden md:block h-[49px]"></div>

<!-- Desktop: Fixed Header at top -->
<div
	class={`hidden md:block fixed top-[65px] left-0 right-0 z-30 bg-background-page/80 backdrop-blur-xl ${className}`}
>
	<div class="max-w-4xl mx-auto px-4 py-2">
		<div class="flex items-center gap-3">
			<a
				href={href}
				class="inline-flex items-center justify-center w-9 h-9 rounded-lg hover:bg-background-cardHover transition-colors group"
				aria-label="Zurück"
			>
				<svg
					class="w-5 h-5 text-text-secondary group-hover:text-text-primary transition-all group-hover:-translate-x-0.5"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
					aria-hidden="true"
				>
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"
					></path>
				</svg>
			</a>

			<h1 class="text-base font-semibold text-text-primary truncate">
				{title}
			</h1>
		</div>
	</div>
</div>

<!-- Mobile: Fixed pill at bottom above nav -->
<div
	id="back-button-pill"
	class={`md:hidden fixed bottom-[72px] left-1/2 -translate-x-1/2 z-40 w-[calc(100%-2rem)] max-w-sm ${className}`}
	style="--scroll-progress: 0"
>
	{/* Progress border layer - outside the pill */}
	<div class="absolute -inset-[5px] rounded-full p-[5px] overflow-hidden z-[-1]">
		<div
			class="absolute inset-0 rounded-full scroll-progress-indicator"
			style="--scroll-progress: 0"
		>
		</div>
	</div>

	<div
		class="bg-background-card/95 backdrop-blur-xl border border-border/50 rounded-full shadow-2xl px-4 py-3"
	>
		<div class="flex items-center gap-3">
			<a
				href={href}
				class="inline-flex items-center justify-center w-7 h-7 rounded-full hover:bg-background-cardHover/50 transition-colors group"
				aria-label="Zurück"
			>
				<svg
					class="w-5 h-5 text-text-secondary group-hover:text-text-primary transition-all group-hover:-translate-x-0.5"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
					aria-hidden="true"
				>
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"
					></path>
				</svg>
			</a>

			<h1 class="text-base font-semibold text-text-primary truncate flex-1">
				{title}
			</h1>
		</div>
	</div>
</div>

<script>
	// Check if back button exists on page
	const backButtonPill = document.getElementById('back-button-pill');
	const mobileNavPill = document.getElementById('mobile-nav-pill');

	if (backButtonPill && window.innerWidth < 768) {
		// Adjust nav height and hide scroll progress when back button is present
		if (mobileNavPill) {
			// Remove progress border from nav
			const navProgressBorder = mobileNavPill.querySelector('.absolute.-inset-\\[5px\\]');
			if (navProgressBorder) {
				navProgressBorder.style.display = 'none';
			}

			// Make nav pill flatter (same height as back button)
			const navInner = mobileNavPill.querySelector('.mobile-nav-pill-inner');
			if (navInner) {
				// Reduce padding to match back button
				const navLinks = navInner.querySelectorAll('a, button');
				navLinks.forEach((link) => {
					// Change py-4 to py-3 for the container elements
					if (link.classList.contains('py-4')) {
						link.classList.remove('py-4');
						link.classList.add('py-3');
					}
				});

				// Adjust text and icon sizes
				const navTexts = navInner.querySelectorAll('span');
				navTexts.forEach((text) => {
					if (text.classList.contains('text-lg')) {
						text.classList.remove('text-lg');
						text.classList.add('text-base');
					}
				});

				// Adjust logo size
				const logo = navInner.querySelector('img');
				if (logo) {
					logo.classList.remove('h-6', 'w-6');
					logo.classList.add('h-5', 'w-5');
					logo.setAttribute('width', '20');
					logo.setAttribute('height', '20');
				}

				// Adjust menu icon
				const menuIcon = navInner.querySelector('svg');
				if (menuIcon) {
					menuIcon.classList.remove('w-6', 'h-6');
					menuIcon.classList.add('w-5', 'h-5');
				}
			}
		}

		// Copy scroll progress functionality to back button
		const progressIndicators = backButtonPill.querySelectorAll('.scroll-progress-indicator');

		function updateScrollProgress() {
			if (backButtonPill && progressIndicators.length > 0) {
				// Get footer element to exclude it from calculation
				const footer = document.querySelector('footer');
				const footerHeight = footer ? footer.offsetHeight : 0;

				// Calculate scrollable height excluding footer
				const totalHeight = document.documentElement.scrollHeight;
				const scrollableHeight = totalHeight - window.innerHeight - footerHeight;
				const scrollPosition = window.scrollY;
				const scrollProgress =
					scrollableHeight > 0 ? Math.min(scrollPosition / scrollableHeight, 1) : 0;

				// Update progress for all indicators
				backButtonPill.style.setProperty('--scroll-progress', scrollProgress.toString());
				progressIndicators.forEach((indicator) => {
					indicator.style.setProperty('--scroll-progress', scrollProgress.toString());
				});

				// Check if we're in the footer area
				const footerTop = footer ? footer.getBoundingClientRect().top : Infinity;
				const isInFooter = footerTop <= window.innerHeight;

				// Calculate color based on progress
				let color;
				if (isInFooter) {
					// Default gray color when in footer
					color = `rgba(148, 163, 184, 0.3)`;
				} else if (scrollProgress < 0.25) {
					// Bright Red to Bright Orange (0-25%)
					const t = scrollProgress / 0.25;
					color = `rgba(${Math.round(255 - (255 - 255) * t)}, ${Math.round(0 + (165 - 0) * t)}, ${Math.round(0)}, 0.3)`;
				} else if (scrollProgress < 0.5) {
					// Bright Orange to Bright Yellow (25-50%)
					const t = (scrollProgress - 0.25) / 0.25;
					color = `rgba(${Math.round(255)}, ${Math.round(165 + (255 - 165) * t)}, ${Math.round(0)}, 0.3)`;
				} else if (scrollProgress < 0.75) {
					// Bright Yellow to Bright Lime Green (50-75%)
					const t = (scrollProgress - 0.5) / 0.25;
					color = `rgba(${Math.round(255 - (255 - 173) * t)}, ${Math.round(255)}, ${Math.round(0 + (47 - 0) * t)}, 0.3)`;
				} else {
					// Bright Lime Green to Bright Green (75-100%)
					const t = (scrollProgress - 0.75) / 0.25;
					color = `rgba(${Math.round(173 - (173 - 0) * t)}, ${Math.round(255)}, ${Math.round(47 - (47 - 0) * t)}, 0.3)`;
				}

				progressIndicators.forEach((indicator) => {
					indicator.style.setProperty('--progress-color', color);
				});
			}
		}

		// Update on scroll
		window.addEventListener('scroll', updateScrollProgress);
		// Initial update
		updateScrollProgress();
	}
</script>
