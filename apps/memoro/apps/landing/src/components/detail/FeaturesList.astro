---
import { Icon } from 'astro-icon/components';

export interface Props {
	features: string[];
	title?: string;
	icon?: string;
	iconColor?: string;
	columns?: 1 | 2 | 3;
	variant?: 'default' | 'compact' | 'card';
}

const {
	features,
	title,
	icon = '✓',
	iconColor = 'text-primary-DEFAULT',
	columns = 2,
	variant = 'default',
} = Astro.props;

if (!features || features.length === 0) return null;

const gridCols = {
	1: 'grid-cols-1',
	2: 'grid-cols-1 md:grid-cols-2',
	3: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
};
---

{
	variant === 'card' ? (
		<div class="mb-8 p-6 bg-background-page rounded-lg">
			{title && <h2 class="text-xl font-semibold text-text-primary mb-4">{title}</h2>}
			<ul class={`grid ${gridCols[columns]} gap-4`}>
				{features.map((feature) => (
					<li class="flex items-start gap-2">
						<span class={`${iconColor} mt-1 flex-shrink-0`}>{icon}</span>
						<span class="text-text-secondary">{feature}</span>
					</li>
				))}
			</ul>
		</div>
	) : variant === 'compact' ? (
		<div class="space-y-2">
			{title && <h3 class="text-sm font-medium text-text-primary">{title}</h3>}
			<ul class="space-y-1">
				{features.map((feature) => (
					<li class="flex items-start gap-2">
						<span class={`${iconColor} text-sm`}>{icon}</span>
						<span class="text-sm text-text-secondary">{feature}</span>
					</li>
				))}
			</ul>
		</div>
	) : (
		<div>
			{title && (
				<h3 class="text-lg font-semibold text-text-primary mb-4 flex items-center">
					<Icon name="mdi:check-circle" class={`${iconColor} mr-2 w-5 h-5`} />
					{title}
				</h3>
			)}
			<ul class={`grid ${gridCols[columns]} gap-4`}>
				{features.map((feature) => (
					<li class="flex items-start gap-3">
						<span class={`${iconColor} mt-0.5`}>{icon}</span>
						<span class="text-text-secondary">{feature}</span>
					</li>
				))}
			</ul>
		</div>
	)
}
