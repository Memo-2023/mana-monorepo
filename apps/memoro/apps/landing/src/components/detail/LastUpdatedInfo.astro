---
import { useTranslations } from '../../i18n/utils';

export interface Props {
  date: Date | string;
  lang: string;
  prefix?: string;
  variant?: 'default' | 'inline' | 'footer';
  showTime?: boolean;
}

const { 
  date, 
  lang, 
  prefix,
  variant = 'default',
  showTime = false
} = Astro.props;

const t = useTranslations(lang);
const dateObj = typeof date === 'string' ? new Date(date) : date;

// Default prefix
const defaultPrefix = t('contracts.lastUpdated') || 'Last updated';
const finalPrefix = prefix || defaultPrefix;

// Format options
const dateOptions: Intl.DateTimeFormatOptions = {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
};

if (showTime) {
  dateOptions.hour = '2-digit';
  dateOptions.minute = '2-digit';
}

const formattedDate = dateObj.toLocaleDateString(
  lang === 'de' ? 'de-DE' : 'en-US',
  dateOptions
);
---

{variant === 'footer' ? (
  <div class="mt-8 pt-8 border-t border-border">
    <p class="text-sm text-text-muted">
      {finalPrefix}: {' '}
      <time datetime={dateObj.toISOString()}>
        {formattedDate}
      </time>
    </p>
  </div>
) : variant === 'inline' ? (
  <span class="text-sm text-text-tertiary">
    {finalPrefix}: <time datetime={dateObj.toISOString()}>{formattedDate}</time>
  </span>
) : (
  <p class="text-sm text-text-secondary mt-4">
    {finalPrefix}: {' '}
    <time datetime={dateObj.toISOString()} class="font-medium">
      {formattedDate}
    </time>
  </p>
)}