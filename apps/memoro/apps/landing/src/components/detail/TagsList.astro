---
export interface Props {
	tags: string[];
	variant?: 'default' | 'compact';
	linkBase?: string;
}

const { tags, variant = 'default', linkBase } = Astro.props;

if (!tags || tags.length === 0) return null;
---

{
	variant === 'default' ? (
		<div class="mt-8 pt-6 border-t border-border">
			<div class="flex flex-wrap gap-2">
				{tags.map((tag) =>
					linkBase ? (
						<a
							href={`${linkBase}?tag=${encodeURIComponent(tag)}`}
							class="inline-block px-3 py-1 bg-background-cardHover text-text-secondary hover:text-text-primary hover:bg-primary/10 transition-colors rounded-full text-sm border border-border"
						>
							#{tag}
						</a>
					) : (
						<span class="px-3 py-1 bg-background-cardHover text-text-secondary hover:text-text-primary transition-colors rounded-full text-sm border border-border">
							#{tag}
						</span>
					)
				)}
			</div>
		</div>
	) : (
		<div class="flex flex-wrap gap-1.5">
			{tags.map((tag) =>
				linkBase ? (
					<a
						href={`${linkBase}?tag=${encodeURIComponent(tag)}`}
						class="inline-block px-2 py-0.5 bg-background-cardHover text-text-tertiary hover:text-text-secondary text-xs rounded-full transition-colors"
					>
						#{tag}
					</a>
				) : (
					<span class="px-2 py-0.5 bg-background-cardHover text-text-tertiary text-xs rounded-full">
						#{tag}
					</span>
				)
			)}
		</div>
	)
}
