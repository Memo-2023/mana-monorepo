---
interface Props {
	title: string;
	description: string;
	icon: string;
	href: string;
	variant?: 'primary' | 'secondary';
	lang?: string;
}

const { title, description, icon, href, variant = 'secondary', lang = 'de' } = Astro.props;

const variantClasses = {
	primary:
		'bg-gradient-to-r from-primary to-primary-hover text-white hover:shadow-lg hover:shadow-primary/20',
	secondary: 'bg-background-card border border-border hover:border-primary/30 text-text-primary',
};
---

<a
	href={href}
	class={`
    block p-5 rounded-xl transition-all duration-300 group
    ${variantClasses[variant]}
    hover:-translate-y-1
  `}
>
	<div class="flex items-start gap-4">
		<div
			class={`
      w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0
      ${variant === 'primary' ? 'bg-white/20' : 'bg-primary/10'}
    `}
		>
			<span class="text-xl">{icon}</span>
		</div>
		<div class="flex-1">
			<h4
				class={`font-semibold mb-1 ${variant === 'primary' ? 'text-white' : 'text-text-primary'}`}
			>
				{title}
			</h4>
			<p class={`text-sm ${variant === 'primary' ? 'text-white/80' : 'text-text-secondary'}`}>
				{description}
			</p>
			<span
				class={`
        inline-flex items-center gap-1 mt-2 text-sm font-medium
        ${variant === 'primary' ? 'text-white' : 'text-primary'}
        group-hover:gap-2 transition-all
      `}
			>
				{lang === 'de' ? 'Jetzt starten' : 'Get started'}
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
					></path>
				</svg>
			</span>
		</div>
	</div>
</a>
