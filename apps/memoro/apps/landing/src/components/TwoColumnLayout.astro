---
export interface Props {
	reverseOnMobile?: boolean;
	class?: string;
	gap?: 'small' | 'medium' | 'large';
}

const { reverseOnMobile = false, gap = 'medium', class: className = '' } = Astro.props;

const gapClass = {
	small: 'gap-4 md:gap-6',
	medium: 'gap-8 md:gap-12',
	large: 'gap-12 md:gap-16',
}[gap];
---

<div class={`grid md:grid-cols-2 ${gapClass} items-center my-12 ${className}`}>
	<div class={reverseOnMobile ? 'order-2 md:order-1' : ''}>
		<slot name="left" />
	</div>
	<div class={reverseOnMobile ? 'order-1 md:order-2' : ''}>
		<slot name="right" />
	</div>
</div>
