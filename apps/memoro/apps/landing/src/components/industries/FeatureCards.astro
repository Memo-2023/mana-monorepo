---
interface Props {
	features: string[];
	color?: string;
}

const { features, color = 'blue' } = Astro.props;

const colorClasses = {
	blue: 'border-blue-500 bg-blue-500/10 hover:bg-blue-500/20',
	red: 'border-red-500 bg-red-500/10 hover:bg-red-500/20',
	purple: 'border-purple-500 bg-purple-500/10 hover:bg-purple-500/20',
	green: 'border-green-500 bg-green-500/10 hover:bg-green-500/20',
	orange: 'border-orange-500 bg-orange-500/10 hover:bg-orange-500/20',
};

const cardClass = colorClasses[color] || colorClasses.blue;

const featureIcons = {
	Baustellenprotokolle: '📝',
	Mängeldokumentation: '📸',
	Abnahmeprotokolle: '✅',
	Kundenkommunikation: '💬',
	Materialbestellungen: '📦',
	Materiallisten: '📋',
	Baustellenbesprechungen: '👷',
	Arbeitsanweisungen: '📢',
	Mängel: '⚠️',
	Mehrsprachige: '🌍',
};

function getIcon(feature: string): string {
	for (const [key, icon] of Object.entries(featureIcons)) {
		if (feature.includes(key)) {
			return icon;
		}
	}
	return '✨';
}
---

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 my-8">
	{
		features.map((feature) => (
			<div
				class={`p-6 rounded-xl border-2 ${cardClass} transition-all duration-200 transform hover:scale-105`}
			>
				<div class="flex items-start gap-3">
					<span class="text-2xl flex-shrink-0">{getIcon(feature)}</span>
					<p class="text-text-primary font-medium">{feature}</p>
				</div>
			</div>
		))
	}
</div>
