---
interface Props {
  content: any;
  lang: string;
}

const { content, lang } = Astro.props;
---

<div class="my-12" x-data="{ activeTab: 0 }">
  <div class="flex flex-wrap gap-2 mb-6 border-b border-border">
    <button
      @click="activeTab = 0"
      :class="activeTab === 0 ? 'border-b-2 border-primary text-primary' : 'text-text-secondary'"
      class="px-4 py-2 font-medium transition-colors hover:text-primary"
    >
      {lang === 'de' ? 'Für Handwerker' : 'For Craftsmen'}
    </button>
    <button
      @click="activeTab = 1"
      :class="activeTab === 1 ? 'border-b-2 border-primary text-primary' : 'text-text-secondary'"
      class="px-4 py-2 font-medium transition-colors hover:text-primary"
    >
      {lang === 'de' ? 'Für Bauleiter' : 'For Site Managers'}
    </button>
    <button
      @click="activeTab = 2"
      :class="activeTab === 2 ? 'border-b-2 border-primary text-primary' : 'text-text-secondary'"
      class="px-4 py-2 font-medium transition-colors hover:text-primary"
    >
      {lang === 'de' ? 'Für Unternehmen' : 'For Companies'}
    </button>
  </div>
  
  <div class="tab-content">
    <div x-show="activeTab === 0" x-transition:enter="transition ease-out duration-200">
      <slot name="tab1" />
    </div>
    <div x-show="activeTab === 1" x-transition:enter="transition ease-out duration-200">
      <slot name="tab2" />
    </div>
    <div x-show="activeTab === 2" x-transition:enter="transition ease-out duration-200">
      <slot name="tab3" />
    </div>
  </div>
</div>