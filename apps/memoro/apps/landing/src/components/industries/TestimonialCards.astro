---
import { getCollection } from 'astro:content';

interface Props {
	testimonialIds?: string[];
	industry?: string;
	lang: string;
	limit?: number;
}

const { testimonialIds, industry, lang, limit = 3 } = Astro.props;

let testimonials = [];

if (testimonialIds && testimonialIds.length > 0) {
	// Lade spezifische Testimonials nach IDs
	const allTestimonials = await getCollection('testimonials');
	testimonials = testimonialIds
		.map((id) => {
			const cleanId = id.startsWith(`${lang}/`) ? id : `${lang}/${id}`;
			return allTestimonials.find((t) => t.slug === cleanId);
		})
		.filter(Boolean)
		.slice(0, limit);
} else if (industry) {
	// Lade Testimonials nach Branche
	testimonials = await getCollection('testimonials', ({ data }) => {
		return data.lang === lang && data.industry === industry && data.featured === true;
	});
	testimonials = testimonials.slice(0, limit);
}
---

{
	testimonials.length > 0 && (
		<div class="my-12">
			<h2 class="text-3xl font-bold text-text-primary mb-8">
				{lang === 'de' ? 'Erfolgsgeschichten aus der Praxis' : 'Success Stories from Practice'}
			</h2>

			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
				{testimonials.map(async (testimonial) => {
					const { Content } = await testimonial.render();
					return (
						<div class="bg-background-card rounded-xl p-6 border border-border hover:border-primary transition-colors">
							<div class="mb-4">
								<blockquote class="text-text-secondary italic mb-4">
									"{testimonial.data.text}"
								</blockquote>
							</div>

							<div class="flex items-center gap-4 pt-4 border-t border-border">
								{testimonial.data.image ? (
									<img
										src={testimonial.data.image}
										alt={testimonial.data.name}
										class="w-12 h-12 rounded-full object-cover"
										width="48"
										height="48"
										loading="lazy"
										decoding="async"
									/>
								) : (
									<div class="w-12 h-12 rounded-full bg-primary/10 border border-primary/20 flex items-center justify-center">
										<svg
											class="w-6 h-6 text-primary"
											fill="none"
											stroke="currentColor"
											viewBox="0 0 24 24"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="2"
												d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
											/>
										</svg>
									</div>
								)}
								<div>
									<div class="font-semibold text-text-primary">{testimonial.data.name}</div>
									<div class="text-sm text-text-secondary">
										{testimonial.data.role}
										{testimonial.data.company && <span> • {testimonial.data.company}</span>}
									</div>
								</div>
							</div>

							<details class="mt-4">
								<summary class="text-primary hover:text-primary-hover cursor-pointer text-sm font-medium">
									{lang === 'de' ? 'Vollständige Geschichte lesen' : 'Read full story'}
								</summary>
								<div class="mt-4 prose prose-sm prose-invert max-w-none">
									<Content />
								</div>
							</details>
						</div>
					);
				})}
			</div>
		</div>
	)
}
