---
interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  items: FAQ[];
  lang: string;
}

const { items, lang } = Astro.props;
---

<div class="my-12">
  <h2 class="text-3xl font-bold text-text-primary mb-8">
    {lang === 'de' ? 'Häufige Fragen' : 'Frequently Asked Questions'}
  </h2>
  
  <div class="space-y-4" x-data="{ openItem: null }">
    {items.map((item, index) => (
      <div class="bg-background-card rounded-lg border border-border overflow-hidden">
        <button
          @click={`openItem = openItem === ${index} ? null : ${index}`}
          class="w-full px-6 py-4 text-left flex items-center justify-between hover:bg-background-cardHover transition-colors"
        >
          <span class="font-medium text-text-primary pr-4">{item.question}</span>
          <svg
            :class={`openItem === ${index} ? 'rotate-180' : ''`}
            class="w-5 h-5 text-text-secondary transition-transform flex-shrink-0"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div
          x-show={`openItem === ${index}`}
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 -translate-y-4"
          x-transition:enter-end="opacity-100 translate-y-0"
          class="px-6 pb-4"
        >
          <p class="text-text-secondary">{item.answer}</p>
        </div>
      </div>
    ))}
  </div>
</div>