---
// ArticleNavigation.astro
// Diese Komponente zeigt Navigationsbuttons für den vorherigen und nächsten Artikel an
import Button from './atoms/Button.astro';

interface Props {
	prevArticle: {
		slug: string;
		title: string;
		lang: string;
		collection: string;
	} | null;
	nextArticle: {
		slug: string;
		title: string;
		lang: string;
		collection: string;
	} | null;
	lang: string;
	collection: string;
}

const { prevArticle, nextArticle, lang, collection } = Astro.props;

// Übersetzungen für die Buttons
const translations = {
	de: {
		previous: 'Zurück',
		next: 'Weiter',
	},
	en: {
		previous: 'Previous',
		next: 'Next',
	},
};

const t = translations[lang as keyof typeof translations] || translations.en;

// Funktion zum Generieren der korrekten URLs
function getArticleUrl(article: Props['prevArticle'] | Props['nextArticle']) {
	if (!article) return '';

	// Extrahiere den reinen Slug ohne Sprachpräfix
	let cleanSlug = article.slug;

	// Wenn der Slug ein Sprachpräfix enthält (z.B. "de/healthcare"), extrahiere nur den Teil nach dem Präfix
	const langPrefix = `${article.lang}/`;
	if (cleanSlug.startsWith(langPrefix)) {
		cleanSlug = cleanSlug.substring(langPrefix.length);
	}

	// Generiere die URL im Format /{lang}/{collection}/{slug}
	return `/${article.lang}/${article.collection}/${cleanSlug}`;
}
---

<div class="mt-12 pt-6 border-t border-border">
	<div
		class="flex flex-col-reverse sm:flex-row justify-between items-stretch sm:items-center gap-4"
	>
		{
			prevArticle && (
				<Button
					href={getArticleUrl(prevArticle)}
					variant="secondary"
					size="md"
					class="group w-full sm:w-auto"
				>
					<span class="mr-2 transform group-hover:-translate-x-1 transition-transform duration-200">
						&larr;
					</span>
					<span>
						{t.previous}:{' '}
						{prevArticle.title.length > 25
							? prevArticle.title.substring(0, 25) + '...'
							: prevArticle.title}
					</span>
				</Button>
			)
		}

		{!prevArticle && <div class="hidden sm:block" />}

		{
			nextArticle && (
				<Button
					href={getArticleUrl(nextArticle)}
					variant="primary"
					size="md"
					class="group w-full sm:w-auto"
				>
					<span>
						{t.next}:{' '}
						{nextArticle.title.length > 25
							? nextArticle.title.substring(0, 25) + '...'
							: nextArticle.title}
					</span>
					<span class="ml-2 transform group-hover:translate-x-1 transition-transform duration-200">
						&rarr;
					</span>
				</Button>
			)
		}
	</div>
</div>
