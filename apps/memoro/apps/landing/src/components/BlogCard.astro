---
interface Props {
  title: string;
  excerpt?: string;
  description?: string;
  pubDate?: Date;
  publishDate?: Date;
  author?: string;
  slug: string;
  tags?: string[];
  lang: string;
  image?: string;
  category?: 'News' | 'Tutorial' | 'Experiment';
}

const { 
  title, 
  excerpt, 
  description, 
  pubDate, 
  publishDate, 
  author = "Admin", 
  slug, 
  tags = [], 
  lang, 
  image = "/images/blog/default.jpg",
  category 
} = Astro.props;

// Use either publishDate or pubDate, whichever is available
const date = publishDate || pubDate;
const formattedDate = date 
  ? new Date(date).toLocaleDateString(lang === "de" ? "de-DE" : "en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "";

// Use either excerpt or description, whichever is available
const content = excerpt || description || "";

// Category labels
const categoryLabels: Record<string, Record<string, string>> = {
  de: {
    News: 'Neuigkeiten',
    Tutorial: 'Anleitung',
    Experiment: 'Experiment'
  },
  en: {
    News: 'News',
    Tutorial: 'Tutorial',
    Experiment: 'Experiment'
  }
};

// Category colors
const categoryColors = {
  News: 'bg-blue-100 text-blue-700 border-blue-200',
  Tutorial: 'bg-green-100 text-green-700 border-green-200',
  Experiment: 'bg-purple-100 text-purple-700 border-purple-200'
};
---

<a href={`/${lang}/blog/${slug}`} class="block w-full">
  <article class="bg-background-card rounded-xl overflow-hidden group relative hover:bg-background-cardHover transition-all duration-DEFAULT border border-border hover:border-border-hover flex flex-col md:flex-row">
    <div class="w-full md:w-1/3">
      <img
        src={image}
        alt={title}
        class="w-full h-48 md:h-full object-cover"
        width="400"
        height="300"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="relative p-6 sm:p-8 w-full md:w-2/3">
      <div class="flex items-center justify-between text-sm text-text-muted mb-4 opacity-60">
        {date && (
          <time datetime={date instanceof Date ? date.toISOString() : ""}>
            {formattedDate}
          </time>
        )}
        <div class="flex items-center gap-3">
          <span>{author}</span>
          {category && (
            <span class={`px-2 py-1 text-xs font-medium rounded-full border ${categoryColors[category]}`}>
              {categoryLabels[lang]?.[category] || category}
            </span>
          )}
        </div>
      </div>

      <h2 class="text-xl font-medium text-text-primary opacity-90 group-hover:opacity-100 mb-3">
        {title}
      </h2>

      <p class="text-text-secondary opacity-80 group-hover:opacity-90 mb-4 line-clamp-2">
        {content}
      </p>

      {
        tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-2 overflow-x-auto whitespace-nowrap pb-2 scrollbar-none bg-background-subtle rounded-lg p-3">
            {tags.map((tag) => (
              <span class="px-3 py-1 bg-background-cardHover text-text-muted rounded-full text-sm border border-border">
                #{tag}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </article>
</a>
