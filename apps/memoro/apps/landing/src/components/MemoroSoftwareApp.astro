---
import StructuredData from './StructuredData.astro';

const { lang } = Astro.props;

const softwareData = {
  name: "Memoro",
  applicationCategory: "ProductivityApplication",
  applicationSubCategory: "BusinessApplication",
  operatingSystem: ["iOS", "Android", "Windows", "macOS", "Linux"],
  description: lang === 'de'
    ? "Memoro verwandelt gesprochene Worte in strukturierte Dokumentation. KI-gestützte Transkription, Zusammenfassung und Aufgabenerkennung für Meetings, Notizen und Brainstorming."
    : "Memoro transforms spoken words into structured documentation. AI-powered transcription, summarization and task detection for meetings, notes and brainstorming.",
  offers: [
    {
      "@type": "Offer",
      name: lang === 'de' ? "Kostenlos" : "Free",
      price: "0",
      priceCurrency: "EUR",
      description: lang === 'de' ? "180 Minuten/Monat" : "180 minutes/month"
    },
    {
      "@type": "Offer",
      name: "Plus",
      price: "9",
      priceCurrency: "EUR",
      description: lang === 'de' ? "600 Minuten/Monat" : "600 minutes/month"
    },
    {
      "@type": "Offer",
      name: "Pro",
      price: "23",
      priceCurrency: "EUR",
      description: lang === 'de' ? "1800 Minuten/Monat" : "1800 minutes/month"
    },
    {
      "@type": "Offer",
      name: "Ultra",
      price: "42",
      priceCurrency: "EUR",
      description: lang === 'de' ? "4800 Minuten/Monat" : "4800 minutes/month"
    }
  ],
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.8",
    ratingCount: "523",
    bestRating: "5"
  },
  downloadUrl: [
    "https://apps.apple.com/app/memoro",
    "https://play.google.com/store/apps/details?id=ai.memoro.app"
  ],
  screenshot: [
    "https://memoro.ai/images/screenshots/memoro-recording.png",
    "https://memoro.ai/images/screenshots/memoro-transcription.png",
    "https://memoro.ai/images/screenshots/memoro-summary.png"
  ],
  featureList: lang === 'de' ? [
    "Automatische Transkription in 24 Sprachen",
    "KI-gestützte Zusammenfassung",
    "Sprechererkennung (bis zu 12 Personen)",
    "Aufgaben- und Terminerkennung",
    "Export in Word, PDF, Markdown",
    "Offline-Modus",
    "Ende-zu-Ende-Verschlüsselung"
  ] : [
    "Automatic transcription in 24 languages",
    "AI-powered summarization",
    "Speaker recognition (up to 12 people)",
    "Task and appointment detection",
    "Export to Word, PDF, Markdown",
    "Offline mode",
    "End-to-end encryption"
  ],
  softwareVersion: "2.3.0",
  permissions: lang === 'de' ? [
    "Mikrofonzugriff für Aufnahmen",
    "Speicherzugriff für Dateien",
    "Internetzugang für KI-Verarbeitung"
  ] : [
    "Microphone access for recordings",
    "Storage access for files",
    "Internet access for AI processing"
  ],
  creator: {
    "@type": "Organization",
    name: "Memoro",
    url: "https://memoro.ai"
  }
};
---

<StructuredData type="SoftwareApplication" data={softwareData} />