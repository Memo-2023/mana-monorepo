---
import VideoPopup from './VideoPopup.astro';

interface Props {
	title: string;
	subtitle: string;
	image: string;
	variant?: 'default' | 'fullwidth' | 'widescreen';
	ctaText?: string;
	ctaLink?: string;
	ctaMicroCopy?: string;
	secondaryCtaText?: string;
	secondaryCtaLink?: string;
	secondaryCtaVideoId?: string;
	socialProof?: {
		rating: number;
		reviewCount: number;
		quote: string;
		author: string;
	};
	trustBadges?: Array<{
		icon: string;
		text: string;
	}>;
}

const {
	title,
	subtitle,
	image,
	variant = 'default',
	ctaText,
	ctaLink,
	ctaMicroCopy,
	secondaryCtaText,
	secondaryCtaLink,
	secondaryCtaVideoId,
	socialProof,
	trustBadges,
} = Astro.props;
---

{
	variant === 'widescreen' ? (
		<section class="max-w-7xl mx-auto px-4 pt-8 pb-4 md:pt-4 md:pb-6">
			<div class="space-y-4 md:space-y-5">
				{/* Widescreen Image - standalone on mobile */}
				<div class="relative w-full aspect-[2.5/1] sm:aspect-[3/1] md:aspect-[4/1] lg:aspect-[5/1] overflow-hidden rounded-2xl">
					<img
						src={image}
						alt="Meeting Protokoll Software Memoro - Automatische KI-Transkription und Spracherkennung"
						class="absolute inset-0 w-full h-full object-cover object-center"
						width="1920"
						height="800"
						loading="eager"
						fetchpriority="high"
						decoding="async"
					/>
					<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/50 to-transparent" />

					{/* Text Content Over Image - only on larger screens */}
					<div class="hidden lg:flex absolute inset-0 items-center p-4 md:p-6 lg:p-8">
						<div class="w-full">
							<div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-center">
								<div class="max-w-sm">
									<h1 class="text-2xl sm:text-3xl md:text-4xl text-white font-bold leading-[1.6] sm:leading-[1.5] md:leading-[1.45] text-left">
										{title}
									</h1>
								</div>
								<div class="flex justify-end">
									<div class="max-w-sm">
										<p class="text-base sm:text-lg md:text-xl text-white text-left leading-[1.9] sm:leading-[1.85] md:leading-[1.8] tracking-wide">
											{subtitle}
										</p>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>

				{/* Text Content Below Image - only on smaller screens */}
				<div class="lg:hidden">
					<div class="space-y-3">
						<h1 class="text-2xl sm:text-3xl md:text-4xl text-text-primary font-bold leading-[1.6] sm:leading-[1.5] md:leading-[1.45] text-left">
							{title}
						</h1>
						<p class="text-base sm:text-lg md:text-xl text-text-secondary text-left leading-[1.9] sm:leading-[1.85] md:leading-[1.8]">
							{subtitle}
						</p>
					</div>
				</div>

				{/* Optional CTAs */}
				{(ctaText || secondaryCtaText) && (
					<div class="flex flex-col sm:flex-row gap-3 justify-start px-4">
						{ctaText && ctaLink && (
							<a
								href={ctaLink}
								class="inline-flex items-center justify-center gap-2 px-6 py-2.5 text-base font-semibold text-white bg-primary hover:bg-primary-hover rounded-lg transition-all duration-300 shadow-lg hover:shadow-xl"
							>
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
									/>
								</svg>
								{ctaText}
							</a>
						)}
						{secondaryCtaText && secondaryCtaVideoId ? (
							<VideoPopup
								videoId={secondaryCtaVideoId}
								buttonText={secondaryCtaText}
								buttonClass="inline-flex items-center justify-center px-6 py-2.5 text-base font-medium text-text-primary bg-transparent hover:bg-background-cardHover border-2 border-border rounded-lg transition-colors"
							/>
						) : (
							secondaryCtaText &&
							secondaryCtaLink && (
								<a
									href={secondaryCtaLink}
									class="inline-flex items-center justify-center px-6 py-2.5 text-base font-medium text-text-primary bg-transparent hover:bg-background-cardHover border-2 border-border rounded-lg transition-colors"
								>
									{secondaryCtaText}
								</a>
							)
						)}
					</div>
				)}
			</div>
		</section>
	) : variant === 'fullwidth' ? (
		<section class="max-w-7xl mx-auto px-4 pt-8 pb-4 md:py-6">
			<div class="space-y-4">
				{/* Mobile: Stack layout, Desktop: Overlay */}
				<div class="flex flex-col md:relative w-full">
					{/* Image - First on mobile, with overlay on desktop */}
					<div class="relative w-full aspect-[16/10] sm:aspect-[16/9] md:aspect-[21/9] overflow-hidden rounded-2xl order-1 md:order-none mb-3 sm:mb-4 md:mb-0">
						<img
							src={image}
							alt="Meeting Protokoll Software Memoro - Automatische KI-Transkription und Spracherkennung"
							class="absolute inset-0 w-full h-full object-cover object-center"
							width="1920"
							height="800"
							loading="eager"
							fetchpriority="high"
							decoding="async"
						/>
						{/* Gradient overlay only on desktop */}
						<div class="hidden md:block absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent" />
					</div>

					{/* Text Content - Below image on mobile, overlay on desktop */}
					<div class="order-2 md:order-none md:absolute md:inset-0 md:z-20 md:flex md:items-end md:justify-center">
						<div class="text-center max-w-3xl space-y-2 sm:space-y-3 md:space-y-4 px-4 md:px-8 md:pb-8">
							<h1 class="text-2xl min-[375px]:text-3xl sm:text-4xl md:text-5xl text-text-primary md:text-white font-bold leading-[1.6] sm:leading-[1.5] md:leading-[1.45] hero-fade-in">
								{title}
							</h1>
							<p class="text-base min-[375px]:text-lg sm:text-lg md:text-xl text-text-secondary md:text-gray-200 max-w-2xl mx-auto leading-[1.9] sm:leading-[1.85] md:leading-[1.8]">
								{subtitle}
							</p>
						</div>
					</div>
				</div>

				{/* CTAs and Trust Badges below image */}
				<div class="text-center space-y-4 px-4">
					{(ctaText || secondaryCtaText) && (
						<div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center">
							{ctaText && ctaLink && (
								<a
									href={ctaLink}
									class="inline-flex items-center justify-center gap-2 px-6 sm:px-8 py-3 sm:py-4 text-base sm:text-lg font-semibold text-white bg-primary hover:bg-primary-hover rounded-lg transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-1 transform w-full sm:w-auto"
								>
									<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="2"
											d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
										/>
									</svg>
									{ctaText}
								</a>
							)}
							{secondaryCtaText && secondaryCtaVideoId ? (
								<VideoPopup
									videoId={secondaryCtaVideoId}
									buttonText={secondaryCtaText}
									buttonClass="inline-flex items-center justify-center px-6 py-3 text-base sm:text-lg font-medium text-text-primary bg-transparent hover:bg-background-cardHover border-2 border-border rounded-lg transition-colors w-full sm:w-auto"
								/>
							) : (
								secondaryCtaText &&
								secondaryCtaLink && (
									<a
										href={secondaryCtaLink}
										class="inline-flex items-center justify-center px-6 py-3 text-base sm:text-lg font-medium text-text-primary bg-transparent hover:bg-background-cardHover border-2 border-border rounded-lg transition-colors w-full sm:w-auto"
									>
										{secondaryCtaText}
									</a>
								)
							)}
						</div>
					)}

					{ctaMicroCopy && <p class="text-sm text-text-muted mt-2">{ctaMicroCopy}</p>}

					{trustBadges && trustBadges.length > 0 && (
						<div class="flex flex-wrap gap-2 sm:gap-3 justify-center">
							{trustBadges.map((badge) => (
								<div class="inline-flex items-center gap-1.5 sm:gap-2 px-3 sm:px-4 py-1.5 sm:py-2 bg-white/5 rounded-full border border-white/10 backdrop-blur-sm">
									<span class="text-sm sm:text-base">{badge.icon}</span>
									<span class="text-[10px] sm:text-xs font-medium text-gray-300">{badge.text}</span>
								</div>
							))}
						</div>
					)}
				</div>
			</div>
		</section>
	) : (
		<section class="max-w-7xl mx-auto px-4 pt-8 pb-8 md:py-12">
			<div class="grid md:grid-cols-2 gap-8 items-center mb-8 md:mb-12">
				<div class="relative order-2 md:order-1 overflow-hidden rounded-2xl group">
					<div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent z-10 opacity-60" />
					<img
						src={image}
						alt={title}
						class="w-full h-auto object-cover shadow-2xl transform group-hover:scale-105 transition-transform duration-700"
						width="800"
						height="600"
						loading="eager"
						fetchpriority="high"
						decoding="async"
					/>
				</div>
				<div class="text-center md:text-left order-1 md:order-2 space-y-6">
					<h1 class="text-heading-mobile md:text-display text-text-primary mb-6 leading-[1.6] md:leading-[1.45] hero-fade-in">
						{title}
					</h1>
					<p class="text-subheading-mobile md:text-subheading text-text-secondary max-w-xl mb-8 leading-[1.9] md:leading-[1.8]">
						{subtitle}
					</p>
					{(ctaText || secondaryCtaText) && (
						<div class="space-y-4">
							<div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
								{ctaText && ctaLink && (
									<a
										href={ctaLink}
										class="inline-flex items-center justify-center gap-2 px-8 py-4 text-lg font-semibold text-white bg-primary hover:bg-primary-hover rounded-lg transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-1 transform"
									>
										<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="2"
												d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
											/>
										</svg>
										{ctaText}
									</a>
								)}
								{secondaryCtaText && secondaryCtaVideoId ? (
									<VideoPopup videoId={secondaryCtaVideoId} buttonText={secondaryCtaText} />
								) : (
									secondaryCtaText &&
									secondaryCtaLink && (
										<a
											href={secondaryCtaLink}
											class="inline-flex items-center justify-center px-6 py-3 text-lg font-medium text-text-primary bg-transparent hover:bg-background-cardHover border-2 border-border rounded-lg transition-colors"
										>
											{secondaryCtaText}
										</a>
									)
								)}
							</div>
						</div>
					)}

					{trustBadges && trustBadges.length > 0 && (
						<div class="flex flex-wrap gap-3 mt-8 justify-center md:justify-start">
							{trustBadges.map((badge) => (
								<div class="inline-flex items-center gap-2 px-4 py-2 bg-white/5 rounded-full border border-white/10 backdrop-blur-sm">
									<span class="text-base">{badge.icon}</span>
									<span class="text-xs font-medium text-gray-300">{badge.text}</span>
								</div>
							))}
						</div>
					)}
				</div>
			</div>
		</section>
	)
}
