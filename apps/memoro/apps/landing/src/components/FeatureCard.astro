---
import type { CollectionEntry } from "astro:content";
import { getLangFromUrl } from "../i18n/utils";

interface Props {
  title: string;
  description: string;
  icon: string;
  href: string;
  lang?: string;
}

const { title, description, icon, href, lang } = Astro.props;

const iconClass =
  "bg-background-card/20 text-primary-DEFAULT border border-border group-hover:border-border-hover backdrop-blur-md group-hover:bg-background-card/10";
---

<a
  href={href}
  class="flex flex-col h-full p-6 rounded-xl bg-background-card border border-border hover:bg-background-cardHover hover:border-border-hover transition-all duration-DEFAULT group relative"
>
  <div class="relative">
    <span class="absolute text-4xl top-1/2 -translate-y-1/2 left-5">{icon}</span
    >
    <div
      class={`w-20 h-20 rounded-full ${iconClass} flex items-center justify-center mb-4 relative z-10 group-hover:text-white/90 transition-colors duration-DEFAULT`}
    >
      <span class="text-4xl">{icon}</span>
    </div>
  </div>
  <h3 class="text-xl font-semibold text-text-primary mb-2">{title}</h3>
  <p class="text-text-secondary flex-grow">{description}</p>

  <div
    class="mt-4 flex items-center justify-end text-primary-DEFAULT opacity-50 group-hover:opacity-100 transition-all duration-DEFAULT"
  >
    <span class="text-sm font-medium"
      >{lang === "de" ? "Mehr erfahren" : "Learn more"}</span
    >
    <svg
      class="w-4 h-4 ml-2"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M9 5l7 7-7 7"></path>
    </svg>
  </div>
</a>
