---
interface Props {
  title: string;
  description: string;
  icon: string;
  color: string;
  href: string;
}

const { title, description, icon, color, href } = Astro.props;
const iconClass =
  "bg-background-card text-primary-DEFAULT border border-border group-hover:border-border-hover";
---

<a
  href={href}
  class="flex flex-col h-full p-6 rounded-xl bg-background-card border border-border hover:bg-background-cardHover hover:border-border-hover transition-all duration-DEFAULT group"
>
  <div
    class={`w-12 h-12 rounded-lg ${iconClass} flex items-center justify-center mb-4 backdrop-blur-sm group-hover:text-white/90 transition-colors duration-DEFAULT`}
  >
    <span class="text-2xl">{icon}</span>
  </div>
  <h3 class="text-xl font-semibold text-text-primary mb-2">{title}</h3>
  <p class="text-text-secondary flex-grow">{description}</p>
</a>
