---
import { getCollection } from 'astro:content';
import { getLangFromUrl } from '../i18n/utils';
import BlogCard from './BlogCard.astro';

const lang = getLangFromUrl(Astro.url) as string;
const posts = await getCollection('blog', ({ data }) => {
	return data.lang === lang && !data.draft;
});

// Sort posts by date and get the latest 2
const sortedPosts = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const latestPosts = sortedPosts.slice(0, 2);

// If no posts are available, return early
if (latestPosts.length === 0) {
	return null;
}
---

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-20">
	<div class="text-center max-w-3xl mx-auto mb-16">
		<h2 class="text-heading-mobile md:text-heading text-text-primary mb-4">
			{lang === 'de' ? 'Aktuelle Blog-Beiträge' : 'Latest Blog Posts'}
		</h2>
	</div>

	<div class="flex flex-col gap-8 max-w-4xl mx-auto">
		{
			latestPosts.map((post) => (
				<BlogCard
					title={post.data.title}
					description={post.data.description}
					pubDate={post.data.pubDate}
					author={post.data.author}
					slug={post.slug}
					tags={post.data.tags}
					image={post.data.image}
					lang={lang}
					category={post.data.category}
				/>
			))
		}
	</div>

	<div class="text-center mt-8 px-4 sm:px-0">
		<a
			href={`/${lang}/blog`}
			class="inline-flex items-center text-primary-DEFAULT hover:underline transition-all"
		>
			{lang === 'de' ? 'Zum Blog' : 'Visit the blog'}
			<svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
				></path>
			</svg>
		</a>
	</div>
</section>
