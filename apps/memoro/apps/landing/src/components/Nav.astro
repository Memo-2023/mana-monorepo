---
import Button from "./atoms/Button.astro";
import LanguagePicker from "./LanguagePicker.astro";
import { Icon } from "astro-icon/components";
import { defaultLang } from "../i18n/ui";

interface Props {
  pageTitle?: string;
}

const { pageTitle } = Astro.props;
const { pathname } = Astro.url;
const pathSegments = pathname.split("/").filter(Boolean);
const currentLang = (pathSegments[0] === 'de' || pathSegments[0] === 'en') ? pathSegments[0] : defaultLang;
const isLandingPage = pathname === '/' || pathname === '/de/' || pathname === '/en/' || pathname === '/de' || pathname === '/en';

// Function to check if the current page matches the link
const isActive = (href: string) => {
  const cleanPath = pathname.endsWith('/') ? pathname.slice(0, -1) : pathname;
  const cleanHref = href.endsWith('/') ? href.slice(0, -1) : href;
  return cleanPath === cleanHref || (cleanPath === `/${currentLang}` && cleanHref === `/${currentLang}/`);
};
---

{/* Desktop Navigation */}
<nav
  class="hidden md:block bg-background-page/80 backdrop-blur-xl sticky top-0 z-50 border-b border-border"
>
  <div class="px-4 py-3 relative">
    <div
      class="flex items-center justify-between w-full"
    >
      {/* Logo and Breadcrumbs */}
      <div class="flex-shrink-0 z-10 flex items-center gap-4">
        <a
          href={`/${currentLang}/`}
          class="flex items-center gap-3 hover:opacity-80 transition-opacity"
        >
          <img src="/images/brand/logo.svg" alt="Memoro - Meeting Protokoll Software und KI-Transkription" class="h-7 w-7" width="28" height="28" loading="eager" decoding="async" />
          <span class="text-lg font-bold text-text-primary">Memoro</span>
        </a>

        {/* Made & Hosted in Germany Badge */}
        <div class="hidden lg:flex items-center gap-2 px-3 py-1.5 bg-background-card border border-border rounded-full">
          {/* Custom Germany Flag */}
          <div class="flex flex-col w-3.5 h-6 rounded-sm overflow-hidden">
            <div class="flex-[1.15] bg-black"></div>
            <div class="flex-1 bg-red-600"></div>
            <div class="flex-1 bg-yellow-400"></div>
          </div>
          <div class="flex flex-col leading-tight">
            <span class="text-[10px] font-medium text-text-secondary uppercase tracking-wide">Made & Hosted in</span>
            <span class="text-[10px] font-semibold text-text-primary uppercase tracking-wide">Germany</span>
          </div>
        </div>
      </div>

      {/* Desktop Navigation - Absolutely Centered */}
      <div class="hidden xl:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
        <div class="flex items-center gap-6">
          <a
            href={`/${currentLang}/features`}
            class={`transition-all ${isActive(`/${currentLang}/features`) ? 'text-text-primary underline' : 'text-text-secondary hover:text-text-primary hover:underline'}`}
            >{currentLang === "de" ? "Funktionen" : "Features"}</a
          >
          <a
            href={`/${currentLang}/industries`}
            class={`transition-all ${isActive(`/${currentLang}/industries`) ? 'text-text-primary underline' : 'text-text-secondary hover:text-text-primary hover:underline'}`}
            >{currentLang === "de" ? "Branchen" : "Industries"}</a
          >
          <a
            href={`/${currentLang}/guides`}
            class={`transition-all ${isActive(`/${currentLang}/guides`) ? 'text-text-primary underline' : 'text-text-secondary hover:text-text-primary hover:underline'}`}
            >Anleitungen</a
          >
          <a
            href={`/${currentLang}/blog`}
            class={`transition-all ${isActive(`/${currentLang}/blog`) ? 'text-text-primary underline' : 'text-text-secondary hover:text-text-primary hover:underline'}`}
            >Blog</a
          >
          <a
            href={`/${currentLang}/prices`}
            class={`transition-all ${isActive(`/${currentLang}/prices`) ? 'text-text-primary underline' : 'text-text-secondary hover:text-text-primary hover:underline'}`}
            >{currentLang === "de" ? "Preise" : "Prices"}</a
          >
        </div>
      </div>

      {/* Right side: Download Button, Language Picker and Menu Button */}
      <div class="flex items-center gap-2 z-10 flex-shrink-0">
        {/* Language Picker - visible on medium screens and up */}
        <div class="hidden md:block">
          <LanguagePicker />
        </div>
        
        {/* Login Button - visible on medium screens and up */}
        <Button href="https://web.memoro.ai" variant="secondary" size="md" class="hidden md:flex whitespace-nowrap items-center gap-2" target="_blank">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          <span>Login</span>
        </Button>
        
        {/* Download Button - visible on medium screens and up */}
        <Button href={`/${currentLang}/download`} variant="primary" size="md" class="hidden md:flex whitespace-nowrap items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          <span>Herunterladen</span>
        </Button>
        
        {/* Language Picker - Mobile only (controlled by JavaScript) */}
        <div id="mobile-language-picker" class="md:hidden opacity-0 pointer-events-none transition-opacity duration-200">
          <LanguagePicker />
        </div>
        
        {/* Menu Button - All screen sizes */}
        <button
          id="mobile-menu-button"
          class="p-2 rounded-lg hover:bg-background-cardHover transition-colors text-text-secondary hover:text-text-primary"
          aria-label="Menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              class="mobile-menu-icon"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
            <path
              class="mobile-menu-close hidden"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</nav>

{/* Mobile Navigation - Top Bar */}
<nav
  class="md:hidden bg-background-page/80 backdrop-blur-xl sticky top-0 z-50 border-b border-border"
>
  <div class="px-4 py-3">
    <div class="flex items-center justify-between">
      {/* Logo and Badge */}
      <div class="flex items-center gap-2">
        <a
          href={`/${currentLang}/`}
          class="flex items-center gap-3 hover:opacity-80 transition-opacity"
        >
          <img src="/images/brand/logo.svg" alt="Memoro - Meeting Protokoll Software und KI-Transkription" class="h-7 w-7" width="28" height="28" loading="eager" decoding="async" />
          <span class="text-lg font-bold text-text-primary">Memoro</span>
        </a>

        {/* Made & Hosted in Germany Badge - Mobile */}
        <div class="flex items-center gap-1.5 px-2 py-1 bg-background-card border border-border rounded-full">
          {/* Custom Germany Flag */}
          <div class="flex flex-col w-2.5 h-4 rounded-sm overflow-hidden">
            <div class="flex-[1.15] bg-black"></div>
            <div class="flex-1 bg-red-600"></div>
            <div class="flex-1 bg-yellow-400"></div>
          </div>
          <div class="flex flex-col leading-tight">
            <span class="text-[8px] font-medium text-text-secondary uppercase tracking-wide">Made in</span>
            <span class="text-[8px] font-semibold text-text-primary uppercase tracking-wide">Germany</span>
          </div>
        </div>
      </div>

      {/* Right side: Language Picker and Menu Button */}
      <div class="flex items-center gap-2">
        {/* Language Picker */}
        <div id="mobile-language-picker">
          <LanguagePicker />
        </div>

        {/* Menu Button */}
        <button
          id="mobile-menu-button"
          class="p-2 rounded-lg hover:bg-background-cardHover transition-colors text-text-secondary hover:text-text-primary"
          aria-label="Menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              class="mobile-menu-icon"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
            <path
              class="mobile-menu-close hidden"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</nav>

{/* Mobile Menu Backdrop */}
<div
  id="mobile-menu-backdrop"
  class="fixed inset-0 bg-black/40 opacity-0 pointer-events-none transition-opacity duration-200 z-[60] md:hidden"
  aria-hidden="true"
></div>

{/* Mobile Menu - Dropdown from top */}
<div
  id="mobile-menu"
  class="fixed top-[65px] left-0 right-0 bottom-0 md:bottom-auto md:left-auto md:right-4 md:translate-x-0 opacity-0 translate-y-[-10px] pointer-events-none transition-all duration-200 transform origin-top z-[70] w-full md:max-w-md md:px-0"
  aria-hidden="true"
>
  <div class="bg-background-page/95 backdrop-blur-xl border-x-0 border-t-0 border-b border-border/30 md:border md:rounded-2xl shadow-2xl h-full md:max-h-[calc(100vh-80px)] w-full flex flex-col overflow-hidden">
    <div class="p-3 overflow-y-auto flex-1">
      {/* Main Navigation */}
      <div class="pb-1">
        <h3 class="text-xs font-normal text-text-secondary/50 px-3 pb-1 pt-1">
          {currentLang === "de" ? "Navigation" : "Navigation"}
        </h3>
        <a
          href={`/${currentLang}/features`}
          class="group flex items-center gap-3 px-3 py-2 hover:bg-background-cardHover rounded-md transition-colors"
        >
          <Icon name="mdi:sparkles" class="w-5 h-5 text-text-secondary" />
          <span
            class={`text-lg font-medium text-text-primary transition-all duration-300 ${isActive(`/${currentLang}/features`) ? 'underline' : 'group-hover:underline'}`}
            >{currentLang === "de" ? "Funktionen" : "Features"}</span
          >
        </a>
        <a
          href={`/${currentLang}/industries`}
          class="group flex items-center gap-3 px-3 py-2 hover:bg-background-cardHover rounded-md transition-colors"
        >
          <Icon name="mdi:office-building" class="w-5 h-5 text-text-secondary" />
          <span
            class={`text-lg font-medium text-text-primary transition-all duration-300 ${isActive(`/${currentLang}/industries`) ? 'underline' : 'group-hover:underline'}`}
            >{currentLang === "de" ? "Branchen" : "Industries"}</span
          >
        </a>
        <a
          href={`/${currentLang}/prices`}
          class="group flex items-center gap-3 px-3 py-2 hover:bg-background-cardHover rounded-md transition-colors"
        >
          <Icon name="mdi:tag" class="w-5 h-5 text-text-secondary" />
          <span
            class={`text-lg font-medium text-text-primary transition-all duration-300 ${isActive(`/${currentLang}/prices`) ? 'underline' : 'group-hover:underline'}`}
            >{currentLang === "de" ? "Preise" : "Prices"}</span
          >
        </a>
        <a
          href={`/${currentLang}/blog`}
          class="group flex items-center gap-3 px-3 py-2 hover:bg-background-cardHover rounded-md transition-colors"
        >
          <Icon name="mdi:pencil-box-outline" class="w-5 h-5 text-text-secondary" />
          <span
            class={`text-lg font-medium text-text-primary transition-all duration-300 ${isActive(`/${currentLang}/blog`) ? 'underline' : 'group-hover:underline'}`}
            >Blog</span
          >
        </a>
        <a
          href={`/${currentLang}/guides`}
          class="group flex items-center gap-3 px-3 py-2 hover:bg-background-cardHover rounded-md transition-colors"
        >
          <Icon name="mdi:book-open-variant" class="w-5 h-5 text-text-secondary" />
          <span
            class={`text-lg font-medium text-text-primary transition-all duration-300 ${isActive(`/${currentLang}/guides`) ? 'underline' : 'group-hover:underline'}`}
            >{currentLang === "de" ? "Anleitungen" : "Guides"}</span
          >
        </a>
      </div>

      {/* Hilfe Sektion */}
      <div class="pt-2 pb-1">
        <h3 class="text-xs font-normal text-text-secondary/50 px-3 pb-1 pt-1">
          {currentLang === "de" ? "Hilfe" : "Help"}
        </h3>
        <a
          href={`/${currentLang}/blueprints`}
          class="group flex items-center gap-3 px-3 py-2 hover:bg-background-cardHover rounded-md transition-colors"
        >
          <Icon name="mdi:file-document-outline" class="w-5 h-5 text-text-secondary" />
          <span class={`text-lg font-medium text-text-primary transition-all duration-300 ${isActive(`/${currentLang}/blueprints`) ? 'underline' : 'group-hover:underline'}`}>
            {currentLang === "de" ? "Vorlagen" : "Blueprints"}
          </span>
        </a>
        <a
          href={`/memories?lang=${currentLang}`}
          class="group flex items-center gap-3 px-3 py-2 hover:bg-background-cardHover rounded-md transition-colors"
        >
          <Icon name="mdi:brain" class="w-5 h-5 text-text-secondary" />
          <span class="text-lg font-medium text-text-primary transition-all duration-300 group-hover:underline">
            Memories
          </span>
        </a>
        <a
          href={`/${currentLang}/faq`}
          class="group flex items-center gap-3 px-3 py-2 hover:bg-background-cardHover rounded-md transition-colors"
        >
          <Icon name="mdi:help-circle-outline" class="w-5 h-5 text-text-secondary" />
          <span class={`text-lg font-medium text-text-primary transition-all duration-300 ${isActive(`/${currentLang}/faq`) ? 'underline' : 'group-hover:underline'}`}>
            FAQ
          </span>
        </a>
      </div>

      {/* Unternehmen Sektion */}
      <div class="pt-2 pb-1">
        <h3 class="text-xs font-normal text-text-secondary/50 px-3 pb-1 pt-1">
          {currentLang === "de" ? "Unternehmen" : "Company"}
        </h3>
        <a
          href={`/${currentLang}/team`}
          class="group flex items-center gap-3 px-3 py-2 hover:bg-background-cardHover rounded-md transition-colors"
        >
          <Icon name="mdi:account-group" class="w-5 h-5 text-text-secondary" />
          <span class={`text-lg font-medium text-text-primary transition-all duration-300 ${isActive(`/${currentLang}/team`) ? 'underline' : 'group-hover:underline'}`}>
            Team
          </span>
        </a>
        <a
          href={`/${currentLang}/contact`}
          class="group flex items-center gap-3 px-3 py-2 hover:bg-background-cardHover rounded-md transition-colors"
        >
          <Icon name="mdi:email-outline" class="w-5 h-5 text-text-secondary" />
          <span class={`text-lg font-medium text-text-primary transition-all duration-300 ${isActive(`/${currentLang}/contact`) ? 'underline' : 'group-hover:underline'}`}>
            {currentLang === "de" ? "Kontakt" : "Contact"}
          </span>
        </a>
        <a
          href={`/${currentLang}/about`}
          class="group flex items-center gap-3 px-3 py-2 hover:bg-background-cardHover rounded-md transition-colors"
        >
          <Icon name="mdi:information-outline" class="w-5 h-5 text-text-secondary" />
          <span class={`text-lg font-medium text-text-primary transition-all duration-300 ${isActive(`/${currentLang}/about`) ? 'underline' : 'group-hover:underline'}`}>
            {currentLang === "de" ? "Über uns" : "About Us"}
          </span>
        </a>
        <a
          href={`/${currentLang}/statistics`}
          class="group flex items-center gap-3 px-3 py-2 hover:bg-background-cardHover rounded-md transition-colors"
        >
          <Icon name="mdi:chart-bar" class="w-5 h-5 text-text-secondary" />
          <span class={`text-lg font-medium text-text-primary transition-all duration-300 ${isActive(`/${currentLang}/statistics`) ? 'underline' : 'group-hover:underline'}`}>
            {currentLang === "de" ? "Statistiken" : "Statistics"}
          </span>
        </a>
      </div>
      
      {/* Rechtliches Sektion */}
      <div class="pt-2 pb-1">
        <h3 class="text-xs font-normal text-text-secondary/50 px-3 pb-1 pt-1">
          {currentLang === "de" ? "Rechtliches" : "Legal"}
        </h3>
        <a
          href={`/${currentLang}/privacy`}
          class="group flex items-center gap-3 px-3 py-2 hover:bg-background-cardHover rounded-md transition-colors"
        >
          <Icon name="mdi:shield-check" class="w-5 h-5 text-text-secondary" />
          <span class={`text-lg font-medium text-text-primary transition-all duration-300 ${isActive(`/${currentLang}/privacy`) ? 'underline' : 'group-hover:underline'}`}>
            {currentLang === "de" ? "Datenschutz" : "Privacy Policy"}
          </span>
        </a>
        <a
          href={`/${currentLang}/imprint`}
          class="group flex items-center gap-3 px-3 py-2 hover:bg-background-cardHover rounded-md transition-colors"
        >
          <Icon name="mdi:scale-balance" class="w-5 h-5 text-text-secondary" />
          <span class={`text-lg font-medium text-text-primary transition-all duration-300 ${isActive(`/${currentLang}/imprint`) ? 'underline' : 'group-hover:underline'}`}>
            {currentLang === "de" ? "Impressum" : "Legal Notice"}
          </span>
        </a>
        <a
          href={`/${currentLang}/terms`}
          class="group flex items-center gap-3 px-3 py-2 hover:bg-background-cardHover rounded-md transition-colors"
        >
          <Icon name="mdi:file-check-outline" class="w-5 h-5 text-text-secondary" />
          <span class={`text-lg font-medium text-text-primary transition-all duration-300 ${isActive(`/${currentLang}/terms`) ? 'underline' : 'group-hover:underline'}`}>
            {currentLang === "de" ? "AGB" : "Terms of Service"}
          </span>
        </a>
        <a
          href={`/${currentLang}/contracts`}
          class="group flex items-center gap-3 px-3 py-2 hover:bg-background-cardHover rounded-md transition-colors"
        >
          <Icon name="mdi:file-sign" class="w-5 h-5 text-text-secondary" />
          <span class={`text-lg font-medium text-text-primary transition-all duration-300 ${isActive(`/${currentLang}/contracts`) ? 'underline' : 'group-hover:underline'}`}>
            {currentLang === "de" ? "Verträge" : "Contracts"}
          </span>
        </a>
      </div>
    </div>
    
    {/* Sticky Buttons at bottom */}
    <div class="p-3 border-t border-border/30 space-y-2">
      <Button
        href="https://web.memoro.ai"
        variant="secondary"
        size="md"
        class="w-full justify-center items-center gap-2"
        target="_blank">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
        <span>Login</span>
      </Button>
      <Button
        href={`/${currentLang}/download`}
        variant="primary"
        size="md"
        class="w-full justify-center items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        <span>Herunterladen</span>
      </Button>
    </div>
  </div>
</div>

<script>
  const mobileMenuButtons = document.querySelectorAll("#mobile-menu-button");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileMenuBackdrop = document.getElementById("mobile-menu-backdrop");
  const menuIcons = document.querySelectorAll(".mobile-menu-icon");
  const closeIcons = document.querySelectorAll(".mobile-menu-close");

  console.log("Mobile menu initialization:", {
    buttons: mobileMenuButtons.length,
    menu: !!mobileMenu,
    backdrop: !!mobileMenuBackdrop,
    menuIcons: menuIcons.length,
    closeIcons: closeIcons.length
  });

  let isMenuOpen = false;

  function updateMenuState(open: boolean) {
    isMenuOpen = open;
    mobileMenuButtons.forEach(button => button?.setAttribute("aria-expanded", String(open)));
    mobileMenu?.setAttribute("aria-hidden", String(!open));
    mobileMenuBackdrop?.setAttribute("aria-hidden", String(!open));

    // Toggle icons
    menuIcons.forEach(icon => icon?.classList.toggle("hidden", open));
    closeIcons.forEach(icon => icon?.classList.toggle("hidden", !open));

    // Toggle backdrop visibility
    if (mobileMenuBackdrop) {
      if (open) {
        mobileMenuBackdrop.classList.remove("opacity-0", "pointer-events-none");
      } else {
        mobileMenuBackdrop.classList.add("opacity-0", "pointer-events-none");
      }
    }

    // Toggle blur on main content
    const mainContent = document.querySelector('main');
    const footer = document.querySelector('footer');
    if (mainContent) {
      if (open) {
        mainContent.classList.add('brightness-[0.3]', 'transition-all', 'duration-200');
      } else {
        mainContent.classList.remove('brightness-[0.3]');
      }
    }
    if (footer) {
      if (open) {
        footer.classList.add('brightness-[0.3]', 'transition-all', 'duration-200');
      } else {
        footer.classList.remove('brightness-[0.3]');
      }
    }

    // Toggle menu visibility with translate animation
    if (mobileMenu) {
      if (open) {
        console.log("Opening mobile menu");
        mobileMenu.classList.remove("pointer-events-none", "opacity-0", "translate-y-[-10px]");
        mobileMenu.classList.add("translate-y-0");
        document.body.style.overflow = "hidden";
      } else {
        console.log("Closing mobile menu");
        mobileMenu.classList.add("pointer-events-none", "opacity-0", "translate-y-[-10px]");
        mobileMenu.classList.remove("translate-y-0");
        document.body.style.overflow = "";
      }
    } else {
      console.error("Mobile menu element not found!");
    }
  }

  mobileMenuButtons.forEach(button => {
    button?.addEventListener("click", () => {
      updateMenuState(!isMenuOpen);
    });
  });

  // Close menu when clicking on backdrop
  mobileMenuBackdrop?.addEventListener("click", () => {
    updateMenuState(false);
  });

  // Close menu when clicking outside
  document.addEventListener("click", (event) => {
    const target = event.target as Node;
    const isClickOnButton = Array.from(mobileMenuButtons).some(button => button?.contains(target));
    if (
      isMenuOpen &&
      mobileMenu &&
      !mobileMenu.contains(target) &&
      !isClickOnButton &&
      target !== mobileMenuBackdrop
    ) {
      updateMenuState(false);
    }
  });
</script>
