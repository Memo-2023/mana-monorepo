---
// Umami Analytics Component
const WEBSITE_ID =
	import.meta.env.PUBLIC_UMAMI_WEBSITE_ID || '9a78c3d3-2f24-4a10-9304-d99d3a323fa8';
const UMAMI_URL = import.meta.env.PUBLIC_UMAMI_URL || 'https://umami.mana.ai/script.js';
---

<!-- Umami Analytics - Cookie-free and GDPR compliant -->
<script
	defer
	src={UMAMI_URL}
	data-website-id={WEBSITE_ID}
	data-auto-track="true"
	data-do-not-track="true"
	data-cache="true"
	data-domains="memoro.ai,www.memoro.ai"></script>
