---
interface Props {
	videoId: string;
	buttonText: string;
	buttonClass?: string;
}

const {
	videoId,
	buttonText,
	buttonClass = 'inline-flex items-center justify-center px-6 py-3 text-lg font-medium text-text-primary bg-transparent hover:bg-background-cardHover border-2 border-border rounded-lg transition-colors',
} = Astro.props;
---

<button id="video-popup-trigger" class={buttonClass} aria-label={buttonText}>
	<svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
		<path d="M8 5v14l11-7z"></path>
	</svg>
	{buttonText}
</button>

<!-- Video Popup Modal -->
<div
	id="video-popup-modal"
	class="fixed inset-0 z-50 hidden items-center justify-center bg-black bg-opacity-75 backdrop-blur-sm"
	aria-hidden="true"
>
	<div class="relative w-full max-w-4xl mx-4">
		<button
			id="video-popup-close"
			class="absolute -top-12 right-0 text-white hover:text-gray-300 transition-colors"
			aria-label="Close video"
		>
			<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2"
					d="M6 18L18 6M6 6l12 12"></path>
			</svg>
		</button>
		<div class="aspect-video bg-black rounded-lg overflow-hidden">
			<iframe
				id="video-iframe"
				class="w-full h-full"
				src=""
				title="Memoro Demo Video"
				frameborder="0"
				allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
				allowfullscreen></iframe>
		</div>
	</div>
</div>

<script define:vars={{ videoId }}>
	const trigger = document.getElementById('video-popup-trigger');
	const modal = document.getElementById('video-popup-modal');
	const closeBtn = document.getElementById('video-popup-close');
	const iframe = document.getElementById('video-iframe');

	function openModal() {
		modal.classList.remove('hidden');
		modal.classList.add('flex');
		modal.setAttribute('aria-hidden', 'false');
		iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0`;
		document.body.style.overflow = 'hidden';
	}

	function closeModal() {
		modal.classList.add('hidden');
		modal.classList.remove('flex');
		modal.setAttribute('aria-hidden', 'true');
		iframe.src = '';
		document.body.style.overflow = '';
	}

	trigger.addEventListener('click', openModal);
	closeBtn.addEventListener('click', closeModal);

	// Close on background click
	modal.addEventListener('click', (e) => {
		if (e.target === modal) {
			closeModal();
		}
	});

	// Close on Escape key
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
			closeModal();
		}
	});
</script>
