---
import type { CollectionEntry } from "astro:content";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

interface Props {
  title: string;
  description: string;
  difficulty?: string;
  duration?: string;
  category?: string;
  slug: string;
  lang: string;
  image?: string;
}

const { title, description, difficulty = "intermediate", duration = "5 min", category = "Guide", slug, lang } = Astro.props;
const t = useTranslations(lang);

// Remove language prefix if present
const cleanSlug = slug.replace(`${lang}/`, "");

const difficultyConfig = {
  beginner: {
    label: t("guides.difficulty.beginner"),
    color: "bg-success/30 text-success border border-success",
  },
  intermediate: {
    label: t("guides.difficulty.intermediate"),
    color: "bg-primary/30 text-primary border border-primary",
  },
  advanced: {
    label: t("guides.difficulty.advanced"),
    color: "bg-danger/30 text-danger border border-danger",
  },
};

// Use "intermediate" as default if provided difficulty is not in the config
const difficultyKey = difficulty in difficultyConfig ? difficulty : "intermediate";
---

<a href={`/${lang}/guides/${cleanSlug}`} class="block">
  <article
    class="bg-background-card rounded-xl overflow-hidden group relative hover:bg-background-cardHover transition-all duration-DEFAULT border border-border hover:border-border-hover"
  >
    <div class="relative p-6">
      <div class="flex items-center gap-3 mb-4">
        <span
          class={`px-2 py-1 rounded-full text-xs font-medium ${difficultyConfig[difficultyKey].color}`}
        >
          {difficultyConfig[difficultyKey].label}
        </span>
        <span class="text-sm text-text-muted">
          ⏱️ {duration}
        </span>
      </div>

      <h3
        class="text-xl font-medium text-text-primary opacity-90 group-hover:opacity-100 mb-2"
      >
        {title}
      </h3>

      <p class="text-text-secondary opacity-80 group-hover:opacity-90 mb-4">
        {description}
      </p>

      <div class="flex items-center justify-between">
        <span class="text-sm text-text-muted">
          📂 {category}
        </span>
        <span
          class="text-primary text-sm font-medium flex items-center gap-1 group-hover:translate-x-1 transition-all duration-DEFAULT"
        >
          {t("guides.readMore") || "Read More"}
          <span aria-hidden="true" class="transition-transform duration-DEFAULT"
            >→</span
          >
        </span>
      </div>
    </div>
  </article>
</a>
