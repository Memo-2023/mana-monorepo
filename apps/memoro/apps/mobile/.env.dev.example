# Development Environment Variables for Memoro App
# Copy this to .env.dev and update with your values

# Local Backend Service (when running locally)
EXPO_PUBLIC_MEMORO_MIDDLEWARE_URL=http://localhost:3001

# Supabase (can use production or a dev instance)
EXPO_PUBLIC_SUPABASE_URL=https://npgifbrwhftlbrbaglmi.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# App Configuration
EXPO_PUBLIC_STORAGE_BUCKET=user-uploads

# RevenueCat (optional for dev)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Google OAuth (optional for dev)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Analytics (optional for dev)
EXPO_PUBLIC_UMAMI_WEBSITE_ID=
EXPO_PUBLIC_UMAMI_API_URL=