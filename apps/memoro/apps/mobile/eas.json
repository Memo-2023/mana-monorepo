{
	"cli": {
		"version": ">= 16.3.0",
		"appVersionSource": "local"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal",
			"ios": {
				"image": "latest"
			},
			"env": {
				"EXPO_PUBLIC_USE_ENV_FILE": ".env.dev"
			}
		},
		"preview": {
			"distribution": "internal",
			"ios": {
				"image": "latest"
			},
			"android": {
				"buildType": "app-bundle"
			},
			"env": {
				"EXPO_PUBLIC_USE_ENV_FILE": ".env.dev"
			}
		},
		"simulator": {
			"ios": {
				"simulator": true,
				"image": "latest"
			},
			"env": {
				"EXPO_PUBLIC_USE_ENV_FILE": ".env.prod"
			}
		},
		"production": {
			"autoIncrement": true,
			"ios": {
				"image": "latest"
			},
			"env": {
				"EXPO_PUBLIC_USE_ENV_FILE": ".env.prod"
			}
		}
	},
	"submit": {
		"preview": {
			"android": {
				"track": "internal",
				"releaseStatus": "draft"
			}
		},
		"production": {}
	}
}
