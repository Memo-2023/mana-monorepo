		"expo-symbols": "~55.0.5",
		"expo-system-ui": "~55.0.9",
		"i18next": "^25.1.3",
		"idb": "^8.0.2",
		"lottie-react-native": "~7.3.4",
		"nativewind": "^4.1.23",
		"phosphor-react-native": "^3.0.3",
		"react": "19.2.0",
		"react-dom": "19.2.0",
