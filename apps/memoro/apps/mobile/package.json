		"expo-font": "~55.0.4",
		"expo-haptics": "~55.0.8",
		"expo-image-picker": "~55.0.11",
		"expo-keep-awake": "~55.0.4",
		"expo-linear-gradient": "~55.0.8",
		"expo-linking": "~55.0.7",
