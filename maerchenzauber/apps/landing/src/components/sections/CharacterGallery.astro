---
import Card from '../ui/Card.astro';

// In the future, this will fetch from API
// For now, we show an empty state
const characters: any[] = [];
---

<section class="section bg-bg-primary">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center mb-12 md:mb-16">
      <h2 class="font-grandstander font-bold text-3xl md:text-4xl lg:text-5xl text-text-primary mb-4">
        Unsere Helden-Galerie
      </h2>
      <p class="text-text-secondary text-lg max-w-3xl mx-auto">
        Jeder Charakter ist einzigartig und wartet darauf, seine Geschichte zu erzählen
      </p>
    </div>

    <!-- Character Grid -->
    {characters.length > 0 ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-4 gap-6 md:gap-8">
        {characters.map((character) => (
          <div class="group cursor-pointer">
            <div class="relative">
              {/* Avatar Container */}
              <div class="relative w-full aspect-square rounded-full overflow-hidden bg-bg-card border-2 border-transparent group-hover:border-yellow-light transition-all duration-300">
                <img
                  src={character.image}
                  alt={character.name}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                />
                {/* Hover Overlay */}
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
              </div>

              {/* Glow Effect on Hover */}
              <div class="absolute inset-0 rounded-full opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
                <div class="absolute inset-0 rounded-full bg-yellow-light/20 blur-xl"></div>
              </div>
            </div>

            {/* Character Info */}
            <div class="text-center mt-4">
              <h3 class="font-semibold text-text-primary group-hover:text-yellow-light transition-colors">
                {character.name}
              </h3>
              <p class="text-text-secondary text-sm">
                {character.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <!-- Empty State: Beautiful placeholder with call to action -->
      <div class="max-w-4xl mx-auto">
        <div class="bg-gradient-to-br from-bg-card to-bg-darker rounded-2xl p-12 md:p-16 text-center relative overflow-hidden">
          <!-- Decorative background elements -->
          <div class="absolute inset-0 opacity-10">
            <div class="absolute top-10 left-10 w-32 h-32 bg-purple-500 rounded-full blur-3xl"></div>
            <div class="absolute bottom-10 right-10 w-40 h-40 bg-pink-500 rounded-full blur-3xl"></div>
            <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-48 h-48 bg-yellow-light rounded-full blur-3xl"></div>
          </div>

          <!-- Content -->
          <div class="relative z-10">
            <!-- Icon/Avatar Placeholder -->
            <div class="mb-6 flex justify-center gap-4">
              <div class="w-20 h-20 bg-gradient-to-br from-purple-400 to-pink-500 rounded-full shadow-lg animate-bounce" style="animation-delay: 0s; animation-duration: 2s;"></div>
              <div class="w-20 h-20 bg-gradient-to-br from-yellow-light to-orange-400 rounded-full shadow-lg animate-bounce" style="animation-delay: 0.2s; animation-duration: 2s;"></div>
              <div class="w-20 h-20 bg-gradient-to-br from-blue-400 to-cyan-500 rounded-full shadow-lg animate-bounce" style="animation-delay: 0.4s; animation-duration: 2s;"></div>
            </div>

            <!-- Title -->
            <h3 class="font-grandstander font-bold text-3xl md:text-4xl text-text-primary mb-4">
              Die ersten Helden werden gerade geboren!
            </h3>

            <!-- Description -->
            <p class="text-text-secondary text-lg md:text-xl mb-8 max-w-2xl mx-auto leading-relaxed">
              Hier werden bald wundervolle Charaktere zu sehen sein.
              <span class="text-yellow-light font-semibold">Erschaffe jetzt deinen eigenen Helden</span> und lass ihn in magischen Geschichten lebendig werden!
            </p>

            <!-- Call to Action Button -->
            <a href="#download" class="inline-flex items-center gap-3 bg-gradient-to-r from-purple-500 to-pink-500 hover:from-pink-500 hover:to-purple-500 text-white font-bold py-4 px-8 rounded-full text-lg transition-all duration-300 shadow-xl hover:shadow-2xl hover:scale-105">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
              Deinen Helden erstellen
            </a>

            <!-- Features list -->
            <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-6 text-left max-w-3xl mx-auto">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 bg-yellow-light/20 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-5 h-5 text-yellow-light" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-text-primary mb-1">Einzigartige Charaktere</h4>
                  <p class="text-text-secondary text-sm">Erstelle Helden nach deinen Vorstellungen</p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <div class="w-8 h-8 bg-yellow-light/20 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-5 h-5 text-yellow-light" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M4 3a2 2 0 100 4h12a2 2 0 100-4H4z"></path>
                    <path fill-rule="evenodd" d="M3 8h14v7a2 2 0 01-2 2H5a2 2 0 01-2-2V8zm5 3a1 1 0 011-1h2a1 1 0 110 2H9a1 1 0 01-1-1z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-text-primary mb-1">Foto-Upload</h4>
                  <p class="text-text-secondary text-sm">Lade ein Foto hoch und erstelle einen passenden Helden</p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <div class="w-8 h-8 bg-yellow-light/20 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-5 h-5 text-yellow-light" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-text-primary mb-1">Schnell & Einfach</h4>
                  <p class="text-text-secondary text-sm">In wenigen Minuten zum fertigen Charakter</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    )}

    <!-- CTA - Only show when there are characters -->
    {characters.length > 0 && (
      <div class="text-center mt-12">
        <Card variant="glow" className="inline-block" padding="lg">
          <div class="flex flex-col items-center">
            <div class="text-5xl mb-4">✨</div>
            <h3 class="font-grandstander font-bold text-2xl text-text-primary mb-3">
              Erstelle deinen eigenen Helden
            </h3>
            <p class="text-text-secondary mb-6 max-w-md">
              Lass deiner Fantasie freien Lauf und erschaffe einen einzigartigen Charakter für deine Geschichten
            </p>
            <a href="#download" class="btn-primary text-lg px-8 py-4">
              Charakter erstellen
            </a>
          </div>
        </Card>
      </div>
    )}
  </div>
</section>