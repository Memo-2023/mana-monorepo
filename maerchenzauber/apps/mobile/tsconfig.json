{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "lib": [
      "ES2021"
    ],
    "module": "esnext",
    "target": "ES2021",
    "moduleResolution": "bundler",
    "baseUrl": "./",
    "paths": {
      "@storyteller/shared-types": [
        "./src/shared-types/src"
      ],
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "components/organisms"
  ],
  "exclude": [
    "node_modules",
    ".expo",
    "dist"
  ],
  "extends": "expo/tsconfig.base"
}
