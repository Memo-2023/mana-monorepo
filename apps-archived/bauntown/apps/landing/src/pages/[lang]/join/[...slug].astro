---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { languages } from '../../../i18n/ui';
import { getLangFromUrl, useTranslations } from '../../../utils/i18n';
import Newsletter from '../../../components/Newsletter.astro';
import ContentSubmission from '../../../components/ContentSubmission.astro';

export async function getStaticPaths() {
	const joinEntries = await Promise.all(
		Object.keys(languages).map(async (lang) => {
			const langJoinEntries = await getCollection('join', ({ id }) => {
				return id.startsWith(`${lang}/`) && !id.endsWith('/index.md');
			});

			return langJoinEntries.map((entry) => {
				// Get just the filename part from the slug
				const slugParts = entry.slug.split('/');
				const fileName = slugParts[slugParts.length - 1];

				return {
					params: {
						lang,
						slug: fileName,
					},
					props: { entry },
				};
			});
		})
	);

	// Flatten array of arrays
	return joinEntries.flat();
}

const { entry } = Astro.props;
const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);
const { Content } = await entry.render();
---

<Layout title={entry.data.title}>
	<div class="join-detail-container">
		<header class="join-detail-header">
			<h1>{entry.data.title}</h1>
			<p class="hero-description">{entry.data.description}</p>

			{
				entry.data.image && (
					<div class="hero-image-container">
						<img src={entry.data.image} alt={entry.data.title} class="hero-image" />
					</div>
				)
			}
		</header>

		<div class="content-container">
			<Content />
		</div>

		<div class="back-link-container">
			<a href={`/${lang}/join`} class="back-link">
				← {
					lang === 'de'
						? 'Zurück zur Übersicht'
						: lang === 'it'
							? 'Torna alla panoramica'
							: 'Back to overview'
				}
			</a>
		</div>

		<section class="join-detail-submission">
			<div class="section-header">
				<h2>{t('join.addToPage')}</h2>
				<div class="section-decoration"></div>
			</div>
			<ContentSubmission
				defaultType={entry.slug.includes('community')
					? 'mission'
					: entry.slug.includes('content')
						? 'tutorial'
						: 'vision'}
			/>
		</section>
	</div>
</Layout>

<style>
	.join-detail-container {
		max-width: 900px;
		margin: 0 auto;
		padding: 3rem 1.5rem;
	}

	.join-detail-header {
		margin-bottom: 4rem;
		text-align: center;
	}

	h1 {
		font-size: 3rem;
		margin-bottom: 1.25rem;
		background: linear-gradient(90deg, var(--accent-color), #fb923c);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		text-fill-color: transparent;
		line-height: 1.2;
	}

	.hero-description {
		font-size: 1.35rem;
		color: var(--text-muted);
		max-width: 800px;
		margin: 0 auto 2rem;
		line-height: 1.6;
	}

	.hero-image-container {
		max-width: 900px;
		margin: 3rem auto 1rem;
		position: relative;
		border-radius: 1rem;
		overflow: hidden;
		box-shadow:
			0 20px 25px -5px rgba(0, 0, 0, 0.1),
			0 10px 10px -5px rgba(0, 0, 0, 0.04);
	}

	.hero-image {
		width: 100%;
		border-radius: 1rem;
		transition: transform 0.5s ease;
	}

	.hero-image-container:hover .hero-image {
		transform: scale(1.02);
	}

	.content-container {
		margin: 0 auto 4rem;
		line-height: 1.8;
		font-size: 1.1rem;
	}

	.content-container :global(h2) {
		font-size: 2rem;
		margin-top: 3rem;
		margin-bottom: 1.25rem;
		color: var(--text-color);
	}

	.content-container :global(h3) {
		font-size: 1.5rem;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		color: var(--text-color);
	}

	.content-container :global(p) {
		margin-bottom: 1.75rem;
		color: var(--text-muted);
	}

	.content-container :global(ul) {
		margin-bottom: 2rem;
		padding-left: 1.5rem;
	}

	.content-container :global(li) {
		margin-bottom: 0.75rem;
		color: var(--text-muted);
	}

	.content-container :global(a) {
		color: var(--accent-color);
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition: border-color 0.2s ease;
	}

	.content-container :global(a:hover) {
		border-color: var(--accent-color);
	}

	.back-link-container {
		margin: 3rem 0;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		color: var(--accent-color);
		font-weight: 600;
		text-decoration: none;
		transition: all 0.2s ease;
		padding: 0.5rem 1rem;
		border-radius: 0.5rem;
		background-color: rgba(var(--accent-color-rgb), 0.1);
	}

	.back-link:hover {
		color: var(--accent-hover);
		background-color: rgba(var(--accent-color-rgb), 0.15);
		transform: translateX(-3px);
	}

	.join-detail-submission {
		margin-top: 4rem;
		padding-top: 3rem;
		border-top: 1px solid var(--border-color);
	}

	.section-header {
		text-align: center;
		margin-bottom: 2.5rem;
	}

	.section-header h2 {
		font-size: 2rem;
		margin-bottom: 1rem;
	}

	.section-decoration {
		width: 80px;
		height: 4px;
		background: linear-gradient(90deg, var(--accent-color), #fb923c);
		margin: 0 auto;
		border-radius: 2px;
	}

	@media (max-width: 768px) {
		.join-detail-container {
			padding: 2rem 1rem;
		}

		h1 {
			font-size: 2.25rem;
		}

		.hero-description {
			font-size: 1.1rem;
		}

		.content-container {
			font-size: 1rem;
		}

		.content-container :global(h2) {
			font-size: 1.75rem;
		}

		.content-container :global(h3) {
			font-size: 1.35rem;
		}

		.section-header h2 {
			font-size: 1.75rem;
		}
	}
</style>
