---
export interface Props {
	features?: string[];
	memoro?: Record<string, boolean | string>;
	competitor?: Record<string, boolean | string>;
	competitorName?: string;
}

const { features = [], memoro = {}, competitor = {}, competitorName = 'Competitor' } = Astro.props;
---

<div class="overflow-x-auto">
	<table class="w-full bg-white rounded-lg shadow-md">
		<thead>
			<tr class="bg-gray-100">
				<th class="p-4 text-left font-semibold">Sicherheitsfeature</th>
				<th class="p-4 text-center font-semibold">Memoro</th>
				<th class="p-4 text-center font-semibold">{competitorName}</th>
			</tr>
		</thead>
		<tbody>
			{
				features.map((feature, index) => (
					<tr class={index % 2 === 0 ? 'bg-gray-50' : 'bg-white'}>
						<td class="p-4 font-medium">{feature}</td>
						<td class="p-4 text-center">
							{typeof memoro[feature] === 'boolean' ? (
								memoro[feature] ? (
									<span class="text-green-600 font-bold">✓</span>
								) : (
									<span class="text-red-600">✗</span>
								)
							) : (
								<span>{memoro[feature] || '-'}</span>
							)}
						</td>
						<td class="p-4 text-center">
							{typeof competitor[feature] === 'boolean' ? (
								competitor[feature] ? (
									<span class="text-green-600">✓</span>
								) : (
									<span class="text-red-600">✗</span>
								)
							) : (
								<span>{competitor[feature] || '-'}</span>
							)}
						</td>
					</tr>
				))
			}
		</tbody>
	</table>
</div>
