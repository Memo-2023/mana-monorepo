---
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { Icon } from 'astro-icon/components';
import IndustryCard from './IndustryCard.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Get all industries for the current language and sort by order
const industries = await getCollection('industries', ({ data }) => {
	return data.lang === lang;
});

const sortedIndustries = industries
	.sort((a, b) => (a.data.order || 999) - (b.data.order || 999))
	.slice(0, 6); // Show 6 industries for large screens
---

<section class="py-20 bg-background-page">
	<div class="max-w-7xl mx-auto px-4">
		<div class="text-center mb-12">
			<h2 class="text-heading-mobile md:text-heading text-text-primary mb-4">
				{
					lang === 'de'
						? 'Für jede Branche die richtige Lösung'
						: 'The right solution for every industry'
				}
			</h2>
			<p class="text-subheading-mobile md:text-subheading text-text-secondary max-w-3xl mx-auto">
				{
					lang === 'de'
						? 'Memoro passt sich flexibel an die Bedürfnisse verschiedener Branchen an. Entdecken Sie, wie Memoro in Ihrer Branche eingesetzt werden kann.'
						: 'Memoro adapts flexibly to the needs of different industries. Discover how Memoro can be used in your industry.'
				}
			</p>
		</div>

		<!-- Industry Cards Grid -->
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
			{
				sortedIndustries.map((industry, index) => {
					// Entferne den Sprachpräfix aus dem Slug, wenn vorhanden
					const langPrefix = `${lang}/`;
					const cleanSlug = industry.slug.startsWith(langPrefix)
						? industry.slug.substring(langPrefix.length)
						: industry.slug;

					return (
						<div class={index > 2 ? 'hidden lg:block' : ''}>
							<IndustryCard
								title={industry.data.title}
								description={industry.data.description}
								icon={industry.data.icon}
								color={industry.data.color}
								href={`/${lang}/industries/${cleanSlug}`}
							/>
						</div>
					);
				})
			}
		</div>

		<!-- CTA to all industries -->
		<div class="text-center">
			<a
				href={`/${lang}/industries`}
				class="bg-primary text-white px-8 py-3 rounded-lg hover:bg-primary-hover transition-colors duration-DEFAULT inline-flex items-center font-medium"
			>
				{lang === 'de' ? 'Alle Branchen entdecken' : 'Discover all industries'}
				<Icon name="mdi:arrow-right" class="w-5 h-5 ml-2" />
			</a>
		</div>
	</div>
</section>
