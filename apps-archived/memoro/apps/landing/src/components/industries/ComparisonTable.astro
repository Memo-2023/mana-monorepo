---
interface Props {
	comparison: {
		withMemoro: string[];
		withoutMemoro: string[];
	};
	lang: string;
}

const { comparison, lang } = Astro.props;
---

<div class="my-12">
	<h2 class="text-3xl font-bold text-text-primary mb-8 text-center">
		{lang === 'de' ? 'Der Memoro Unterschied' : 'The Memoro Difference'}
	</h2>

	<div class="grid md:grid-cols-2 gap-6">
		<div class="bg-red-500/10 rounded-xl p-6 border-2 border-red-500/30">
			<h3 class="text-xl font-semibold text-red-600 mb-4 flex items-center gap-2">
				<span class="text-2xl">❌</span>
				{lang === 'de' ? 'Ohne Memoro' : 'Without Memoro'}
			</h3>
			<ul class="space-y-3">
				{
					comparison.withoutMemoro.map((item) => (
						<li class="flex items-start gap-2">
							<span class="text-red-500 mt-1">•</span>
							<span class="text-text-secondary">{item}</span>
						</li>
					))
				}
			</ul>
		</div>

		<div class="bg-green-500/10 rounded-xl p-6 border-2 border-green-500/30">
			<h3 class="text-xl font-semibold text-green-600 mb-4 flex items-center gap-2">
				<span class="text-2xl">✅</span>
				{lang === 'de' ? 'Mit Memoro' : 'With Memoro'}
			</h3>
			<ul class="space-y-3">
				{
					comparison.withMemoro.map((item) => (
						<li class="flex items-start gap-2">
							<span class="text-green-500 mt-1">•</span>
							<span class="text-text-secondary">{item}</span>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</div>
