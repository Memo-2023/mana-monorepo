---
import { Icon } from 'astro-icon/components';

interface Statistic {
	value: string;
	label: string;
	icon?: string;
}

interface Props {
	statistics: Statistic[];
}

const { statistics } = Astro.props;
---

<div class="bg-gradient-to-r from-primary/10 to-primary-hover/10 rounded-2xl p-8 my-12">
	<div class="grid grid-cols-2 md:grid-cols-4 gap-6">
		{
			statistics.map((stat) => (
				<div class="text-center">
					{stat.icon && (
						<div class="text-3xl mb-2">
							<Icon name={`mdi:${stat.icon}`} class="w-8 h-8 mx-auto text-primary" />
						</div>
					)}
					<div class="text-3xl md:text-4xl font-bold text-primary mb-2 animate-counter">
						{stat.value}
					</div>
					<div class="text-sm text-text-secondary">{stat.label}</div>
				</div>
			))
		}
	</div>
</div>

<style>
	@keyframes counter {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-counter {
		animation: counter 0.8s ease-out forwards;
	}
</style>
