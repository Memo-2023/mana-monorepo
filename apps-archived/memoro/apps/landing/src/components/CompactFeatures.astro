---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { Icon } from 'astro-icon/components';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const featureGroups = [
	{
		title: lang === 'de' ? 'Erfassen' : 'Capture',
		icon: 'mdi:microphone',
		features: [
			lang === 'de' ? '24 Sprachen + Dialekte' : '24 languages + dialects',
			lang === 'de' ? 'Bis zu 12 Sprecher' : 'Up to 12 speakers',
			lang === 'de' ? 'Audio-Upload (MP3, WAV, etc.)' : 'Audio upload (MP3, WAV, etc.)',
			lang === 'de' ? 'Offline-Modus verfügbar' : 'Offline mode available',
		],
	},
	{
		title: lang === 'de' ? 'Verstehen' : 'Understand',
		icon: 'mdi:brain',
		features: [
			lang === 'de' ? 'KI-Zusammenfassungen' : 'AI summaries',
			lang === 'de' ? 'Automatische Gliederung' : 'Automatic structuring',
			lang === 'de' ? 'Stimmungsanalyse' : 'Sentiment analysis',
			lang === 'de' ? 'Themen-Erkennung' : 'Topic detection',
		],
	},
	{
		title: lang === 'de' ? 'Nutzen' : 'Utilize',
		icon: 'mdi:rocket-launch',
		features: [
			lang === 'de' ? 'Word, PDF, Markdown Export' : 'Word, PDF, Markdown export',
			lang === 'de' ? 'API-Integration' : 'API integration',
			lang === 'de' ? 'Team-Kollaboration' : 'Team collaboration',
			lang === 'de' ? 'Volltextsuche' : 'Full-text search',
		],
	},
];
---

<section class="py-16 md:py-24 bg-background-page">
	<div class="max-w-7xl mx-auto px-4">
		<h2 class="text-heading-mobile md:text-heading text-text-primary text-center mb-12">
			{lang === 'de' ? 'Alles was Sie brauchen' : 'Everything You Need'}
		</h2>

		<div class="grid md:grid-cols-3 gap-8">
			{
				featureGroups.map((group) => (
					<div class="text-center bg-background-card rounded-2xl p-8 border border-border hover:bg-background-cardHover hover:border-border-hover transition-all duration-DEFAULT">
						<div class="mb-4">
							<Icon name={group.icon} class="w-16 h-16 text-primary mx-auto" />
						</div>
						<h3 class="text-xl font-semibold mb-4 text-text-primary">{group.title}</h3>
						<ul class="space-y-2">
							{group.features.map((feature) => (
								<li class="flex items-center justify-center">
									<Icon name="mdi:check" class="w-5 h-5 text-primary mr-2" />
									<span class="text-text-secondary">{feature}</span>
								</li>
							))}
						</ul>
					</div>
				))
			}
		</div>
	</div>
</section>
