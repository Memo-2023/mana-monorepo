---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { Icon } from "astro-icon/components";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const stats = lang === 'de' ? [
  {
    label: "Über 2800 Nutzer",
    value: "2800",
    icon: "mdi:account-group"
  },
  {
    label: "6000 Stunden Aufnahmen",
    value: "6000",
    icon: "mdi:microphone"
  },
  {
    label: "60 Millionen Wörter",
    value: "60000000",
    icon: "mdi:text"
  }
] : [
  {
    label: "Over 2800 Users",
    value: "2800",
    icon: "mdi:account-group"
  },
  {
    label: "6000 Hours of Recordings",
    value: "6000",
    icon: "mdi:microphone"
  },
  {
    label: "60 Million Words",
    value: "60000000",
    icon: "mdi:text"
  }
];

---

<section class="py-20 bg-background-page">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-heading-mobile md:text-heading text-text-primary mb-4">
        {t("numbers.title")}
      </h2>
      <p class="text-subheading-mobile md:text-subheading text-text-secondary max-w-3xl mx-auto">
        {t("numbers.subtitle")}
      </p>
    </div>

    <!-- Stats Progress Bars -->
    <div class="max-w-3xl mx-auto space-y-4">
      {stats.map((stat, index) => (
        <div class="stat-item relative h-16 md:h-20 rounded-xl overflow-hidden" data-index={index}>
          <!-- Background with 20% opacity -->
          <div class="absolute inset-0 bg-primary opacity-20"></div>
          
          <!-- Animated bar -->
          <div class="stat-bar absolute inset-0 bg-primary flex items-center px-6 md:px-8 transition-all duration-[5000ms] ease-out" style="width: 0%">
            <div class="flex items-center gap-3 text-white stat-label opacity-0 transition-opacity duration-200">
              <Icon name={stat.icon} class="w-5 h-5 md:w-6 md:h-6 flex-shrink-0" />
              <p class="text-base md:text-lg font-medium whitespace-nowrap">
                {stat.label}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>


  </div>
</section>

<style>
  .stat-value {
    font-variant-numeric: tabular-nums;
  }
</style>

<script>
  // Animate progress bars when they come into view
  const observerOptions = {
    threshold: 0.3,
    rootMargin: '0px'
  };

  const animateBar = (statItem: Element) => {
    const index = parseInt(statItem.getAttribute('data-index') || '0');
    const bar = statItem.querySelector('.stat-bar') as HTMLElement;
    const label = statItem.querySelector('.stat-label') as HTMLElement;
    
    // Stagger the animations
    setTimeout(() => {
      // Animate bar to 100%
      bar.style.width = '100%';
      
      // Show label after bar starts animating
      setTimeout(() => {
        label.style.opacity = '1';
      }, 200);
    }, index * 200); // 200ms delay between each bar
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateBar(entry.target);
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  // Observe all stat items
  document.querySelectorAll('.stat-item').forEach(stat => {
    observer.observe(stat);
  });
</script>