---
import type { HTMLAttributes } from 'astro/types';
import BackButton from '../detail/BackButton.astro';

interface Props extends HTMLAttributes<'main'> {
	title?: string;
	description?: string;
	backLink?: {
		href: string;
		text?: string;
	};
	containerClass?: string;
	articleClass?: string;
	contentClass?: string;
	noProse?: boolean;
}

const {
	title,
	description,
	backLink,
	containerClass = 'max-w-4xl mx-auto px-4 pt-12 pb-6 sm:pb-8',
	articleClass = '',
	contentClass,
	noProse = false,
	...rest
} = Astro.props;

// Default prose classes
const defaultProseClass = `prose prose-lg max-w-none prose-invert
  prose-h1:!text-3xl prose-h1:!font-bold prose-h1:!text-text-primary
  prose-h2:!text-2xl prose-h2:!font-semibold prose-h2:!text-text-primary
  prose-h3:!text-xl prose-h3:!font-semibold prose-h3:!text-text-primary
  prose-h4:!text-lg prose-h4:!font-semibold prose-h4:!text-text-primary
  prose-p:!text-text-secondary prose-p:!leading-relaxed
  prose-a:!text-primary hover:prose-a:!text-primary-hover
  prose-strong:!text-text-primary prose-strong:!font-semibold
  prose-code:!text-primary prose-code:!bg-background-cardHover prose-code:!px-1 prose-code:!py-0.5 prose-code:!rounded
  prose-pre:!bg-background-cardHover prose-pre:!border prose-pre:!border-border prose-pre:!text-text-secondary
  prose-blockquote:!border-l-4 prose-blockquote:!border-primary prose-blockquote:!bg-background-cardHover prose-blockquote:!text-text-secondary prose-blockquote:!italic
  prose-ul:!text-text-secondary prose-li:!text-text-secondary
  prose-li:marker:!text-primary`;

const finalContentClass = noProse ? contentClass || '' : contentClass || defaultProseClass;
---

<main class="bg-background-page" {...rest}>
	<div class={containerClass}>
		{backLink && title && <BackButton href={backLink.href} title={title} />}

		<article class={articleClass}>
			{/* Custom header slot or default header */}
			{
				Astro.slots.has('header') ? (
					<slot name="header" />
				) : (
					title && (
						<header class="mb-8">
							<h1 class="text-3xl font-bold text-text-primary">{title}</h1>
							{description && <p class="text-xl text-text-secondary mt-2">{description}</p>}
						</header>
					)
				)
			}

			{/* Before content slot */}
			{Astro.slots.has('before-content') && <slot name="before-content" />}

			{/* Main content */}
			<div class={finalContentClass}>
				<slot />
			</div>

			{/* After content slot */}
			{Astro.slots.has('after-content') && <slot name="after-content" />}

			{/* Footer slot for navigation, etc. */}
			{Astro.slots.has('footer') && <slot name="footer" />}
		</article>

		{/* Outside article slot */}
		{Astro.slots.has('outside-article') && <slot name="outside-article" />}
	</div>
</main>
