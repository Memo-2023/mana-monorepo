---
import { getCollection } from 'astro:content';
import { getLangFromUrl } from '../i18n/utils';
import FeatureCard from './FeatureCard.astro';

interface Props {
	title?: string;
	description?: string;
	viewAllText?: string;
	viewAllLink?: string;
}

const { title, description, viewAllText, viewAllLink } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const features = await getCollection('features', ({ data }) => {
	return data.lang === lang;
});

// Nimm die ersten 3 Features
const previewFeatures = features.slice(0, 3);

// Funktion zum Bereinigen des Slugs (Entfernen des Sprachcodes)
const cleanSlug = (slug: string) => {
	return slug.replace(`${lang}/`, '');
};
---

<section class="max-w-7xl mx-auto px-4 py-20 border-t border-border">
	<div class="text-center max-w-3xl mx-auto mb-16">
		<h2 class="text-heading-mobile md:text-heading text-text-primary mb-4">
			{title || (lang === 'de' ? 'Unsere Features' : 'Our Features')}
		</h2>
		<p class="text-subheading-mobile md:text-subheading text-text-secondary">
			{
				description ||
					(lang === 'de'
						? 'Entdecke die wichtigsten Funktionen, die Memoro so besonders machen.'
						: 'Discover the key features that make Memoro special.')
			}
		</p>
	</div>

	<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
		{
			previewFeatures.map((feature) => (
				<FeatureCard
					title={feature.data.title}
					description={feature.data.description}
					icon={feature.data.icon}
					href={`/${lang}/features/${feature.slug.split('/')[1]}`}
					lang={lang}
				/>
			))
		}
	</div>

	<div class="text-center mt-8">
		<a
			href={viewAllLink || `/${lang}/features`}
			class="inline-flex items-center text-primary-DEFAULT hover:text-primary-hover transition-colors"
		>
			{viewAllText || (lang === 'de' ? 'Alle Features entdecken' : 'Explore all features')}
			<svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
				></path>
			</svg>
		</a>
	</div>
</section>
