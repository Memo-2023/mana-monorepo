---
/**
 * A/B Test Component for Hero CTA
 * Experiment: hero-cta-test
 * Variants:
 * - control: "App herunterladen"
 * - variant-b: "Kostenlos testen"
 */

import CallToAction from '../CallToAction.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

interface Props {
	class?: string;
}

const { class: className } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Default CTA text (control)
const defaultCtaText = t('hero.cta_primary');
const defaultCtaDescription = t('hero.cta_description');
---

<div id="hero-cta-experiment" data-experiment="hero-cta-test" class={className}>
	<CallToAction
		title={defaultCtaText}
		description={defaultCtaDescription}
		primaryButtonText={defaultCtaText}
		primaryButtonLink={`/${lang}/download`}
		showSecondaryButton={true}
		secondaryButtonText={t('hero.cta_secondary')}
		secondaryButtonLink={`/${lang}/features`}
		size="large"
		align="center"
	/>
</div>

<script>
	import { getExperiment, trackEvent } from '../../utils/experiments';

	async function applyHeroCtaVariant() {
		const variant = await getExperiment('hero-cta-test');

		if (variant === 'variant-b') {
			// Update CTA text for variant B
			const ctaTitle = document.querySelector('#hero-cta-experiment h2');
			const primaryButton = document.querySelector('#hero-cta-experiment a[href*="/download"]');

			if (ctaTitle) {
				ctaTitle.textContent = 'Kostenlos testen';
			}

			if (primaryButton) {
				const buttonText = primaryButton.querySelector('span');
				if (buttonText) {
					buttonText.textContent = 'Jetzt kostenlos testen';
				}
			}

			// Track that variant B was shown
			trackEvent('experiment_variant_shown', {
				experiment: 'hero-cta-test',
				variant: 'variant-b',
			});
		} else {
			// Track control variant
			trackEvent('experiment_variant_shown', {
				experiment: 'hero-cta-test',
				variant: 'control',
			});
		}
	}

	// Apply variant on load
	document.addEventListener('DOMContentLoaded', applyHeroCtaVariant);

	// Track CTA clicks
	document.addEventListener('click', (e) => {
		const target = e.target as HTMLElement;
		const ctaContainer = target.closest('#hero-cta-experiment');

		if (ctaContainer && target.closest('a')) {
			const link = target.closest('a') as HTMLAnchorElement;
			const isPrimary = link.href.includes('/download');

			getExperiment('hero-cta-test').then((variant) => {
				trackEvent('hero_cta_clicked', {
					experiment: 'hero-cta-test',
					variant: variant || 'control',
					button_type: isPrimary ? 'primary' : 'secondary',
					destination: link.href,
				});
			});
		}
	});
</script>
