---
import { Icon } from 'astro-icon/components';

interface Props {
	quote: string;
	author: string;
	role: string;
	company?: string;
	image?: string;
	href?: string;
	type?: 'private' | 'company' | 'network' | 'press';
	source?: string;
	sourceUrl?: string;
	lang?: string;
}

const {
	quote,
	author,
	role,
	company,
	image,
	href,
	type = 'company',
	source,
	sourceUrl,
	lang = 'de',
} = Astro.props;

const Card = href ? 'a' : 'div';

// Get label for testimonial type
function getTypeLabel(type: string, lang: string) {
	const labels = {
		de: {
			private: 'Privat',
			company: 'Firma',
			network: 'Netzwerk',
			press: 'Presse',
		},
		en: {
			private: 'Private',
			company: 'Company',
			network: 'Network',
			press: 'Press',
		},
	};
	return labels[lang]?.[type] || type;
}

// Get color for testimonial type
function getTypeColor(type: string) {
	switch (type) {
		case 'private':
			return 'bg-blue-100 text-blue-700 border-blue-200';
		case 'company':
			return 'bg-green-100 text-green-700 border-green-200';
		case 'network':
			return 'bg-purple-100 text-purple-700 border-purple-200';
		case 'press':
			return 'bg-orange-100 text-orange-700 border-orange-200';
		default:
			return 'bg-primary/10 text-primary border-primary/20';
	}
}
---

<Card
	href={href}
	class:list={[
		'block group bg-background-card rounded-xl border border-border',
		href &&
			'hover:bg-background-cardHover hover:border-border-hover transition-all duration-DEFAULT',
	]}
>
	<div class="p-6 h-full flex flex-col">
		<blockquote class="text-text-secondary italic mb-6 flex-grow relative">
			<span class="absolute -top-3 left-0 text-4xl text-primary-DEFAULT opacity-20">"</span>
			<span class="block pt-4">{quote}</span>
		</blockquote>

		<div class="flex items-center gap-4 pt-4 border-t border-border">
			{
				image ? (
					<img
						src={image}
						alt={`Portrait of ${author}`}
						class="w-12 h-12 rounded-full object-cover border border-border"
						width="48"
						height="48"
						loading="lazy"
						decoding="async"
					/>
				) : (
					<div class="w-12 h-12 rounded-full bg-primary/10 border border-primary/20 flex items-center justify-center">
						<Icon name="mdi:account" class="w-6 h-6 text-primary" />
					</div>
				)
			}
			<div class="flex-1">
				<div class="flex items-center gap-2 flex-wrap">
					<div
						class:list={[
							'font-medium text-text-primary',
							href && 'group-hover:text-primary-DEFAULT transition-colors',
						]}
					>
						{author}
					</div>
					<span class={`text-xs px-2 py-0.5 rounded-full font-medium border ${getTypeColor(type)}`}>
						{getTypeLabel(type, lang)}
					</span>
				</div>
				<div class="text-sm text-text-secondary">
					{role}
					{company && ` • ${company}`}
				</div>
				{
					type === 'press' && source && (
						<div class="text-xs text-text-muted mt-1">
							{lang === 'de' ? 'Quelle: ' : 'Source: '}
							{sourceUrl ? (
								<a
									href={sourceUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="hover:text-primary transition-colors underline"
									onclick="event.stopPropagation()"
								>
									{source}
								</a>
							) : (
								source
							)}
						</div>
					)
				}
			</div>
		</div>
	</div>
</Card>
