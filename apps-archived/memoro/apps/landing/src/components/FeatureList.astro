---
export interface Props {
	items: Array<{
		label: string;
		description?: string;
		emoji?: string;
	}>;
	title?: string;
	spacing?: 'tight' | 'normal' | 'loose';
	class?: string;
}

const { items, title, spacing = 'normal', class: className = '' } = Astro.props;

const spacingClass = {
	tight: 'space-y-2',
	normal: 'space-y-3',
	loose: 'space-y-4',
}[spacing];
---

{title && <h3 class="text-xl font-semibold mb-4">{title}</h3>}
<ul class={`${spacingClass} ${className}`}>
	{
		items.map((item) => (
			<li>
				{item.emoji && <span>{item.emoji} </span>}
				<strong>{item.label}</strong>
				{item.description && <span> - {item.description}</span>}
			</li>
		))
	}
</ul>
