---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { useTranslations } from '../../../i18n/utils';
import { Icon } from 'astro-icon/components';
import Button from '../../../components/atoms/Button.astro';

export async function getStaticPaths() {
	const wallpapersEntries = await getCollection('wallpapers');

	// Map each wallpaper to a route with language handling
	return wallpapersEntries.map((wallpaper) => {
		const lang = wallpaper.data.lang;
		let slugWithoutLang = wallpaper.slug;

		// Remove language prefix if present
		if (wallpaper.slug.startsWith(`${lang}/`)) {
			slugWithoutLang = wallpaper.slug.replace(`${lang}/`, '');
		}

		return {
			params: {
				lang: lang,
				slug: slugWithoutLang,
			},
			props: { wallpaper },
		};
	});
}

const { wallpaper } = Astro.props;
const { lang } = Astro.params;
const t = useTranslations(lang);

// Get the Content component from the wallpaper
let Content;
try {
	const rendered = await wallpaper.render();
	Content = rendered.Content;
} catch (error) {
	console.error('Error rendering wallpaper:', error);
}

// Übersetzungen
const translations = {
	de: {
		back: 'Zurück zur Übersicht',
		category: 'Kategorie',
		categories: {
			nature: 'Natur',
			abstract: 'Abstrakt',
			city: 'Stadt',
			technology: 'Technologie',
			other: 'Sonstige',
		},
		resolution: 'Auflösung',
		aspectRatio: 'Seitenverhältnis',
		colors: 'Farben',
		tags: 'Tags',
		downloads: 'Downloads',
		lastUpdated: 'Zuletzt aktualisiert',
		preview: 'Vorschau',
		download: 'Herunterladen',
		downloadDesktop: 'Desktop Version herunterladen',
		downloadMobile: 'iPhone Version herunterladen',
		details: 'Details',
		availableVersions: 'Verfügbare Versionen',
	},
	en: {
		back: 'Back to overview',
		category: 'Category',
		categories: {
			nature: 'Nature',
			abstract: 'Abstract',
			city: 'City',
			technology: 'Technology',
			other: 'Other',
		},
		resolution: 'Resolution',
		aspectRatio: 'Aspect Ratio',
		colors: 'Colors',
		tags: 'Tags',
		downloads: 'Downloads',
		lastUpdated: 'Last updated',
		preview: 'Preview',
		download: 'Download',
		downloadDesktop: 'Download Desktop Version',
		downloadMobile: 'Download iPhone Version',
		details: 'Details',
		availableVersions: 'Available Versions',
	},
};

const currentTranslations = translations[lang];

// Get format data
const desktopFormats = wallpaper.data.formats.filter((f) => f.type === 'desktop');
const mobileFormats = wallpaper.data.formats.filter((f) => f.type === 'mobile');
const primaryDesktop =
	desktopFormats.find((f) => f.resolution === '3840x2160') || desktopFormats[0];
const primaryMobile = mobileFormats[0];
---

<Layout title={wallpaper.data.title}>
	<main class="bg-background-page">
		<div class="max-w-7xl mx-auto px-4 py-8 md:py-16">
			<!-- Back Link -->
			<a
				href={`/${lang}/wallpapers`}
				class="inline-flex items-center text-text-secondary hover:text-primary transition-colors mb-8 group"
			>
				<Icon
					name="mdi:arrow-left"
					class="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform"
				/>
				{currentTranslations.back}
			</a>

			<!-- Hero Section -->
			<div class="grid lg:grid-cols-2 gap-12 mb-16">
				<!-- Left Column: Preview Image -->
				<div class="relative">
					<div class="sticky top-8">
						<h2 class="text-lg font-semibold text-text-primary mb-4 flex items-center">
							<Icon name="mdi:image" class="w-5 h-5 mr-2" />
							{currentTranslations.preview}
						</h2>
						<div class="bg-background-card rounded-2xl p-4 shadow-xl">
							<img
								src={wallpaper.data.thumbnail}
								alt={wallpaper.data.title}
								class="w-full h-auto rounded-xl"
							/>
						</div>
					</div>
				</div>

				<!-- Right Column: Title, Description, and Actions -->
				<div>
					<h1 class="text-4xl md:text-5xl font-bold text-text-primary mb-4">
						{wallpaper.data.title}
					</h1>
					<p class="text-xl text-text-secondary mb-8">{wallpaper.data.description}</p>

					<!-- Download Buttons -->
					<div class="space-y-4 mb-8">
						<h3 class="text-lg font-semibold text-text-primary mb-2">
							{currentTranslations.availableVersions}
						</h3>

						{/* Desktop Downloads */}
						{
							desktopFormats.length > 0 && (
								<div class="space-y-2">
									<p class="text-sm text-text-secondary font-medium mb-2">Desktop</p>
									{desktopFormats.map((format) => (
										<Button
											href={format.fileUrl}
											variant="primary"
											size="lg"
											class="w-full group"
											download={format.fileUrl.split('/').pop()}
										>
											<Icon name="mdi:monitor" class="w-6 h-6 mr-3" />
											<span class="flex-1 text-left">
												{format.resolution} ({format.aspectRatio})
											</span>
											<span class="text-sm opacity-75">{format.fileSize}</span>
											<Icon
												name="mdi:download"
												class="w-5 h-5 ml-3 group-hover:translate-y-1 transition-transform"
											/>
										</Button>
									))}
								</div>
							)
						}

						{/* Mobile Downloads */}
						{
							mobileFormats.length > 0 && (
								<div class="space-y-2">
									<p class="text-sm text-text-secondary font-medium mb-2">Mobile</p>
									{mobileFormats.map((format) => (
										<Button
											href={format.fileUrl}
											variant="primary"
											size="lg"
											class="w-full group"
											download={format.fileUrl.split('/').pop()}
										>
											<Icon name="mdi:cellphone" class="w-6 h-6 mr-3" />
											<span class="flex-1 text-left">
												{format.device || 'Mobile'} - {format.resolution}
											</span>
											<span class="text-sm opacity-75">{format.fileSize}</span>
											<Icon
												name="mdi:download"
												class="w-5 h-5 ml-3 group-hover:translate-y-1 transition-transform"
											/>
										</Button>
									))}
								</div>
							)
						}
					</div>

					<!-- Metadata Grid -->
					<div class="bg-background-card rounded-2xl p-6 space-y-6">
						<h2 class="text-lg font-semibold text-text-primary flex items-center">
							<Icon name="mdi:information-outline" class="w-5 h-5 mr-2" />
							{currentTranslations.details}
						</h2>

						<div class="grid grid-cols-2 gap-4">
							<!-- Category -->
							<div>
								<p class="text-sm text-text-secondary mb-1">{currentTranslations.category}</p>
								<span
									class="inline-block px-3 py-1 bg-primary/10 text-primary rounded-full text-sm font-medium"
								>
									{
										currentTranslations.categories[wallpaper.data.category] ||
											wallpaper.data.category
									}
								</span>
							</div>

							<!-- Available Formats -->
							<div class="col-span-2">
								<p class="text-sm text-text-secondary mb-1">
									{currentTranslations.availableVersions}
								</p>
								<p class="font-medium text-text-primary">
									{wallpaper.data.formats.length}
									{lang === 'de' ? 'Formate' : 'Formats'}
								</p>
							</div>

							<!-- Downloads -->
							<div>
								<p class="text-sm text-text-secondary mb-1">{currentTranslations.downloads}</p>
								<p class="font-medium text-text-primary">{wallpaper.data.downloadCount}</p>
							</div>
						</div>

						<!-- Colors -->
						{
							wallpaper.data.colors && wallpaper.data.colors.length > 0 && (
								<div>
									<p class="text-sm text-text-secondary mb-2">{currentTranslations.colors}</p>
									<div class="flex gap-2">
										{wallpaper.data.colors.map((color) => (
											<div
												class="w-10 h-10 rounded-lg shadow-inner border border-border"
												style={`background-color: ${color};`}
												title={color}
											/>
										))}
									</div>
								</div>
							)
						}

						<!-- Tags -->
						{
							wallpaper.data.tags && wallpaper.data.tags.length > 0 && (
								<div>
									<p class="text-sm text-text-secondary mb-2">{currentTranslations.tags}</p>
									<div class="flex flex-wrap gap-2">
										{wallpaper.data.tags.map((tag) => (
											<span class="px-3 py-1 bg-background text-text-secondary rounded-lg text-sm">
												{tag}
											</span>
										))}
									</div>
								</div>
							)
						}

						<!-- Last Updated -->
						{
							wallpaper.data.lastUpdated && (
								<div class="pt-4 border-t border-border">
									<p class="text-sm text-text-secondary">
										{currentTranslations.lastUpdated}:{' '}
										{new Date(wallpaper.data.lastUpdated).toLocaleDateString(
											lang === 'de' ? 'de-DE' : 'en-US',
											{
												year: 'numeric',
												month: 'long',
												day: 'numeric',
											}
										)}
									</p>
								</div>
							)
						}
					</div>
				</div>
			</div>

			<!-- Content Section -->
			<div class="max-w-4xl mx-auto">
				<div
					class="prose prose-lg max-w-none
        prose-headings:text-text-primary
        prose-p:text-text-secondary
        prose-a:text-primary prose-a:no-underline hover:prose-a:underline
        prose-strong:text-text-primary
        prose-ul:text-text-secondary
        prose-ol:text-text-secondary
        prose-h2:text-2xl prose-h2:font-bold prose-h2:mt-8 prose-h2:mb-4
        prose-h3:text-xl prose-h3:font-semibold prose-h3:mt-6 prose-h3:mb-3
        prose-h4:text-lg prose-h4:font-medium prose-h4:mt-4 prose-h4:mb-2"
				>
					{Content && <Content />}
					{
						!Content && (
							<p class="text-red-500 font-medium">
								There was an error rendering this wallpaper's content.
							</p>
						)
					}
				</div>
			</div>
		</div>
	</main>
</Layout>

<style>
	/* Hide the title in the content since we display it in the hero */
	.prose h1:first-child {
		display: none;
	}

	/* Custom styles for download links in content */
	.prose a[href$='.png'] {
		@apply inline-flex items-center px-4 py-2 bg-primary/10 text-primary rounded-lg hover:bg-primary/20 transition-colors no-underline font-medium;
	}

	.prose a[href$='.png']:after {
		content: '↓';
		@apply ml-2;
	}
</style>
