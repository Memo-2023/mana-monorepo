---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import DetailLayout from '../../../components/layouts/DetailLayout.astro';
import ColorTheme from '../../../components/detail/ColorTheme.astro';
import FeaturesList from '../../../components/detail/FeaturesList.astro';
import LastUpdatedInfo from '../../../components/detail/LastUpdatedInfo.astro';
import { useTranslations } from '../../../i18n/utils';

export async function getStaticPaths() {
	const memoriesEntries = await getCollection('memories');

	// Map each memory to a route with language handling
	return memoriesEntries.map((memory) => {
		const lang = memory.data.lang;
		let slugWithoutLang = memory.slug;

		// Remove language prefix if present
		if (memory.slug.startsWith(`${lang}/`)) {
			slugWithoutLang = memory.slug.replace(`${lang}/`, '');
		}

		return {
			params: {
				lang: lang,
				slug: slugWithoutLang,
			},
			props: { memory },
		};
	});
}

const { memory } = Astro.props;
const { lang } = Astro.params;
const t = useTranslations(lang);

// Get the Content component from the memory
let Content;
try {
	const rendered = await memory.render();
	Content = rendered.Content;
} catch (error) {
	console.error('Error rendering memory:', error);
}

// Übersetzungen
const translations = {
	de: {
		back: '← Zurück zur Übersicht',
		features: 'Funktionen',
		compatibility: 'Kompatibilität',
		lastUpdated: 'Zuletzt aktualisiert',
	},
	en: {
		back: '← Back to overview',
		features: 'Features',
		compatibility: 'Compatibility',
		lastUpdated: 'Last updated',
	},
};

const currentTranslations = translations[lang];
---

<Layout title={memory.data.title}>
	<DetailLayout
		containerClass="max-w-4xl mx-auto px-6 sm:px-8 py-6 sm:py-8"
		articleClass=""
		noProse={true}
		backLink={{
			href: `/${lang}/memories`,
		}}
	>
		<Fragment slot="before-content">
			<ColorTheme color={memory.data.color} variant="bar" />

			<div class="p-8">
				<header class="mb-8">
					<div class="flex items-center gap-4 mb-4">
						<ColorTheme color={memory.data.color} icon={memory.data.icon} variant="icon" />

						<div>
							<h1 class="text-3xl font-bold text-text-primary">{memory.data.title}</h1>
							<p class="text-lg text-text-secondary mt-1">{memory.data.description}</p>
						</div>
					</div>

					{
						memory.data.lastUpdated && (
							<LastUpdatedInfo date={memory.data.lastUpdated} lang={lang} />
						)
					}
				</header>

				{/* Features section */}
				{
					memory.data.features && (
						<FeaturesList
							features={memory.data.features}
							title={currentTranslations.features}
							variant="card"
							columns={2}
						/>
					)
				}

				{/* Compatibility section */}
				{
					memory.data.compatibility && memory.data.compatibility.length > 0 && (
						<div class="mb-8 p-6 bg-background-page rounded-lg">
							<h2 class="text-xl font-semibold text-text-primary mb-4">
								{currentTranslations.compatibility}
							</h2>
							<div class="flex flex-wrap gap-2">
								{memory.data.compatibility.map((item) => (
									<span class="px-3 py-1 bg-background-cardHover text-text-secondary rounded-full text-sm">
										{item}
									</span>
								))}
							</div>
						</div>
					)
				}
			</div>

			<div
				class="px-8 pb-8 prose prose-lg max-w-none dark:prose-invert
              prose-h1:text-3xl prose-h1:font-bold
              prose-h2:text-2xl prose-h2:font-semibold
              prose-h3:text-xl prose-h3:font-semibold
              prose-headings:text-text-primary
              prose-p:text-text-secondary
              prose-a:text-primary-DEFAULT hover:prose-a:text-primary-hover
              prose-strong:text-text-primary
              prose-code:text-primary-DEFAULT
              prose-pre:bg-background-cardHover prose-pre:border prose-pre:border-border
              prose-blockquote:border-primary-DEFAULT prose-blockquote:bg-background-cardHover prose-blockquote:text-text-secondary
              prose-li:text-text-secondary"
			>
				{Content && <Content />}
				{
					!Content && (
						<p class="text-red-500">There was an error rendering this memory's content.</p>
					)
				}
			</div>
		</Fragment>
	</DetailLayout></Layout
>
