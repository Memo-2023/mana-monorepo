---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import MemoroSoftwareApp from '../../components/MemoroSoftwareApp.astro';
import MemoroOrganization from '../../components/MemoroOrganization.astro';

export async function getStaticPaths() {
	// Only create German version for now
	return [
		{
			params: { lang: 'de' },
			props: { lang: 'de' },
		},
	];
}

const { lang } = Astro.props;

// Redirect English users to comparison page for now
if (lang === 'en') {
	return Astro.redirect('/en/features', 301);
}

const page = await getEntry('pages', `${lang}/granola-ai-alternative`);

if (!page) {
	return Astro.redirect(`/${lang}`, 404);
}

const { Content } = await page.render();

// Schema.org structured data for comparison page
const comparisonSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	'@id': `https://memoro.ai/${lang}/granola-ai-alternative`,
	url: `https://memoro.ai/${lang}/granola-ai-alternative`,
	name: page.data.title,
	description: page.data.description,
	inLanguage: lang === 'de' ? 'de-DE' : 'en-US',
	isPartOf: {
		'@type': 'WebSite',
		'@id': 'https://memoro.ai/#website',
		url: 'https://memoro.ai',
		name: 'Memoro',
	},
	mainEntity: {
		'@type': 'SoftwareApplication',
		name: 'Memoro',
		applicationCategory: 'BusinessApplication',
		operatingSystem: 'Web, iOS, Android, Windows, macOS',
		offers: {
			'@type': 'Offer',
			price: '9.99',
			priceCurrency: 'EUR',
		},
		aggregateRating: {
			'@type': 'AggregateRating',
			ratingValue: '4.9',
			reviewCount: '1247',
		},
	},
};

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: [
		{
			'@type': 'Question',
			name: 'Kann ich Memoro auch ohne Bot nutzen wie bei Granola?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Ja! Memoro bietet beide Optionen: Sie können diskret ohne Bot aufzeichnen (wie Granola) oder optional einen Bot für automatische Aufnahmen nutzen. Sie haben die volle Kontrolle.',
			},
		},
		{
			'@type': 'Question',
			name: 'Wie viele Meetings sind bei Memoro kostenlos?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Sie erhalten 600 Minuten pro Monat kostenlos - das sind typischerweise 200+ Meetings. Im Gegensatz zu Granolas einmaligen 25 Meetings erneuert sich Ihr Kontingent jeden Monat.',
			},
		},
		{
			'@type': 'Question',
			name: 'Ist Memoro wirklich DSGVO-konform?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Ja, zu 100%. Unsere Server stehen in Deutschland, wir haben einen deutschen Datenschutzbeauftragten und erfüllen alle DSGVO-Anforderungen. Ihre Daten verlassen niemals die EU.',
			},
		},
	],
};
---

<Layout title={page.data.title} description={page.data.description} lang={lang}>
	<Fragment slot="structured-data">
		<script type="application/ld+json" set:html={JSON.stringify(comparisonSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
		<MemoroSoftwareApp />
		<MemoroOrganization />
	</Fragment>

	<article class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 lg:py-20">
		<div
			class="prose prose-lg max-w-none
                prose-headings:text-text-heading
                prose-p:text-text-body
                prose-a:text-primary-600 hover:prose-a:text-primary-700
                prose-strong:text-text-heading
                prose-img:rounded-lg prose-img:shadow-xl"
		>
			<Content />
		</div>
	</article>
</Layout>
