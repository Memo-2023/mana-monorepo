---
import { getCollection, getEntry } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import BlogCard from "../../../components/BlogCard.astro";
import FilterPills from "../../../components/FilterPills.astro";
import EmptyState from "../../../components/EmptyState.astro";
import { useTranslations } from "../../../i18n/utils";

export async function getStaticPaths() {
  return ['de', 'en'].map(lang => ({
    params: { lang },
    props: { lang }
  }));
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Get category from URL query parameter
const url = Astro.url;
const categoryParam = url.searchParams.get('category');

// Error handling for content
let renderError = null;
let heroTitle = "";
let heroSubtitle = "";
let posts = [];

try {
  // Load blog page content
  const page = await getEntry("pages", `${lang}/blog`);
  if (page) {
    const { frontmatter } = await page.render();
    heroTitle = frontmatter?.sections?.hero?.title || t('blog.title') || "Blog";
    heroSubtitle = frontmatter?.sections?.hero?.subtitle || t('blog.description') || "Neuigkeiten und Updates";
  } else {
    heroTitle = t('blog.title') || "Blog";
    heroSubtitle = t('blog.description') || "Neuigkeiten und Updates";
  }

  // Get blog posts for the current language, sorted by publication date
  posts = (
    await getCollection("blog", ({ data }) => {
      return data.lang === lang && !data.draft;
    })
  ).sort((a, b) => {
    // Handle case where dates might be missing
    if (!a.data.pubDate) return 1;
    if (!b.data.pubDate) return -1;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  });
} catch (error) {
  console.error("Error rendering blog index page:", error);
  renderError = error.message;
}

const pageTitle = heroTitle || t('blog.title') || "Blog";

// Group posts by category
const postsByCategory = {
  News: posts.filter(p => p.data.category === 'News'),
  Tutorial: posts.filter(p => p.data.category === 'Tutorial'),
  Experiment: posts.filter(p => p.data.category === 'Experiment')
};

// Category labels
const categoryLabels = {
  de: {
    all: 'Alle',
    News: 'Neuigkeiten',
    Tutorial: 'Anleitungen',
    Experiment: 'Experimente'
  },
  en: {
    all: 'All',
    News: 'News',
    Tutorial: 'Tutorials',
    Experiment: 'Experiments'
  }
};

// Empty state messages
const emptyStateMessages = {
  de: {
    all: {
      title: "Noch keine Blog-Einträge",
      message: "Wir arbeiten daran, spannende Inhalte für Sie zu erstellen. Schauen Sie bald wieder vorbei!",
      icon: "📝"
    },
    News: {
      title: "Keine Neuigkeiten vorhanden",
      message: "Aktuell gibt es keine News-Artikel. Bleiben Sie dran für die neuesten Updates!",
      icon: "📰"
    },
    Tutorial: {
      title: "Keine Anleitungen verfügbar",
      message: "Wir erstellen gerade hilfreiche Tutorials für Sie. Schauen Sie demnächst wieder vorbei!",
      icon: "📚"
    },
    Experiment: {
      title: "Keine Experimente vorhanden",
      message: "Unsere spannenden Experimente sind in Arbeit. Bald gibt es hier mehr zu entdecken!",
      icon: "🧪"
    }
  },
  en: {
    all: {
      title: "No blog posts yet",
      message: "We're working on creating exciting content for you. Check back soon!",
      icon: "📝"
    },
    News: {
      title: "No news available",
      message: "There are no news articles at the moment. Stay tuned for the latest updates!",
      icon: "📰"
    },
    Tutorial: {
      title: "No tutorials available",
      message: "We're creating helpful tutorials for you. Check back soon!",
      icon: "📚"
    },
    Experiment: {
      title: "No experiments available",
      message: "Our exciting experiments are in progress. More to discover here soon!",
      icon: "🧪"
    }
  }
};

// Determine active filter from URL or default to 'all'
let activeFilter = 'all';
if (categoryParam) {
  // Find matching category (case-insensitive)
  const matchingCategory = Object.keys(postsByCategory).find(
    cat => cat.toLowerCase() === categoryParam.toLowerCase()
  );
  if (matchingCategory) {
    activeFilter = matchingCategory;
  }
}

---

<Layout title={pageTitle}>
  <main class="bg-background-page">
    <div class="max-w-7xl mx-auto px-4 pt-20 pb-16 md:py-16">
    {renderError ? (
      <div class="text-center py-12">
        <p class="text-red-500">Error loading content: {renderError}</p>
      </div>
    ) : (
      <>
        <div class="text-center mb-16">
          <h1 class="text-4xl md:text-5xl font-bold text-text-primary mb-4">
            {heroTitle}
          </h1>
          <p class="text-lg text-text-secondary max-w-2xl mx-auto">
            {heroSubtitle}
          </p>
        </div>

        <!-- Filter Pills -->
        <div class="mb-12">
          <FilterPills 
            filters={[
              { value: 'all', label: categoryLabels[lang].all, count: posts.length },
              ...Object.entries(postsByCategory).map(([category, items]) => ({
                value: category,
                label: categoryLabels[lang][category],
                count: items.length
              }))
            ]}
            activeFilter={activeFilter}
            id="blog-filter"
          />
        </div>
        
        {posts.length > 0 ? (
          <div class="posts-grid" data-filter-content="blog-filter">
            {/* All Posts */}
            <div data-type="all" class="space-y-8">
              {posts.length > 0 ? (
                posts.map((post) => (
                  <BlogCard 
                    title={post.data.title}
                    description={post.data.description}
                    publishDate={post.data.pubDate}
                    author={post.data.author}
                    slug={post.slug}
                    tags={post.data.tags}
                    lang={lang}
                    image={post.data.image}
                    category={post.data.category}
                  />
                ))
              ) : (
                <EmptyState 
                  {...emptyStateMessages[lang].all}
                />
              )}
            </div>

            {/* Filtered Views */}
            {Object.entries(postsByCategory).map(([category, items]) => (
              <div data-type={category} class="hidden space-y-8">
                {items.length > 0 ? (
                  items.map((post) => (
                    <BlogCard 
                      title={post.data.title}
                      description={post.data.description}
                      publishDate={post.data.pubDate}
                      author={post.data.author}
                      slug={post.slug}
                      tags={post.data.tags}
                      lang={lang}
                      image={post.data.image}
                      category={post.data.category}
                    />
                  ))
                ) : (
                  <EmptyState 
                    {...emptyStateMessages[lang][category]}
                  />
                )}
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center py-12">
            <p class="text-text-secondary">{t('blog.noPosts') || "Noch keine Blog-Posts verfügbar."}</p>
          </div>
        )}
      </>
    )}
    </div>
  </main>
</Layout>