---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import DetailLayout from '../../../components/layouts/DetailLayout.astro';
import TypeBadge from '../../../components/detail/TypeBadge.astro';
import { useTranslations } from '../../../i18n/utils';
import ArticleNavigation from '../../../components/ArticleNavigation.astro';
import { Icon } from 'astro-icon/components';

export async function getStaticPaths() {
	const testimonials = await getCollection('testimonials');

	// Create routes for testimonials in all languages
	return testimonials.map((testimonial) => {
		// Der Slug kommt als "de/company/zimmerei-hoffmann" oder "de/nils-weiser"
		let cleanSlug = testimonial.slug;

		// Remove language prefix first
		const langPrefix = `${testimonial.data.lang}/`;
		if (cleanSlug.startsWith(langPrefix)) {
			cleanSlug = cleanSlug.substring(langPrefix.length);
		}

		// Now cleanSlug is either "company/zimmerei-hoffmann" or "nils-weiser"
		// Remove type directory if it exists (company/, private/, etc.)
		const typePrefixes = ['company/', 'private/', 'network/', 'press/'];
		for (const prefix of typePrefixes) {
			if (cleanSlug.startsWith(prefix)) {
				cleanSlug = cleanSlug.substring(prefix.length);
				break;
			}
		}

		return {
			params: {
				lang: testimonial.data.lang,
				slug: cleanSlug,
			},
			props: { testimonial },
		};
	});
}

const { testimonial } = Astro.props;
const { lang } = Astro.params;
const t = useTranslations(lang);

// Holen aller Testimonials in der gleichen Sprache
const allTestimonials = await getCollection('testimonials', (t) => t.data.lang === lang);

// Sortieren der Testimonials nach order-Property (falls vorhanden) oder alphabetisch nach Name
const sortedTestimonials = allTestimonials.sort((a, b) => {
	// Wenn beide Testimonials eine order-Property haben, sortiere danach
	if (a.data.order !== undefined && b.data.order !== undefined) {
		return a.data.order - b.data.order;
	}
	// Wenn nur a eine order-Property hat, zeige a zuerst
	if (a.data.order !== undefined) return -1;
	// Wenn nur b eine order-Property hat, zeige b zuerst
	if (b.data.order !== undefined) return 1;
	// Ansonsten alphabetisch nach Name sortieren
	return a.data.name.localeCompare(b.data.name, lang === 'de' ? 'de-DE' : 'en-US');
});

// Finden des aktuellen Index
const currentIndex = sortedTestimonials.findIndex((t) => t.id === testimonial.id);

// Finden der vorherigen und nächsten Testimonials
const prevTestimonial = currentIndex > 0 ? sortedTestimonials[currentIndex - 1] : null;
const nextTestimonial =
	currentIndex < sortedTestimonials.length - 1 ? sortedTestimonials[currentIndex + 1] : null;

const { Content } = await testimonial.render();
---

<Layout title={`${testimonial.data.name} - ${testimonial.data.role}`}>
	<DetailLayout
		containerClass="max-w-4xl mx-auto px-4 py-6 sm:py-8"
		articleClass="bg-transparent border-0 p-0"
		backLink={{
			href: `/${lang}/testimonials`,
		}}
	>
		<Fragment slot="header">
			<header class="mb-12">
				<div class="flex items-start gap-6 mb-8">
					<div class="flex-shrink-0">
						{
							testimonial.data.image ? (
								<img
									src={testimonial.data.image}
									alt={testimonial.data.name}
									class="w-24 h-24 rounded-full object-cover border-4 border-primary/20"
								/>
							) : (
								<div class="w-24 h-24 rounded-full bg-primary/10 border-4 border-primary/20 flex items-center justify-center">
									<Icon name="mdi:account" class="w-12 h-12 text-primary" />
								</div>
							)
						}
					</div>

					<div class="flex-1">
						<div class="flex items-center gap-3 mb-2 flex-wrap">
							<h1 class="text-3xl font-bold text-text-primary">{testimonial.data.name}</h1>
							<TypeBadge type={testimonial.data.type} lang={lang} />
						</div>
						<p class="text-lg text-text-secondary mb-2">
							{testimonial.data.role}
							{testimonial.data.company && ` • ${testimonial.data.company}`}
						</p>

						{
							testimonial.data.type === 'press' && testimonial.data.source && (
								<div class="text-sm text-text-muted">
									{lang === 'de' ? 'Quelle: ' : 'Source: '}
									{testimonial.data.sourceUrl ? (
										<a
											href={testimonial.data.sourceUrl}
											target="_blank"
											rel="noopener noreferrer"
											class="hover:text-primary transition-colors underline"
										>
											{testimonial.data.source}
										</a>
									) : (
										testimonial.data.source
									)}
								</div>
							)
						}
					</div>
				</div>

				<blockquote
					class="text-xl text-text-secondary italic border-l-4 border-primary pl-6 py-2 mb-0"
				>
					"{testimonial.data.text}"
				</blockquote>
			</header>
		</Fragment>

		<Content />

		<Fragment slot="footer">
			<div class="mt-16">
				<ArticleNavigation
					prevArticle={prevTestimonial
						? {
								title: prevTestimonial.data.name,
								slug: (() => {
									let slug = prevTestimonial.slug.replace(`${lang}/`, '');
									// Remove type directory if it exists
									const typePrefixes = ['company/', 'private/', 'network/', 'press/'];
									for (const prefix of typePrefixes) {
										if (slug.startsWith(prefix)) {
											slug = slug.substring(prefix.length);
											break;
										}
									}
									return slug;
								})(),
							}
						: null}
					nextArticle={nextTestimonial
						? {
								title: nextTestimonial.data.name,
								slug: (() => {
									let slug = nextTestimonial.slug.replace(`${lang}/`, '');
									// Remove type directory if it exists
									const typePrefixes = ['company/', 'private/', 'network/', 'press/'];
									for (const prefix of typePrefixes) {
										if (slug.startsWith(prefix)) {
											slug = slug.substring(prefix.length);
											break;
										}
									}
									return slug;
								})(),
							}
						: null}
					lang={lang}
					basePath="testimonials"
				/>
			</div>
		</Fragment>
	</DetailLayout>
</Layout>
