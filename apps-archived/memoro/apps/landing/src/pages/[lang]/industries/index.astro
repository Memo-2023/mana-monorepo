---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import IndustryCard from '../../../components/IndustryCard.astro';
import TestimonialPreview from '../../../components/TestimonialPreview.astro';
import FAQSection from '../../../components/FAQSection.astro';
import CallToAction from '../../../components/CallToAction.astro';
import HeroSection from '../../../components/HeroSection.astro';
import { useTranslations } from '../../../i18n/utils';

export async function getStaticPaths() {
	// Astro's i18n routing with prefixDefaultLocale: false means:
	// - German (de) routes should NOT have /de/ prefix
	// - English (en) routes should have /en/ prefix
	// But [lang] dynamic routes always create /[lang]/ paths
	// So we keep this as is - Astro handles the routing via its i18n config
	return ['de', 'en'].map((lang) => ({
		params: { lang },
		props: { lang },
	}));
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Get industries for the current language, sorted by order
const industries = await getCollection('industries', ({ data }) => {
	return data.lang === lang;
});

const sortedIndustries = industries.sort(
	(a, b) => (parseInt(a.data.order) || 0) - (parseInt(b.data.order) || 0)
);

// FAQ items
const faqItems = [
	{
		question:
			lang === 'de'
				? 'Wie unterstützt Memoro beim Wissensaustausch?'
				: 'How does Memoro support knowledge sharing?',
		answer:
			lang === 'de'
				? 'Memoro nutzt KI, um das Wissen Ihres Teams automatisch zu organisieren und zu verknüpfen, sodass Informationen abteilungsübergreifend leicht zu finden und zu teilen sind.'
				: "Memoro uses AI to automatically organize and link your team's knowledge, making information easy to find and share across departments.",
	},
	{
		question:
			lang === 'de'
				? 'Kann Memoro mit unseren bestehenden Tools integriert werden?'
				: 'Can Memoro integrate with our existing tools?',
		answer:
			lang === 'de'
				? 'Ja, Memoro lässt sich nahtlos in beliebte Tools wie Slack, Microsoft Teams und Google Workspace integrieren, um Wissen dort zu erfassen und zu teilen, wo Ihr Team bereits arbeitet.'
				: 'Yes, Memoro integrates seamlessly with popular tools like Slack, Microsoft Teams, and Google Workspace to capture and share knowledge where your team already works.',
	},
	{
		question:
			lang === 'de' ? 'Sind unsere Daten bei Memoro sicher?' : 'Is our data safe with Memoro?',
		answer:
			lang === 'de'
				? 'Absolut. Wir verwenden Verschlüsselung auf Unternehmensniveau und folgen strengen Sicherheitsprotokollen. Ihre Daten werden in EU-basierten Servern gespeichert und entsprechen den DSGVO-Anforderungen.'
				: 'Absolutely. We use enterprise-grade encryption and follow strict security protocols. Your data is stored in EU-based servers and complies with GDPR requirements.',
	},
];
---

<Layout title={lang === 'de' ? 'Branchen | Memoro' : 'Industries | Memoro'}>
	<main class="bg-background-page">
		<HeroSection
			variant="fullwidth"
			title={lang === 'de' ? 'Branchen' : 'Industries'}
			subtitle={lang === 'de'
				? 'Entdecke wie Memoro das Lernen und Wissensmanagement in verschiedenen Branchen verbessert'
				: 'Discover how Memoro enhances learning and knowledge management across different industries'}
			image="/images/product_photos/Memoro-App-ConferenceTalk-Recording.jpg"
		/>

		<div class="max-w-7xl mx-auto px-4 py-16" id="industries">
			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
				{
					sortedIndustries.map((industry) => {
						// Entferne den Sprachpräfix aus dem Slug, wenn vorhanden
						const langPrefix = `${lang}/`;
						const cleanSlug = industry.slug.startsWith(langPrefix)
							? industry.slug.substring(langPrefix.length)
							: industry.slug;

						return (
							<IndustryCard
								title={industry.data.title}
								description={industry.data.description}
								icon={industry.data.icon || '🏢'}
								color={industry.data.color || 'primary'}
								href={`/${lang}/industries/${cleanSlug}`}
							/>
						);
					})
				}
			</div>

			<TestimonialPreview />

			<FAQSection
				title={lang === 'de' ? 'Häufig gestellte Fragen' : 'Frequently Asked Questions'}
				categories={['industries']}
				class="mb-16"
			/>

			<div class="text-center">
				<CallToAction
					title={lang === 'de'
						? 'Bereit für bessere Meeting-Dokumentation?'
						: 'Ready for better meeting documentation?'}
					description={lang === 'de'
						? 'Entdecke wie Memoro deine Meetings effizienter und produktiver macht.'
						: 'Discover how Memoro makes your meetings more efficient and productive.'}
					buttonText={lang === 'de' ? 'App herunterladen' : 'Download App'}
					buttonLink={`/${lang}/download`}
				/>
			</div>
		</div>
	</main>
</Layout>
