# API Configuration
PORT=3001
NODE_ENV=development

# Replicate API (get your key from https://replicate.com/account/api-tokens)
REPLICATE_API_TOKEN=r8_your_replicate_token_here

# CORS Configuration
CORS_ORIGIN=http://localhost:4321

# Storage Configuration (optional, for saving images locally)
STORAGE_PATH=./storage/images

# Redis Configuration (optional, for queue management)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MinIO/S3 Configuration (optional, for cloud storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=persona-images

# API Security
API_KEY=memoro-admin-api-key-2025

# Logging
LOG_LEVEL=debug