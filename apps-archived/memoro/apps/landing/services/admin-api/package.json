		"@fastify/rate-limit": "^10.0.1",
		"fastify": "^5.1.0",
		"replicate": "^0.34.1",
		"zod": "^3.23.8",
		"dotenv": "^16.4.7"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"@typescript-eslint/eslint-plugin": "^8.17.0",
		"@typescript-eslint/parser": "^8.17.0",
		"eslint": "^9.17.0",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2"
	},
	"engines": {
		"node": ">=18.0.0"
