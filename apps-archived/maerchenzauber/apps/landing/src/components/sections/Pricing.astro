---
import Card from '../ui/Card.astro';

const plans = [
	{
		name: 'Starter',
		price: 'Kostenlos',
		mana: '100',
		features: [
			'100 Mana Startguthaben',
			'~3 Geschichten',
			'Alle Features verfügbar',
			'Charaktererstellung',
			'KI-Illustrationen',
		],
		cta: 'Kostenlos starten',
		popular: false,
	},
	{
		name: 'Familie',
		price: '9,99€',
		period: '/Monat',
		mana: '500',
		features: [
			'500 Mana monatlich',
			'~15 Geschichten',
			'Prioritäts-Support',
			'Exklusive Charaktere',
			'Werbefreie Nutzung',
		],
		cta: 'Jetzt upgraden',
		popular: true,
	},
	{
		name: 'Unbegrenzt',
		price: '19,99€',
		period: '/Monat',
		mana: 'Unbegrenzt',
		features: [
			'Unbegrenzte Mana',
			'Unbegrenzte Geschichten',
			'Premium-Support',
			'Early Access Features',
			'Export-Funktionen',
		],
		cta: 'Premium wählen',
		popular: false,
	},
];
---

<section id="pricing" class="section bg-bg-darker">
	<div class="container-custom">
		<!-- Section Header -->
		<div class="text-center mb-12 md:mb-16">
			<h2
				class="font-grandstander font-bold text-3xl md:text-4xl lg:text-5xl text-text-primary mb-4"
			>
				Einfache, transparente Preise
			</h2>
			<p class="text-text-secondary text-lg max-w-3xl mx-auto">
				Wähle das passende Paket für deine Familie
			</p>
		</div>

		<!-- Mana Explanation -->
		<div class="text-center mb-12">
			<Card variant="default" className="inline-block" padding="md">
				<div class="flex items-center gap-3">
					<div
						class="w-10 h-10 bg-yellow-dark rounded-full flex items-center justify-center glow-yellow"
					>
						<span class="text-white font-bold">M</span>
					</div>
					<div class="text-left">
						<div class="text-text-primary font-semibold">Was sind Mana-Token?</div>
						<div class="text-text-secondary text-sm">
							Mana sind Credits für die Generierung von Geschichten. 1 Geschichte ≈ 30-40 Mana
						</div>
					</div>
				</div>
			</Card>
		</div>

		<!-- Pricing Cards -->
		<div class="grid md:grid-cols-3 gap-6 md:gap-8">
			{
				plans.map((plan) => (
					<Card
						variant="hover"
						className={plan.popular ? 'border-2 border-yellow-dark relative' : ''}
						padding="lg"
					>
						{plan.popular && (
							<div class="absolute -top-4 left-1/2 -translate-x-1/2">
								<span class="bg-yellow-dark text-white px-4 py-1 rounded-full text-sm font-semibold">
									Beliebteste Wahl
								</span>
							</div>
						)}

						<div class="text-center">
							{/* Plan Name */}
							<h3 class="font-grandstander font-bold text-2xl text-text-primary mb-4">
								{plan.name}
							</h3>

							{/* Price */}
							<div class="mb-6">
								<span class="text-4xl font-bold text-text-primary">{plan.price}</span>
								{plan.period && <span class="text-text-secondary ml-1">{plan.period}</span>}
							</div>

							{/* Mana Amount */}
							<div class="flex items-center justify-center gap-2 mb-8">
								<div class="w-8 h-8 bg-yellow-dark/20 rounded-full flex items-center justify-center">
									<span class="text-yellow-light font-bold text-sm">M</span>
								</div>
								<span class="text-yellow-light font-semibold">{plan.mana} Mana</span>
							</div>

							{/* Features */}
							<ul class="space-y-3 mb-8 text-left">
								{plan.features.map((feature) => (
									<li class="flex items-start gap-2">
										<svg
											class="w-5 h-5 text-yellow-light mt-0.5 flex-shrink-0"
											fill="none"
											stroke="currentColor"
											viewBox="0 0 24 24"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="2"
												d="M5 13l4 4L19 7"
											/>
										</svg>
										<span class="text-text-secondary">{feature}</span>
									</li>
								))}
							</ul>

							{/* CTA Button */}
							<a
								href="/download"
								class={`w-full inline-block text-center ${plan.popular ? 'btn-primary' : 'btn-secondary'}`}
							>
								{plan.cta}
							</a>
						</div>
					</Card>
				))
			}
		</div>

		<!-- Additional Info */}
    <div class="text-center mt-12">
      <p class="text-text-secondary">
        Alle Preise inkl. MwSt. • Jederzeit kündbar • Keine versteckten Kosten
      </p>
    </div>
  </div>
</section>-->
	</div>
</section>
