// Jährliche Pläne
const yearlyPlans = [
	{
		name: 'Kostenlos',
		price: '0€',
		period: '/Jahr',
		mana: '150',
		savings: null,
		features: [
			'150 Mana monatlich',
			'~5 Geschichten/Monat',
			'Alle Features verfügbar',
			'Charaktererstellung',
			'KI-Illustrationen',
		],
		cta: 'Kostenlos starten',
		popular: false,
	},
	{
		name: 'Kleiner Mana Stream',
		price: '47,99€',
		period: '/Jahr',
		mana: '600',
		savings: 'Spare 23,89€ (33%)',
		features: [
			'600 Mana monatlich',
			'~20 Geschichten/Monat',
			'Alle Features',
			'Prioritäts-Support',
			'Werbefreie Nutzung',
		],
		cta: 'Jetzt upgraden',
		popular: false,
	},
	{
		name: 'Mittlerer Mana Stream',
		price: '119,99€',
		period: '/Jahr',
		mana: '1500',
		savings: 'Spare 59,89€ (33%)',
		features: [
			'1500 Mana monatlich',
			'~50 Geschichten/Monat',
			'Premium-Support',
			'Exklusive Charaktere',
			'Early Access Features',
		],
		cta: 'Jetzt upgraden',
		popular: true,
	},
	{
