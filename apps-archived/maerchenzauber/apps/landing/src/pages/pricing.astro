// Mana Tränke (Einmalkäufe)
const manaPotions = [
	{
		name: 'Kleiner Mana Trank',
		price: '4,99€',
		mana: '350',
		stories: '~12 Geschichten',
		cta: 'Kaufen',
	},
	{
		name: 'Mittlerer Mana Trank',
		price: '9,99€',
		mana: '700',
		stories: '~23 Geschichten',
		cta: 'Kaufen',
		popular: true,
	},
	{
		name: 'Großer Mana Trank',
		price: '19,99€',
		mana: '1400',
		stories: '~47 Geschichten',
		cta: 'Kaufen',
	},
	{
		name: 'Riesiger Mana Trank',
		price: '39,99€',
		mana: '2800',
		stories: '~93 Geschichten',
		cta: 'Kaufen',
	},
