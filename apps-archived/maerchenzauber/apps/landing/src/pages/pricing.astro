		price: '49,99€',
		period: '/Monat',
		mana: '5000',
		features: [
			'5000 Mana monatlich',
			'~165 Geschichten',
			'Persönlicher Support',
			'Alle Premium-Features',
			'Unbegrenzte Exporte',
		],
