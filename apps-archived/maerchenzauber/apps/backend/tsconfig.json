{
	"compilerOptions": {
		"module": "commonjs",
		"moduleResolution": "node",
		"declaration": true,
		"removeComments": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"target": "ES2021",
		"sourceMap": true,
		"outDir": "./dist",
		"baseUrl": "./",
		"rootDir": "./",
		"skipLibCheck": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"paths": {
			"@storyteller/shared-types": ["./src/shared-types/src"],
			"@/*": ["./src/*"]
		}
	},
	"include": ["src/**/*", "test/**/*"],
	"exclude": ["node_modules", "dist"]
}
