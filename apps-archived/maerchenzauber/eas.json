{
	"cli": {
		"version": ">= 16.17.4",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal"
		},
		"preview": {
			"distribution": "internal"
		},
		"production": {
			"autoIncrement": true,
			"env": {
				"NPM_CONFIG_USERCONFIG": "./.npmrc.eas"
			},
			"ios": {
				"buildConfiguration": "Release",
				"credentialsSource": "remote"
			},
			"prebuild": {
				"preInstall": "bash ./mobile/eas-build-pre-install.sh"
			}
		}
	},
	"submit": {
		"production": {}
	}
}
