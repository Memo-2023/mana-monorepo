          const detailsTitle = document.createElement('h2');
          detailsTitle.classList.add('text-xl', 'font-bold', 'mb-4', 'dark:text-white');
          detailsTitle.textContent = 'Company Details';
          
          detailsSection.appendChild(detailsTitle);
          
          const detailsGrid = document.createElement('div');
          detailsGrid.classList.add('grid', 'grid-cols-1', 'md:grid-cols-2', 'gap-4');
          
          // Add company details
          const details = [
            { label: 'Founded', value: developer.foundedYear },
            { label: 'Headquarters', value: developer.headquarters },
            { label: 'Country', value: developer.country },
            { label: 'Employees', value: developer.employees },
            { label: 'Industry', value: developer.industry }
          ];
          
          details.forEach(detail => {
            if (detail.value) {
              const detailItem = document.createElement('div');
              
              const label = document.createElement('h3');
              label.classList.add('text-sm', 'uppercase', 'text-gray-500', 'dark:text-gray-400');
              label.textContent = detail.label;
              
              const value = document.createElement('p');
              value.classList.add('text-gray-700', 'dark:text-gray-300');
              value.textContent = detail.value;
              
              detailItem.appendChild(label);
              detailItem.appendChild(value);
              detailsGrid.appendChild(detailItem);
            }
          });
          
          detailsSection.appendChild(detailsGrid);
          contentElement.appendChild(detailsSection);
          
          // Key Products section
          if (developer.keyProducts && developer.keyProducts.length > 0) {
            const productsSection = document.createElement('div');
            
            const productsTitle = document.createElement('h2');
            productsTitle.classList.add('text-xl', 'font-bold', 'mb-4', 'dark:text-white');
            productsTitle.textContent = 'Key Products';
            
            productsSection.appendChild(productsTitle);
            
            const productsList = document.createElement('ul');
            productsList.classList.add('list-disc', 'list-inside', 'text-gray-700', 'dark:text-gray-300', 'space-y-1');
            
            developer.keyProducts.forEach(product => {
              const li = document.createElement('li');
              li.textContent = product;
              productsList.appendChild(li);
            });
            
            productsSection.appendChild(productsList);
            contentElement.appendChild(productsSection);
          }
          
          // Software showcase section
          const softwareSection = document.createElement('div');
          softwareSection.classList.add('mt-8');
          
          const softwareTitle = document.createElement('h2');
          softwareTitle.classList.add('text-xl', 'font-bold', 'mb-4', 'dark:text-white');
          softwareTitle.textContent = 'Featured Software';
          
          softwareSection.appendChild(softwareTitle);
          
          const softwareGrid = document.createElement('div');
          softwareGrid.classList.add('grid', 'grid-cols-1', 'md:grid-cols-2', 'gap-4');
          
          // Add placeholder for software cards
          for (let i = 0; i < 2; i++) {
            const card = document.createElement('div');
            card.classList.add('bg-gray-100', 'dark:bg-gray-700', 'p-4', 'rounded-lg', 'flex', 'items-center');
            
            const logo = document.createElement('div');
            logo.classList.add('w-12', 'h-12', 'bg-white', 'dark:bg-gray-600', 'rounded', 'mr-3', 'flex-shrink-0', 'flex', 'items-center', 'justify-center');
            logo.innerHTML = '<svg class="w-6 h-6 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>';
            
            const content = document.createElement('div');
            const title = document.createElement('div');
            title.classList.add('font-medium', 'dark:text-white');
            title.textContent = `Sample Software ${i+1}`;
            
            const category = document.createElement('div');
            category.classList.add('text-sm', 'text-gray-500', 'dark:text-gray-400');
            category.textContent = 'Category';
            
            content.appendChild(title);
            content.appendChild(category);
            
            card.appendChild(logo);
            card.appendChild(content);
            softwareGrid.appendChild(card);
          }
          
          softwareSection.appendChild(softwareGrid);
          contentElement.appendChild(softwareSection);
        }
      }
      
      // Handle search input
      const searchInput = document.getElementById('developer-search-input');
      if (searchInput) {
        searchInput.addEventListener('input', (e) => {
          const searchTerm = e.target.value.toLowerCase();
          const listItems = document.querySelectorAll('#developer-list-container > div');
          
          listItems.forEach(item => {
            const itemText = item.textContent.toLowerCase();
            if (itemText.includes(searchTerm)) {
              item.style.display = 'block';
            } else {
              item.style.display = 'none';
            }
          });
        });
      }
      
      // Initialize comparison if URL has compare parameter
      const urlParams = new URLSearchParams(window.location.search);
      const compareWith = urlParams.get('compare');
      
      if (compareWith) {
        const selectedDeveloper = sampleDevelopers.find(d => d.id === compareWith);
        if (selectedDeveloper) {
          updateComparisonDeveloper(selectedDeveloper);
        }
      }
      
      // Add a direct event listener to the compare button to populate items
      document.querySelectorAll('[x-text="isCompareMode ? \'${t.software.expandView}\' : \'${t.developer.inlineCompare}\'"]').forEach(btn => {
        btn.addEventListener('click', () => {
          console.log("Compare button clicked, will load items");
          // Short delay to ensure Alpine has updated its state
          setTimeout(() => populateDeveloperItems(), 100);
        });
      });
      
      // Initialize - always load items in compare mode
      setTimeout(() => {
        // Check URL parameters
        const urlParams = new URLSearchParams(window.location.search);
        const compareWith = urlParams.get('compare');
        
        // Check if we're in compare mode through Alpine.js
        if (comparisonComponent && comparisonComponent.$data.isCompareMode) {
          console.log("We're in compare mode, loading items immediately");
          populateDeveloperItems();
        } else if (compareWith) {
          console.log("Compare parameter found in URL, loading items");
          populateDeveloperItems();
        }
      }, 500);
    });
  </script>
</BaseLayout>

