---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SoftwareCard from '../../../components/SoftwareCard.astro';
import { getCollection } from 'astro:content';
import { loadTranslations } from '../../../utils/i18n';
import { i18nConfig } from '../../../content/config';

export async function getStaticPaths() {
  const developers = await getCollection('developers');
  const paths = [];
  
  for (const locale of i18nConfig.locales) {
    const localeDevelopers = developers.filter(developer => developer.id.startsWith(locale + '/'));
    
    for (const developer of localeDevelopers) {
      // Fix: ID should NOT include file extension .md
      let id = developer.id.split('/')[1]; // Get ID after locale
      if (id.endsWith('.md')) {
        id = id.replace('.md', '');
      }
      
      paths.push({
        params: { 
          lang: locale, 
          id
        },
        props: { developer, locale, allDevelopers: developers }
      });
    }
  }
  
  return paths;
}

const { developer, locale, allDevelopers } = Astro.props;

// Prepare similar developers for the comparison feature
const similarDevelopers = allDevelopers
  .filter(item => {
    // Skip the current developer
    if (item.id === developer.id) return false;
    
    // Extract the developer's locale and industry
    const [itemLocale] = item.id.split('/');
    
    // Only include developers with the same locale 
    // and same industry if available
    return itemLocale === locale && 
      (!developer.data.industry || !item.data.industry || 
       item.data.industry === developer.data.industry);
  })
  .map(item => {
    // Format the developer data for the frontend
    return {
      id: item.id.split('/')[1].replace(/\.md$/, ''),
      name: item.data.name,
      description: item.data.description,
      industry: item.data.industry || '',
      country: item.data.country || '',
      foundedYear: item.data.foundedYear,
      employees: item.data.employees,
      logo: item.data.logo || '/logos/sample-logo.svg',
      keyProducts: item.data.keyProducts || []
    };
  });
const t = await loadTranslations(locale);

// Get all software from this developer
const allSoftware = await getCollection('software');

// The URL parameter 'id' is already cleaned in getStaticPaths
const developerId = Astro.params.id;

// Find all software by this developer
const softwareItems = allSoftware.filter(item => {
  const hasDeveloper = !!item.data.developer;
  const developerValue = hasDeveloper ? item.data.developer.toLowerCase() : '';
  return developerValue === developerId.toLowerCase();
});

// Convert to the format needed for display  
const allDeveloperSoftware = softwareItems.map(software => {
  const softwareLocale = software.id.split('/')[0];
  return {
    id: software.id.split('/')[1],
    locale: softwareLocale,
    ...software.data
  };
});

// Group software by ID to avoid duplicates from different languages
const softwareByID = {};
allDeveloperSoftware.forEach(software => {
  const keyName = software.id;
  
  // If we don't have this software yet, add it
  if (!softwareByID[keyName]) {
    softwareByID[keyName] = software;
    return;
  }
  
  // If we already have this software, prefer the current locale
  if (software.locale === locale) {
    softwareByID[keyName] = software;
  }
});

// Convert back to array for display
const developerSoftware = Object.values(softwareByID);

// Sort first by locale matching the current locale, then by name
developerSoftware.sort((a, b) => {
  // First sort by locale (current locale first)
  if (a.locale === locale && b.locale !== locale) return -1;
  if (a.locale !== locale && b.locale === locale) return 1;
  
  // Then sort alphabetically by name
  return a.name.localeCompare(b.name);
});

// Get all categories used by this developer's software
const categories = [...new Set(developerSoftware.flatMap(software => software.categories || []))];

// Get all categories collection for category names
const allCategories = await getCollection('categories');
const categoryMap = {};
allCategories.forEach(category => {
  let id = category.id.split('/')[1];
  // Remove .md extension if present
  if (id.endsWith('.md')) {
    id = id.replace('.md', '');
  }
  categoryMap[id] = category.data.name;
});
---

<BaseLayout title={developer.data.name}>
  {/* Hidden elements to pass data to client-side JavaScript */}
  <div id="current-developer-name" style="display:none">{developer.data.name}</div>
  <div id="current-developer-industry" style="display:none">{developer.data.industry || ''}</div>
  <div id="similar-developers-list" style="display:none">{JSON.stringify(similarDevelopers)}</div>
  
  <div 
    x-data="{
      isCompareMode: false,
      selectedDeveloperId: null,
      currentViewSide: 'left',
      isLeftMinimized: false,
      isRightMinimized: false,
      allDevelopers: [],
      
      toggleCompareMode() {
        this.isCompareMode = !this.isCompareMode;
        if (!this.isCompareMode) {
          // Remove the compare parameter from URL when exiting compare mode
          const url = new URL(window.location.href);
          url.searchParams.delete('compare');
          window.history.pushState({}, '', url.toString());
          this.selectedDeveloperId = null;
        }
      },
      
      switchViewSide(side) {
        this.currentViewSide = side;
      },
      
      toggleMinimize(side) {
        if (side === 'left') {
          this.isLeftMinimized = !this.isLeftMinimized;
          if (this.isLeftMinimized && this.isRightMinimized) {
            this.isRightMinimized = false;
          }
        } else {
          this.isRightMinimized = !this.isRightMinimized;
          if (this.isRightMinimized && this.isLeftMinimized) {
            this.isLeftMinimized = false;
          }
        }
      }
    }"
    x-init="() => {
      const urlParams = new URLSearchParams(window.location.search);
      const compareWith = urlParams.get('compare');
      
      if (compareWith) {
        isCompareMode = true;
        selectedDeveloperId = compareWith;
      }
    }"
    class="container mx-auto px-4 py-8"
  >
    <!-- Main container with conditional layout based on comparison mode -->
    <div 
      class="flex flex-col lg:flex-row transition-all duration-300" 
      :class="{'lg:space-x-6': isCompareMode}"
    >
      <!-- Left panel (current developer) -->
      <div 
        class="transition-all duration-300 overflow-hidden" 
        :class="{
          'w-full': !isCompareMode,
          'lg:w-1/2': isCompareMode && !isLeftMinimized && !isRightMinimized,
          'lg:w-1/4': isCompareMode && isLeftMinimized && !isRightMinimized,
          'lg:w-3/4': isCompareMode && !isLeftMinimized && isRightMinimized
        }"
      >
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden h-full">
          <!-- Developer Header -->
          <div class="p-8 pb-4 bg-gradient-to-r from-blue-700 to-indigo-800 text-white">
            <div class="flex flex-col md:flex-row gap-6 items-center md:items-start">
              <!-- Toggle minimize button for comparison mode -->
              <template x-if="isCompareMode">
                <button 
                  @click="toggleMinimize('left')" 
                  class="absolute top-4 left-4 text-white/80 hover:text-white"
                  :aria-label="isLeftMinimized ? '${t.software.expandView}' : '${t.software.minimizeView}'"
                >
                  <svg x-show="!isLeftMinimized" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />
                  </svg>
                  <svg x-show="isLeftMinimized" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7" />
                  </svg>
                </button>
              </template>
            
              {developer.data.logo ? (
                <img 
                  src={developer.data.logo} 
                  alt={developer.data.name} 
                  class="w-32 h-32 rounded-xl bg-white p-2 object-contain"
                />
              ) : (
                <div class="w-32 h-32 rounded-xl bg-white/20 flex items-center justify-center text-4xl">
                  {developer.data.name.charAt(0)}
                </div>
              )}
              
              <div class="flex-1 text-center md:text-left">
                <h1 class="text-3xl font-bold mb-2">{developer.data.name}</h1>
                
                {developer.data.foundedYear && (
                  <p class="text-blue-100 mb-1">
                    {t.developer?.founded || "Founded"}: {developer.data.foundedYear}
                  </p>
                )}
                
                {developer.data.headquarters && (
                  <p class="text-blue-100 mb-1">
                    {t.developer?.headquarters || "Headquarters"}: {developer.data.headquarters}
                  </p>
                )}
                
                {developer.data.country && (
                  <p class="text-blue-100 mb-4">
                    {t.developer?.country || "Country"}: {developer.data.country}
                  </p>
                )}
                
                <div class="flex flex-wrap gap-4 justify-center md:justify-start mt-4">
                  <a 
                    href={developer.data.website} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="px-4 py-2 bg-white/10 hover:bg-white/20 rounded-lg transition-colors text-white"
                  >
                    {t.common?.website || "Website"} ↗
                  </a>
                  
                  {developer.data.socialMedia?.github && (
                    <a 
                      href={developer.data.socialMedia.github} 
                      target="_blank" 
                      rel="noopener noreferrer"
                      class="px-4 py-2 bg-white/10 hover:bg-white/20 rounded-lg transition-colors text-white"
                    >
                      GitHub ↗
                    </a>
                  )}
                  
                  <!-- Compare button -->
                  <button 
                    @click="toggleCompareMode" 
                    class="px-4 py-2 bg-white/20 hover:bg-white/30 rounded-lg transition-colors text-white"
                    x-text="isCompareMode ? '${t.software.expandView}' : '${t.developer.inlineCompare}'"
                  ></button>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Developer content - conditionally show based on minimized state -->
          <div x-show="!isLeftMinimized || !isCompareMode" x-transition>
            <div :class="{'hidden lg:block': isCompareMode && currentViewSide !== 'left', 'block': !isCompareMode || currentViewSide === 'left'}">
              <!-- Company Info -->
              <div class="p-8 border-b border-gray-200 dark:border-gray-700">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                  <!-- Left column: About -->
                  <div class="md:col-span-2">
                    <h2 class="text-2xl font-bold mb-4 dark:text-white">{t.common?.about || "About"}</h2>
                    
                    <div class="prose prose-lg dark:prose-invert max-w-none">
                      {developer.body ? (
                        <Fragment set:html={developer.body} />
                      ) : (
                        <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
                          {developer.data.description}
                        </p>
                      )}
                    </div>
                  </div>
                  
                  <!-- Right column: Company details -->
                  <div>
                    <h2 class="text-xl font-bold mb-4 dark:text-white">{t.common?.details || "Details"}</h2>
                    
                    <div class="space-y-4">
                      {developer.data.industry && (
                        <div>
                          <h3 class="text-sm uppercase text-gray-500 dark:text-gray-400">{t.developer?.industry || "Industry"}</h3>
                          <p class="text-gray-700 dark:text-gray-300">{developer.data.industry}</p>
                        </div>
                      )}
                      
                      {developer.data.employees && (
                        <div>
                          <h3 class="text-sm uppercase text-gray-500 dark:text-gray-400">{t.developer?.employees || "Employees"}</h3>
                          <p class="text-gray-700 dark:text-gray-300">{developer.data.employees}</p>
                        </div>
                      )}
                      
                      {developer.data.revenue && (
                        <div>
                          <h3 class="text-sm uppercase text-gray-500 dark:text-gray-400">{t.developer?.revenue || "Annual Revenue"}</h3>
                          <p class="text-gray-700 dark:text-gray-300">{developer.data.revenue}</p>
                        </div>
                      )}
                      
                      {developer.data.keyProducts && developer.data.keyProducts.length > 0 && (
                        <div>
                          <h3 class="text-sm uppercase text-gray-500 dark:text-gray-400">{t.developer?.keyProducts || "Key Products"}</h3>
                          <ul class="list-disc list-inside text-gray-700 dark:text-gray-300">
                            {developer.data.keyProducts.map(product => (
                              <li>{product}</li>
                            ))}
                          </ul>
                        </div>
                      )}
                      
                      {developer.data.socialMedia && Object.keys(developer.data.socialMedia).length > 0 && (
                        <div>
                          <h3 class="text-sm uppercase text-gray-500 dark:text-gray-400">{t.developer?.socialMedia || "Social Media"}</h3>
                          <div class="flex flex-wrap gap-3 mt-2">
                            {developer.data.socialMedia.twitter && (
                              <a href={developer.data.socialMedia.twitter} target="_blank" rel="noopener noreferrer" class="text-gray-600 hover:text-blue-500 dark:text-gray-400 dark:hover:text-blue-400">
                                <span class="sr-only">Twitter</span>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                                  <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
                                </svg>
                              </a>
                            )}
                            {developer.data.socialMedia.github && (
                              <a href={developer.data.socialMedia.github} target="_blank" rel="noopener noreferrer" class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">
                                <span class="sr-only">GitHub</span>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                                </svg>
                              </a>
                            )}
                            {developer.data.socialMedia.linkedin && (
                              <a href={developer.data.socialMedia.linkedin} target="_blank" rel="noopener noreferrer" class="text-gray-600 hover:text-blue-700 dark:text-gray-400 dark:hover:text-blue-600">
                                <span class="sr-only">LinkedIn</span>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                                  <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                                </svg>
                              </a>
                            )}
                            {developer.data.socialMedia.facebook && (
                              <a href={developer.data.socialMedia.facebook} target="_blank" rel="noopener noreferrer" class="text-gray-600 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-500">
                                <span class="sr-only">Facebook</span>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                                  <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/>
                                </svg>
                              </a>
                            )}
                          </div>
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- Software by this developer -->
              {developerSoftware.length > 0 && (
                <div class="p-8">
                  <h2 class="text-2xl font-bold mb-6 dark:text-white">
                    {t.developer?.software || "Software by"} {developer.data.name}
                    <span class="text-sm text-gray-500 ml-2">({developerSoftware.length} software products)</span>
                  </h2>
                  
                  {/* Category Filter Pills - only show if there are categories */}
                  {categories.length > 0 && (
                    <div class="relative mb-8">
                      <div class="overflow-x-auto pb-4 hide-scrollbar">
                        <div class="flex space-x-2 min-w-max px-2">
                          <button 
                            class="category-pill active bg-primary text-white px-4 py-2 rounded-full text-sm font-medium shadow-md transform transition-all hover:shadow-lg" 
                            data-category="all"
                          >
                            {t.common?.all || "All"}
                          </button>
                          {categories.map(category => (
                            <button 
                              class="category-pill bg-white dark:bg-gray-700 text-gray-800 dark:text-white px-4 py-2 rounded-full text-sm font-medium shadow-md transform transition-all hover:shadow-lg hover:bg-gray-100 dark:hover:bg-gray-600" 
                              data-category={category}
                            >
                              {categoryMap[category] || category}
                            </button>
                          ))}
                        </div>
                      </div>
                      <div class="absolute left-0 top-0 bottom-0 w-8 bg-gradient-to-r from-white dark:from-gray-800 to-transparent pointer-events-none"></div>
                      <div class="absolute right-0 top-0 bottom-0 w-8 bg-gradient-to-l from-white dark:from-gray-800 to-transparent pointer-events-none"></div>
                    </div>
                  )}

                  {/* Software Cards Grid */}
                  <div class="software-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" :class="{'lg:grid-cols-2': isCompareMode}">
                    {developerSoftware.map((software, index) => (
                      <div id={`software-${index}`} class="software-card" data-categories={JSON.stringify(software.categories || [])}>
                        <SoftwareCard software={software} />
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </div>
          
          <!-- Minimized view for the left panel -->
          <template x-if="isLeftMinimized && isCompareMode">
            <div class="p-6 flex flex-col items-center justify-center border-r border-gray-200 dark:border-gray-700 h-full">
              {developer.data.logo ? (
                <div class="w-24 h-24 rounded-lg bg-white dark:bg-gray-700 p-2 flex items-center justify-center mb-3">
                  <img src={developer.data.logo} alt={developer.data.name} class="max-w-full max-h-full" />
                </div>
              ) : (
                <div class="w-24 h-24 rounded-xl bg-gray-200 dark:bg-gray-700 flex items-center justify-center text-3xl mb-3">
                  {developer.data.name.charAt(0)}
                </div>
              )}
              <h2 class="text-center text-xl font-bold mb-2 dark:text-white">{developer.data.name}</h2>
              <p class="text-center text-sm text-gray-500 dark:text-gray-400 mb-4 line-clamp-3">{developer.data.description}</p>
            </div>
          </template>
        </div>
      </div>
      
      <!-- Right panel (comparison developer) - only shown in compare mode -->
      <div 
        x-show="isCompareMode" 
        x-transition
        class="lg:w-1/2 mt-8 lg:mt-0 transition-all duration-300"
        :class="{
          'lg:w-1/2': !isLeftMinimized && !isRightMinimized,
          'lg:w-3/4': isLeftMinimized && !isRightMinimized,
          'lg:w-1/4': !isLeftMinimized && isRightMinimized
        }"
      >
        <!-- Developer list for selecting comparison - directly integrated into the right panel -->
        <template x-if="!selectedDeveloperId && isCompareMode">
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm h-full overflow-hidden">
            <div class="p-4 border-b border-gray-200 dark:border-gray-700">
              <h3 class="text-lg font-bold" id="developer-selection-title">{t.developer.selectAnother}</h3>
              <div class="mt-4">
                <input 
                  type="text" 
                  placeholder={t.common.search} 
                  class="w-full p-2 border border-gray-300 dark:border-gray-600 rounded-md focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white"
                  id="developer-search-input"
                />
              </div>
            </div>
            
            <div class="p-0 overflow-y-auto" style="max-height: calc(100vh - 200px);" id="developer-list-container">
              <div class="py-8 text-center text-gray-500 dark:text-gray-400">
                <svg class="animate-spin h-8 w-8 mx-auto mb-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <div id="loading-message">Loading developers...</div>
                <button 
                  onclick="populateDeveloperItems(); document.getElementById('loading-message').textContent = 'Loading...';"
                  class="mt-4 px-3 py-1 bg-primary text-white rounded-md text-sm hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary"
                >
                  Load available developers
                </button>
              </div>
            </div>
          </div>
        </template>
        
        <!-- Selected developer for comparison - this will be populated dynamically -->
        <template x-if="selectedDeveloperId">
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm h-full overflow-hidden">
            <!-- Header for the selected developer -->
            <div class="p-6 bg-gradient-to-r from-indigo-700 to-purple-800 text-white flex items-center">
              <!-- Toggle minimize button -->
              <button 
                @click="toggleMinimize('right')" 
                class="mr-4 text-white/80 hover:text-white"
                :aria-label="isRightMinimized ? '${t.software.expandView}' : '${t.software.minimizeView}'"
              >
                <svg x-show="!isRightMinimized" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7" />
                </svg>
                <svg x-show="isRightMinimized" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />
                </svg>
              </button>
              
