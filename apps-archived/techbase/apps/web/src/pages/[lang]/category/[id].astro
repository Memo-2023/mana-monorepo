---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SoftwareCard from '../../../components/SoftwareCard.astro';
import FilterSidebar from '../../../components/FilterSidebar.astro';
import { loadTranslations } from '../../../utils/i18n';
import { i18nConfig } from '../../../content/config';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allCategories = await getCollection('categories');
  
  const paths = [];
  for (const entry of allCategories) {
    const [locale, id] = entry.id.split('/');
    
    // Remove .md extension if present
    const cleanId = id.replace('.md', '');
    
    paths.push({
      params: { lang: locale, id: cleanId },
      props: { entry, locale, id: cleanId }
    });
  }
  
  return paths;
}

const { entry, locale, id } = Astro.props;
const t = await loadTranslations(locale);

// Get category data from the entry
let category;
const allCategories = await getCollection('categories');
const categoryEntry = allCategories.find(cat => 
  cat.id === `${locale}/${id}` || cat.id === `${locale}/${id}.md`
);

if (categoryEntry) {
  category = {
    id,
    ...categoryEntry.data
  };
} else {
  return new Response('Category not found', { status: 404 });
}

// Get software in this category
const allSoftware = await getCollection('software');
const softwareList = allSoftware
  .filter(software => {
    // Only include software matching this locale
    if (!software.id.startsWith(locale + '/')) return false;
    
    // Only include software that has this category
    return software.data.categories.includes(id) || 
           software.data.categories.includes(category.name);
  })
  .map(software => {
    const softwareId = software.id.split('/')[1];
    return {
      id: softwareId,
      ...software.data,
      // In a real implementation, these metrics would come from Supabase
      metrics: {
        easeOfUse: { average: 4.2, count: 15 },
        featureRichness: { average: 3.8, count: 12 },
        valueForMoney: { average: 4.5, count: 18 },
        support: { average: 3.5, count: 10 },
        reliability: { average: 4.0, count: 14 }
      }
    };
  });

// Get all unique platforms from the software list for filtering
const platforms = [...new Set(softwareList.flatMap(software => software.platforms || []))];

// Get the categories again for filtering
const categoriesCollection = await getCollection('categories');
// Get additional related categories for filtering
const relatedCategories = categoriesCollection
  .filter(cat => {
    const catId = cat.id.split('/')[1].replace('.md', '');
    return cat.id.startsWith(locale + '/') && catId !== id;
  })
  .map(cat => ({
    id: cat.id.split('/')[1].replace('.md', ''),
    name: cat.data.name
  }));
---

<BaseLayout title={category.name}>
  <!-- Hero section with category info -->
  <section class="relative py-16 bg-gradient-to-br from-primary to-blue-700 text-white w-full overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid-pattern" width="10" height="10" patternUnits="userSpaceOnUse">
            <rect width="10" height="10" fill="none" stroke="white" stroke-width="0.5" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid-pattern)" />
      </svg>
    </div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="flex items-center justify-center mb-6">
        <div class="w-20 h-20 rounded-full bg-white bg-opacity-20 flex items-center justify-center text-4xl mr-6">
          {category.icon || '📊'}
        </div>
        <h1 class="text-4xl md:text-5xl font-bold">{category.name}</h1>
      </div>
      <p class="text-xl text-center max-w-3xl mx-auto text-blue-100">{category.description}</p>
      <div class="mt-8 text-center">
        <span class="inline-block bg-white bg-opacity-20 backdrop-blur-sm px-4 py-2 rounded-full text-sm">
          {softwareList.length} {softwareList.length === 1 ? 
            (locale === 'de' ? 'Software' : 'Software') : 
            (locale === 'de' ? 'Software-Produkte' : 'Software Products')}
        </span>
      </div>
    </div>
  </section>
  
  <div class="container mx-auto px-4 py-12">
    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Sidebar filters with improved design -->
      <div class="lg:w-1/4">
        <div class="sticky top-24">
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md border border-gray-100 dark:border-gray-700">
            <FilterSidebar 
              categories={relatedCategories} 
              platforms={platforms} 
            />
          </div>
        </div>
      </div>
      
      <!-- Software grid with enhanced cards -->
      <div class="lg:w-3/4">
        {softwareList.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {softwareList.map(software => (
              <div class="transition-all duration-300 hover:translate-y-[-4px]">
                <a href={`/${locale}/software/${software.id}`} class="block h-full group">
                  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 h-full flex flex-col overflow-hidden border border-gray-100 dark:border-gray-700">
                    <div class="p-6 flex-grow">
                      <div class="flex items-center mb-4">
                        {software.logo ? (
                          <div class="w-14 h-14 bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-xl p-2 flex items-center justify-center mr-4 overflow-hidden">
                            <img src={software.logo} alt={software.name} class="max-w-full max-h-full object-contain" />
                          </div>
                        ) : (
                          <div class="w-14 h-14 bg-gray-100 dark:bg-gray-700 rounded-xl flex items-center justify-center mr-4 text-2xl text-gray-400">
                            💻
                          </div>
                        )}
                        
                        <div>
                          <h3 class="text-xl font-bold group-hover:text-primary dark:group-hover:text-blue-400 dark:text-white transition-colors duration-200">{software.name}</h3>
                          {software.developer && (
                            <p class="text-sm text-gray-500 dark:text-gray-400">by {software.developer}</p>
                          )}
                        </div>
                      </div>
                      
                      <p class="text-gray-600 dark:text-gray-300 mb-5 line-clamp-3">{software.description}</p>
                      
                      <div class="flex flex-wrap gap-2 mb-4">
                        {software.categories?.slice(0, 3).map(category => (
                          <span class="px-3 py-1 bg-gray-100 dark:bg-gray-700 rounded-full text-xs text-gray-700 dark:text-gray-300 font-medium">
                            {category}
                          </span>
                        ))}
                        {software.categories?.length > 3 && (
                          <span class="px-3 py-1 bg-gray-100 dark:bg-gray-700 rounded-full text-xs text-gray-700 dark:text-gray-300 font-medium">
                            +{software.categories.length - 3}
                          </span>
                        )}
                      </div>
                      
                      <div class="flex flex-wrap gap-2">
                        {software.platforms?.slice(0, 4).map(platform => (
                          <span class="px-3 py-1 bg-blue-50 dark:bg-blue-900 text-blue-700 dark:text-blue-300 rounded-full text-xs font-medium flex items-center">
                            {platform === 'Windows' && <span class="mr-1">🪟</span>}
                            {platform === 'macOS' && <span class="mr-1">🍎</span>}
                            {platform === 'Linux' && <span class="mr-1">🐧</span>}
                            {platform === 'Android' && <span class="mr-1">🤖</span>}
                            {platform === 'iOS' && <span class="mr-1">📱</span>}
                            {platform === 'Web' && <span class="mr-1">🌐</span>}
                            {platform}
                          </span>
                        ))}
                        {software.platforms?.length > 4 && (
                          <span class="px-3 py-1 bg-blue-50 dark:bg-blue-900 text-blue-700 dark:text-blue-300 rounded-full text-xs font-medium">
                            +{software.platforms.length - 4}
                          </span>
                        )}
                      </div>
                    </div>
                    
                    <div class="bg-gray-50 dark:bg-gray-700 px-6 py-4 border-t border-gray-100 dark:border-gray-600">
                      <div class="flex justify-between items-center">
                        <div class="flex items-center">
                          <div class="flex">
                            {Array.from({ length: 5 }).map((_, i) => {
                              const metrics = software.metrics || {};
                              const metricKeys = Object.keys(metrics);
                              if (metricKeys.length === 0) return <span class="text-gray-300 dark:text-gray-600">★</span>;
                              
                              let totalRating = 0;
                              metricKeys.forEach(key => {
                                totalRating += metrics[key].average || 0;
                              });
                              
                              const rating = totalRating / metricKeys.length;
                              const fullStars = Math.floor(rating);
                              const partialStar = rating - fullStars;
                              
                              if (i < fullStars) return <span class="text-yellow-400">★</span>;
                              if (i === fullStars && partialStar > 0.3) return <span class="text-yellow-400">★</span>;
                              return <span class="text-gray-300 dark:text-gray-600">★</span>;
                            })}
                          </div>
                          <span class="ml-2 font-bold dark:text-white">
                            {(() => {
                              const metrics = software.metrics || {};
                              const metricKeys = Object.keys(metrics);
                              if (metricKeys.length === 0) return "0.0";
                              
                              let totalRating = 0;
                              metricKeys.forEach(key => {
                                totalRating += metrics[key].average || 0;
                              });
                              
                              return (totalRating / metricKeys.length).toFixed(1);
                            })()}
                          </span>
                        </div>
                        
                        <span class="text-primary dark:text-blue-400 font-medium group-hover:underline flex items-center">
                          {t.common.explore} <span class="transform transition-transform group-hover:translate-x-1">→</span>
                        </span>
                      </div>
                    </div>
                  </div>
                </a>
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center py-16 bg-gray-50 dark:bg-gray-700 rounded-lg shadow-sm border border-gray-100 dark:border-gray-600">
            <div class="text-6xl mb-6">🔍</div>
            <p class="text-lg text-gray-600 dark:text-gray-300 mb-4">
              {locale === 'de' ? 'Noch keine Software in dieser Kategorie.' : 'No software in this category yet.'}
            </p>
            <p class="text-gray-500 dark:text-gray-400">
              {locale === 'de' ? 'Schauen Sie später wieder vorbei.' : 'Check back later.'}
            </p>
          </div>
        )}
      </div>
    </div>
  </div>
</BaseLayout>