---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SoftwareCard from '../../components/SoftwareCard.astro';
import SearchBar from '../../components/SearchBar.astro';
import { loadTranslations } from '../../utils/i18n';
import { i18nConfig } from '../../content/config';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return i18nConfig.locales.map(locale => {
    return {
      params: { lang: locale },
      props: { locale }
    };
  });
}

const { locale } = Astro.props;
const t = await loadTranslations(locale);

// Fetch software data from content collections
const allSoftware = await getCollection('software');

// Filter software by locale
const localeSoftware = allSoftware
  .filter(entry => entry.id.startsWith(locale + '/'))
  .map(entry => {
    const id = entry.id.split('/')[1]; // Get the id part after locale/
    return {
      id,
      ...entry.data,
      // Add empty metrics for now - in real implementation, these would come from Supabase
      metrics: {
        easeOfUse: { average: 4.2, count: 15 },
        featureRichness: { average: 3.8, count: 12 },
        valueForMoney: { average: 4.5, count: 18 },
        support: { average: 3.5, count: 10 },
        reliability: { average: 4.0, count: 14 }
      }
    };
  });

// Featured software would be a curated list or most popular
const featuredSoftware = localeSoftware;

// Fetch categories from content collections
const allCategories = await getCollection('categories');

// Filter categories by locale and add debug info
const categories = allCategories
  .filter(entry => entry.id.startsWith(locale + '/'))
  .map(entry => {
    const id = entry.id.split('/')[1]; // Get the id part after locale/
    console.log(`Category "${entry.data.name}" has ID: ${id}`);
    return {
      id,
      ...entry.data
    };
  });
---

<BaseLayout title={t.homepage.title}>
  <!-- Hero Section -->
  <section class="relative py-20 overflow-hidden bg-gradient-to-br from-blue-700 via-blue-800 to-blue-900 w-screen mt-[-16px]">
    <!-- Small Grid (Mobile) -->
    <div class="absolute inset-0 opacity-5 block sm:hidden">
      <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid-sm" width="5" height="5" patternUnits="userSpaceOnUse">
            <rect width="5" height="5" fill="none" stroke="white" stroke-width="0.2" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid-sm)" />
      </svg>
    </div>
    
    <!-- Medium Grid (Tablet) -->
    <div class="absolute inset-0 opacity-5 hidden sm:block md:hidden">
      <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid-md" width="8" height="8" patternUnits="userSpaceOnUse">
            <rect width="8" height="8" fill="none" stroke="white" stroke-width="0.2" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid-md)" />
      </svg>
    </div>
    
    <!-- Large Grid (Desktop) -->
    <div class="absolute inset-0 opacity-5 hidden md:block lg:hidden">
      <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid-lg" width="12" height="12" patternUnits="userSpaceOnUse">
            <rect width="12" height="12" fill="none" stroke="white" stroke-width="0.3" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid-lg)" />
      </svg>
    </div>
    
    <!-- Extra Large Grid (Large Desktop) -->
    <div class="absolute inset-0 opacity-5 hidden lg:block">
      <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid-xl" width="16" height="16" patternUnits="userSpaceOnUse">
            <rect width="16" height="16" fill="none" stroke="white" stroke-width="0.3" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid-xl)" />
      </svg>
    </div>
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-blue-400 rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob"></div>
    <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-indigo-400 rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob animation-delay-2000"></div>

    <div class="container relative mx-auto px-4 flex flex-col md:flex-row items-center gap-12">
      <div class="md:w-1/2 text-center md:text-left text-white">
        <h1 class="text-4xl md:text-6xl font-bold mb-6 leading-tight">{t.homepage.title}</h1>
        <p class="text-xl md:text-2xl mb-8 text-blue-100">{t.homepage.subtitle}</p>
        <div class="max-w-lg mx-auto md:mx-0 mb-8">
          <SearchBar placeholder={`${t.common.search}...`} />
        </div>
        <div class="flex flex-wrap justify-center md:justify-start gap-4">
          <a href={`/${locale}/categories`} class="btn bg-white text-primary hover:bg-gray-100 shadow-lg transform transition-transform hover:-translate-y-1">
            {t.common.categories}
          </a>
          <a href={`/${locale}/compare`} class="btn bg-transparent border-2 border-white text-white hover:bg-white hover:text-primary shadow-lg transform transition-transform hover:-translate-y-1">
            {t.common.compare}
          </a>
        </div>
      </div>
      <div class="md:w-1/2 flex justify-center">
        <div class="relative w-full max-w-lg">
          <div class="absolute top-0 -left-4 w-72 h-72 bg-purple-300 rounded-full mix-blend-multiply filter blur-xl opacity-30 animate-blob"></div>
          <div class="absolute top-0 -right-4 w-72 h-72 bg-blue-300 rounded-full mix-blend-multiply filter blur-xl opacity-30 animate-blob animation-delay-4000"></div>
          <div class="absolute -bottom-8 left-20 w-72 h-72 bg-indigo-300 rounded-full mix-blend-multiply filter blur-xl opacity-30 animate-blob animation-delay-2000"></div>
          <div class="relative">
            <div class="w-full h-full bg-white/10 backdrop-blur-sm rounded-2xl border border-white/20 shadow-2xl p-8">
              <div class="grid grid-cols-2 gap-4">
                {featuredSoftware.slice(0, 4).map((software, index) => (
                  <div class="bg-white/20 rounded-lg p-4 flex flex-col items-center justify-center hover:bg-white/30 transition-colors">
                    <div class="w-12 h-12 rounded-full bg-white/90 flex items-center justify-center mb-2">
                      {software.icon || '💻'}
                    </div>
                    <p class="text-white font-medium text-center">{software.name}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Software Listings Section with Category Filter -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold mb-8 text-center">{t.homepage.software || "Software"}</h2>
      
      <!-- Category Pills as Horizontal Scrollable Filter -->
      <div class="relative mb-8">
        <div class="overflow-x-auto pb-4 hide-scrollbar">
          <div class="flex space-x-2 min-w-max px-2">
            <button 
              class="category-pill active bg-primary text-white px-4 py-2 rounded-full text-sm font-medium shadow-md transform transition-all hover:shadow-lg" 
              data-category="all"
            >
              {t.common.all || "All"}
            </button>
            {categories.map(category => {
              // Ensure the category ID does not have .md extension
              const cleanId = category.id.replace('.md', '');
              return (
                <button 
                  class="category-pill bg-white dark:bg-gray-700 text-gray-800 dark:text-white px-4 py-2 rounded-full text-sm font-medium shadow-md transform transition-all hover:shadow-lg hover:bg-gray-100 dark:hover:bg-gray-600" 
                  data-category={cleanId}
                  data-category-name={category.name}
                >
                  {category.name}
                </button>
              );
            })}
          </div>
        </div>
        <div class="absolute left-0 top-0 bottom-0 w-8 bg-gradient-to-r from-white dark:from-gray-900 to-transparent pointer-events-none"></div>
        <div class="absolute right-0 top-0 bottom-0 w-8 bg-gradient-to-l from-white dark:from-gray-900 to-transparent pointer-events-none"></div>
      </div>
      
      <!-- Software Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {localeSoftware.map(software => {
          // Ensure categories is an array and log for debugging
          const categories = software.categories || [];
          console.log(`Software ${software.name} categories:`, categories);
          return (
            <div class="software-card" data-categories={JSON.stringify(categories)}>
              <SoftwareCard software={software} />
            </div>
          );
        })}
      </div>
    </div>
  </section>
  
  <!-- Client-side filtering script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const categoryPills = document.querySelectorAll('.category-pill');
      const softwareCards = document.querySelectorAll('.software-card');
      
      // Debug function
      function debugLog(message, data) {
        console.log(message, data);
      }
      
      // Set up click event for category pills
      categoryPills.forEach(pill => {
        pill.addEventListener('click', () => {
          // Update active state
          categoryPills.forEach(p => p.classList.remove('active', 'bg-primary', 'text-white'));
          categoryPills.forEach(p => p.classList.add('bg-white', 'dark:bg-gray-700', 'text-gray-800', 'dark:text-white', 'hover:bg-gray-100', 'dark:hover:bg-gray-600'));
          
          pill.classList.add('active', 'bg-primary', 'text-white');
          pill.classList.remove('bg-white', 'dark:bg-gray-700', 'text-gray-800', 'dark:text-white', 'hover:bg-gray-100', 'dark:hover:bg-gray-600');
          
          // Remove .md from the category ID if present
          let selectedCategory = pill.getAttribute('data-category');
          selectedCategory = selectedCategory.replace('.md', '');
          debugLog('Selected category (cleaned):', selectedCategory);
          
          // Filter software cards
          softwareCards.forEach(card => {
            try {
              if (selectedCategory === 'all') {
                card.classList.remove('hidden');
                return;
              }
              
              const categoriesAttr = card.getAttribute('data-categories');
              debugLog('Card categories attribute:', categoriesAttr);
              
              // Handle potential JSON parsing errors gracefully
              let categories = [];
              try {
                categories = JSON.parse(categoriesAttr || '[]');
              } catch (e) {
                debugLog('Error parsing categories:', e);
                categories = [];
              }
              
              debugLog('Parsed categories:', categories);
              
              // Get category name as well as ID for matching
              const categoryPill = document.querySelector(`.category-pill[data-category="${selectedCategory}"]`);
              const categoryName = categoryPill ? categoryPill.getAttribute('data-category-name') : '';
              
              debugLog('Category name from pill:', categoryName);
              
              // Convert everything to lowercase for case-insensitive comparison
              const lowerSelectedCategory = selectedCategory.toLowerCase();
              const lowerCategoryName = categoryName ? categoryName.toLowerCase() : '';
              const lowerCategories = categories.map(c => typeof c === 'string' ? c.toLowerCase() : '');
              
              debugLog('Lower categories:', lowerCategories);
              debugLog('Looking for category ID:', lowerSelectedCategory);
              debugLog('Looking for category name:', lowerCategoryName);
              
              // Show the card if it contains either the selected category ID or name (case insensitive)
              if (lowerCategories.includes(lowerSelectedCategory) || 
                  (lowerCategoryName && lowerCategories.includes(lowerCategoryName))) {
                debugLog('Match found!', card);
                card.classList.remove('hidden');
              } else {
                debugLog('No match, hiding card', card);
                card.classList.add('hidden');
              }
            } catch (error) {
              console.error('Error in filtering:', error);
              // If there's an error, we'll show the card to be safe
              card.classList.remove('hidden');
            }
          });
        });
      });
      
      // Log initial state for debugging
      debugLog('All category pills:', categoryPills);
      debugLog('All software cards:', softwareCards);
      softwareCards.forEach(card => {
        debugLog('Card data-categories:', card.getAttribute('data-categories'));
      });
    });
  </script>
  
  <!-- Categories Section -->
  {categories.length > 0 && (
    <section class="py-12 bg-gray-50 dark:bg-gray-800 transition-colors duration-200">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold mb-8 text-center dark:text-white">{t.homepage.categories}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {categories.map(category => (
            <a href={`/${locale}/category/${category.id}`} class="block group">
              <div class="bg-white dark:bg-gray-700 rounded-lg shadow-sm overflow-hidden border border-gray-100 dark:border-gray-600 transition-all group-hover:shadow-md h-full">
                <div class="p-6">
                  <div class="flex items-center mb-4">
                    {category.icon && (
                      <div class="w-12 h-12 rounded-full bg-primary bg-opacity-10 dark:bg-opacity-20 flex items-center justify-center mr-4 text-2xl">
                        {category.icon}
                      </div>
                    )}
                    
                    <h3 class="text-xl font-bold group-hover:text-primary dark:group-hover:text-blue-400 dark:text-white transition-colors">
                      {category.name}
                    </h3>
                  </div>
                  
                  <p class="text-gray-600 dark:text-gray-300">
                    {category.description}
                  </p>
                </div>
                
                <div class="bg-gray-50 dark:bg-gray-600 px-6 py-3 border-t border-gray-100 dark:border-gray-700">
                  <div class="flex justify-end items-center">
                    <span class="text-primary dark:text-blue-400 group-hover:underline">
                      {t.common.explore} →
                    </span>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
  
  <!-- Call to Action Section -->
  <section class="py-16 bg-gray-800 dark:bg-gray-900 text-white transition-colors duration-200">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Compare Software Solutions</h2>
      <p class="text-xl mb-8 max-w-3xl mx-auto">Find the perfect software for your needs with our comprehensive comparison tools.</p>
      <a href={`/${locale}/compare`} class="btn bg-primary dark:bg-blue-600 text-white hover:bg-blue-600 dark:hover:bg-blue-700 text-lg px-8 py-3 transition-colors duration-200">
        {t.common.compare}
      </a>
    </div>
  </section>
</BaseLayout>