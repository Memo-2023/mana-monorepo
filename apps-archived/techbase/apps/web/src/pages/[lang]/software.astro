---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SoftwareCard from '../../components/SoftwareCard.astro';
import SearchBar from '../../components/SearchBar.astro';
import { loadTranslations } from '../../utils/i18n';
import { i18nConfig } from '../../content/config';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return i18nConfig.locales.map(locale => {
    return {
      params: { lang: locale },
      props: { locale }
    };
  });
}

const { locale } = Astro.props;
const t = await loadTranslations(locale);

// Fetch software data from content collections
const allSoftware = await getCollection('software');

// Filter software by locale
const localeSoftware = allSoftware
  .filter(entry => entry.id.startsWith(locale + '/'))
  .map(entry => {
    const id = entry.id.split('/')[1]; // Get the id part after locale/
    return {
      id,
      ...entry.data,
      // Add empty metrics for now - in real implementation, these would come from Supabase
      metrics: {
        easeOfUse: { average: 4.2, count: 15 },
        featureRichness: { average: 3.8, count: 12 },
        valueForMoney: { average: 4.5, count: 18 },
        support: { average: 3.5, count: 10 },
        reliability: { average: 4.0, count: 14 }
      }
    };
  });

// Fetch categories from content collections
const allCategories = await getCollection('categories');

// Filter categories by locale and add debug info
const categories = allCategories
  .filter(entry => entry.id.startsWith(locale + '/'))
  .map(entry => {
    const id = entry.id.split('/')[1]; // Get the id part after locale/
    return {
      id,
      ...entry.data
    };
  });
---

<BaseLayout title={t.common.software}>
  <!-- Hero section -->
  <section class="relative py-16 bg-gradient-to-br from-primary to-blue-700 text-white w-full overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid-pattern" width="10" height="10" patternUnits="userSpaceOnUse">
            <rect width="10" height="10" fill="none" stroke="white" stroke-width="0.5" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid-pattern)" />
      </svg>
    </div>
    <div class="absolute bottom-0 right-0 w-64 h-64 bg-blue-300 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob"></div>
    <div class="absolute top-0 left-0 w-64 h-64 bg-purple-300 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob animation-delay-4000"></div>
    
    <div class="container mx-auto px-4 relative z-10 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">{t.common.software}</h1>
      <p class="text-xl max-w-2xl mx-auto mb-8 text-blue-100">
        {locale === 'de' 
          ? 'Entdecken Sie Software-Lösungen für jede Anforderung und finden Sie die perfekte Wahl für Ihre Bedürfnisse.'
          : 'Discover software solutions for every requirement and find the perfect choice for your needs.'}
      </p>
      
      <!-- Compact Search Bar -->
      <div class="max-w-xl mx-auto mb-4">
        <SearchBar placeholder={`${t.common.search}...`} />
      </div>
      
      <div class="mt-4">
        <span class="inline-block bg-white bg-opacity-20 backdrop-blur-sm px-4 py-2 rounded-full text-sm">
          {localeSoftware.length} {localeSoftware.length === 1 
            ? (locale === 'de' ? 'Software' : 'Software')
            : (locale === 'de' ? 'Software-Produkte' : 'Software Products')}
        </span>
      </div>
    </div>
  </section>
  
  <div class="container mx-auto px-4 py-12">
    
    <!-- Category Pills as Horizontal Scrollable Filter -->
    <div class="relative mb-8">
      <div class="overflow-x-auto pb-4 hide-scrollbar">
        <div class="flex space-x-2 min-w-max px-2">
          <button 
            class="category-pill active bg-primary text-white px-4 py-2 rounded-full text-sm font-medium shadow-md transform transition-all hover:shadow-lg" 
            data-category="all"
          >
            {t.common.all}
          </button>
          {categories.map(category => {
            // Ensure the category ID does not have .md extension
            const cleanId = category.id.replace('.md', '');
            return (
              <button 
                class="category-pill bg-white dark:bg-gray-700 text-gray-800 dark:text-white px-4 py-2 rounded-full text-sm font-medium shadow-md transform transition-all hover:shadow-lg hover:bg-gray-100 dark:hover:bg-gray-600" 
                data-category={cleanId}
                data-category-name={category.name}
              >
                {category.name}
              </button>
            );
          })}
        </div>
      </div>
      <div class="absolute left-0 top-0 bottom-0 w-8 bg-gradient-to-r from-white dark:from-gray-900 to-transparent pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-8 bg-gradient-to-l from-white dark:from-gray-900 to-transparent pointer-events-none"></div>
    </div>
    
    <!-- Software Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {localeSoftware.map(software => {
        // Ensure categories is an array and log for debugging
        const categories = software.categories || [];
        return (
          <div class="software-card" data-categories={JSON.stringify(categories)}>
            <SoftwareCard software={software} />
          </div>
        );
      })}
    </div>
  </div>
  
  <!-- Client-side filtering script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const categoryPills = document.querySelectorAll('.category-pill');
      const softwareCards = document.querySelectorAll('.software-card');
      
      // Debug function
      function debugLog(message, data) {
        console.log(message, data);
      }
      
      // Set up click event for category pills
      categoryPills.forEach(pill => {
        pill.addEventListener('click', () => {
          // Update active state
          categoryPills.forEach(p => p.classList.remove('active', 'bg-primary', 'text-white'));
          categoryPills.forEach(p => p.classList.add('bg-white', 'dark:bg-gray-700', 'text-gray-800', 'dark:text-white', 'hover:bg-gray-100', 'dark:hover:bg-gray-600'));
          
          pill.classList.add('active', 'bg-primary', 'text-white');
          pill.classList.remove('bg-white', 'dark:bg-gray-700', 'text-gray-800', 'dark:text-white', 'hover:bg-gray-100', 'dark:hover:bg-gray-600');
          
          // Remove .md from the category ID if present
          let selectedCategory = pill.getAttribute('data-category');
          selectedCategory = selectedCategory.replace('.md', '');
          debugLog('Selected category (cleaned):', selectedCategory);
          
          // Filter software cards
          softwareCards.forEach(card => {
            try {
              if (selectedCategory === 'all') {
                card.classList.remove('hidden');
                return;
              }
              
              const categoriesAttr = card.getAttribute('data-categories');
              debugLog('Card categories attribute:', categoriesAttr);
              
              // Handle potential JSON parsing errors gracefully
              let categories = [];
              try {
                categories = JSON.parse(categoriesAttr || '[]');
              } catch (e) {
                debugLog('Error parsing categories:', e);
                categories = [];
              }
              
              debugLog('Parsed categories:', categories);
              
              // Get category name as well as ID for matching
              const categoryPill = document.querySelector(`.category-pill[data-category="${selectedCategory}"]`);
              const categoryName = categoryPill ? categoryPill.getAttribute('data-category-name') : '';
              
              debugLog('Category name from pill:', categoryName);
              
              // Convert everything to lowercase for case-insensitive comparison
              const lowerSelectedCategory = selectedCategory.toLowerCase();
              const lowerCategoryName = categoryName ? categoryName.toLowerCase() : '';
              const lowerCategories = categories.map(c => typeof c === 'string' ? c.toLowerCase() : '');
              
              debugLog('Lower categories:', lowerCategories);
              debugLog('Looking for category ID:', lowerSelectedCategory);
              debugLog('Looking for category name:', lowerCategoryName);
              
              // Show the card if it contains either the selected category ID or name (case insensitive)
              if (lowerCategories.includes(lowerSelectedCategory) || 
                  (lowerCategoryName && lowerCategories.includes(lowerCategoryName))) {
                debugLog('Match found!', card);
                card.classList.remove('hidden');
              } else {
                debugLog('No match, hiding card', card);
                card.classList.add('hidden');
              }
            } catch (error) {
              console.error('Error in filtering:', error);
              // If there's an error, we'll show the card to be safe
              card.classList.remove('hidden');
            }
          });
        });
      });
      
      // Log initial state for debugging
      debugLog('All category pills:', categoryPills);
      debugLog('All software cards:', softwareCards);
      softwareCards.forEach(card => {
        debugLog('Card data-categories:', card.getAttribute('data-categories'));
      });
    });
  </script>
  
  <style>
    /* Hide scrollbar but maintain scrolling functionality */
    .hide-scrollbar {
      -ms-overflow-style: none;  /* IE and Edge */
      scrollbar-width: none;     /* Firefox */
    }
    .hide-scrollbar::-webkit-scrollbar {
      display: none;  /* Chrome, Safari, Opera */
    }
  </style>
</BaseLayout>