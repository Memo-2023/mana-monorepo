---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../utils/supabase';

// We would normally check authentication here
// For demo purposes, we'll just fetch the statistics

// Fetch comment statistics
const { data: commentsData, error: commentsError } = await supabase
  .from('comments')
  .select('is_approved, is_spam', { count: 'exact' })
  .order('created_at', { ascending: false });

const totalComments = commentsData?.length || 0;
const pendingComments = commentsData?.filter(c => !c.is_approved && !c.is_spam).length || 0;
const approvedComments = commentsData?.filter(c => c.is_approved).length || 0;
const spamComments = commentsData?.filter(c => c.is_spam).length || 0;

// Fetch voting statistics
const { data: votesData, error: votesError } = await supabase
  .from('votes')
  .select('metric', { count: 'exact' });

const totalVotes = votesData?.length || 0;

// Get metrics distribution
const metricCounts = {};
votesData?.forEach(vote => {
  metricCounts[vote.metric] = (metricCounts[vote.metric] || 0) + 1;
});

// Format metric names for display
const formatMetricName = (metric) => {
  switch(metric) {
    case 'easeOfUse': return 'Ease of Use';
    case 'featureRichness': return 'Feature Richness';
    case 'valueForMoney': return 'Value for Money';
    case 'support': return 'Support';
    case 'reliability': return 'Reliability';
    default: return metric;
  }
};
---

<AdminLayout title="Dashboard">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- Total Comments Card -->
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h3 class="text-gray-500 text-sm font-medium uppercase tracking-wider mb-1">Total Comments</h3>
      <p class="text-3xl font-bold">{totalComments}</p>
      <div class="mt-2 flex">
        <span class="text-xs font-medium bg-blue-100 text-blue-800 px-2.5 py-0.5 rounded-full mr-2">
          {pendingComments} pending
        </span>
        <span class="text-xs font-medium bg-green-100 text-green-800 px-2.5 py-0.5 rounded-full">
          {approvedComments} approved
        </span>
      </div>
    </div>
    
    <!-- Spam Comments Card -->
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h3 class="text-gray-500 text-sm font-medium uppercase tracking-wider mb-1">Spam Comments</h3>
      <p class="text-3xl font-bold">{spamComments}</p>
      <div class="mt-2">
        <span class="text-xs font-medium bg-red-100 text-red-800 px-2.5 py-0.5 rounded-full">
          {((spamComments / totalComments) * 100).toFixed(1)}% of total
        </span>
      </div>
    </div>
    
    <!-- Total Votes Card -->
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h3 class="text-gray-500 text-sm font-medium uppercase tracking-wider mb-1">Total Votes</h3>
      <p class="text-3xl font-bold">{totalVotes}</p>
    </div>
    
    <!-- Recent Activity Card -->
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h3 class="text-gray-500 text-sm font-medium uppercase tracking-wider mb-1">Pending Moderation</h3>
      <p class="text-3xl font-bold">{pendingComments}</p>
      <div class="mt-2">
        <a href="/admin/comments" class="text-sm text-primary hover:underline">
          Moderate comments →
        </a>
      </div>
    </div>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-6">
    <!-- Vote Distribution Card -->
    <div class="bg-white rounded-lg shadow-sm p-6 md:col-span-2">
      <h3 class="font-semibold text-lg mb-4">Vote Distribution by Metric</h3>
      
      <div class="space-y-4">
        {Object.entries(metricCounts).map(([metric, count]) => (
          <div>
            <div class="flex justify-between mb-1">
              <span class="text-sm font-medium">{formatMetricName(metric)}</span>
              <span class="text-sm text-gray-500">{count} votes ({((count / totalVotes) * 100).toFixed(1)}%)</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2.5">
              <div class="bg-primary h-2.5 rounded-full" style={`width: ${(count / totalVotes) * 100}%`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>
    
    <!-- Quick Actions Card -->
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h3 class="font-semibold text-lg mb-4">Quick Actions</h3>
      
      <div class="space-y-3">
        <a href="/admin/comments" class="block p-3 bg-gray-50 hover:bg-gray-100 rounded-lg transition">
          <div class="font-medium">Moderate Comments</div>
          <div class="text-sm text-gray-500 mt-1">Review and approve pending comments</div>
        </a>
        
        <a href="/" class="block p-3 bg-gray-50 hover:bg-gray-100 rounded-lg transition">
          <div class="font-medium">View Website</div>
          <div class="text-sm text-gray-500 mt-1">Go to the public-facing website</div>
        </a>
      </div>
    </div>
  </div>
</AdminLayout>