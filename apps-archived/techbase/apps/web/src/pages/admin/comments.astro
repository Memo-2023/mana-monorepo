---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../utils/supabase';
import { getCollection } from 'astro:content';

// We would normally check authentication here
// For demo purposes, we'll just fetch the comments

// Default empty arrays in case of errors
let pendingComments = [];
let approvedComments = [];

try {
  // Fetch pending comments
  const { data: pending, error: pendingError } = await supabase
    .from('comments')
    .select('*')
    .eq('is_approved', false)
    .eq('is_spam', false)
    .order('created_at', { ascending: false });

  if (!pendingError && pending) {
    pendingComments = pending;
  }

  // Fetch recent approved comments
  const { data: approved, error: approvedError } = await supabase
    .from('comments')
    .select('*')
    .eq('is_approved', true)
    .order('created_at', { ascending: false })
    .limit(5);

  if (!approvedError && approved) {
    approvedComments = approved;
  }
} catch (error) {
  console.error('Error fetching comments:', error);
  // Continue with empty arrays
}

// Create a map of software IDs to names using content collection instead of DB
const softwareMap = {};

try {
  // Get all software entries from content collections
  const allSoftware = await getCollection('software');
  
  // Build a map of software IDs to names
  allSoftware.forEach(entry => {
    const [locale, id] = entry.id.split('/');
    const fullId = entry.id; // Use full ID as used in the comments table
    softwareMap[fullId] = entry.data.name;
  });
} catch (error) {
  console.error('Error loading software data:', error);
}

// Format date for display
function formatDate(dateString) {
  const date = new Date(dateString);
  return date.toLocaleString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
}

// Handle comment moderation actions
const { searchParams } = Astro.url;
const actionType = searchParams.get('action');
const commentId = searchParams.get('id');

let actionResult = null;

if (actionType && commentId) {
  if (actionType === 'approve') {
    const { data, error } = await supabase
      .from('comments')
      .update({ 
        is_approved: true,
        moderated_at: new Date().toISOString(),
        moderated_by: 'admin' // In a real app, this would be the actual admin's ID
      })
      .eq('id', commentId);
      
    actionResult = error ? { success: false, message: error.message } : { success: true, message: 'Comment approved successfully' };
  }
  
  if (actionType === 'reject') {
    const { data, error } = await supabase
      .from('comments')
      .update({ 
        is_spam: true,
        moderated_at: new Date().toISOString(),
        moderated_by: 'admin' // In a real app, this would be the actual admin's ID
      })
      .eq('id', commentId);
      
    actionResult = error ? { success: false, message: error.message } : { success: true, message: 'Comment marked as spam' };
  }
}
---

<AdminLayout title="Comment Moderation">
  <!-- Action Result Notification -->
  {actionResult && (
    <div class={`mb-6 p-4 rounded-md ${actionResult.success ? 'bg-green-50 text-green-800' : 'bg-red-50 text-red-800'}`}>
      {actionResult.message}
    </div>
  )}
  
  <!-- Pending Comments Section -->
  <section class="bg-white rounded-lg shadow-sm p-6 mb-8">
    <h2 class="text-xl font-bold mb-4">Pending Comments ({pendingComments?.length || 0})</h2>
    
    {pendingComments && pendingComments.length > 0 ? (
      <div class="divide-y divide-gray-200">
        {pendingComments.map(comment => (
          <div class="py-4 first:pt-0 last:pb-0">
            <div class="flex justify-between mb-2">
              <div>
                <span class="font-medium">{comment.user_name}</span>
                <span class="mx-2 text-gray-400">•</span>
                <span class="text-sm text-gray-500">On {softwareMap[comment.software_id] || comment.software_id}</span>
              </div>
              <div class="text-sm text-gray-500">{formatDate(comment.created_at)}</div>
            </div>
            
            <p class="text-gray-700 mb-3">{comment.comment}</p>
            
            <div class="flex space-x-3">
              <a 
                href={`/admin/comments?action=approve&id=${comment.id}`} 
                class="px-3 py-1.5 bg-green-50 text-green-700 rounded-md text-sm font-medium hover:bg-green-100"
              >
                Approve
              </a>
              <a 
                href={`/admin/comments?action=reject&id=${comment.id}`} 
                class="px-3 py-1.5 bg-red-50 text-red-700 rounded-md text-sm font-medium hover:bg-red-100"
              >
                Mark as Spam
              </a>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="text-center py-8 text-gray-500">
        No pending comments to moderate
      </div>
    )}
  </section>
  
  <!-- Recent Approved Comments Section -->
  <section class="bg-white rounded-lg shadow-sm p-6">
    <h2 class="text-xl font-bold mb-4">Recently Approved Comments</h2>
    
    {approvedComments && approvedComments.length > 0 ? (
      <div class="divide-y divide-gray-200">
        {approvedComments.map(comment => (
          <div class="py-4 first:pt-0 last:pb-0">
            <div class="flex justify-between mb-2">
              <div>
                <span class="font-medium">{comment.user_name}</span>
                <span class="mx-2 text-gray-400">•</span>
                <span class="text-sm text-gray-500">On {softwareMap[comment.software_id] || comment.software_id}</span>
              </div>
              <div>
                <span class="text-sm text-gray-500">{formatDate(comment.created_at)}</span>
                <span class="mx-2 text-gray-400">•</span>
                <span class="text-xs px-2 py-0.5 bg-green-100 text-green-800 rounded-full">Approved</span>
              </div>
            </div>
            
            <p class="text-gray-700">{comment.comment}</p>
          </div>
        ))}
      </div>
    ) : (
      <div class="text-center py-8 text-gray-500">
        No approved comments yet
      </div>
    )}
  </section>
</AdminLayout>