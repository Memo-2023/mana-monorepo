      if (valueBar) valueBar.style.width = `${(valueForMoney.average / 5) * 100}%`;
      const valueCount = document.getElementById('compare-value-count');
      if (valueCount) valueCount.textContent = `${valueForMoney.count} votes`;
      
      // Werte aktualisieren für Support
      if (compareSupportValue) compareSupportValue.textContent = `${support.average.toFixed(1)} / 5`;
      const supportBar = document.getElementById('compare-support-bar');
      if (supportBar) supportBar.style.width = `${(support.average / 5) * 100}%`;
      const supportCount = document.getElementById('compare-support-count');
      if (supportCount) supportCount.textContent = `${support.count} votes`;
      
      // Werte aktualisieren für Reliability
      if (compareReliabilityValue) compareReliabilityValue.textContent = `${reliability.average.toFixed(1)} / 5`;
      const reliabilityBar = document.getElementById('compare-reliability-bar');
      if (reliabilityBar) reliabilityBar.style.width = `${(reliability.average / 5) * 100}%`;
      const reliabilityCount = document.getElementById('compare-reliability-count');
      if (reliabilityCount) reliabilityCount.textContent = `${reliability.count} votes`;
    };
    
    // Filter-Funktion für die Suche
    const filterSoftware = (searchTerm) => {
      if (!searchTerm || searchTerm.length < 2) {
        filteredSoftware = similarSoftware;
        renderSoftwareList(filteredSoftware);
        return;
      }
      
      const term = searchTerm.toLowerCase();
      filteredSoftware = similarSoftware.filter(software => {
        return software.name.toLowerCase().includes(term) || 
               software.description.toLowerCase().includes(term) ||
               (software.categories && software.categories.some(cat => cat.toLowerCase().includes(term)));
      });
      
      renderSoftwareList(filteredSoftware);
    };
    
    // Panel schließen
    const closePanel = () => {
      if (closeCompareBtn) {
        // Panel identifizieren
        const panel = closeCompareBtn.closest('.comparison-panel');
        if (!panel) return;
        
        // Den übergeordneten Container finden
        const compareContainer = panel.closest('.compare-panel-container, .compare-panel-container-2, .compare-panel-container-3');
        if (!compareContainer) return;
        
        console.log('Closing panel:', compareContainer.className);
        
        // Panel ausblenden
        compareContainer.classList.add('hidden');
        compareContainer.style.width = '0';
        
        // Breite der restlichen Panels anpassen
        adjustPanelWidths();
        
        // Überprüfen, ob alle Vergleichspanels geschlossen sind
        const allCompareContainers = document.querySelectorAll('.compare-panel-container, .compare-panel-container-2, .compare-panel-container-3');
        const allHidden = Array.from(allCompareContainers).every(container => container.classList.contains('hidden'));
        
        if (allHidden) {
          // Vergleichsmodus deaktivieren - URL-Parameter entfernen
          const url = new URL(window.location.href);
          url.searchParams.delete('compare');
          window.history.pushState({}, '', url.toString());
          
          // Plus-Button ausblenden
          const addCompareBtn = document.getElementById('addCompareBtn');
          if (addCompareBtn) {
            addCompareBtn.classList.add('hidden');
          }
          
          // Detail-Panel auf volle Breite zurücksetzen
          const leftPanel = document.querySelector('.left-panel');
          if (leftPanel) {
            leftPanel.style.width = '100%';
          }
          
          // Vergleichscontainer ausblenden
          const compareContainer = document.querySelector('.compare-panels-container');
          if (compareContainer) {
            compareContainer.classList.add('hidden');
            compareContainer.style.display = 'none';
          }
          
          // Mobile-Switcher ausblenden
          const mobileSwitcher = document.querySelector('.mobile-switcher');
          if (mobileSwitcher) {
            mobileSwitcher.classList.add('hidden');
          }
        }
      }
    };
    
    // Panel-Breiten anpassen
    function adjustPanelWidths() {
      // Zählen, wie viele Panel angezeigt werden
      const allPanels = document.querySelectorAll('.compare-panel-container, .compare-panel-container-2, .compare-panel-container-3, .left-panel');
      const visiblePanels = Array.from(allPanels).filter(panel => !panel.classList.contains('hidden')).length;
      
      if (visiblePanels === 0) return;
      
      // Breite basierend auf sichtbaren Panels anpassen
      const panelWidth = `lg:w-1/${visiblePanels}`;
      
      // Alle sichtbaren Panels anpassen
      Array.from(allPanels).forEach(panel => {
        if (!panel.classList.contains('hidden')) {
          // Alle Breitenklassen entfernen
          panel.classList.remove('w-full', 'lg:w-1/2', 'lg:w-1/3', 'lg:w-1/4');
          panel.classList.add(panelWidth);
        }
      });
    }
    
    // Zeige die Software-Liste an
    const showSoftwareList = () => {
      if (selectOtherSoftwareBtn) {
        softwareDetailView.style.display = 'none';
        minimizedView.style.display = 'none';
        softwareListView.style.display = 'block';
      }
    };
    
    // Event-Listener einrichten
    if (searchInput) {
      searchInput.addEventListener('input', () => filterSoftware(searchInput.value));
    }
    
    if (selectOtherSoftwareBtn) {
      selectOtherSoftwareBtn.addEventListener('click', showSoftwareList);
    }
    
    if (closeCompareBtn) {
      closeCompareBtn.addEventListener('click', closePanel);
    }
    
    // URL-Parameter überprüfen
    const checkURLParams = () => {
      const urlParams = new URLSearchParams(window.location.search);
      const compareId = urlParams.get('compare');
      
      if (compareId) {
        selectComparisonSoftware(compareId);
      }
    };
    
    // Initialisierung starten
    initializeFromContainer();
    checkURLParams();
    
    // Prüfen, ob Daten vorhanden sind
    if (similarSoftware.length === 0) {
      // Verzögerung, um sicherzustellen, dass Daten verfügbar sind
      setTimeout(() => {
        initializeFromContainer();
        
        if (similarSoftware.length === 0) {
          emptyMessage.style.display = 'block';
        }
      }, 500);
    }
  });
</script>
)}