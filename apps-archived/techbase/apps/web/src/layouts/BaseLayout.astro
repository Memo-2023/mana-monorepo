---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'TechBase - Software-Vergleiche, Bewertungen und mehr' } = Astro.props;
---

<!DOCTYPE html>
<html lang="de" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | TechBase</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:inline>
      /* Sofortige Anwendung des Dark-Modes, um Flackern zu vermeiden */
      html.dark {
        background-color: #111827; /* bg-gray-900 */
        color: #f3f4f6; /* text-gray-100 */
      }
      
      html.dark body {
        background-color: #111827; /* bg-gray-900 */
        color: #f3f4f6; /* text-gray-100 */
      }
      
      /* Header-spezifische Stile */
      html.dark header {
        background-color: #1f2937 !important; /* dark:bg-gray-800 */
      }
      
      /* Footer-spezifische Stile */
      html.dark footer {
        background-color: #1f2937 !important; /* bg-gray-800 */
      }
      
      /* Main-Bereich */
      html.dark main {
        background-color: #111827; /* bg-gray-900 */
      }
      
      /* Card-Hintergründe */
      html.dark .bg-white {
        background-color: #1f2937 !important; /* dark:bg-gray-800 */
      }
      
      /* Text-Farben */
      html.dark .text-gray-700 {
        color: #d1d5db !important; /* dark:text-gray-300 */
      }
      
      /* Extra spezifische Stile */
      html.dark .shadow-sm,
      html.dark .shadow-md {
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.5) !important;
      }
    </style>
    <!-- Initial dark mode script to avoid flash of incorrect theme -->
    <script is:inline>
      // Sofort den Dark Mode setzen
      document.documentElement.classList.add('dark');
      
      // Anschließend, wenn Dokument geladen ist, die Einstellung aus localStorage überprüfen
      document.addEventListener('DOMContentLoaded', () => {
        // Check for theme preference in localStorage
        const theme = (() => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
          }
          // Default to dark theme
          return 'dark';
        })();
              
        // Apply theme class based on local storage
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      });
    </script>
    
    <!-- Debug-Skript für Entwicklung -->
    <script is:inline src="/debug.js"></script>
    
    <!-- Alpine.js -->
    <script is:inline defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    <!-- Eigene JS-Utilities -->
    <script is:inline src="/software.js"></script>
  </head>
  <body class="min-h-screen flex flex-col transition-colors duration-200 ease-in-out relative overflow-x-hidden">
    <Header />
    <main class="flex-grow w-full">
      <slot />
    </main>
    <Footer />
  </body>
</html>