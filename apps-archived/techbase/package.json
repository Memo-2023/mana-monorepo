{
	"name": "techbase",
	"version": "1.0.0",
	"private": true,
	"description": "TechBase - Software Comparison Platform",
	"scripts": {
		"dev": "turbo run dev",
		"dev:web": "pnpm --filter @techbase/web dev",
		"dev:backend": "pnpm --filter @techbase/backend dev",
		"build": "turbo run build",
		"lint": "turbo run lint",
		"clean": "turbo run clean",
		"db:push": "pnpm --filter @techbase/backend db:push",
		"db:studio": "pnpm --filter @techbase/backend db:studio"
	},
	"devDependencies": {
		"typescript": "^5.9.3"
	},
	"packageManager": "pnpm@9.15.0"
}
