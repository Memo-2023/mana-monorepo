    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.2",
    "prettier-plugin-tailwindcss": "^0.6.10",
    "svelte": "^5.18.3",
    "svelte-check": "^4.1.3",
    "tailwindcss": "^3.4.17",
