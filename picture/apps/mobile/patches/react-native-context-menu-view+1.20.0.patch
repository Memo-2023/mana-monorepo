+const React = require("react");
+const { View } = require("react-native");
+
+// Web polyfill for react-native-context-menu-view
+// On web, we simply render the children without the context menu functionality
+const ContextMenu = (props) => {
+  const { children, style } = props;
+
+  // On web, just render the children in a View
+  // Context menu functionality is not available on web
+  return React.createElement(View, { style: style }, children);
+};
+
+module.exports = ContextMenu;
+module.exports.default = ContextMenu;
